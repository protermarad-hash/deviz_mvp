import 'cloud_sync_models.dart';
import 'cloud_sync_service.dart';

class CloudSyncBridge {
  CloudSyncBridge(this._service);

  final CloudSyncService _service;

  Future<void> queueUser(Map<String, dynamic> user) async {
    final id = (user['id'] ?? '').toString();
    if (id.isEmpty) return;
    await _service.queueUpsert(
      entityType: CloudEntityType.users,
      entityId: id,
      payload: user,
    );
  }

