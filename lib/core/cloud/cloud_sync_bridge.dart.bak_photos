      payload: team,
    );
  }

  Future<void> queueTeamDelete(String teamId) async {
    final id = teamId.trim();
    if (id.isEmpty) return;
    await _service.queueDelete(
      entityType: CloudEntityType.teams,
      entityId: id,
    );
  }

