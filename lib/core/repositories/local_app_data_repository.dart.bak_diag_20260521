  @override
  Future<String> nextClientCode() async {
    final items = await listClients();
    var max = 0;
    for (final item in items) {
      final raw = item.clientCode.trim().toUpperCase();
      if (!raw.startsWith('CL-')) continue;
      final seq = int.tryParse(raw.substring(3));
      if (seq != null && seq > max) {
        max = seq;
      }
    }
    return 'CL-${(max + 1).toString().padLeft(4, '0')}';
  }

