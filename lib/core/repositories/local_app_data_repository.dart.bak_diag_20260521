  @override
  Future<CompanyProfile> loadCompanyProfile() async {
    final localProfile = await _readLocalCompanyProfileOnly();
    final localPdfSettings = await _readLocalPdfExportSettings(
      fallbackProfile: localProfile,
    );
    if (!_isCompanyProfileCloudAvailable) {
      _lastCompanyProfileDataSourceLabel = 'local_cache';
      _lastCompanyProfileFallbackReason = 'cloud indisponibil';
      return localProfile.copyWith(pdfExportSettings: localPdfSettings);
    }
    try {
      final snapshot = await _companyProfileDocument.get();
      final raw = snapshot.data();
      CompanyProfile cloudProfile;
      if (snapshot.exists && raw != null && raw.isNotEmpty) {
        cloudProfile = CompanyProfile.fromMap(raw);
      } else if (_hasCompanyProfileGlobalData(localProfile)) {
        await _companyProfileDocument.set(
          _companyProfileToCloudMap(localProfile),
          SetOptions(merge: true),
        );
        cloudProfile = localProfile.copyWith(
          pdfExportSettings: const PdfExportSettings(),
        );
      } else {
        cloudProfile = const CompanyProfile();
      }
      // Dacă cloud nu are token SmartBill (versiune veche fără câmpul salvat),
      // folosim credențialele din cache-ul local care le-a păstrat.
      final resolvedSmartBill =
          cloudProfile.smartBillSettings.token.trim().isNotEmpty
              ? cloudProfile.smartBillSettings
              : localProfile.smartBillSettings;

      // Fallback pentru câmpuri care lipseau din documentul Firebase vechi.
      // Preferăm valoarea din cloud dacă există; altfel folosim cache-ul local.
      // Acest fallback asigură compatibilitate cu versiunile anterioare ale app-ului
      // care nu salvau aceste câmpuri în Firebase.
      String resolveField(String cloudVal, String localVal) =>
          cloudVal.trim().isNotEmpty ? cloudVal.trim() : localVal.trim();

      final merged = cloudProfile.copyWith(
        pdfExportSettings: localPdfSettings,
        smartBillSettings: resolvedSmartBill,
        contactEmail: resolveField(
            cloudProfile.contactEmail, localProfile.contactEmail),
        website: resolveField(cloudProfile.website, localProfile.website),
        city: resolveField(cloudProfile.city, localProfile.city),
        county: resolveField(cloudProfile.county, localProfile.county),
        currency: resolveField(cloudProfile.currency, localProfile.currency),
        language: resolveField(cloudProfile.language, localProfile.language),
      );
      await _writeCompanyProfileCache(merged);
      _lastCompanyProfileDataSourceLabel = 'cloud';
      _lastCompanyProfileFallbackReason = '';
      return merged;
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
      _lastCompanyProfileDataSourceLabel = 'local_cache';
      _lastCompanyProfileFallbackReason = error.toString().trim();
      return localProfile.copyWith(pdfExportSettings: localPdfSettings);
    }
  }

  Future<CompanyProfile> _readLocalCompanyProfileOnly() async {
    final prefs = await SharedPreferences.getInstance();
    const keys = <String>[
      _companySettingsKey,
      'company_settings',
      'deviz_company_settings_v1',
    ];
    for (final key in keys) {
      final raw = prefs.getString(key);
      if (raw == null || raw.trim().isEmpty) {
        continue;
      }
      try {
        final decoded = jsonDecode(raw);
        if (decoded is Map<String, dynamic>) {
          return CompanyProfile.fromMap(decoded);
        }
        if (decoded is Map) {
          return CompanyProfile.fromMap(Map<String, dynamic>.from(decoded));
        }
      } catch (_) {
        // Keep trying fallback keys.
      }
    }
    return const CompanyProfile();
  }

