  @override
  Future<List<RegistryEntry>> listRegistryEntries() async {
    final localEntries = await _readMergedLocalRegistryEntries();
    if (!_isRegistryCloudAvailable) {
      _lastRegistryDataSourceLabel = 'local_cache';
      _lastRegistryFallbackReason = 'cloud indisponibil';
      return localEntries;
    }

    try {
      final snapshot = await _registryEntriesCollection.get();
      final cloudEntriesBuffer = <RegistryEntry>[];
      for (final doc in snapshot.docs) {
        final rawEntry = RegistryEntry.fromMap(<String, dynamic>{
          ...doc.data(),
          'id': (doc.data()['id'] ?? doc.id).toString(),
        });
        final normalizedEntry = _normalizeRegistryEntry(rawEntry);
        if (!_sameRegistryEntry(rawEntry, normalizedEntry)) {
          await _registryEntriesCollection.doc(normalizedEntry.id).set(
                _registryEntryToCloudMap(normalizedEntry),
                SetOptions(merge: true),
              );
        }
        if (normalizedEntry.id.trim().isNotEmpty) {
          cloudEntriesBuffer.add(normalizedEntry);
        }
      }
      var cloudEntries = cloudEntriesBuffer.toList(growable: false);

      if (localEntries.isNotEmpty) {
        final knownKeys = cloudEntries
            .map(_registryEntryIdentityKey)
            .where((key) => key.isNotEmpty)
            .toSet();
        for (final localEntry in localEntries) {
          final normalizedLocalEntry = _ensureRegistryEntryId(localEntry);
          final key = _registryEntryIdentityKey(normalizedLocalEntry);
          if (key.isEmpty || knownKeys.contains(key)) {
            continue;
          }
          await _registryEntriesCollection.doc(normalizedLocalEntry.id).set(
                _registryEntryToCloudMap(normalizedLocalEntry),
                SetOptions(merge: true),
              );
          cloudEntries = <RegistryEntry>[
            ...cloudEntries,
            normalizedLocalEntry,
          ];
          knownKeys.add(key);
        }
      }

      final merged = _sortRegistryEntries(
        _mergeRegistryEntries(cloudEntries, const <RegistryEntry>[]),
      );
      await _writeRegistryEntries(merged);
      _lastRegistryDataSourceLabel = 'cloud';
      _lastRegistryFallbackReason = '';
      return merged;
    } catch (error) {
      _lastRegistryDataSourceLabel = 'local_cache';
      _lastRegistryFallbackReason = error.toString();
      return localEntries;
    }
  }

  @override
  Future<void> saveRegistryEntry(RegistryEntry entry) async {
    final normalizedEntry =
        _normalizeRegistryEntry(_ensureRegistryEntryId(entry));
    var queuedOffline = !_isRegistryCloudAvailable;
    if (_isRegistryCloudAvailable) {
      try {
        await _registryEntriesCollection.doc(normalizedEntry.id).set(
              _registryEntryToCloudMap(normalizedEntry),
              SetOptions(merge: true),
            );
        _lastRegistryDataSourceLabel = 'cloud';
        _lastRegistryFallbackReason = '';
      } catch (error) {
        _lastRegistryDataSourceLabel = 'local_cache';
        _lastRegistryFallbackReason = error.toString();
        queuedOffline = true;
      }
    } else {
      _lastRegistryDataSourceLabel = 'local_cache';
      _lastRegistryFallbackReason = 'cloud indisponibil';
    }
    if (queuedOffline) {
      await OfflineSyncRuntime.instance
          .queueRegistryEntryUpsert(_registryEntryToCloudMap(normalizedEntry));
    }

    await _upsertLocalRegistryEntry(normalizedEntry);
    await _mirrorRegistryEntryToLegacyStore(normalizedEntry);
  }

  @override
  Future<void> deleteRegistryEntry(String entryId) async {
    final trimmedId = entryId.trim();
    if (trimmedId.isEmpty) {
      return;
    }
    var queuedOffline = !_isRegistryCloudAvailable;
    if (_isRegistryCloudAvailable) {
      try {
        await _registryEntriesCollection.doc(trimmedId).delete();
        _lastRegistryDataSourceLabel = 'cloud';
        _lastRegistryFallbackReason = '';
      } catch (error) {
        _lastRegistryDataSourceLabel = 'local_cache';
        _lastRegistryFallbackReason = error.toString();
        queuedOffline = true;
      }
    } else {
      _lastRegistryDataSourceLabel = 'local_cache';
      _lastRegistryFallbackReason = 'cloud indisponibil';
    }
    if (queuedOffline) {
      await OfflineSyncRuntime.instance.queueRegistryEntryDelete(trimmedId);
    }

    final items = [...await _readLocalRegistryEntriesOnly()]
      ..removeWhere((item) => item.id == trimmedId);
    await _writeRegistryEntries(items);
    await RegistryStore.removeByReferenceId(trimmedId);
  }

  @override
  Future<RegistrySettings> loadRegistrySettings() async {
    final localSettings = await _readLocalRegistrySettingsOnly();
    if (!_isRegistryCloudAvailable) {
      return localSettings;
    }

    try {
      final snapshot = await _registrySettingsDocument.get();
      final raw = snapshot.data();
      if (raw != null && raw.isNotEmpty) {
        final settings = RegistrySettings.fromMap(raw);
        await _writeLocalRegistrySettings(settings);
        return settings;
      }
      if (!_isDefaultRegistrySettings(localSettings)) {
        await _registrySettingsDocument.set(
          localSettings.toMap(),
          SetOptions(merge: true),
        );
      }
      return localSettings;
    } catch (_) {
      return localSettings;
    }
  }

