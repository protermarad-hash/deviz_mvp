  @override
  Future<AppUser?> loadCurrentUser() async {
    final prefs = await SharedPreferences.getInstance();
    final raw = prefs.getString(_currentUserKey);
    if (raw == null || raw.trim().isEmpty) {
      return null;
    }
    final decoded = jsonDecode(raw);
    if (decoded is! Map<String, dynamic>) {
      return null;
    }
    return AppUser.fromMap(decoded);
  }

  @override
  Future<void> saveCurrentUser(AppUser? user) async {
    final prefs = await SharedPreferences.getInstance();
    if (user == null) {
      await prefs.remove(_currentUserKey);
      return;
    }
    await prefs.setString(_currentUserKey, jsonEncode(user.toMap()));
  }

  @override
  Future<List<Appointment>> listAppointments() async {
    final localItems = await _readLocalAppointmentsOnly();
    if (!_isAppointmentsCloudAvailable) {
      _lastAppointmentsDataSourceLabel = 'local_cache';
      _lastAppointmentsFallbackReason = 'cloud indisponibil';
      return localItems;
    }

    try {
      // Dacă cache-ul local e gol (instalare nouă sau date șterse),
      // descarcă TOT istoricul din Firestore — indiferent de vârstă.
      // Astfel datele din 10 ani sunt disponibile imediat pe orice dispozitiv.
      if (localItems.isEmpty) {
        return await listAllAppointments();
      }

      // Cache local există → fetch incremental: ultimele 14 luni din cloud
      // + datele istorice din cache local (strategia normală de refresh rapid).
      final windowStart = DateTime.now().subtract(const Duration(days: 425));
      final windowStartStr = windowStart.toIso8601String().substring(0, 10);
      final snapshot = await _appointmentsCollection
          .where('scheduled_date', isGreaterThanOrEqualTo: windowStartStr)
          .get();
      var cloudItems = snapshot.docs
          .map((doc) => Appointment.fromMap(doc.data()))
          .where((item) => item.id.trim().isNotEmpty)
          .toList(growable: false);

      // Tombstone-uri din cache local (max 60 min) sau Firestore.
      final serverTombstoneIds = await _getServerTombstoneIds();

      // Retry pending deletions and filter them from cloud results.
      // PERFORMANȚĂ: Firestore deletes rulează în BACKGROUND (nu blochează lista).
      // IDs-urile rămân în pendingDeleteIds pentru filtrare — se curăță asincron.
      final pendingDeleteIds = await _readDeletedAppointmentIds();
      if (pendingDeleteIds.isNotEmpty) {
        unawaited(_retryPendingDeletesBackground(Set<String>.from(pendingDeleteIds)));
      }

      // Filter out all deleted IDs (local pending + server tombstones)
      final allDeletedIds = {
        ...pendingDeleteIds,
        ...serverTombstoneIds,
      };
      if (allDeletedIds.isNotEmpty) {
        cloudItems = cloudItems
            .where((item) => !allDeletedIds.contains(item.id))
            .toList(growable: false);
      }

      // Combină: datele din cloud + local-only (create/modificate offline).
      final cloudIds = cloudItems.map((item) => item.id).toSet();

      // BUG FIX: Preferă versiunea locală pentru programările cu modificări
      // offline în așteptare. Fără asta, sincronizarea cloud suprascrie
      // modificările offline înainte ca queue-ul să le trimită în Firestore
      // (race condition la restart cu internet).
      final pendingIds = await OfflineSyncRuntime.instance
          .pendingUpsertEntityIds(CloudEntityType.appointments);
      final localById = <String, Appointment>{
        for (final item in localItems) item.id: item,
      };
      final resolvedCloudItems = cloudItems.map((cloudItem) {
        if (pendingIds.contains(cloudItem.id) &&
            localById.containsKey(cloudItem.id)) {
          return localById[cloudItem.id]!; // preferă modificarea offline
        }
        return cloudItem;
      }).toList(growable: false);

      // BUG FIX: Include și programările create offline (nu există în cloud).
      // Vechea logică includea DOAR items mai vechi de 14 luni — programările
      // noi create offline cu dată recentă dispăreau complet din merge.
      final localOnlyItems = localItems
          .where((item) =>
              !allDeletedIds.contains(item.id) &&
              !cloudIds.contains(item.id))
          .toList(growable: false);

      // Re-queue local-only items în BACKGROUND — nu blochează lista.
      // PERFORMANȚĂ: era O(n) × SharedPreferences read+write; acum fire-and-forget.
      if (localOnlyItems.isNotEmpty) {
        unawaited(_queueAppointmentsBatch(localOnlyItems));
      }

      final merged =
          _sortAppointments([...resolvedCloudItems, ...localOnlyItems]);
      await _writeAppointments(merged);
      _lastAppointmentsDataSourceLabel = 'cloud';
      _lastAppointmentsFallbackReason = '';
      return merged;
    } catch (error) {
      _lastAppointmentsDataSourceLabel = 'local_cache';
      _lastAppointmentsFallbackReason = error.toString();
      return localItems;
    }
  }

  @override
  Future<List<Appointment>> listAllAppointments() async {
    final localItems = await _readLocalAppointmentsOnly();
    if (!_isAppointmentsCloudAvailable) {
      return localItems;
    }
    try {
      // Fetch complet din Firestore, fără filtru de dată
      final snapshot = await _appointmentsCollection.get();
      var cloudItems = snapshot.docs
          .map((doc) => Appointment.fromMap(doc.data()))
          .where((item) => item.id.trim().isNotEmpty)
          .toList(growable: false);

      final serverTombstoneIds = await _getServerTombstoneIds();
      final pendingDeleteIds = await _readDeletedAppointmentIds();
      final allDeletedIds = {...pendingDeleteIds, ...serverTombstoneIds};
      if (allDeletedIds.isNotEmpty) {
        cloudItems = cloudItems
            .where((item) => !allDeletedIds.contains(item.id))
            .toList(growable: false);
      }
      // Include și programările locale cu modificări offline pending
      final cloudIds = cloudItems.map((item) => item.id).toSet();
      final pendingIds = await OfflineSyncRuntime.instance
          .pendingUpsertEntityIds(CloudEntityType.appointments);
      final localById = <String, Appointment>{
        for (final item in localItems) item.id: item,
      };
      final resolvedCloudItems = cloudItems.map((cloudItem) {
        if (pendingIds.contains(cloudItem.id) &&
            localById.containsKey(cloudItem.id)) {
          return localById[cloudItem.id]!;
        }
        return cloudItem;
      }).toList(growable: false);
      final localOnlyItems = localItems
          .where((item) =>
              !allDeletedIds.contains(item.id) &&
              !cloudIds.contains(item.id))
          .toList(growable: false);
      // Re-queue local-only items în BACKGROUND (fire-and-forget)
      if (localOnlyItems.isNotEmpty) {
        unawaited(_queueAppointmentsBatch(localOnlyItems));
      }
      final merged =
          _sortAppointments([...resolvedCloudItems, ...localOnlyItems]);
      await _writeAppointments(merged);
      _lastAppointmentsDataSourceLabel = 'cloud';
      _lastAppointmentsFallbackReason = '';
      return merged;
    } catch (error) {
      _lastAppointmentsDataSourceLabel = 'local_cache';
      _lastAppointmentsFallbackReason = error.toString();
      return localItems;
    }
  }

  @override
  Future<void> saveAppointment(Appointment appointment) async {
    // 1. Salvare locală imediată
    final items = [...await _readLocalAppointmentsOnly()];
    final index = items.indexWhere((item) => item.id == appointment.id);
    if (index >= 0) {
      items[index] = appointment;
    } else {
      items.add(appointment);
    }
    await _writeAppointments(_sortAppointments(items));
    // 2. Queue offline — garantează sincronizarea (CLAUDE.md: queue în repository)
    unawaited(OfflineSyncRuntime.instance.queueAppointment(appointment));
    // 3. Firestore direct — best-effort, fire-and-forget (BUG 8: nu await)
    if (_isAppointmentsCloudAvailable) {
      _appointmentsCollection
          .doc(appointment.id)
          .set(appointment.toMap(), SetOptions(merge: true))
          .then((_) {
            _lastAppointmentsDataSourceLabel = 'cloud';
            _lastAppointmentsFallbackReason = '';
          })
          .catchError((error) {
            _lastAppointmentsDataSourceLabel = 'local_cache';
            _lastAppointmentsFallbackReason = error.toString();
          });
    } else {
      _lastAppointmentsDataSourceLabel = 'local_cache';
      _lastAppointmentsFallbackReason = 'cloud indisponibil';
    }
  }

  @override
  Future<void> deleteAppointment(String appointmentId) async {
    final trimmedId = appointmentId.trim();
    if (trimmedId.isEmpty) {
      return;
    }
    // 1. Ștergere locală imediată
    final items = [...await _readLocalAppointmentsOnly()]
      ..removeWhere((item) => item.id == appointmentId);
    await _writeAppointments(items);
    // 2. Adaugă în pending set local (pentru filtrare la listare)
    await _addDeletedAppointmentId(trimmedId);
    // 3. Queue delete (CLAUDE.md: queue în repository)
    unawaited(OfflineSyncRuntime.instance.queueAppointmentDelete(trimmedId));
    // 4. Firestore direct — best-effort, fire-and-forget (BUG 8: nu await)
    if (_isAppointmentsCloudAvailable) {
      _appointmentsCollection.doc(trimmedId).delete().then((_) {
        // Tombstone pentru alte dispozitive
        _deletedAppointmentsCollection
            .doc(trimmedId)
            .set({'deletedAt': FieldValue.serverTimestamp()})
            .then((_) => _invalidateTombstoneCache())
            .catchError((_) {});
        // Curăță din pending set după succes
        _removeDeletedAppointmentIds({trimmedId});
        _lastAppointmentsDataSourceLabel = 'cloud';
        _lastAppointmentsFallbackReason = '';
      }).catchError((error) {
        _lastAppointmentsDataSourceLabel = 'local_cache';
        _lastAppointmentsFallbackReason = error.toString();
        // Rămâne în pending set pentru retry la listare
      });
    } else {
      _lastAppointmentsDataSourceLabel = 'local_cache';
      _lastAppointmentsFallbackReason = 'cloud indisponibil';
    }
  }

  // ── Helper-e background pentru listAppointments ──────────────────────────

  /// Reîncearcă ștergerile Firestore PENDENTE în background.
  /// Rulează complet asincron — nu blochează niciodată `listAppointments()`.
  Future<void> _retryPendingDeletesBackground(Set<String> pendingIds) async {
    if (!_isAppointmentsCloudAvailable) return;
    final retried = <String>{};
    for (final id in pendingIds) {
      try {
        await _appointmentsCollection.doc(id).delete();
        try {
          await _deletedAppointmentsCollection
              .doc(id)
              .set({'deletedAt': FieldValue.serverTimestamp()});
          await _invalidateTombstoneCache();
        } catch (_) {}
        retried.add(id);
      } catch (_) {
        // Retry la următoarea deschidere a modulului
      }
    }
    if (retried.isNotEmpty) {
      await _removeDeletedAppointmentIds(retried);
    }
  }

  /// Queue-uiește o listă de programări cu O(1) I/O SharedPreferences.
  /// Înlocuiește bucla `for (item in list) { await queue(item); }` — O(n) → O(1) I/O.
  Future<void> _queueAppointmentsBatch(List<Appointment> items) async {
    await OfflineSyncRuntime.instance.queueAppointmentsBatch(items);
  }

  // ─────────────────────────────────────────────────────────────────────────

  // Returnează tombstone IDs din cache local (max 60 min vechi) sau Firestore.
  Future<Set<String>> _getServerTombstoneIds() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      final tsStr = prefs.getString(_tombstoneCacheTsKey);
      Set<String>? cached;
      final rawCached = prefs.getStringList(_tombstoneCacheKey);
      if (rawCached != null) {
        cached = Set<String>.from(rawCached);
        if (tsStr != null) {
          final ts = DateTime.tryParse(tsStr);
          if (ts != null &&
              DateTime.now().difference(ts) < _tombstoneCacheTtl) {
            return cached; // cache proaspăt
          }
        }
      }
      // Refresh din Firestore
      try {
        final tombstones = await _deletedAppointmentsCollection.get();
        final ids = tombstones.docs.map((d) => d.id).toSet();
        await prefs.setStringList(_tombstoneCacheKey, ids.toList());
        await prefs.setString(
            _tombstoneCacheTsKey, DateTime.now().toIso8601String());
        return ids;
      } catch (_) {
        return cached ?? {}; // cache vechi ca fallback
      }
    } catch (_) {
      return {};
    }
  }

  // Invalidează cache-ul de tombstone-uri (apelat după ce scriem un tombstone).
  Future<void> _invalidateTombstoneCache() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      await prefs.remove(_tombstoneCacheTsKey);
    } catch (_) {}
  }

