    if (_isRegistryCloudAvailable) {
      try {
        await _registrySettingsDocument.set(
          settings.toMap(),
          SetOptions(merge: true),
        );
      } catch (_) {}
    }
    await _writeLocalRegistrySettings(settings);
  }

  @override
  Future<RegistryEntry> registerGeneratedDocument({
    required RegistryType registryType,
    required String documentCategory,
    required String documentTitle,
    required String documentNumber,
    DateTime? documentDate,
    String issuerName = '',
    String recipientName = '',
    String clientId = '',
    String jobId = '',
    String offerId = '',
    String estimateId = '',
    String contractId = '',
    String ticketId = '',
    String filePath = '',
    String fileName = '',
    String notes = '',
    String status = '',
  }) async {
    final settings = await loadRegistrySettings();
    final items = await listRegistryEntries();
    final now = DateTime.now();
    final year = now.year;
    final prefix = registryType == RegistryType.intrare
        ? settings.incomingPrefix.trim().isEmpty
            ? registryType.defaultPrefix
            : settings.incomingPrefix.trim().toUpperCase()
        : settings.outgoingPrefix.trim().isEmpty
            ? registryType.defaultPrefix
            : settings.outgoingPrefix.trim().toUpperCase();

    final filtered = items.where((item) {
      if (item.registryType != registryType) {
        return false;
      }
      if (!settings.resetSequenceYearly) {
        return true;
      }
      return item.year == year;
    }).toList();

    final sequenceNumber = filtered.isEmpty
        ? 1
        : filtered
                .map((item) => item.sequenceNumber)
                .reduce((a, b) => a > b ? a : b) +
            1;
    final normalizedDocumentNumber = documentNumber.trim();
    final registryNumber = normalizedDocumentNumber.isNotEmpty
        ? normalizedDocumentNumber
        : '$prefix-$year-${sequenceNumber.toString().padLeft(4, '0')}';

    final entry = RegistryEntry(
      id: now.microsecondsSinceEpoch.toString(),
      registryNumber: registryNumber,
      registryType: registryType,
      sequenceNumber: sequenceNumber,
      year: year,
      registeredAt: now,
      documentNumber: documentNumber,
      documentDate: documentDate,
      documentTitle: documentTitle,
      documentCategory: documentCategory,
      issuerName: issuerName,
      recipientName: recipientName,
      clientId: clientId,
      jobId: jobId,
      offerId: offerId,
      estimateId: estimateId,
      contractId: contractId,
      ticketId: ticketId,
      filePath: filePath,
      fileName: fileName,
      notes: notes,
      status: status.isEmpty
          ? (registryType == RegistryType.intrare
              ? settings.defaultIncomingStatus
              : settings.defaultOutgoingStatus)
          : status,
    );

    await saveRegistryEntry(entry);
    return entry;
  }

  Future<List<RegistryEntry>> _readLocalRegistryEntriesOnly() async {
    final prefs = await SharedPreferences.getInstance();
    final raw = prefs.getString(_registryEntriesKey);
    if (raw == null || raw.trim().isEmpty) {
      return const <RegistryEntry>[];
    }

    final decoded = jsonDecode(raw);
    if (decoded is! List<dynamic>) {
      return const <RegistryEntry>[];
    }

    final entries = decoded
        .map(
          (item) => RegistryEntry.fromMap(
            Map<String, dynamic>.from(item as Map),
          ),
        )
        .toList(growable: false);
    final normalizedEntries =
        entries.map(_normalizeRegistryEntry).toList(growable: false);
    if (_sameRegistryEntryLists(entries, normalizedEntries)) {
      return normalizedEntries;
    }
    final sortedNormalizedEntries = _sortRegistryEntries(normalizedEntries);
    await _writeRegistryEntries(sortedNormalizedEntries);
    return sortedNormalizedEntries;
  }

  Future<List<RegistryEntry>> _readMergedLocalRegistryEntries() async {
    final storedEntries = await _readLocalRegistryEntriesOnly();
    final legacyRows = await RegistryStore.readEntries();
    final legacyEntries = legacyRows
        .map(_legacyRegistryEntryFromRow)
        .where((item) => item.id.trim().isNotEmpty)
        .toList(growable: false);
    final merged = _sortRegistryEntries(
      _mergeRegistryEntries(storedEntries, legacyEntries),
    );
    if (!_sameRegistryEntryLists(storedEntries, merged)) {
      await _writeRegistryEntries(merged);
    }
    return merged;
  }

  Future<void> _upsertLocalRegistryEntry(RegistryEntry entry) async {
    final items = [...await _readLocalRegistryEntriesOnly()];
    final key = _registryEntryIdentityKey(entry);
    final index = items.indexWhere(
      (item) =>
          item.id == entry.id ||
          (key.isNotEmpty && _registryEntryIdentityKey(item) == key),
    );
    if (index >= 0) {
      items[index] = entry;
    } else {
      items.add(entry);
    }
    await _writeRegistryEntries(_sortRegistryEntries(items));
  }

  Future<RegistrySettings> _readLocalRegistrySettingsOnly() async {
    final prefs = await SharedPreferences.getInstance();
    final raw = prefs.getString(_registrySettingsKey);
    if (raw == null || raw.trim().isEmpty) {
      return const RegistrySettings();
    }

    final decoded = jsonDecode(raw);
    if (decoded is! Map<String, dynamic>) {
      return const RegistrySettings();
    }

    return RegistrySettings.fromMap(decoded);
  }

  Future<void> _writeLocalRegistrySettings(RegistrySettings settings) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString(_registrySettingsKey, jsonEncode(settings.toMap()));
  }

  RegistryEntry _legacyRegistryEntryFromRow(Map<String, dynamic> row) {
    final number =
        (row['number'] ?? row['numarDocument'] ?? '').toString().trim();
    final type =
        RegistryStore.normalizeDocumentType(row['type'] ?? row['source']);
    final registeredAt = _parseRegistryDateTime(
      (row['updatedAt'] ?? row['createdAt'] ?? row['date'] ?? '').toString(),
    );
    final effectiveId =
        (row['referenceId'] ?? row['id'] ?? '').toString().trim();
    return RegistryEntry(
      id: effectiveId.isEmpty
          ? _registryStableId(
              type: type,
              primaryNumber: number,
            )
          : effectiveId,
      registryNumber: number,
      registryType: RegistryType.iesire,
      sequenceNumber: _extractRegistrySequence(number),
      year: registeredAt.year,
      registeredAt: registeredAt,
      documentNumber: number,
      documentDate: _parseRegistryDate(
        (row['date'] ?? row['documentDate'] ?? '').toString(),
      ),
      documentTitle: (row['title'] ?? '').toString().trim(),
      documentCategory: RegistryStore.documentTypeLabelUi(type),
      issuerName: '',
      recipientName: (row['client'] ?? '').toString().trim(),
      clientId: '',
      jobId: (row['jobId'] ?? row['jobCode'] ?? '').toString().trim(),
      offerId: '',
      estimateId: '',
      contractId: '',
      ticketId: '',
      filePath: (row['filePath'] ?? '').toString().trim(),
      fileName: '',
      notes: '',
      status: (row['status'] ?? '').toString().trim(),
    );
  }

  Map<String, dynamic> _registryEntryToCloudMap(RegistryEntry entry) {
    return <String, dynamic>{
      ...entry.toMap(),
      'id': entry.id,
      'registered_at': entry.registeredAt.toIso8601String(),
      'document_date': entry.documentDate?.toIso8601String(),
    };
  }

  RegistryEntry _ensureRegistryEntryId(RegistryEntry entry) {
    final currentId = entry.id.trim();
    if (currentId.isNotEmpty) {
      return entry;
    }
    return entry.copyWith(
      id: _registryStableId(
        type: RegistryStore.normalizeDocumentType(entry.documentCategory),
        primaryNumber: entry.registryNumber.isNotEmpty
            ? entry.registryNumber
            : entry.documentNumber,
      ),
    );
  }

  RegistryEntry _normalizeRegistryEntry(RegistryEntry entry) {
    final normalizedDocumentNumber = entry.documentNumber.trim();
    if (normalizedDocumentNumber.isEmpty ||
        entry.registryNumber.trim() == normalizedDocumentNumber) {
      return entry;
    }
    return entry.copyWith(registryNumber: normalizedDocumentNumber);
  }

  bool _sameRegistryEntryLists(
    List<RegistryEntry> left,
    List<RegistryEntry> right,
  ) {
    if (left.length != right.length) {
      return false;
    }
    for (var index = 0; index < left.length; index++) {
      if (!_sameRegistryEntry(left[index], right[index])) {
        return false;
      }
    }
    return true;
  }

  bool _sameRegistryEntry(RegistryEntry left, RegistryEntry right) {
    return jsonEncode(left.toMap()) == jsonEncode(right.toMap());
  }

  List<RegistryEntry> _mergeRegistryEntries(
    List<RegistryEntry> primary,
    List<RegistryEntry> secondary,
  ) {
    final byKey = <String, RegistryEntry>{};
    for (final item in <RegistryEntry>[...primary, ...secondary]) {
      final normalized = _ensureRegistryEntryId(item);
      final key = _registryEntryIdentityKey(normalized);
      if (key.isEmpty) {
        continue;
      }
      byKey[key] = normalized;
    }
    return byKey.values.toList(growable: false);
  }

  List<RegistryEntry> _sortRegistryEntries(List<RegistryEntry> entries) {
    final items = [...entries];
    items.sort((a, b) => b.registeredAt.compareTo(a.registeredAt));
    return items;
  }

  String _registryEntryIdentityKey(RegistryEntry entry) {
    final id = entry.id.trim();
    if (id.isNotEmpty) {
      return 'id:$id';
    }
    final registryNumber = entry.registryNumber.trim();
    final documentNumber = entry.documentNumber.trim();
    if (registryNumber.isEmpty && documentNumber.isEmpty) {
      return '';
    }
    return 'doc:$registryNumber|$documentNumber|${entry.documentCategory.trim().toLowerCase()}';
  }

  String _registryStableId({
    required String type,
    required String primaryNumber,
  }) {
    final normalizedType = type.trim().isEmpty ? 'document' : type.trim();
    final normalizedNumber = primaryNumber.trim().isEmpty
        ? DateTime.now().microsecondsSinceEpoch.toString()
        : primaryNumber.trim();
    final sanitized =
        normalizedNumber.replaceAll(RegExp(r'[^A-Za-z0-9]+'), '_');
    return 'registry_${normalizedType}_$sanitized';
  }

  int _extractRegistrySequence(String raw) {
    final match = RegExp(r'(\d+)(?!.*\d)').firstMatch(raw);
    return int.tryParse(match?.group(1) ?? '') ?? 0;
  }

  DateTime _parseRegistryDateTime(String raw) {
    return DateTime.tryParse(raw) ?? DateTime.now();
  }

  DateTime? _parseRegistryDate(String raw) {
    return DateTime.tryParse(raw);
  }

  bool _isDefaultRegistrySettings(RegistrySettings settings) {
    final defaults = const RegistrySettings().toMap();
    final current = settings.toMap();
    return jsonEncode(defaults) == jsonEncode(current);
  }

  Future<void> _mirrorRegistryEntryToLegacyStore(RegistryEntry entry) async {
    final normalizedType = RegistryStore.normalizeDocumentType(
      entry.documentCategory.isNotEmpty
          ? entry.documentCategory
          : entry.registryType.storageValue,
    );
    if (normalizedType.isEmpty) {
      return;
    }
    final allocatedNumber = await RegistryStore.allocateNumber(
      type: normalizedType,
      existingNumber: entry.documentNumber.trim().isNotEmpty
          ? entry.documentNumber
          : entry.registryNumber,
    );
    await RegistryStore.upsertEntry(
      type: normalizedType,
      number: allocatedNumber,
      title: entry.documentTitle.trim(),
