  Future<List<Appointment>> _readLocalAppointmentsOnly() async {
    // Cache hit — O(1), fără JSON decode, fără disc I/O
    if (_appointmentsMemCache != null) return _appointmentsMemCache!;

    // Prima citire — citim de pe disc și populăm cache-ul
    final prefs = await SharedPreferences.getInstance();
    final raw = prefs.getString(_appointmentsKey);
    if (raw == null || raw.trim().isEmpty) {
      _appointmentsMemCache = const <Appointment>[];
      return _appointmentsMemCache!;
    }

    final decoded = jsonDecode(raw);
    if (decoded is! List<dynamic>) {
      _appointmentsMemCache = const <Appointment>[];
      return _appointmentsMemCache!;
    }

    _appointmentsMemCache = _sortAppointments(
      decoded
          .map(
            (item) => Appointment.fromMap(
              Map<String, dynamic>.from(item as Map),
            ),
          )
          .toList(growable: false),
    );
    return _appointmentsMemCache!;
  }

  List<Appointment> _sortAppointments(List<Appointment> items) {
    final sorted = [...items];
    sorted.sort((a, b) {
      final byStart =
          a.effectiveStartDateTime.compareTo(b.effectiveStartDateTime);
      if (byStart != 0) return byStart;
      return a.effectiveEndDateTime.compareTo(b.effectiveEndDateTime);
    });
    return sorted;
  }

