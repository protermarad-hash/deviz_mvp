  int _computeDaysCount(DateTime start, DateTime end) {
    final from = DateTime(start.year, start.month, start.day);
    final to = DateTime(end.year, end.month, end.day);
    final diff = to.difference(from).inDays + 1;
    return diff < 1 ? 1 : diff;
  }

  int _compareComplaints(ComplaintRecord a, ComplaintRecord b) {
    final dateCompare = b.complaintDate.compareTo(a.complaintDate);
    if (dateCompare != 0) {
      return dateCompare;
    }
    return b.updatedAt.compareTo(a.updatedAt);
  }

  int _compareRepairReports(RepairReportRecord a, RepairReportRecord b) {
    final dateCompare = b.interventionDate.compareTo(a.interventionDate);
    if (dateCompare != 0) {
      return dateCompare;
    }
    return b.updatedAt.compareTo(a.updatedAt);
  }

  int _compareWarrantyInterventionReports(
    WarrantyInterventionReportRecord a,
    WarrantyInterventionReportRecord b,
  ) {
    final left = a.documentDate ?? a.updatedAt;
    final right = b.documentDate ?? b.updatedAt;
    final dateCompare = right.compareTo(left);
    if (dateCompare != 0) {
      return dateCompare;
    }
    return b.updatedAt.compareTo(a.updatedAt);
  }

  int _compareComplaintClientCentralizers(
    ComplaintClientCentralizerRecord a,
    ComplaintClientCentralizerRecord b,
  ) {
    final dateCompare = b.periodEnd.compareTo(a.periodEnd);
    if (dateCompare != 0) {
      return dateCompare;
    }
    return b.updatedAt.compareTo(a.updatedAt);
  }

  int _compareComplaintWorkOrders(
    ComplaintWorkOrderRecord a,
    ComplaintWorkOrderRecord b,
  ) {
    final dateCompare = b.issueDate.compareTo(a.issueDate);
    if (dateCompare != 0) {
      return dateCompare;
    }
    return b.updatedAt.compareTo(a.updatedAt);
