  @override
  Future<List<FieldPhotoRecord>> listFieldPhotos({
    String sourceModule = '',
    String sourceEntityId = '',
    String documentId = '',
  }) async {
    final localItems = await _readLocalFieldPhotosOnly();
    final normalizedModule = sourceModule.trim();
    final normalizedEntityId = sourceEntityId.trim();
    final normalizedDocumentId = documentId.trim();

    // IMPORTANT: NU mai folosim isOnline — DNS lookup-ul durează ~2s la startup,
    // timp în care isOnline=false și s-ar returna cache local gol (bug critic).
    // Folosim isInitialized: Firebase SDK e gata să facă query-uri chiar dacă
    // DNS lookup-ul nu a terminat încă. Dacă e offline, get() eșuează → catch → local.
    if (!FirebaseBootstrap.isInitialized) {
      return _filterFieldPhotos(
        localItems,
        sourceModule: normalizedModule,
        sourceEntityId: normalizedEntityId,
        documentId: normalizedDocumentId,
      );
    }

    try {
      // Optimizare: dacă avem un sourceEntityId specific, filtrăm direct în Firestore
      // (single-field where = fără index compus necesar) în loc să descărcăm TOATE pozele.
      // Când nu avem entityId (ex: _loadPhotoCountsAsync fără filtru), descărcăm tot.
      Query<Map<String, dynamic>> query = _fieldPhotosCollection;
      if (normalizedEntityId.isNotEmpty) {
        query = query.where('source_entity_id', isEqualTo: normalizedEntityId);
      } else if (normalizedModule.isNotEmpty) {
        query = query.where('source_module', isEqualTo: normalizedModule);
      }

      debugPrint('[FieldPhotos] listFieldPhotos: '
          'module="$normalizedModule" entityId="$normalizedEntityId" '
          'docId="$normalizedDocumentId" '
          'isInit=${FirebaseBootstrap.isInitialized} isOnline=${FirebaseBootstrap.isOnline}');

      var cloudItems = await query.get().then(
            (snapshot) => snapshot.docs
                .map((doc) => FieldPhotoRecord.fromMap(doc.data()))
                .where((item) => item.id.trim().isNotEmpty)
                .toList(growable: false),
          );

      debugPrint('[FieldPhotos] Firestore returned ${cloudItems.length} docs, '
          'localCache has ${localItems.length} items');

      // Merge cloud + local-only (poze create offline, neajunse în Firestore)
      if (localItems.isNotEmpty) {
        final knownIds = cloudItems.map((item) => item.id).toSet();
        for (final item in localItems) {
          final id = item.id.trim();
          if (id.isEmpty || knownIds.contains(id)) {
            continue;
          }
          // Guard resurrection: nu re-uploadăm poze șterse de pe alt dispozitiv.
          // Dacă fișierul local NU EXISTĂ și poza are downloadUrl = alt device, skip.
          // Dacă fișierul local EXISTĂ = dispozitivul original, scriem în Firestore.
          final localFilePath = item.filePath.trim();
          final localFileExists =
              localFilePath.isNotEmpty && File(localFilePath).existsSync();
          if (!localFileExists && item.downloadUrl.trim().isNotEmpty) {
            continue;
          }
          // Verifică că poza aparține filtrului curent înainte de a o include
          if (normalizedEntityId.isNotEmpty &&
              item.sourceEntityId.trim() != normalizedEntityId) {
            continue;
          }
          if (normalizedModule.isNotEmpty &&
              item.sourceModule.trim() != normalizedModule) {
            continue;
          }
          try {
            await _fieldPhotosCollection.doc(id).set(
                  item.toMap(),
                  SetOptions(merge: true),
                );
          } catch (_) {}
          cloudItems = <FieldPhotoRecord>[...cloudItems, item];
          knownIds.add(id);
        }
      }

      // Actualizează cache local DOAR cu pozele din această entitate
      // (nu suprascrie toate pozele cu un subset filtrat)
      if (normalizedEntityId.isEmpty && normalizedModule.isEmpty) {
        // Fără filtru = am descărcat tot → salvăm tot în cache
        final merged = [...cloudItems]..sort(_compareFieldPhotos);
        await _writeFieldPhotos(merged);
      }

      return _filterFieldPhotos(
        cloudItems,
        sourceModule: normalizedModule,
        sourceEntityId: normalizedEntityId,
        documentId: normalizedDocumentId,
      );
    } catch (e, stack) {
      // LOGGING EROARE — afișăm eroarea reală, nu o înghițim în tăcere
      debugPrint('[FieldPhotos] ❌ EROARE Firestore: $e');
      debugPrint('[FieldPhotos] Stack: $stack');
      // Firestore indisponibil → fallback la cache local
      return _filterFieldPhotos(
        localItems,
        sourceModule: normalizedModule,
        sourceEntityId: normalizedEntityId,
