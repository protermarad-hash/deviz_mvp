  Future<List<ClientRecord>> _readLocalClientsOnly() async {
    final prefs = await SharedPreferences.getInstance();
    final raw = prefs.getString(_clientsKey);
    if (raw != null && raw.trim().isNotEmpty) {
      try {
        final decoded = jsonDecode(raw);
        if (decoded is List<dynamic>) {
          final items = decoded
              .whereType<Map>()
              .map(
                  (row) => ClientRecord.fromMap(Map<String, dynamic>.from(row)))
              .where((item) => item.id.trim().isNotEmpty)
              .toList()
            ..sort(
                (a, b) => a.name.toLowerCase().compareTo(b.name.toLowerCase()));
          if (items.isNotEmpty) {
            return items;
          }
        }
      } catch (_) {}
    }

    final legacy = await _loadLegacyListRows(
      priorityKeys: const <String>[
        'clients_v1',
        'deviz_clients_v1',
        'clients',
      ],
      keyHints: const <String>['client', 'clients'],
    );
    final now = DateTime.now();
    final converted = <ClientRecord>[];
    for (var i = 0; i < legacy.length; i++) {
      final row = legacy[i];
      final mapped = ClientRecord.fromMap(row);
      final id =
          mapped.id.isEmpty ? '${now.microsecondsSinceEpoch + i}' : mapped.id;
      converted.add(
        mapped.copyWith(
          id: id,
          clientCode: mapped.clientCode.isEmpty
              ? 'CL-${(i + 1).toString().padLeft(4, '0')}'
              : mapped.clientCode,
          createdAt: mapped.createdAt,
          updatedAt: mapped.updatedAt,
        ),
      );
    }
    converted
        .sort((a, b) => a.name.toLowerCase().compareTo(b.name.toLowerCase()));
    return converted;
  }

