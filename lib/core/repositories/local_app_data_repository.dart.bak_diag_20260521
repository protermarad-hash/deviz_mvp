  int _compareFieldPhotos(FieldPhotoRecord a, FieldPhotoRecord b) {
    final dateCompare = b.takenAt.compareTo(a.takenAt);
    if (dateCompare != 0) {
      return dateCompare;
    }
    return b.updatedAt.compareTo(a.updatedAt);
  }

  int _compareMonthlyTimesheets(
    MonthlyTimesheetRecord a,
    MonthlyTimesheetRecord b,
  ) {
    if (a.year != b.year) {
      return b.year.compareTo(a.year);
    }
    if (a.month != b.month) {
      return b.month.compareTo(a.month);
    }
    return b.updatedAt.compareTo(a.updatedAt);
  }

  List<FieldPhotoRecord> _filterFieldPhotos(
    List<FieldPhotoRecord> items, {
    required String sourceModule,
    required String sourceEntityId,
    required String documentId,
  }) {
    return items.where((item) {
      if (sourceModule.isNotEmpty && item.sourceModule.trim() != sourceModule) {
        return false;
      }
      if (sourceEntityId.isNotEmpty &&
          item.sourceEntityId.trim() != sourceEntityId) {
        return false;
      }
      // FIX: documentId NU se mai aplică ca filtru exclusiv dacă sourceEntityId
      // este deja specificat și unic (ex: appointment ID).
      // Problema: dacă poza a fost salvată cu documentId=appointmentId
      // dar managerul deschide cu documentId=jobId (legat ulterior),
      // filtrul strict ascundea poza.
      // Soluție: documentId se aplică DOAR când sourceEntityId este gol
      // (cazul rar în care documentId e singurul identificator).
      if (sourceEntityId.isEmpty &&
          documentId.isNotEmpty &&
          item.documentId.trim() != documentId) {
        return false;
      }
      return true;
    }).toList(growable: false)
      ..sort(_compareFieldPhotos);
  }

  Future<String> _nextSequenceNumber({
    required String type,
    required DateTime date,
    required List<String> items,
  }) async {
    final year = date.year.toString();
    final prefix = '$type-$year-';
    int max = 0;
    for (final raw in items) {
      final value = raw.trim().toUpperCase();
      if (!value.startsWith(prefix)) {
        continue;
      }
      final seq = int.tryParse(value.substring(prefix.length));
      if (seq != null && seq > max) {
        max = seq;
      }
    }
    return '$type-$year-${(max + 1).toString().padLeft(4, '0')}';
  }

  Future<String> _nextConfiguredDocumentNumber({
    required String documentType,
    required DateTime date,
    required List<String> items,
  }) async {
    final settings = await loadRegistrySettings();
    final normalizedType =
        RegistryDocumentSeriesCatalog.normalizeType(documentType);
    final prefix = settings.seriesPrefixFor(normalizedType);
    final includeYear =
        RegistryDocumentSeriesCatalog.includeYear(normalizedType);
    final year = date.year.toString();
    final normalizedPrefix = prefix.trim().toUpperCase();
    final pattern = includeYear
        ? RegExp(
            '^${RegExp.escape(normalizedPrefix)}-$year-(\\d+)' r'$',
            caseSensitive: false,
          )
        : RegExp(
            '^${RegExp.escape(normalizedPrefix)}-(\\d+)' r'$',
            caseSensitive: false,
          );
    var max = 0;
    for (final raw in items) {
      final match = pattern.firstMatch(raw.trim().toUpperCase());
      if (match == null) {
        continue;
      }
      final value = int.tryParse(match.group(1) ?? '');
      if (value != null && value > max) {
        max = value;
      }
    }
    final nextValue = (max + 1).toString().padLeft(4, '0');
    if (includeYear) {
      return '$normalizedPrefix-$year-$nextValue';
    }
    return '$normalizedPrefix-$nextValue';
  }

  Future<List<Map<String, dynamic>>> _loadLegacyListRows({
    required List<String> priorityKeys,
    required List<String> keyHints,
  }) async {
    final prefs = await SharedPreferences.getInstance();
    for (final key in priorityKeys) {
      final rows = _decodeListRows(prefs.getString(key));
      if (rows.isNotEmpty) {
        return rows;
      }
    }

    final keys = prefs.getKeys().toList()..sort((a, b) => a.compareTo(b));
    for (final key in keys) {
      final lower = key.toLowerCase();
      if (!keyHints.any((hint) => lower.contains(hint))) {
        continue;
      }
      final rows = _decodeListRows(prefs.getString(key));
      if (rows.isNotEmpty) {
        return rows;
      }
    }
    return const <Map<String, dynamic>>[];
  }

  List<Map<String, dynamic>> _decodeListRows(String? raw) {
    if (raw == null || raw.trim().isEmpty) {
      return const <Map<String, dynamic>>[];
    }
    dynamic decoded;
    try {
      decoded = jsonDecode(raw);
    } catch (_) {
      return const <Map<String, dynamic>>[];
    }
    if (decoded is! List<dynamic>) {
      return const <Map<String, dynamic>>[];
    }
    return decoded
        .whereType<Map>()
        .map((item) => Map<String, dynamic>.from(item))
        .toList();
  }

  String _firstNonEmptyString(
    Map<String, dynamic> map,
    List<String> keys, {
    String fallback = '',
  }) {
    for (final key in keys) {
      final value = (map[key] ?? '').toString().trim();
      if (value.isNotEmpty) {
        return value;
      }
    }
    return fallback;
  }

  List<LookupItem> _dedupeLookup(List<LookupItem> items) {
    final map = <String, LookupItem>{};
    for (final item in items) {
      map[item.id] = item;
    }
    return map.values.toList();
  }

  Future<PdfExportSettings> _readLocalPdfExportSettings({
    CompanyProfile? fallbackProfile,
  }) async {
    final prefs = await SharedPreferences.getInstance();
    final raw = prefs.getString(_companyPdfExportSettingsKey);
    if (raw != null && raw.trim().isNotEmpty) {
      try {
        final decoded = jsonDecode(raw);
        if (decoded is Map<String, dynamic>) {
          return PdfExportSettings.fromMap(decoded);
        }
        if (decoded is Map) {
          return PdfExportSettings.fromMap(Map<String, dynamic>.from(decoded));
        }
      } catch (_) {}
    }
    return (fallbackProfile ?? const CompanyProfile()).pdfExportSettings;
  }

  Future<void> _writeLocalPdfExportSettings(PdfExportSettings settings) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString(
      _companyPdfExportSettingsKey,
      jsonEncode(settings.toMap()),
    );
  }

  Future<void> _writeCompanyProfileCache(CompanyProfile profile) async {
    final prefs = await SharedPreferences.getInstance();
    Map<String, dynamic> base = <String, dynamic>{};
    final existing = prefs.getString(_companySettingsKey);
    if (existing != null && existing.trim().isNotEmpty) {
      try {
        final decoded = jsonDecode(existing);
        if (decoded is Map<String, dynamic>) {
          base = Map<String, dynamic>.from(decoded);
        } else if (decoded is Map) {
          base = Map<String, dynamic>.from(decoded);
        }
      } catch (_) {}
    }
    final merged = <String, dynamic>{...base, ...profile.toMap()};
    final payload = jsonEncode(merged);
    await prefs.setString(_companySettingsKey, payload);
    await prefs.setString('company_settings', payload);
    await prefs.setString('deviz_company_settings_v1', payload);
  }

