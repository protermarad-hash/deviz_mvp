class ProgramariPage extends StatefulWidget {
  const ProgramariPage({
    super.key,
    required this.repository,
    this.fieldAuthRoleKey,
    this.fieldAuthUserEmail,
    this.fieldAuthUserId,
    this.fieldAuthTeamId,
    this.initialDraftAppointment,
    this.autoOpenDraftOnStart = false,
    this.autoCloseAfterDraftSave = false,
    this.initialFocusAppointmentId = '',
    this.onAppointmentSaved,
  });

  final AppDataRepository repository;
  final String? fieldAuthRoleKey;
  final String? fieldAuthUserEmail;
  final String? fieldAuthUserId;
  final String? fieldAuthTeamId;
  final Appointment? initialDraftAppointment;
  final bool autoOpenDraftOnStart;
  final bool autoCloseAfterDraftSave;
  final String initialFocusAppointmentId;
  final Future<void> Function(Appointment appointment)? onAppointmentSaved;

  @override
  State<ProgramariPage> createState() => _ProgramariPageState();
}

