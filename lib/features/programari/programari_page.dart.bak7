                          const SizedBox(height: 12),
                          DropdownButtonFormField<String>(
                            initialValue: selectedStatus,
                            decoration:
                                const InputDecoration(labelText: 'Status'),
                            items: _statusOptions
                                .map(
                                  (status) => DropdownMenuItem<String>(
                                    value: status.key,
                                    child: Text(status.value),
                                  ),
