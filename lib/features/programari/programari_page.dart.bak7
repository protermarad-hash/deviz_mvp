  String _jobLabel(String jobId) {
    if (jobId.trim().isEmpty) return '-';
    // O(1) lookup din Map pre-construit în _loadSecondaryDataAsync()
    return _jobLabelById[jobId] ?? jobId;
  }

  String _jobCode(String jobId) {
    final label = _jobLabel(jobId);
    if (label == '-' || label.trim().isEmpty) return '-';
    final idx = label.indexOf(' - ');
    if (idx > 0) {
      return label.substring(0, idx).trim();
    }
    return label;
  }

  String _teamName(String teamId) {
    if (teamId.trim().isEmpty) return '-';
    // O(1) lookup din Map pre-construit în _loadSecondaryDataAsync()
    return _teamNameById[teamId] ?? teamId;
  }

  List<String> _normalizeIdList(Iterable<String> values) {
    final result = <String>[];
    for (final value in values) {
      final id = value.trim();
      if (id.isEmpty || result.contains(id)) {
        continue;
      }
      result.add(id);
    }
    return result;
  }

  List<String> _appointmentTeamIds(Appointment item) =>
      _normalizeIdList(item.resolvedAssignedTeamIds);

  List<String> _appointmentEmployeeIds(Appointment item) =>
      _normalizeIdList(item.assignedEmployeeIds);

  String _summarizeLabels(
    List<String> labels, {
    String emptyLabel = '-',
    int visibleCount = 2,
  }) {
    if (labels.isEmpty) {
      return emptyLabel;
    }
    if (labels.length <= visibleCount) {
      return labels.join(', ');
    }
    final remaining = labels.length - visibleCount;
    return '${labels.take(visibleCount).join(', ')} +$remaining';
  }

  List<String> _teamNamesFromIds(List<String> teamIds) {
    return _normalizeIdList(teamIds.map(_teamName));
  }

  MasterEmployee? _employeeById(String employeeId) {
    final id = employeeId.trim();
    if (id.isEmpty) return null;
    for (final employee in _masterEmployees) {
      if (employee.id == id) return employee;
    }
    return null;
  }

  String _employeeNameFromIds(List<String> employeeIds) {
    return _summarizeLabels(_employeeNamesFromIds(employeeIds));
  }

  List<String> _employeeNamesFromIds(List<String> employeeIds) {
    final labels = <String>[];
    for (final employeeId in _normalizeIdList(employeeIds)) {
      final employee = _employeeById(employeeId);
      if (employee == null) {
        labels.add(employeeId);
        continue;
      }
      labels.add(employee.name.trim().isEmpty ? employee.id : employee.name);
    }
    return labels;
  }

  String _teamIdFromEmployee(String employeeId) {
    final employee = _employeeById(employeeId);
    if (employee != null && employee.teamId.trim().isNotEmpty) {
      return employee.teamId.trim();
    }
    final id = employeeId.trim();
    if (id.isEmpty) return '';
    for (final team in _masterTeams) {
      if (team.memberIds.contains(id)) {
        return team.id;
      }
    }
    return '';
  }

  // Returnează din cache — calculat o singură dată când se schimbă datele/filtrele
  List<Appointment> get _filteredItems => _cachedFilteredItems;

  // Recalculează cache-ul de filtrare; apelat din setState ori de câte ori
  // se schimbă _items, _statusFilter, _teamFilter, _jobFilter, _employeeScopeMode
  // sau _currentAuthUser.
  void _updateFilteredCache() {
    final scopedBase = _items.where(_isVisibleForCurrentUser);
    final scoped =
        _isEmployeeRole ? scopedBase.where(_matchesEmployeeScope) : scopedBase;
    _cachedFilteredItems = scoped.where((item) {
      if (_statusFilter.isNotEmpty &&
          _normalizeStatusValue(item.status) != _statusFilter) {
        return false;
      }
      if (_teamFilter.isNotEmpty &&
          !_appointmentTeamIds(item).contains(_teamFilter)) {
        return false;
      }
      if (_jobFilter.isNotEmpty && item.jobId != _jobFilter) {
        return false;
      }
      if (_documentFilter == 'cu_documente' &&
          item.linkedDocuments.isEmpty) {
        return false;
      }
      if (_documentFilter == 'fara_documente' &&
          item.linkedDocuments.isNotEmpty) {
        return false;
      }
      return true;
    }).toList(growable: false);

    if (!_canManageAppointmentFinancials) {
      _cachedNrNeincasate = 0;
    } else {
      final cutoff = DateTime.now().subtract(const Duration(days: 7));
      _cachedNrNeincasate = _items
          .where((item) =>
              item.status == 'finalizata' &&
              item.adminFinancialStatus ==
                  AppointmentFinancialStatus.neincasata &&
              item.effectiveStartDateTime.isBefore(cutoff))
          .length;
    }
  }

  bool get _canCreateAdministrativeAppointments {
    final role = AppRolePolicy.resolve(roleKey: widget.fieldAuthRoleKey);
    return AppRolePolicy.canAccessTeamLead(role);
  }

  bool get _canCreateOperationalAppointments {
    final role = AppRolePolicy.resolve(roleKey: widget.fieldAuthRoleKey);
    return AppRolePolicy.canAccessTeamLead(role) ||
        AppRolePolicy.isEmployee(role);
  }

  bool get _isAdminRole =>
      AppRolePolicy.resolve(roleKey: widget.fieldAuthRoleKey) ==
      UserRole.admin;

  bool get _canManageAppointmentFinancials => _isAdminRole;

  bool get _canManageAppointmentMaterialKits => _isAdminRole;

  bool get _canEditInterventionPrice =>
      AppRolePolicy.canAccessOffice(
        AppRolePolicy.resolve(roleKey: widget.fieldAuthRoleKey),
      );

  // Returnează din cache — calculat în _updateFilteredCache()
  int get _nrProgramariNeincasate => _cachedNrNeincasate;

  bool _isVisibleForCurrentUser(Appointment item) {
    final role = AppRolePolicy.resolve(roleKey: widget.fieldAuthRoleKey);
    if (AppRolePolicy.canAccessOffice(role)) {
      return true;
    }

    final authTeamId = (widget.fieldAuthTeamId ?? '').trim();
    final authUserId = (widget.fieldAuthUserId ?? '').trim();
    final authEmail = (widget.fieldAuthUserEmail ?? '').trim().toLowerCase();
    final authEmployeeId = (_currentAuthUser?.employeeId ?? '').trim();
    final assignedTeamIds = _appointmentTeamIds(item).toSet();
    final itemAssignedUserId = item.assignedUserId.trim();
    final itemAssignedEmail = item.assignedUserEmail.trim().toLowerCase();
    final assignedEmployeeIds = _appointmentEmployeeIds(item).toSet();

    final sameTeam =
        authTeamId.isNotEmpty && assignedTeamIds.contains(authTeamId);
    final sameUser = authUserId.isNotEmpty && itemAssignedUserId == authUserId;
    final sameEmail = authEmail.isNotEmpty && itemAssignedEmail == authEmail;
    final sameEmployee = authEmployeeId.isNotEmpty &&
        assignedEmployeeIds.contains(authEmployeeId);

    if (role == UserRole.sefEchipa) {
      return sameTeam || sameUser || sameEmail || sameEmployee;
    }
    if (role == UserRole.tehnician) {
      return sameTeam || sameUser || sameEmail || sameEmployee;
    }
    return true;
  }

  bool _matchesEmployeeScope(Appointment item) {
    final authTeamId = _currentUserTeamId;
    final authUserId = (widget.fieldAuthUserId ?? '').trim();
    final authEmail = (widget.fieldAuthUserEmail ?? '').trim().toLowerCase();
    final authEmployeeId = (_currentAuthUser?.employeeId ?? '').trim();
    final assignedTeamIds = _appointmentTeamIds(item);
    final itemAssignedUserId = item.assignedUserId.trim();
    final itemAssignedEmail = item.assignedUserEmail.trim().toLowerCase();
    final sameEmployee = authEmployeeId.isNotEmpty &&
        _appointmentEmployeeIds(item).contains(authEmployeeId);

    final sameTeam =
        authTeamId.isNotEmpty && assignedTeamIds.contains(authTeamId);
    final sameUser = authUserId.isNotEmpty && itemAssignedUserId == authUserId;
    final sameEmail = authEmail.isNotEmpty && itemAssignedEmail == authEmail;
    final isMine = sameUser || sameEmail || sameEmployee;

    switch (_employeeScopeMode) {
      case _EmployeeScopeMode.mine:
        return isMine;
      case _EmployeeScopeMode.team:
        return sameTeam;
      case _EmployeeScopeMode.all:
        return isMine || sameTeam;
    }
  }

  Future<ComplaintRecord?> _loadComplaintForAppointment(
      Appointment item) async {
    final complaintId = item.complaintId.trim();
    if (complaintId.isEmpty) {
      return null;
    }
    final complaints = await widget.repository.listComplaints();
    return complaints
        .where((entry) => entry.id == complaintId)
        .fold<ComplaintRecord?>(
          null,
          (previous, entry) => previous ?? entry,
        );
  }

  Future<WarrantyCertificateRecord?> _resolveWarrantyCertificateForAppointment(
    Appointment item, {
    ComplaintRecord? complaint,
  }) async {
    final certificates =
        await _productCatalogService.listWarrantyCertificates();
    final complaintCertificateId =
        complaint?.warrantyCertificateId.trim() ?? '';
    if (complaintCertificateId.isNotEmpty) {
      final direct = certificates
          .where((entry) => entry.id == complaintCertificateId)
          .fold<WarrantyCertificateRecord?>(
            null,
            (previous, entry) => previous ?? entry,
          );
      if (direct != null) {
        return direct;
      }
    }
    final jobId = item.jobId.trim();
    if (jobId.isNotEmpty) {
      final byJob = certificates
          .where((entry) => entry.jobId.trim() == jobId)
          .fold<WarrantyCertificateRecord?>(
            null,
            (previous, entry) => previous ?? entry,
          );
      if (byJob != null) {
        return byJob;
      }
    }
    final clientId = item.clientId.trim();
    if (clientId.isNotEmpty) {
      return certificates
          .where((entry) => entry.buyerClientId.trim() == clientId)
          .fold<WarrantyCertificateRecord?>(
            null,
            (previous, entry) => previous ?? entry,
          );
    }
    return null;
  }

  Future<WarrantyCertificateRecord> _buildAppointmentWarrantyCertificate({
    required Appointment item,
    required List<WarrantyCertificateRecord> certificates,
    ComplaintRecord? complaint,
    WarrantyCertificateRecord? existing,
  }) async {
    final now = DateTime.now();
    final identity = existing == null ||
            (existing.certificateSeries.trim().isEmpty &&
                existing.certificateNumber.trim().isEmpty)
        ? _productCatalogService.nextCertificateIdentity(
            certificates,
            now: now,
          )
        : (
            series: existing.certificateSeries,
            number: existing.certificateNumber,
          );
    final company = await widget.repository.loadCompanyProfile();
    final job = _jobRecordById(item.jobId);
    final client = _clientRecordById(item.clientId);
    final effectiveDate = item.effectiveStartDateTime;
    final sellerName = company.companyName.trim().isNotEmpty
        ? company.companyName.trim()
        : company.contactName.trim();
    final buyerAddressParts = <String>[
      client?.address.trim() ?? item.location.trim(),
      client?.city.trim() ?? job?.city.trim() ?? '',
      client?.county.trim() ?? job?.county.trim() ?? '',
    ].where((entry) => entry.isNotEmpty).toList(growable: false);
    final equipmentType = complaint?.equipmentType?.label ??
        existing?.equipmentType ??
        job?.category.trim() ??
        '';
    final jobTitle = job == null
        ? item.title.trim()
        : '${job.jobCode.trim()} | ${job.title.trim()}'.trim();

    return WarrantyCertificateRecord(
      id: existing?.id ?? 'warranty-certificate-${now.microsecondsSinceEpoch}',
      saleId: existing?.saleId ?? '',
      sourceType: item.jobId.trim().isNotEmpty
          ? WarrantyCertificateSourceType.job
          : WarrantyCertificateSourceType.manual,
      jobId: existing?.jobId ?? item.jobId.trim(),
      jobTitle: existing?.jobTitle ?? jobTitle,
      sourceEquipmentId: existing?.sourceEquipmentId ?? '',
      sourceEquipmentLabel: existing?.sourceEquipmentLabel ?? item.title.trim(),
      certificateSeries: identity.series.trim(),
      certificateNumber: identity.number.trim(),
      documentDate: existing?.documentDate ?? effectiveDate,
      equipmentType: equipmentType,
      brand: existing?.brand ?? complaint?.equipmentBrand.trim() ?? '',
      model: existing?.model ?? complaint?.equipmentModel.trim() ?? '',
      serialNumberIndoor: existing?.serialNumberIndoor ??
          complaint?.indoorUnitSerials.trim() ??
          '',
      serialNumberOutdoor: existing?.serialNumberOutdoor ??
          complaint?.outdoorUnitSerial.trim() ??
          '',
      invoiceNumber: existing?.invoiceNumber ?? '',
      saleDate: existing?.saleDate ?? effectiveDate,
      warrantyMonths: existing?.warrantyMonths ?? 24,
      warrantyStartDate: existing?.warrantyStartDate ?? effectiveDate,
      warrantyEndDate: existing?.warrantyEndDate ??
          DateTime(
              effectiveDate.year, effectiveDate.month + 24, effectiveDate.day),
      sellerName: existing?.sellerName ?? sellerName,
      sellerAddress: existing?.sellerAddress ?? company.address.trim(),
      sellerEmail: existing?.sellerEmail ?? company.email.trim(),
      sellerPhone: existing?.sellerPhone ?? company.phone.trim(),
      sellerTaxId: existing?.sellerTaxId ?? company.cui.trim(),
      buyerClientId: existing?.buyerClientId ?? item.clientId.trim(),
      buyerName: existing?.buyerName ??
          _resolvedClientName(item.clientId, item.clientName),
      buyerAddress: existing?.buyerAddress ?? buyerAddressParts.join(', '),
      buyerPhone: existing?.buyerPhone ?? _detailPhone(item),
      buyerTaxOrCnp: existing?.buyerTaxOrCnp ?? client?.cui.trim() ?? '',
      installerName: existing?.installerName ?? sellerName,
      installerAddress: existing?.installerAddress ?? company.address.trim(),
      installerEmail: existing?.installerEmail ?? company.email.trim(),
      installerPhone: existing?.installerPhone ?? company.phone.trim(),
      installerTaxId: existing?.installerTaxId ?? company.cui.trim(),
      installerPersons:
          existing?.installerPersons ?? _employeeLabelForAppointment(item),
      installationDate: existing?.installationDate ?? effectiveDate,
      termsText:
          existing?.termsText ?? ProductCatalogService.defaultWarrantyTerms,
      status: existing?.status ?? 'draft',
      registryEntryId: existing?.registryEntryId ?? '',
      documentType: existing?.documentType ?? 'warranty_certificate',
      sourceModule: existing?.sourceModule ?? 'programari',
      generatedDocumentPath: existing?.generatedDocumentPath ?? '',
      generatedDocumentFileName: existing?.generatedDocumentFileName ?? '',
      warrantyServiceHistoryIds:
          existing?.warrantyServiceHistoryIds ?? const <String>[],
      complaintIds: existing?.complaintIds ??
          (complaint == null ? const <String>[] : <String>[complaint.id]),
      warrantyServiceTickets: existing?.warrantyServiceTickets ??
          const <WarrantyServiceTicketRecord>[],
      createdAt: existing?.createdAt ?? now,
      updatedAt: now,
    );
  }

  Future<void> _generateAppointmentWarrantyCertificatePdf(
    WarrantyCertificateRecord certificate,
  ) async {
    try {
      final filePath = await WarrantyCertificatePdfService.export(
        repository: widget.repository,
        certificate: certificate,
      );
      var persisted = certificate.copyWith(
        generatedDocumentPath: filePath,
        generatedDocumentFileName: _fileNameFromPath(filePath),
        updatedAt: DateTime.now(),
      );
      if (persisted.registryEntryId.trim().isEmpty) {
        final entry = await widget.repository.registerGeneratedDocument(
          registryType: RegistryType.iesire,
          documentCategory: 'Certificat garantie',
          documentTitle:
              'Certificat de garantie ${persisted.fullCertificateNumber.trim().isEmpty ? persisted.id : persisted.fullCertificateNumber}',
          documentNumber: persisted.fullCertificateNumber.trim().isEmpty
              ? persisted.id
              : persisted.fullCertificateNumber,
          documentDate: persisted.documentDate,
          issuerName: persisted.sellerName,
          recipientName: persisted.buyerName,
          clientId: persisted.buyerClientId,
          jobId: persisted.jobId,
          filePath: filePath,
          fileName: persisted.generatedDocumentFileName,
          notes: 'Generat rapid din modulul Programari.',
          status: 'emis',
        );
        persisted = persisted.copyWith(registryEntryId: entry.id);
      }
      await _productCatalogService.saveWarrantyCertificate(persisted);
      if (!mounted) {
        return;
      }
      await PdfActionsHelper.showPdfActions(
        context,
        filePath: filePath,
        title: 'Certificat de garanție generat',
        shareSubject:
            'Certificat garanție ${persisted.fullCertificateNumber.trim().isEmpty ? persisted.id : persisted.fullCertificateNumber}',
        shareText: 'Certificat de garanție generat din aplicație.',
      );
    } catch (error) {
      if (!mounted) {
        return;
      }
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Nu am putut genera certificatul de garantie: $error'),
        ),
      );
    }
  }

  Future<void> _openQuickDocumentAction(
    Appointment item,
    _AppointmentQuickDocumentAction action,
  ) async {
    switch (action) {
      case _AppointmentQuickDocumentAction.linkedDocuments:
        await _openLinkedDocumentsManagerForAppointment(item);
        return;
      case _AppointmentQuickDocumentAction.fieldPhotos:
        await _openFieldPhotosForAppointment(item);
        return;
      case _AppointmentQuickDocumentAction.repairReport:
        await _openRepairReportForAppointment(item);
        return;
      case _AppointmentQuickDocumentAction.warrantyIntervention:
        await _openWarrantyInterventionReportForAppointment(item);
        return;
      case _AppointmentQuickDocumentAction.jobSiteDocuments:
        await _openJobSiteDocumentsForAppointment(item);
        return;
      case _AppointmentQuickDocumentAction.warrantyCertificate:
        await _openWarrantyCertificateForAppointment(item);
        return;
    }
  }

