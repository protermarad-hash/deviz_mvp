  String get _dataSourceUiLabel {
    if (_dataSourceLabel != 'local_cache') {
      return _dataSourceLabel;
    }
    final reason =
        (_cloudFallbackReason ?? FirebaseBootstrap.lastErrorMessage ?? '')
            .trim();
    if (reason.isEmpty) {
      return _dataSourceLabel;
    }
    return '$_dataSourceLabel • Motiv fallback: ${reason.length > 90 ? '${reason.substring(0, 90)}…' : reason}';
  }

  String _shortCloudError(Object error) {
    final raw = error.toString().replaceAll('\n', ' ').trim();
    if (raw.isEmpty) {
      return 'necunoscută';
    }
    return raw.length > 140 ? '${raw.substring(0, 140)}…' : raw;
  }

  void _programariLog(String message) {
    debugPrint('[Programari] $message');
  }

  void _setStateLogged(String reason, VoidCallback fn) {
    if (!mounted) return;
    _programariLog('setState reason=$reason');
    setState(fn);
  }

  int get _activeBackgroundTasksCount =>
      _activeBackgroundTasks.length +
      (OfflineSyncRuntime.instance.isSyncing ? 1 : 0);

  void _logActiveBackgroundTasks() {
    _programariLog('active background tasks count=$_activeBackgroundTasksCount');
  }

  void _startBackgroundTask(String label, Future<void> Function() task) {
    final token = '$label#${++_backgroundTaskSerial}';
    final stopwatch = Stopwatch()..start();
    _activeBackgroundTasks[token] = stopwatch;
    _programariLog('$label start');
    _logActiveBackgroundTasks();
    task().then((_) {
      _programariLog('$label end duration_ms=${stopwatch.elapsedMilliseconds}');
    }).catchError((error, stackTrace) {
      _programariLog('$label error duration_ms=${stopwatch.elapsedMilliseconds} error=$error');
      FirebaseBootstrap.registerRuntimeError(error);
    }).whenComplete(() {
      _activeBackgroundTasks.remove(token);
      _logActiveBackgroundTasks();
    });
  }

  @override
  void initState() {
    super.initState();
    _programariLog('initState start');
    _refreshCloudRepositories();
    _loadAllPreferences();
    // Future.microtask evită operații grele în primul frame (CLAUDE.md ANTI-PATTERN 2)
    Future.microtask(_load);
    // Reîncarcă din cloud când internetul devine disponibil după startup
    // (CLAUDE.md ANTI-PATTERN 4 — pagini care nu se reîncarcă după startup)
    FirebaseBootstrap.onlineNotifier.addListener(_onOnlineChanged);
    // Reîncarcă clienții doar debounced, ca să evităm storm-ul de reload-uri.
    LocalAppDataRepository.clientsChangeCount.addListener(
      _onClientsChangeCountUpdated,
    );
  }

  /// Apelat când starea online/offline se schimbă.
  /// Reîncarcă datele din cloud NUMAI dacă lista e goală (CLAUDE.md ANTI-PATTERN 4).
  /// NU reîncărcăm dacă datele există — previne reload la fiecare fluctuație WiFi.
  void _onOnlineChanged() {
    if (FirebaseBootstrap.isOnline && mounted && _items.isEmpty && !_loading) {
      _load();
    }
  }

  void _refreshCloudRepositories() {
    if (FirebaseBootstrap.isInitialized) {
      _clientiCloudRepository ??= FirebaseClientiRepository();
      _lucrariCloudRepository ??= FirebaseLucrariRepository();
    }
  }

  @override
  void dispose() {
    FirebaseBootstrap.onlineNotifier.removeListener(_onOnlineChanged);
    LocalAppDataRepository.clientsChangeCount.removeListener(
      _onClientsChangeCountUpdated,
    );
    _clientsReloadDebounce?.cancel();
    _pageScrollController.dispose();
    super.dispose();
  }

  /// Reîncarcă doar lista de clienți fără a reîncărca toate datele.
  void _onClientsChangeCountUpdated() {
    if (_secondaryDataLoading) {
      _programariLog('clientsChangeCount skip reason=secondary_loading');
      return;
    }
    _clientsReloadDebounce?.cancel();
    _programariLog('clientsChangeCount debounce scheduled');
    _clientsReloadDebounce = Timer(const Duration(milliseconds: 250), () {
      unawaited(_reloadClientsOnly(reason: 'clientsChangeCount'));
    });
  }

  Future<void> _reloadClientsOnly({String reason = 'manual'}) async {
    if (_secondaryDataLoading) {
      _programariLog('reload clients skip reason=secondary_loading');
      return;
    }
    if (_clientsReloadInProgress) {
      _programariLog('reload clients skip reason=already_running');
      return;
    }
    final now = DateTime.now();
    if (_lastClientsReloadAt != null &&
        now.difference(_lastClientsReloadAt!) <
            const Duration(milliseconds: 250)) {
      _programariLog('reload clients skip reason=debounced');
      return;
    }
    _clientsReloadInProgress = true;
    _lastClientsReloadAt = now;
    _programariLog('reload clients start source=$reason');
    try {
      final results = await Future.wait<dynamic>([
        _listClientsLookupResolved(),
        widget.repository.listClients(),
      ]);
      if (!mounted) return;
      _setStateLogged('reload clients only', () {
        _clients = results[0] as List<LookupItem>;
        _clientRecords = results[1] as List<ClientRecord>;
        _clientNameById = {
          for (final c in _clients)
            if (c.id.trim().isNotEmpty)
              c.id: c.name.trim().isEmpty ? c.id : c.name,
        };
        _clientRecordByIdMap = {
          for (final c in _clientRecords)
            if (c.id.trim().isNotEmpty) c.id: c,
        };
      });
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
      _programariLog('reload clients error source=$reason error=$error');
    } finally {
      _clientsReloadInProgress = false;
      _programariLog('reload clients end source=$reason');
    }
  }

  Future<void> _load() async {
    // syncPending() NU se apelează aici — rulează deja la startup, la fiecare 30s
    // din bootstrap și la resume. A-l apela și din _load() e redundant și costisitor.
    _refreshCloudRepositories();
    final stopwatch = Stopwatch()..start();
    try {
      // ── Faza 1: programări + utilizator curent → afișăm lista imediat ──
      final phase1 = await Future.wait<dynamic>(<Future<dynamic>>[
        _listAppointmentsResolved(),
        _loadCurrentAuthUserResolved(),
      ]);
      if (!mounted) return;
      _setStateLogged('load phase1 results', () {
        _items = phase1[0] as List<Appointment>;
        _currentAuthUser = phase1[1] as FieldAuthUser?;
        _loading = false;
        _updateFilteredCache();
      });
      _startBackgroundTask('photo counts background', _loadPhotoCountsAsync);
      await _handleInitialNavigationIntents();

      // ── Faza 2: date secundare în background (dropdown-uri, filtre, echipe) ──
      _startBackgroundTask('secondary preload', _loadSecondaryDataAsync);
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
      if (mounted) {
        _cloudFallbackReason = _shortCloudError(error);
        _setStateLogged('load error', () => _loading = false);
      }
    } finally {
      _programariLog(
        'load end duration_ms=${stopwatch.elapsedMilliseconds} count=${_items.length}',
      );
    }
  }

  // Date secundare: jobs, clienți, echipe, angajați, parteneri, kit-uri.
  // Apelat în background după ce lista de programări este deja vizibilă.
  Future<void> _loadSecondaryDataAsync() {
    final active = _secondaryDataLoadFuture;
    if (active != null) {
      _programariLog('secondary preload skip reason=already_running');
      return active;
    }
    final future = _loadSecondaryDataAsyncImpl();
    _secondaryDataLoadFuture = future;
    return future.whenComplete(() {
      if (identical(_secondaryDataLoadFuture, future)) {
        _secondaryDataLoadFuture = null;
      }
    });
  }

  Future<void> _loadSecondaryDataAsyncImpl() async {
    _secondaryDataLoading = true;
    try {
      final results = await Future.wait<dynamic>(<Future<dynamic>>[
        _listJobsLookupResolved(),
        _listClientsLookupResolved(),
        _listClientRecordsResolved(),
        _listJobRecordsResolved(),
        widget.repository.listTeams(),
        _listMasterEmployeesResolved(),
        widget.repository.listPartners(),
        _kitCatalogService.listTemplates(),
      ]);
      if (!mounted) return;
      final fetchedTeams = results[4] as List<Team>;
      final derivedMasterTeams = fetchedTeams
          .where((t) => t.id.trim().isNotEmpty)
          .map(_masterTeamFromRepository)
          .toList(growable: false);
      if (derivedMasterTeams.isNotEmpty) {
        await MasterLocalStore.writeTeams(derivedMasterTeams);
      }
      final masterTeamsResolved = derivedMasterTeams.isNotEmpty
          ? derivedMasterTeams
          : await MasterLocalStore.readTeams();
      if (!mounted) return;
      _setStateLogged('load secondary data', () {
        final jobsBundle = results[0] as _JobsLookupBundle;
        _jobs = jobsBundle.lookupItems;
        _jobClientById = jobsBundle.jobClientById;
        _clients = results[1] as List<LookupItem>;
        _clientRecords = results[2] as List<ClientRecord>;
        _jobRecords = results[3] as List<JobRecord>;
        _teams = fetchedTeams;
        _masterEmployees = results[5] as List<MasterEmployee>;
        _masterTeams = masterTeamsResolved;
        _partnerRecords = results[6] as List<PartnerRecord>;
        _materialKitTemplates =
            results[7] as List<AppointmentMaterialKitTemplate>;

        // Construieste Maps O(1) pentru lookup rapid în build()
        // Evita bucle O(n) per card (ex: 200 progr. × 100 clienti = 20k iter.)
        _clientNameById = {
          for (final c in _clients)
            if (c.id.trim().isNotEmpty)
              c.id: c.name.trim().isEmpty ? c.id : c.name,
        };
        _jobLabelById = {
          for (final j in _jobs)
            if (j.id.trim().isNotEmpty)
              j.id: j.name.trim().isEmpty ? j.id : j.name,
        };
        _teamNameById = {
          for (final t in fetchedTeams)
            if (t.id.trim().isNotEmpty)
              t.id: t.name.trim().isEmpty ? t.id : t.name,
          for (final t in masterTeamsResolved)
            if (t.id.trim().isNotEmpty)
              t.id: t.name.trim().isEmpty ? t.id : t.name,
        };
        _teamColorById = {
          for (final t in masterTeamsResolved)
            if (t.id.trim().isNotEmpty && t.colorValue != 0)
              t.id: Color(t.colorValue),
        };
        // Maps O(1) pentru record complet — elimină for-loop din itemBuilder
        _clientRecordByIdMap = {
          for (final c in results[2] as List<ClientRecord>)
            if (c.id.trim().isNotEmpty) c.id: c,
        };
        _jobRecordByIdMap = {
          for (final j in results[3] as List<JobRecord>)
            if (j.id.trim().isNotEmpty) j.id: j,
        };

        _updateFilteredCache();
      });
      _secondaryDataReady = true;
      _programariLog(
        'secondary data counts clients=${_clientRecords.length} jobs=${_jobRecords.length} partners=${_partnerRecords.length}',
      );
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
    } finally {
      _secondaryDataLoading = false;
    }
  }

  // Cache catalog produse — evită reîncărcarea la fiecare deschidere dialog.
  Future<List<ProductCatalogRecord>> _getCatalogProducts() async {
    if (_cachedCatalogProducts != null) return _cachedCatalogProducts!;
    try {
      final all = await _productCatalogService.listProducts();
      _cachedCatalogProducts = all
          .where((p) => p.isActive && p.name.trim().isNotEmpty)
          .toList(growable: false);
    } catch (_) {
      _cachedCatalogProducts = const [];
    }
    return _cachedCatalogProducts!;
  }

  Future<void> _loadPhotoCountsAsync() async {
    // OPTIMIZARE CRITICĂ: folosim NUMAI cache-ul local pentru numărare.
    // Varianta cu listFieldPhotos(sourceModule:'programari') descarca TOATE pozele
    // din Firestore (sute de documente) doar pentru a le număra — extrem de lent.
    // Cache-ul local conține pozele dispozitivului curent și e suficient pentru badge-uri.
    try {
      final photos = await widget.repository.listFieldPhotosLocalOnly(
        sourceModule: 'programari',
      );
      final counts = <String, int>{};
      for (final photo in photos) {
        final id = photo.sourceEntityId.trim();
        if (id.isNotEmpty) {
          counts[id] = (counts[id] ?? 0) + 1;
        }
      }
      if (!mounted) return;
      _setStateLogged('photo counts ready', () => _photoCountByEntityId = counts);
    } catch (_) {}
  }

  bool get _hasEditorReferenceData =>
      _secondaryDataReady ||
      _clientRecords.isNotEmpty ||
      _jobRecords.isNotEmpty ||
      _partnerRecords.isNotEmpty;

  Future<void> _ensureSecondaryDataReadyForEditor() async {
    if (_hasEditorReferenceData) {
      return;
    }
    final stopwatch = Stopwatch()..start();
    _programariLog('editor preload waiting for secondary data');
    final future = _secondaryDataLoadFuture ?? _loadSecondaryDataAsync();
    var loadingShown = false;
    unawaited(Future<void>.delayed(const Duration(milliseconds: 150)).then((_) {
      if (!mounted || _hasEditorReferenceData || loadingShown) {
        return Future<void>.value();
      }
      loadingShown = true;
      _programariLog('editor preload showing loading state');
      return showDialog<void>(
        context: context,
        barrierDismissible: false,
        builder: (dialogContext) => const AlertDialog(
          content: Row(
            children: [
              SizedBox(
                width: 20,
                height: 20,
                child: CircularProgressIndicator(strokeWidth: 2),
              ),
              SizedBox(width: 12),
              Expanded(
                child: Text('Se încarcă clienții, lucrările și partenerii...'),
              ),
            ],
          ),
        ),
      );
    }));
    await future;
    if (loadingShown &&
        mounted &&
        Navigator.of(context, rootNavigator: true).canPop()) {
      Navigator.of(context, rootNavigator: true).pop();
    }
    _programariLog(
      'editor preload wait end duration_ms=${stopwatch.elapsedMilliseconds} ready=$_secondaryDataReady',
    );
  }

  Future<void> _handleInitialNavigationIntents() async {
    if (!mounted) {
      return;
    }
    if (!_didHandleInitialDraft &&
        widget.autoOpenDraftOnStart &&
        widget.initialDraftAppointment != null) {
      _didHandleInitialDraft = true;
      WidgetsBinding.instance.addPostFrameCallback((_) async {
        if (!mounted) {
          return;
        }
        await _openEditor(
          draftAppointment: widget.initialDraftAppointment,
          closePageOnSave: widget.autoCloseAfterDraftSave,
        );
      });
      return;
    }
    final initialFocusId = widget.initialFocusAppointmentId.trim();
    if (_didHandleInitialFocus || initialFocusId.isEmpty) {
      return;
    }
    final target =
        _items.where((item) => item.id == initialFocusId).fold<Appointment?>(
              null,
              (previous, item) => item,
            );
    if (target == null) {
      return;
    }
    _didHandleInitialFocus = true;
    WidgetsBinding.instance.addPostFrameCallback((_) async {
      if (!mounted) {
        return;
      }
      await _openDetails(target);
    });
  }

  // Un singur SharedPreferences.getInstance() pentru toate preferințele — mai rapid la start
  Future<void> _loadAllPreferences() async {
    final prefs = await SharedPreferences.getInstance();
    final rawView = (prefs.getString(_viewModePreferenceKey) ?? '').trim();
    final startHour = prefs.getInt(_plannerBaseStartHourPreferenceKey) ??
        _defaultWorkdayStartHour;
    final endHour =
        prefs.getInt(_plannerBaseEndHourPreferenceKey) ?? _defaultWorkdayEndHour;
    final visibleDays = prefs.getInt(_calendarVisibleDaysPreferenceKey) ?? 7;
    final zoom = prefs.getDouble(_calendarZoomPreferenceKey) ?? 1.0;
    final rawTeam =
        (prefs.getString(_defaultAppointmentTeamIdsPreferenceKey) ?? '').trim();
    // Filtre active — restaurate la redeschiderea modulului
    final savedFilterTeam =
        (prefs.getString(_filterTeamPreferenceKey) ?? '').trim();
    final savedFilterStatus =
        (prefs.getString(_filterStatusPreferenceKey) ?? '').trim();
    final savedFilterJob =
        (prefs.getString(_filterJobPreferenceKey) ?? '').trim();
    final savedFilterScope =
        (prefs.getString(_filterEmployeeScopePreferenceKey) ?? '').trim();
    if (!mounted) return;
    _setStateLogged('load preferences', () {
      if (rawView.isNotEmpty) {
        _viewMode = rawView == _ProgramariViewMode.list.name
            ? _ProgramariViewMode.list
            : _ProgramariViewMode.calendar;
      }
      _plannerBaseStartHour = startHour.clamp(0, 23);
      _plannerBaseEndHour = endHour.clamp(startHour.clamp(0, 23) + 1, 24);
      _calendarVisibleDays =
          _calendarVisibleDayOptions.contains(visibleDays) ? visibleDays : 7;
      _calendarZoom = zoom.clamp(0.78, 1.16);
      if (rawTeam.isNotEmpty) {
        final ids = rawTeam
            .split(',')
            .map((e) => e.trim())
            .where((e) => e.isNotEmpty)
            .toList(growable: false);
        if (ids.isNotEmpty) _defaultAppointmentTeamIds = ids;
      }
      // Restaurăm filtrele active
      _teamFilter = savedFilterTeam;
      _statusFilter = savedFilterStatus;
      _jobFilter = savedFilterJob;
      if (savedFilterScope.isNotEmpty) {
        _employeeScopeMode = _EmployeeScopeMode.values.firstWhere(
          (e) => e.name == savedFilterScope,
          orElse: () => _EmployeeScopeMode.all,
        );
      }
    });
  }

  Future<void> _persistViewModePreference(_ProgramariViewMode mode) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString(_viewModePreferenceKey, mode.name);
  }

  Future<void> _persistPlannerBaseRangePreference() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setInt(
      _plannerBaseStartHourPreferenceKey,
      _plannerBaseStartHour,
    );
    await prefs.setInt(
      _plannerBaseEndHourPreferenceKey,
      _plannerBaseEndHour,
    );
  }

  Future<void> _persistCalendarDisplayPreferences() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setInt(_calendarVisibleDaysPreferenceKey, _calendarVisibleDays);
    await prefs.setDouble(_calendarZoomPreferenceKey, _calendarZoom);
  }

  /// Salvează filtrele active în SharedPreferences — apelat la fiecare
  /// schimbare de filtru ca utilizatorul să regăsească selecția la revenire.
  Future<void> _persistFilterPreferences() async {
    final prefs = await SharedPreferences.getInstance();
    await Future.wait([
      prefs.setString(_filterTeamPreferenceKey, _teamFilter),
      prefs.setString(_filterStatusPreferenceKey, _statusFilter),
      prefs.setString(_filterJobPreferenceKey, _jobFilter),
      prefs.setString(
          _filterEmployeeScopePreferenceKey, _employeeScopeMode.name),
    ]);
  }

  Future<void> _persistDefaultAppointmentTeamPreference() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString(
      _defaultAppointmentTeamIdsPreferenceKey,
      _defaultAppointmentTeamIds.join(','),
    );
  }

  Future<void> _openDefaultAppointmentSettingsDialog() async {
    List<String> editedTeamIds = List<String>.of(_defaultAppointmentTeamIds);
    final teamOptions = _masterTeams
        .map(
          (t) => MapEntry<String, String>(
            t.id,
            t.name.trim().isEmpty ? t.id : t.name,
          ),
        )
        .toList(growable: false);

    if (!mounted) return;

    await showDialog<void>(
      context: context,
      builder: (dialogContext) {
        return StatefulBuilder(
          builder: (ctx, setDialogState) {
            return AlertDialog(
              title: const Text('Setări implicite programări'),
              content: SizedBox(
                width: 480,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      'Echipa implicita este pre-selectata la crearea programarilor noi. Util pentru echipa cu cele mai multe solicitari.',
                      style: Theme.of(ctx).textTheme.bodyMedium,
                    ),
                    const SizedBox(height: 16),
                    OutlinedButton.icon(
                      onPressed: () async {
                        final nextSelection = await _openMultiSelectDialog(
                          title: 'Echipă implicită',
                          emptyLabel: 'Nu există echipe disponibile.',
                          options: teamOptions,
                          initialSelectedIds: editedTeamIds,
                        );
                        if (nextSelection == null) return;
                        setDialogState(() {
                          editedTeamIds = nextSelection;
                        });
                      },
                      icon: const Icon(Icons.groups_outlined),
                      label: Text(
                        editedTeamIds.isEmpty
                            ? 'Selectează echipă implicită'
                            : 'Echipe selectate (${editedTeamIds.length})',
                      ),
                    ),
                    const SizedBox(height: 8),
                    if (editedTeamIds.isNotEmpty)
                      Wrap(
                        spacing: 8,
                        runSpacing: 8,
                        children: editedTeamIds
                            .map(
                              (id) => Chip(
                                label: Text(_teamName(id)),
                                avatar: const Icon(
                                  Icons.groups_outlined,
                                  size: 16,
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                    if (editedTeamIds.isEmpty)
                      Text(
                        'Nicio echipă implicită setată. La creare se va folosi echipa utilizatorului logat sau echipa derivată din angajați.',
                        style: Theme.of(ctx).textTheme.bodySmall,
                      ),
                  ],
                ),
              ),
              actions: [
                TextButton(
                  onPressed: () => Navigator.of(dialogContext).pop(),
                  child: const Text('Renunță'),
                ),
                FilledButton(
                  onPressed: () async {
                    setState(() {
                      _defaultAppointmentTeamIds = editedTeamIds;
                    });
                    await _persistDefaultAppointmentTeamPreference();
                    if (dialogContext.mounted) {
                      Navigator.of(dialogContext).pop();
                    }
                    if (mounted) {
                      ScaffoldMessenger.of(context).showSnackBar(
                        const SnackBar(
                          content: Text(
                            'Setările implicite pentru programări au fost salvate.',
                          ),
                        ),
                      );
                    }
                  },
                  child: const Text('Salvează'),
                ),
              ],
            );
          },
        );
      },
    );
  }

  Future<FieldAuthUser?> _loadCurrentAuthUserResolved() async {
    final authUserId = (widget.fieldAuthUserId ?? '').trim();
    final authEmail = (widget.fieldAuthUserEmail ?? '').trim().toLowerCase();
    if (authUserId.isEmpty && authEmail.isEmpty) {
      return null;
    }
    try {
      final authRepository = FieldAuthRepositoryFactory.create();
      final users = await authRepository.listUsers();
      if (authUserId.isNotEmpty) {
        for (final user in users) {
          if (user.id.trim() == authUserId) {
            return user;
          }
        }
      }
      if (authEmail.isNotEmpty) {
        for (final user in users) {
          if (user.email.trim().toLowerCase() == authEmail) {
            return user;
          }
        }
      }
    } catch (_) {}
    return null;
  }

  Future<List<MasterEmployee>> _listMasterEmployeesResolved() async {
    try {
      final rows = await widget.repository.listEmployeesLookup();
      final mapped = rows
          .where((row) => row.id.trim().isNotEmpty)
          .map(_masterEmployeeFromLookup)
          .toList(growable: false);
      if (mapped.isNotEmpty) {
        await MasterLocalStore.writeEmployees(mapped);
        return mapped;
      }
      return MasterLocalStore.readEmployees();
    } catch (_) {
      return MasterLocalStore.readEmployees();
    }
  }

  MasterEmployee _masterEmployeeFromLookup(EmployeeLookup row) {
    return MasterEmployee(
      id: row.id.trim(),
      name: row.name.trim(),
      role: row.role.trim(),
      active: row.active,
      laborCostType: row.laborCostType,
      costLunar: row.costLunar,
      tarifOrar: row.tarifOrar,
      oreLunareStandard: row.oreLunareStandard,
      dailyAllowance: row.perDiemPerDay,
      defaultLodgingCost: row.lodgingPerDay,
      requiresLodgingByDefault: row.requiresLodgingByDefault,
    );
  }

  MasterTeam _masterTeamFromRepository(Team row) {
    return MasterTeam(
      id: row.id.trim(),
      name: row.name.trim(),
      notes: row.notes.trim(),
      memberIds: row.memberEmployeeIds
          .map((item) => item.trim())
          .where((item) => item.isNotEmpty)
          .toList(growable: false),
    );
  }

  /// Returns the custom color of the first assigned team with a color set.
  Color? _teamColorForAppointment(Appointment item) {
    // O(n) în loc de O(n²) — _teamColorById e Map pre-construit
    for (final teamId in _appointmentTeamIds(item)) {
      final color = _teamColorById[teamId];
      if (color != null) return color;
    }
    return null;
  }

  Future<List<Appointment>> _listAppointmentsResolved() async {
    final items = _loadAllHistory
        ? await widget.repository.listAllAppointments()
        : await widget.repository.listAppointments();
    _syncAppointmentDataSourceLabel();
    return items;
  }

  Future<List<LookupItem>> _listClientsLookupResolved() async {
    final cloud = _clientiCloudRepository;
    if (cloud == null) {
      return widget.repository.listClientsLookup();
    }
    try {
      final cloudItems = await cloud.listClients();
      final lookup = cloudItems
          .where((item) => item.id.trim().isNotEmpty)
          .map((item) => LookupItem(id: item.id, name: item.name))
          .toList(growable: false);
      return lookup;
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
      _cloudFallbackReason = _shortCloudError(error);
      return widget.repository.listClientsLookup();
    }
  }

  Future<List<ClientRecord>> _listClientRecordsResolved() async {
    final cloud = _clientiCloudRepository;
    if (cloud == null) {
      return widget.repository.listClients();
    }
    try {
      return await cloud.listClients();
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
      _cloudFallbackReason = _shortCloudError(error);
      return widget.repository.listClients();
    }
  }

  Future<_JobsLookupBundle> _listJobsLookupResolved() async {
    final cloud = _lucrariCloudRepository;
    if (cloud == null) {
      return _listJobsLookupFromLocal();
    }
    try {
      final cloudItems = await cloud.listJobs();
      final lookup =
          cloudItems.where((item) => item.id.trim().isNotEmpty).map((item) {
        final label = item.jobCode.trim().isEmpty
            ? item.title
            : '${item.jobCode} - ${item.title}';
        return LookupItem(id: item.id, name: label);
      }).toList(growable: false);
      final jobClient = <String, String>{
        for (final job in cloudItems) job.id: job.clientId,
      };
      return _JobsLookupBundle(
        lookupItems: lookup,
        jobClientById: jobClient,
      );
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
      _cloudFallbackReason = _shortCloudError(error);
      return _listJobsLookupFromLocal();
    }
  }

  Future<List<JobRecord>> _listJobRecordsResolved() async {
    final cloud = _lucrariCloudRepository;
    if (cloud == null) {
      return widget.repository.listJobs();
    }
    try {
      return await cloud.listJobs();
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
      _cloudFallbackReason = _shortCloudError(error);
      return widget.repository.listJobs();
    }
  }

  Future<_JobsLookupBundle> _listJobsLookupFromLocal() async {
    final lookup = await widget.repository.listJobsLookup();
    final localJobs = await widget.repository.listJobs();
    final jobClient = <String, String>{
      for (final job in localJobs) job.id: job.clientId,
    };
    return _JobsLookupBundle(
      lookupItems: lookup,
      jobClientById: jobClient,
    );
  }

  /// Reload rapid: reincarca doar lista de programari din depozitul local.
  /// Folosit dupa actiuni rapide (schimbare status, poze, documente atasate)
  /// care nu modifica clienti, lucrari sau echipe — mult mai rapid decat _load().
  Future<void> _reloadAppointmentsOnly() async {
    try {
      final items = await _listAppointmentsResolved();
      if (!mounted) return;
      _setStateLogged('reload appointments only', () {
        _items = items;
        _updateFilteredCache();
      });
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
    }
  }

  Future<void> _saveAppointmentResolved(Appointment item) async {
    await widget.repository.saveAppointment(item);
    _syncAppointmentDataSourceLabel();
    // Queue apelat din repository (CLAUDE.md: nu din pagini)
  }

  Future<void> _writeAppointmentHistory({
    required Appointment item,
    required String action,
    Appointment? previous,
  }) async {
    final changedBy = (widget.fieldAuthUserEmail ?? '').trim().isNotEmpty
        ? widget.fieldAuthUserEmail!.trim()
        : (_currentAuthUser?.email ?? '').trim();
    try {
      await widget.repository.logAppointmentHistory(
        appointmentId: item.id,
        clientId: item.clientId,
        action: action,
        changedBy: changedBy,
        before: previous?.toMap(),
        after: action == 'delete' ? null : item.toMap(),
      );
    } catch (_) {
      // History is best-effort.
    }
  }

  String _appointmentNotificationTitle(
    NotificationEventType eventType,
    Appointment item,
  ) {
    switch (eventType) {
      case NotificationEventType.appointmentCreated:
        return 'Programare noua alocata';
      case NotificationEventType.appointmentPostponed:
        return 'Programare amanata';
      case NotificationEventType.appointmentCancelled:
        return 'Programare anulata';
      case NotificationEventType.appointmentUpdated:
        return 'Programare actualizata';
      default:
        return item.title.trim().isEmpty ? 'Programare' : item.title.trim();
    }
  }

  String _appointmentNotificationMessage(Appointment item) {
    final title = item.title.trim().isEmpty ? 'Fara titlu' : item.title.trim();
    final date =
        '${item.scheduledDate.day.toString().padLeft(2, '0')}.${item.scheduledDate.month.toString().padLeft(2, '0')}.${item.scheduledDate.year.toString().padLeft(4, '0')}';
    final teamLabel = _teamNamesFromIds(_appointmentTeamIds(item)).join(', ');
    return '$title | Data: $date | Interval: ${item.startTime} - ${item.endTime} | Status: ${item.status.trim().isEmpty ? '-' : item.status.trim()} | Echipe: ${teamLabel.isEmpty ? '-' : teamLabel}';
  }

  /// Returnează true dacă s-au schimbat câmpuri relevante pentru notificare email.
  /// Email NU se trimite pentru: plăți, încasări, materiale, prețuri, poze, note interne.
  bool _hasRelevantChangesForEmail(Appointment current, Appointment previous) {
    if (current.title.trim() != previous.title.trim()) { return true; }
    if (current.clientId.trim() != previous.clientId.trim()) { return true; }
    if (current.clientName.trim() != previous.clientName.trim()) { return true; }
    if (_normalizeStatusValue(current.status) !=
        _normalizeStatusValue(previous.status)) {
      return true;
    }
    if (current.teamId.trim() != previous.teamId.trim()) { return true; }
    if (current.assignedUserId.trim() != previous.assignedUserId.trim()) {
      return true;
    }
    if (current.assignedUserEmail.trim() !=
        previous.assignedUserEmail.trim()) {
      return true;
    }
    final currentTeams = (current.assignedTeamIds..sort()).join(',');
    final previousTeams = (previous.assignedTeamIds..sort()).join(',');
    if (currentTeams != previousTeams) { return true; }
    final currentEmployees = (current.assignedEmployeeIds..sort()).join(',');
    final previousEmployees = (previous.assignedEmployeeIds..sort()).join(',');
    if (currentEmployees != previousEmployees) { return true; }
    if (current.location.trim() != previous.location.trim()) { return true; }
    if (current.type.trim() != previous.type.trim()) { return true; }
    return false;
  }

  Future<void> _notifyAppointmentSaved({
    required Appointment item,
    Appointment? previous,
  }) async {
    final assignedTeamIds = _appointmentTeamIds(item);
    final assignedEmployeeIds = _appointmentEmployeeIds(item);
    if (assignedTeamIds.isEmpty &&
        assignedEmployeeIds.isEmpty &&
        item.assignedUserId.trim().isEmpty &&
        item.assignedUserEmail.trim().isEmpty) {
      return;
    }
    final previousStart = previous?.effectiveStartDateTime;
    final previousEnd = previous?.effectiveEndDateTime;
    final currentStart = item.effectiveStartDateTime;
    final currentEnd = item.effectiveEndDateTime;
    final status = _normalizeStatusValue(item.status);
    final eventType = previous == null
        ? NotificationEventType.appointmentCreated
        : status == 'anulata'
            ? NotificationEventType.appointmentCancelled
            : previousStart != null &&
                    previousEnd != null &&
                    (previousStart != currentStart || previousEnd != currentEnd)
                ? NotificationEventType.appointmentPostponed
                : NotificationEventType.appointmentUpdated;
    // Pentru appointmentUpdated, verificăm dacă s-au schimbat câmpuri relevante.
    // Nu trimitem email pentru modificări financiare, materiale, note interne sau poze.
    if (eventType == NotificationEventType.appointmentUpdated &&
        previous != null &&
        !_hasRelevantChangesForEmail(item, previous)) {
      return;
    }
    await _notificationService.dispatchEvent(
      NotificationDispatchRequest(
        eventType: eventType,
        title: _appointmentNotificationTitle(eventType, item),
        message: _appointmentNotificationMessage(item),
        sourceModule: 'programari',
        sourceEntityId: item.id,
        sourceLabel:
            item.title.trim().isEmpty ? 'Programare' : item.title.trim(),
        recipientUserIds: item.assignedUserId.trim().isEmpty
            ? const <String>[]
            : <String>[item.assignedUserId.trim()],
        recipientEmails: item.assignedUserEmail.trim().isEmpty
            ? const <String>[]
            : <String>[item.assignedUserEmail.trim()],
        recipientTeamIds: assignedTeamIds,
        recipientEmployeeIds: assignedEmployeeIds,
        metadata: <String, dynamic>{
          'status': item.status,
          'scheduled_date': item.scheduledDate.toIso8601String(),
          'job_id': item.jobId,
          'complaint_id': item.complaintId,
        },
      ),
    );
  }

  /// Sincronizează automat tranzacțiile financiare ale partenerilor
  /// din câmpurile financiare ale programării:
  ///   - forPartnerInvoiceAmount → PartnerTransaction (intrare, incasare_programare)
  ///   - executingPartnerCommission → PartnerTransaction (iesire, plata_programare)
  /// ID-urile sunt deterministe (ptxn_{id}_for / ptxn_{id}_exec) pentru upsert corect.
  Future<void> _syncPartnerFinancialFromAppointment(
    Appointment item, {
    Appointment? previous,
  }) async {
    final repo = PartnerFinancialRepository();
    final now = DateTime.now();
    final appointmentLabel = item.title.trim().isEmpty
        ? 'Programare ${item.scheduledDate.day.toString().padLeft(2, '0')}.${item.scheduledDate.month.toString().padLeft(2, '0')}.${item.scheduledDate.year}'
        : item.title.trim();

    // --- 1. forPartner: partenerul pentru care lucrăm (noi încasăm de la el) ---
    final forTxnId = 'ptxn_${item.id}_for';

    // Dacă partenerul s-a schimbat față de versiunea anterioară → șterge vechea tranzacție
    final prevForPartnerId = previous?.forPartnerId.trim() ?? '';
    final currForPartnerId = item.forPartnerId.trim();
    if (prevForPartnerId.isNotEmpty &&
        prevForPartnerId != currForPartnerId) {
      await repo.deleteTransaction(forTxnId);
      // Queue apelat din PartnerFinancialRepository.deleteTransaction() (CLAUDE.md)
    }

    if (currForPartnerId.isNotEmpty && item.forPartnerInvoiceAmount > 0) {
      final forTxn = PartnerTransaction(
        id: forTxnId,
        partnerId: currForPartnerId,
        partnerName: item.forPartnerName.trim(),
        type: PartnerTransactionType.incasareProgramare,
        direction: PartnerTransactionDirection.intrare,
        amount: item.forPartnerInvoiceAmount,
        date: item.scheduledDate,
        description: 'Programare: $appointmentLabel',
        referenceId: item.id,
        referenceType: 'programare',
        paymentMethod: PartnerTransactionPaymentMethod.transfer,
        status: _mapPartnerPaymentStatus(item.forPartnerReceiveStatus),
        createdAt: now,
        updatedAt: now,
      );
      await repo.upsertTransaction(forTxn);
      // Queue apelat din PartnerFinancialRepository.upsertTransaction() (CLAUDE.md)
    } else if (currForPartnerId.isEmpty || item.forPartnerInvoiceAmount <= 0) {
      // Suma eliminată sau partenerul eliminat → șterge tranzacția dacă există
      await repo.deleteTransaction(forTxnId);
      // Queue apelat din PartnerFinancialRepository.deleteTransaction() (CLAUDE.md)
    }

    // --- 2. executingPartner: partenerul care execută (noi îi plătim) ---
    final execTxnId = 'ptxn_${item.id}_exec';

    final prevExecPartnerId = previous?.executingPartnerId.trim() ?? '';
    final currExecPartnerId = item.executingPartnerId.trim();
    if (prevExecPartnerId.isNotEmpty &&
        prevExecPartnerId != currExecPartnerId) {
      await repo.deleteTransaction(execTxnId);
      // Queue apelat din PartnerFinancialRepository.deleteTransaction() (CLAUDE.md)
    }

    if (currExecPartnerId.isNotEmpty && item.executingPartnerCommission > 0) {
      final execTxn = PartnerTransaction(
        id: execTxnId,
        partnerId: currExecPartnerId,
        partnerName: item.executingPartnerName.trim(),
        type: PartnerTransactionType.plataProgramare,
        direction: PartnerTransactionDirection.iesire,
        amount: item.executingPartnerCommission,
        date: item.scheduledDate,
        description: 'Programare: $appointmentLabel',
        referenceId: item.id,
        referenceType: 'programare',
        paymentMethod: PartnerTransactionPaymentMethod.transfer,
        status: _mapPartnerPaymentStatus(item.executingPartnerPaymentStatus),
        createdAt: now,
        updatedAt: now,
      );
      await repo.upsertTransaction(execTxn);
      // Queue apelat din PartnerFinancialRepository.upsertTransaction() (CLAUDE.md)
    } else if (currExecPartnerId.isEmpty ||
        item.executingPartnerCommission <= 0) {
      await repo.deleteTransaction(execTxnId);
      // Queue apelat din PartnerFinancialRepository.deleteTransaction() (CLAUDE.md)
    }
  }

  /// Convertește PartnerPaymentStatus (din programare) în PartnerTransactionStatus (financiar).
  PartnerTransactionStatus _mapPartnerPaymentStatus(
    PartnerPaymentStatus status,
  ) {
    switch (status) {
      case PartnerPaymentStatus.neplatit:
        return PartnerTransactionStatus.neplatit;
      case PartnerPaymentStatus.platitPartial:
        return PartnerTransactionStatus.partial;
      case PartnerPaymentStatus.platit:
      case PartnerPaymentStatus.conformContract:
        return PartnerTransactionStatus.platit;
    }
  }

  Future<void> _deleteAppointmentResolved(String id) async {
    await widget.repository.deleteAppointment(id);
    _syncAppointmentDataSourceLabel();
    // Queue apelat din repository (CLAUDE.md: nu din pagini)
  }

  Future<void> _confirmAndDeleteAppointment(Appointment item) async {
    final confirmed = await showDialog<bool>(
      context: context,
      builder: (dialogContext) => AlertDialog(
        title: const Text('Sterge programarea?'),
        content: const Text(
          'Se va sterge doar programarea selectata. Datele clientului, lucrarii si reclamatiei raman neschimbate.',
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(dialogContext).pop(false),
            child: const Text('Renunta'),
          ),
          FilledButton.tonal(
            onPressed: () => Navigator.of(dialogContext).pop(true),
            child: const Text('Sterge'),
          ),
        ],
      ),
    );
    if (confirmed != true) {
      return;
    }
    if (!mounted) return;
    // Optimistic UI: scoate din listă imediat — nu așteaptă Firestore
    _setStateLogged('delete optimistic ui', () {
      _items = _items.where((a) => a.id != item.id).toList(growable: false);
      _updateFilteredCache();
    });
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(content: Text('Programarea a fost stearsa.')),
    );
    // Operații async în fundal (nu blochează UI)
    _startBackgroundTask(
      'history background delete',
      () => _writeAppointmentHistory(item: item, action: 'delete'),
    );
    _deleteAppointmentResolved(item.id).catchError((e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Eroare la ștergere: $e')),
        );
        _reloadAppointmentsOnly(); // restaurează starea la eroare
      }
    });
  }

  void _syncAppointmentDataSourceLabel() {
    final repository = widget.repository;
    if (repository is LocalAppDataRepository) {
      _dataSourceLabel = repository.lastAppointmentsDataSourceLabel;
      final reason = repository.lastAppointmentsFallbackReason.trim();
      _cloudFallbackReason = reason.isEmpty ? null : _shortCloudError(reason);
      return;
    }
    _dataSourceLabel = 'cloud';
    _cloudFallbackReason = null;
  }

  String _normalizeStatusValue(String raw) {
    final v = raw
        .trim()
        .toLowerCase()
        .replaceAll('ă', 'a')
        .replaceAll('â', 'a')
        .replaceAll('î', 'i')
        .replaceAll('ș', 's')
        .replaceAll('ş', 's')
        .replaceAll('ț', 't')
        .replaceAll('ţ', 't')
        .replaceAll('-', '_')
        .replaceAll(' ', '_');
    switch (v) {
      case 'planificata':
      case 'planned':
      case 'noua':
        return 'planificata';
      case 'in_curs':
      case 'incurs':
      case 'in_progress':
        return 'in_curs';
      case 'finalizata':
      case 'done':
      case 'completed':
        return 'finalizata';
      case 'amanata':
      case 'postponed':
        return 'amanata';
      case 'anulata':
      case 'canceled':
      case 'cancelled':
        return 'anulata';
      default:
        return 'planificata';
    }
  }

  String _statusLabel(String raw) {
    final key = _normalizeStatusValue(raw);
    for (final option in _statusOptions) {
      if (option.key == key) return option.value;
    }
    return 'Planificata';
  }

  String _normalizePriorityValue(String raw) {
    final value = raw
        .trim()
        .toLowerCase()
        .replaceAll('ă', 'a')
        .replaceAll('â', 'a')
        .replaceAll('î', 'i')
        .replaceAll('ș', 's')
        .replaceAll('ş', 's')
        .replaceAll('ț', 't')
        .replaceAll('ţ', 't');
    if (value.contains('urgent') || value.contains('critic')) {
      return 'ridicata';
    }
    if (value.contains('mare') ||
        value.contains('high') ||
        value.contains('ridicat')) {
      return 'ridicata';
    }
    if (value.contains('med')) {
      return 'medie';
    }
    if (value.contains('mic') ||
        value.contains('low') ||
        value.contains('scaz')) {
      return 'joasa';
    }
    return value;
  }

  String _priorityLabel(String raw) {
    final trimmed = raw.trim();
    if (trimmed.isEmpty) {
      return '-';
    }
    final normalized = _normalizePriorityValue(trimmed);
    switch (normalized) {
      case 'ridicata':
        return 'Ridicata';
      case 'medie':
        return 'Medie';
      case 'joasa':
        return 'Joasa';
      default:
        return trimmed;
    }
  }

  Color? _colorFromCode(String raw) {
    final normalized = raw.trim().replaceFirst('#', '');
    if (normalized.isEmpty) {
      return null;
    }
    final hex = normalized.length == 6 ? 'FF$normalized' : normalized;
    final value = int.tryParse(hex, radix: 16);
    if (value == null) {
      return null;
    }
    return Color(value);
  }

  String _colorCodeFromColor(Color color) {
    final argb =
        color.toARGB32().toRadixString(16).padLeft(8, '0').toUpperCase();
    final rgb = argb.substring(2);
    return '#$rgb';
  }

  /// Returns a vivid accent color based on appointment status.
  Color _statusAccentColor(String statusRaw) {
    switch (_normalizeStatusValue(statusRaw)) {
      case 'in_curs':
        return Colors.orange.shade800;
      case 'finalizata':
        return Colors.green.shade800;
      case 'amanata':
        return Colors.amber.shade800;
      case 'anulata':
        return Colors.red.shade700;
      case 'planificata':
      default:
        return Colors.blue.shade700;
    }
  }

  /// Color priority: manual colorCode > team color > status-based color.
  Color _appointmentAccentColor(Appointment item) {
    final manual = _colorFromCode(item.colorCode);
    if (manual != null) return manual;
    final teamColor = _teamColorForAppointment(item);
    if (teamColor != null) return teamColor;
    return _statusAccentColor(item.status);
  }

  /// Background fill is always driven by STATUS so each status has a distinct
  /// faded hue. The team / manual colour is reserved for the left strip and
  /// border outline, giving a clear two-layer visual cue.
  Color _appointmentSurfaceColor(Appointment item) {
    final statusColor = _statusAccentColor(item.status);
    return Color.alphaBlend(
      statusColor.withValues(alpha: 0.13),
      Theme.of(context).colorScheme.surface,
    );
  }

  String _appointmentColorLabel(String colorCode) {
    final normalized = colorCode.trim().toUpperCase();
    if (normalized.isEmpty) {
      return 'Auto dupa echipa / status';
    }
    for (final preset in _appointmentColorPresets) {
      if (_colorCodeFromColor(preset.color) == normalized) {
        return preset.label;
      }
    }
    return normalized;
  }

  List<AppointmentLinkedDocument> _normalizeLinkedDocuments(
    Iterable<AppointmentLinkedDocument> entries,
  ) {
    final seenPaths = <String>{};
    final normalized = <AppointmentLinkedDocument>[];
    for (final entry in entries) {
      final path = entry.filePath.trim();
      if (path.isEmpty || seenPaths.contains(path)) {
        continue;
      }
      seenPaths.add(path);
      final fileName = entry.fileName.trim().isEmpty
          ? _fileNameFromPath(path)
          : entry.fileName.trim();
      normalized.add(
        entry.copyWith(
          filePath: path,
          fileName: fileName,
          label: entry.label.trim().isEmpty ? fileName : entry.label.trim(),
        ),
      );
    }
    return List<AppointmentLinkedDocument>.unmodifiable(normalized);
  }

  Future<AppointmentLinkedDocument?> _pickAppointmentLinkedDocument() async {
    final result = await FilePicker.platform.pickFiles(
      type: FileType.any,
      allowMultiple: false,
      withData: false,
    );
    if (result == null || result.files.isEmpty) {
      return null;
    }
    final picked = result.files.single;
    final path = (picked.path ?? '').trim();
    if (path.isEmpty) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('Fisierul selectat nu poate fi accesat local.'),
          ),
        );
      }
      return null;
    }
    final fileName = picked.name.trim().isEmpty
        ? _fileNameFromPath(path)
        : picked.name.trim();
    return AppointmentLinkedDocument(
      label: fileName,
      filePath: path,
      fileName: fileName,
    );
  }

  Future<AppointmentLinkedDocument?> _capturePhotoAsLinkedDocument(
    FieldPhotoInputSource source,
  ) async {
    final picked = await FieldPhotoCaptureService.pickPhoto(source: source);
    if (picked == null) {
      return null;
    }
    final fileName = picked.fileName.trim().isEmpty
        ? _fileNameFromPath(picked.filePath)
        : picked.fileName.trim();
    return AppointmentLinkedDocument(
      label: 'Foto teren ${_formatDateTime(picked.takenAt)}',
      filePath: picked.filePath,
      fileName: fileName,
    );
  }

  Future<String?> _promptLinkedDocumentLabel({
    required String title,
    required String initialValue,
    String? helperText,
  }) async {
    final controller = TextEditingController(text: initialValue);
    return showDialog<String>(
      context: context,
      builder: (dialogContext) => AlertDialog(
        title: Text(title),
        content: TextField(
          textCapitalization: TextCapitalization.sentences,
          controller: controller,
          autofocus: true,
          decoration: InputDecoration(
            labelText: 'Eticheta document',
            helperText: helperText,
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(dialogContext).pop(),
            child: const Text('Renunta'),
          ),
          FilledButton(
            onPressed: () {
              final value = controller.text.trim();
              Navigator.of(dialogContext).pop(value);
            },
            child: const Text('Salveaza'),
          ),
        ],
      ),
    );
  }

  Future<void> _openLinkedDocumentsManagerForAppointment(
    Appointment appointment,
  ) async {
    var current = appointment;
    var documents = _normalizeLinkedDocuments(current.linkedDocuments);
    await showDialog<void>(
      context: context,
      builder: (dialogContext) {
        return StatefulBuilder(
          builder: (context, setDialogState) {
            Future<void> addDocument() async {
              final picked = await _pickAppointmentLinkedDocument();
              if (picked == null) {
                return;
              }
              final updated = _normalizeLinkedDocuments(
                <AppointmentLinkedDocument>[...documents, picked],
              );
              current = current.copyWith(linkedDocuments: updated);
              await _saveAppointmentResolved(current);
              await _reloadAppointmentsOnly();
              if (!dialogContext.mounted) {
                return;
              }
              setDialogState(() {
                documents = updated;
              });
            }

            Future<void> addPhoto(FieldPhotoInputSource source) async {
              final picked = await _capturePhotoAsLinkedDocument(source);
              if (picked == null) {
                return;
              }
              final updated = _normalizeLinkedDocuments(
                <AppointmentLinkedDocument>[...documents, picked],
              );
              current = current.copyWith(linkedDocuments: updated);
              await _saveAppointmentResolved(current);
              await _reloadAppointmentsOnly();
              if (!dialogContext.mounted) {
                return;
              }
              setDialogState(() {
                documents = updated;
              });
            }

            Future<void> removeDocument(
                AppointmentLinkedDocument document) async {
              final updated = _normalizeLinkedDocuments(
                documents.where((entry) => entry.filePath != document.filePath),
              );
              current = current.copyWith(linkedDocuments: updated);
              await _saveAppointmentResolved(current);
              await _reloadAppointmentsOnly();
              if (!dialogContext.mounted) {
                return;
              }
              setDialogState(() {
                documents = updated;
              });
            }

            Future<void> renameDocument(
              AppointmentLinkedDocument document,
            ) async {
              final fileName = document.fileName.trim().isEmpty
                  ? _fileNameFromPath(document.filePath)
                  : document.fileName.trim();
              final updatedLabel = await _promptLinkedDocumentLabel(
                title: 'Redenumeste documentul',
                initialValue: document.label.trim().isEmpty
                    ? fileName
                    : document.label.trim(),
                helperText:
                    'Eticheta se afiseaza in programare, fara sa modifice fisierul original.',
              );
              if (updatedLabel == null || updatedLabel.trim().isEmpty) {
                return;
              }
              final updated = _normalizeLinkedDocuments(
                documents.map(
                  (entry) => entry.filePath == document.filePath
                      ? entry.copyWith(label: updatedLabel.trim())
                      : entry,
                ),
              );
              current = current.copyWith(linkedDocuments: updated);
              await _saveAppointmentResolved(current);
              await _reloadAppointmentsOnly();
              if (!dialogContext.mounted) {
                return;
              }
              setDialogState(() {
                documents = updated;
              });
            }

            return AlertDialog(
              title: const Text('Documente incarcate pe programare'),
              content: SizedBox(
                width: 720,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Wrap(
                      spacing: 8,
                      runSpacing: 8,
                      children: [
                        Chip(
                          avatar:
                              const Icon(Icons.attach_file_outlined, size: 16),
                          label: Text(
                            documents.isEmpty
                                ? 'Fara documente atasate'
                                : 'Documente: ${documents.length}',
                          ),
                          visualDensity: VisualDensity.compact,
                        ),
                        FilledButton.tonalIcon(
                          onPressed: () => addPhoto(
                            FieldPhotoInputSource.camera,
                          ),
                          icon: const Icon(Icons.photo_camera_outlined),
                          label: const Text('Fa poza'),
                        ),
                        FilledButton.tonalIcon(
                          onPressed: () => addPhoto(
                            FieldPhotoInputSource.gallery,
                          ),
                          icon: const Icon(Icons.photo_library_outlined),
                          label: const Text('Alege foto'),
                        ),
                        FilledButton.tonalIcon(
                          onPressed: addDocument,
                          icon: const Icon(Icons.upload_file_outlined),
                          label: const Text('Incarca document'),
                        ),
                      ],
                    ),
                    const SizedBox(height: 12),
                    if (documents.isEmpty)
                      const Padding(
                        padding: EdgeInsets.symmetric(vertical: 12),
                        child: Text(
                          'Incarca formulare, PDF-uri, poze sau alte documente rapide pentru aceasta programare.',
                        ),
                      )
                    else
                      Flexible(
                        child: ListView.separated(
                          shrinkWrap: true,
                          itemCount: documents.length,
                          separatorBuilder: (_, __) => const Divider(height: 1),
                          itemBuilder: (context, index) {
                            final document = documents[index];
                            final fileName = document.fileName.trim().isEmpty
                                ? _fileNameFromPath(document.filePath)
                                : document.fileName.trim();
                            return ListTile(
                              contentPadding: EdgeInsets.zero,
                              leading:
                                  const Icon(Icons.insert_drive_file_outlined),
                              title: Text(document.label.trim()),
                              subtitle: Text(
                                fileName,
                                maxLines: 2,
                                overflow: TextOverflow.ellipsis,
                              ),
                              trailing: Wrap(
                                spacing: 4,
                                children: [
                                  IconButton(
                                    tooltip: 'Deschide',
                                    onPressed: () async {
                                      final result =
                                          await DocumentFileService.openFile(
                                        document.filePath,
                                      );
                                      if (!context.mounted) {
                                        return;
                                      }
                                      ScaffoldMessenger.of(context)
                                          .showSnackBar(
                                        SnackBar(content: Text(result.message)),
                                      );
                                    },
                                    icon:
                                        const Icon(Icons.open_in_new_outlined),
                                  ),
                                  IconButton(
                                    tooltip: 'Distribuie',
                                    onPressed: () async {
                                      await DocumentFileService.shareFile(
                                        document.filePath,
                                      );
                                    },
                                    icon: const Icon(Icons.share_outlined),
                                  ),
                                  IconButton(
                                    tooltip: 'Redenumeste eticheta',
                                    onPressed: () => renameDocument(document),
                                    icon: const Icon(
                                        Icons.drive_file_rename_outline),
                                  ),
                                  IconButton(
                                    tooltip: 'Sterge din programare',
                                    onPressed: () => removeDocument(document),
                                    icon: const Icon(Icons.delete_outline),
                                  ),
                                ],
                              ),
                            );
                          },
                        ),
                      ),
                  ],
                ),
              ),
              actions: [
                TextButton(
                  onPressed: () => Navigator.of(dialogContext).pop(),
                  child: const Text('Inchide'),
                ),
              ],
            );
          },
        );
      },
    );
  }

  Widget _linkedDocumentsChip(Appointment item) {
    final count = item.linkedDocuments.length;
    final hasDocuments = count > 0;
    return Chip(
      avatar: Icon(
        hasDocuments ? Icons.attach_file : Icons.attach_file_outlined,
        size: 16,
        color: hasDocuments ? Colors.blue : null,
      ),
      label: Text(hasDocuments ? '$count doc.' : 'Fără doc.'),
      visualDensity: VisualDensity.compact,
    );
  }

  bool _isComplaintAppointment(Appointment item) =>
      item.complaintId.trim().isNotEmpty;

  String _complaintVisitTypeLabel(ComplaintVisitType? type) {
    return type?.label ?? '-';
  }

  String _complaintVisitOutcomeLabel(ComplaintVisitOutcome? outcome) {
    return outcome?.label ?? '-';
  }

  String _formatDate(DateTime value) {
    return '${value.day.toString().padLeft(2, '0')}.${value.month.toString().padLeft(2, '0')}.${value.year}';
  }

  String _formatDateLong(DateTime value) {
    return DateFormat('d MMMM yyyy', 'ro_RO').format(value);
  }

  String _formatTime(DateTime value) {
    return '${value.hour.toString().padLeft(2, '0')}:${value.minute.toString().padLeft(2, '0')}';
  }

  String _formatDateTime(DateTime value) {
    return '${_formatDate(value)} ${_formatTime(value)}';
  }

  DateTime _dateOnly(DateTime value) {
    return DateTime(value.year, value.month, value.day);
  }

  DateTime _startOfWeekMonday(DateTime value) {
    final day = _dateOnly(value);
    return day.subtract(Duration(days: day.weekday - DateTime.monday));
  }

  bool _isSameDate(DateTime a, DateTime b) {
    return a.year == b.year && a.month == b.month && a.day == b.day;
  }

  TimeOfDay _timeOfDayFromDateTime(DateTime value) {
    return TimeOfDay(hour: value.hour, minute: value.minute);
  }

  DateTime _withDateAndTime(DateTime date, TimeOfDay time) {
    return DateTime(
      date.year,
      date.month,
      date.day,
      time.hour,
      time.minute,
    );
  }

  String _durationLabel(Duration duration) {
    if (duration.inMinutes <= 0) {
      return '0 min';
    }
    final hours = duration.inHours;
    final minutes = duration.inMinutes.remainder(60);
    if (hours > 0 && minutes > 0) {
      return '${hours}h ${minutes.toString().padLeft(2, '0')}m';
    }
    if (hours > 0) {
      return '${hours}h';
    }
    return '${duration.inMinutes} min';
  }

  Color _statusBackgroundColor(String statusRaw) {
    switch (_normalizeStatusValue(statusRaw)) {
      case 'in_curs':
        return Colors.orange.shade100;
      case 'finalizata':
        return Colors.green.shade100;
      case 'amanata':
        return Colors.amber.shade100;
      case 'anulata':
        return Colors.red.shade100;
      case 'planificata':
      default:
        return Colors.blue.shade100;
    }
  }

  Color _statusForegroundColor(String statusRaw) {
    switch (_normalizeStatusValue(statusRaw)) {
      case 'in_curs':
        return Colors.orange.shade900;
      case 'finalizata':
        return Colors.green.shade900;
      case 'amanata':
        return Colors.amber.shade900;
      case 'anulata':
        return Colors.red.shade900;
      case 'planificata':
      default:
        return Colors.blue.shade900;
    }
  }

  // O(1) lookup — înlocuiește for-loop O(n) care cauza jank la scroll
  ClientRecord? _clientRecordById(String clientId) {
    final id = clientId.trim();
    if (id.isEmpty) return null;
    return _clientRecordByIdMap[id];
  }

  // O(1) lookup — înlocuiește for-loop O(n)
  JobRecord? _jobRecordById(String jobId) {
    final id = jobId.trim();
    if (id.isEmpty) return null;
    return _jobRecordByIdMap[id];
  }

  ClientContactPerson? _preferredClientContact(ClientRecord? client) {
    if (client == null) return null;
    if (client.contactPeople.isNotEmpty) {
      return client.contactPeople.first;
    }
    return null;
  }

  String _detailContactPerson(Appointment item) {
    if (item.contactPerson.trim().isNotEmpty) {
      return item.contactPerson.trim();
    }
    final job = _jobRecordById(item.jobId);
    if ((job?.contactPerson ?? '').trim().isNotEmpty) {
      return job!.contactPerson.trim();
    }
    final client = _clientRecordById(item.clientId);
    final contact = _preferredClientContact(client);
    if ((contact?.fullName ?? '').trim().isNotEmpty) {
      return contact!.fullName.trim();
    }
    if ((client?.contactPerson ?? '').trim().isNotEmpty) {
      return client!.contactPerson.trim();
    }
    return '-';
  }

  String _detailPhone(Appointment item) {
    if (item.contactPhone.trim().isNotEmpty) {
      return item.contactPhone.trim();
    }
    final job = _jobRecordById(item.jobId);
    if ((job?.contactPhone ?? '').trim().isNotEmpty) {
      return job!.contactPhone.trim();
    }
    final client = _clientRecordById(item.clientId);
    final contact = _preferredClientContact(client);
    if ((contact?.phone ?? '').trim().isNotEmpty) {
      return contact!.phone.trim();
    }
    if ((client?.phone ?? '').trim().isNotEmpty) {
      return client!.phone.trim();
    }
    return '';
  }

  String _detailEmail(Appointment item) {
    if (item.contactEmail.trim().isNotEmpty) {
      return item.contactEmail.trim();
    }
    final job = _jobRecordById(item.jobId);
    if ((job?.contactPersonEmail ?? '').trim().isNotEmpty) {
      return job!.contactPersonEmail.trim();
    }
    final client = _clientRecordById(item.clientId);
    final contact = _preferredClientContact(client);
    if ((contact?.email ?? '').trim().isNotEmpty) {
      return contact!.email.trim();
    }
    if ((client?.email ?? '').trim().isNotEmpty) {
      return client!.email.trim();
    }
    return '';
  }

  String _detailAddress(Appointment item) {
    if (item.location.trim().isNotEmpty) {
      return item.location.trim();
    }
    final job = _jobRecordById(item.jobId);
    if ((job?.location ?? '').trim().isNotEmpty) {
      return job!.location.trim();
    }
    final client = _clientRecordById(item.clientId);
    if ((client?.address ?? '').trim().isNotEmpty) {
      return client!.address.trim();
    }
    return '-';
  }

  String _resolvedContactPersonForSelection({
    required String selectedClientId,
    required String selectedJobId,
    String preferredValue = '',
  }) {
    if (preferredValue.trim().isNotEmpty) {
      return preferredValue.trim();
    }
    final job = _jobRecordById(selectedJobId);
    if ((job?.contactPerson ?? '').trim().isNotEmpty) {
      return job!.contactPerson.trim();
    }
    final client = _clientRecordById(selectedClientId);
    final contact = _preferredClientContact(client);
    if ((contact?.fullName ?? '').trim().isNotEmpty) {
      return contact!.fullName.trim();
    }
    if ((client?.contactPerson ?? '').trim().isNotEmpty) {
      return client!.contactPerson.trim();
    }
    return '';
  }

