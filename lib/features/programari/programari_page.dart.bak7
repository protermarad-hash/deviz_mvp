                          const SizedBox(height: 12),
                          Wrap(
                            spacing: 8,
                            runSpacing: 8,
                            children: [
                              Chip(
                                avatar: const Icon(Icons.timelapse, size: 16),
                                label: Text(
                                  'Durata: ${_durationLabel(selectedEnd.difference(selectedStart))}',
                                ),
