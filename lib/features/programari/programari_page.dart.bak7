                              const SizedBox(width: 12),
                              Expanded(
                                child: OutlinedButton.icon(
                                  onPressed: () => pickEndTime(setDialogState),
                                  icon: const Icon(Icons.timer_outlined),
                                  label: Text(
                                    'Ora final: ${_formatTime(selectedEnd)}',
