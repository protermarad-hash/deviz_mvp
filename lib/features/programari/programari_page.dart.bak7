  String _phoneUriValue(String phone) {
    return phone.replaceAll(RegExp(r'[^0-9+]'), '');
  }

  String _fileNameFromPath(String path) {
    final normalized = path.replaceAll('\\', '/');
    final segments = normalized.split('/');
    return segments.isEmpty ? path : segments.last;
  }

  String _quickDocumentActionLabel(_AppointmentQuickDocumentAction action) {
    switch (action) {
      case _AppointmentQuickDocumentAction.linkedDocuments:
        return 'Documente incarcate';
      case _AppointmentQuickDocumentAction.fieldPhotos:
        return 'Poze teren';
      case _AppointmentQuickDocumentAction.repairReport:
        return 'PV reparatie';
      case _AppointmentQuickDocumentAction.warrantyIntervention:
        return 'PV / PIF garantie';
      case _AppointmentQuickDocumentAction.jobSiteDocuments:
        return 'Genereaza PV / PIF';
      case _AppointmentQuickDocumentAction.warrantyCertificate:
        return 'Certificat garantie';
    }
  }

  IconData _quickDocumentActionIcon(_AppointmentQuickDocumentAction action) {
    switch (action) {
      case _AppointmentQuickDocumentAction.linkedDocuments:
        return Icons.attach_file_outlined;
      case _AppointmentQuickDocumentAction.fieldPhotos:
        return Icons.photo_camera_outlined;
      case _AppointmentQuickDocumentAction.repairReport:
        return Icons.description_outlined;
      case _AppointmentQuickDocumentAction.warrantyIntervention:
        return Icons.assignment_turned_in_outlined;
      case _AppointmentQuickDocumentAction.jobSiteDocuments:
        return Icons.fact_check_outlined;
      case _AppointmentQuickDocumentAction.warrantyCertificate:
        return Icons.verified_user_outlined;
    }
  }

  List<_AppointmentQuickDocumentAction> _quickDocumentActions(
    Appointment item,
  ) {
    final actions = <_AppointmentQuickDocumentAction>[
      _AppointmentQuickDocumentAction.linkedDocuments,
      _AppointmentQuickDocumentAction.fieldPhotos,
    ];
    if (item.complaintId.trim().isNotEmpty) {
      actions.add(_AppointmentQuickDocumentAction.repairReport);
      actions.add(_AppointmentQuickDocumentAction.warrantyIntervention);
    }
    // Always show PV/PIF documents option (for job-linked AND standalone appointments)
    actions.add(_AppointmentQuickDocumentAction.jobSiteDocuments);
    if (item.jobId.trim().isNotEmpty || item.complaintId.trim().isNotEmpty) {
      actions.add(_AppointmentQuickDocumentAction.warrantyCertificate);
    }
    return actions;
  }

  Widget _buildQuickDocumentMenu(
    Appointment item, {
    bool compact = false,
  }) {
    final actions = _quickDocumentActions(item);
    if (actions.isEmpty) {
      return const SizedBox.shrink();
    }
    return PopupMenuButton<_AppointmentQuickDocumentAction>(
      tooltip: 'PV / PIF / documente rapide',
      onSelected: (value) => _openQuickDocumentAction(item, value),
      itemBuilder: (_) => actions
          .map(
            (action) => PopupMenuItem<_AppointmentQuickDocumentAction>(
              value: action,
              child: Row(
                children: [
                  Icon(_quickDocumentActionIcon(action), size: 18),
                  const SizedBox(width: 8),
                  Expanded(child: Text(_quickDocumentActionLabel(action))),
                ],
              ),
            ),
          )
          .toList(growable: false),
      child: compact
          ? Container(
              padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 6),
              decoration: BoxDecoration(
                borderRadius: BorderRadius.circular(999),
                border: Border.all(
                  color: Theme.of(context).colorScheme.outlineVariant,
                ),
              ),
              child: Icon(
                Icons.description_outlined,
                size: 18,
                color: Theme.of(context).colorScheme.primary,
              ),
            )
          : Chip(
              avatar: const Icon(Icons.description_outlined, size: 16),
              label: const Text('PV / PIF'),
              visualDensity: VisualDensity.compact,
            ),
    );
  }

  Future<void> _launchExternalUri(
    BuildContext context,
    Uri uri, {
    required String failureLabel,
  }) async {
    try {
      final launched = await launchUrl(
        uri,
        mode: LaunchMode.externalApplication,
      );
      if (launched || !context.mounted) {
        return;
      }
    } catch (_) {
      if (!context.mounted) {
        return;
      }
    }
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text('Nu am putut deschide $failureLabel.')),
    );
  }

  int _statusCount(String status) {
    final normalized = _normalizeStatusValue(status);
    return _filteredItems
        .where((item) => _normalizeStatusValue(item.status) == normalized)
        .length;
  }

  String _clientName(String clientId) {
    if (clientId.trim().isEmpty) return '-';
    // O(1) lookup din Map pre-construit în _loadSecondaryDataAsync()
    return _clientNameById[clientId] ?? clientId;
  }

  String _resolvedClientName(String clientId, String fallbackName) {
    final lookupName = _clientName(clientId);
    if (lookupName != '-' &&
        lookupName.trim().isNotEmpty &&
        lookupName != clientId) {
      return lookupName;
    }
    final trimmedFallback = fallbackName.trim();
    if (trimmedFallback.isNotEmpty) {
      return trimmedFallback;
    }
    if (lookupName.trim().isNotEmpty && lookupName != '-') {
      return lookupName;
    }
    return '-';
  }

  /// Returns the first 30-min-aligned free time slot for the given teams
  /// starting from [fromTime], searching up to 14 days ahead.
  /// Returns null if no teams are given or no conflict exists at [fromTime].
  DateTime? _findFirstFreeSlotForTeams({
    required List<String> teamIds,
    required DateTime fromTime,
    required Duration duration,
    String? excludeId,
  }) {
    if (teamIds.isEmpty) return null;
    var candidate = fromTime;
    final maxSearch = fromTime.add(const Duration(days: 14));
    while (candidate.isBefore(maxSearch)) {
      final candidateEnd = candidate.add(duration);
      final hasConflict = _items.any((a) {
        if (a.id == (excludeId ?? '')) return false;
        if (_normalizeStatusValue(a.status) == 'anulata') return false;
        final aTeams = _appointmentTeamIds(a).toSet();
        if (!teamIds.any(aTeams.contains)) return false;
        final aStart = a.effectiveStartDateTime;
        final aEnd = a.effectiveEndDateTime;
        return aEnd.isAfter(candidate) && aStart.isBefore(candidateEnd);
      });
      if (!hasConflict) return candidate;
      candidate = candidate.add(const Duration(minutes: 30));
    }
    return null;
  }

