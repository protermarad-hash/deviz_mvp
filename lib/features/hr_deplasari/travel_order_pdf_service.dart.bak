import 'dart:convert';
import 'dart:typed_data';

import '../../core/pdf_export_settings.dart';
import '../../core/pdf_save_service.dart';
import '../../core/repositories/app_data_repository.dart';
import 'package:pdf/pdf.dart';
import 'package:pdf/widgets.dart' as pw;

import '../../core/lookup_models.dart';
import 'trip_models.dart';

class TravelOrderPdfService {
  const TravelOrderPdfService._();

  static Future<String> export({
    required AppDataRepository repository,
    required TravelOrder order,
    Trip? trip,
    required String companyName,
    required String companyAddress,
    required String companyPhone,
    required String companyEmail,
    String companyCui = '',
    String companyTradeRegister = '',
    String companyBank = '',
    String companyIban = '',
    String companyContactName = '',
    String companyLogoBase64 = '',
    EmployeeLookup? employee,
    LookupItem? team,
    LookupItem? vehicle,
    String assigneeName = '',
    String vehicleName = '',
    String clientName = '',
    String sourceLabel = '',
    String outputDirectory = '',
  }) async {
    final doc = pw.Document();
    final logo = _tryDecodeBase64(companyLogoBase64);
    final companyLocation = companyAddress.trim().isNotEmpty
        ? companyAddress.trim()
        : companyName.trim();
    final periodText =
        '${_dateTime(order.periodStart)} - ${_dateTime(order.periodEnd)}';
    final originLocation =
        _resolvedValue(order.originLocation, fallback: companyLocation);
    final destinationLocation = _resolvedValue(order.destinationLocation);
    final teamName = team?.name ?? '';
    final targetText = employee != null
        ? '${employee.name}${employee.role.isEmpty ? '' : ' (${employee.role})'}'
        : (teamName.trim().isNotEmpty
            ? 'Echipa: $teamName'
            : assigneeName.trim());
    final vehicleResolved = vehicle?.name ?? '';
    final vehicleText =
        vehicleResolved.trim().isNotEmpty ? vehicleResolved : vehicleName;

    doc.addPage(
      pw.MultiPage(
        pageFormat: PdfPageFormat.a4,
        margin: const pw.EdgeInsets.all(16),
        build: (context) {
          return [
            pw.Row(
              crossAxisAlignment: pw.CrossAxisAlignment.start,
              children: [
                if (logo != null)
                  pw.Container(
                    width: 60,
                    height: 42,
                    margin: const pw.EdgeInsets.only(right: 10),
                    child: pw.Image(logo, fit: pw.BoxFit.contain),
                  ),
                pw.Expanded(
                  child: pw.Column(
                    crossAxisAlignment: pw.CrossAxisAlignment.start,
                    children: [
                      if (companyName.trim().isNotEmpty)
                        pw.Text(
                          companyName,
                          style: pw.TextStyle(
                            fontSize: 12,
                            fontWeight: pw.FontWeight.bold,
                          ),
                        ),
                      pw.SizedBox(height: 1),
                      if (companyAddress.trim().isNotEmpty)
                        pw.Text('Adresa: $companyAddress',
                            style: const pw.TextStyle(fontSize: 7.5)),
                      if (companyPhone.trim().isNotEmpty)
                        pw.Text('Tel: $companyPhone',
                            style: const pw.TextStyle(fontSize: 7.5)),
                      if (companyEmail.trim().isNotEmpty)
                        pw.Text('Email: $companyEmail',
                            style: const pw.TextStyle(fontSize: 7.5)),
                      if (companyCui.trim().isNotEmpty)
                        pw.Text('CUI: $companyCui',
                            style: const pw.TextStyle(fontSize: 7.5)),
                    ],
                  ),
                ),
                pw.SizedBox(width: 10),
                pw.Container(
                  padding:
                      const pw.EdgeInsets.symmetric(horizontal: 8, vertical: 6),
                  decoration: pw.BoxDecoration(
                    color: PdfColors.grey100,
                    border: pw.Border.all(color: PdfColors.grey500),
                    borderRadius: pw.BorderRadius.circular(4),
                  ),
                  child: pw.Column(
                    crossAxisAlignment: pw.CrossAxisAlignment.start,
                    children: [
                      pw.Text(
                        'ORDIN DEPLASARE',
                        style: pw.TextStyle(
                          fontWeight: pw.FontWeight.bold,
                          fontSize: 10,
                        ),
                      ),
                      pw.SizedBox(height: 2),
                      pw.Text('Nr: ${order.orderNumber}',
                          style: const pw.TextStyle(fontSize: 8)),
                      pw.Text('Data: ${_date(order.issueDate)}',
                          style: const pw.TextStyle(fontSize: 8)),
                    ],
                  ),
                ),
              ],
            ),
            pw.SizedBox(height: 8),
            _compactSection('Deplasare', [
              _compactRow('Persoana', targetText),
              if (clientName.trim().isNotEmpty)
                _compactRow('Client', clientName),
              _compactRow('Traseu', '$originLocation → $destinationLocation'),
              _compactRow('Perioada', periodText),
              _compactRow('Durata',
                  '${order.resolvedPerDiemDays} zile | ${order.resolvedLodgingNights} nopti'),
              _compactRow('Scop', order.purpose.isEmpty ? '-' : order.purpose),
            ]),
            pw.SizedBox(height: 6),
            pw.Row(
              children: [
                pw.Expanded(
                  child: _compactSection('Transport', [
                    _compactRow('Tip', order.transportType),
                    _compactRow('Auto', vehicleText),
                    _compactRow(
                        'Km est.', order.estimatedKm.toStringAsFixed(1)),
                  ]),
                ),
                pw.SizedBox(width: 6),
                pw.Expanded(
                  child: _compactSection('Costuri (lei)', [
                    _compactRow(
                        'Diurna/zi', order.perDiemPerDay.toStringAsFixed(2)),
                    _compactRow('Total diurna',
                        order.totalPerDiemCost.toStringAsFixed(2)),
                    _compactRow(
                        'Cazare', order.totalLodgingCost.toStringAsFixed(2)),
                    _compactRow(
                        'Avans', order.advanceAmount.toStringAsFixed(2)),
                    _compactRow(
                        'TOTAL', order.totalEstimatedCost.toStringAsFixed(2),
                        bold: true),
                  ]),
                ),
              ],
            ),
            if (order.hasDetailedLodgings && order.lodgings.isNotEmpty) ...[
              pw.SizedBox(height: 6),
              _compactSection(
                'Cazari',
                order.lodgings
                    .take(3)
                    .map((item) => _compactRow(
                          item.location.isEmpty
                              ? 'Cazare'
                              : item.location.substring(
                                  0, (item.location.length / 2).ceil()),
                          '${item.nights} nopti: ${item.resolvedTotalCost.toStringAsFixed(2)} lei',
                        ))
                    .toList(),
              ),
            ],
            if (trip != null && trip.notes.trim().isNotEmpty) ...[
              pw.SizedBox(height: 4),
              _compactSection('Note', [
                pw.Text(
                  trip.notes.length > 150
                      ? '${trip.notes.substring(0, 150)}...'
                      : trip.notes,
                  style: const pw.TextStyle(fontSize: 7.5),
                ),
              ]),
            ],
            pw.SizedBox(height: 8),
            _compactSection('Aprobari', [
              _compactRow('Emis de', order.resolvedIssuedBy),
              _compactRow('Aprobat de', order.resolvedApprovedBy),
              _compactRow('Status', order.status.label),
            ]),
            pw.SizedBox(height: 10),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Expanded(
                  child: pw.Column(
                    children: [
                      pw.Container(height: 0.5, color: PdfColors.black),
                      pw.SizedBox(height: 2),
                      pw.Text('Angajat',
                          style: const pw.TextStyle(fontSize: 7)),
                    ],
                  ),
                ),
                pw.SizedBox(width: 20),
                pw.Expanded(
                  child: pw.Column(
                    children: [
                      pw.Container(height: 0.5, color: PdfColors.black),
                      pw.SizedBox(height: 2),
                      pw.Text('Emitent',
                          style: const pw.TextStyle(fontSize: 7)),
                    ],
                  ),
                ),
                pw.SizedBox(width: 20),
                pw.Expanded(
                  child: pw.Column(
                    children: [
                      pw.Container(height: 0.5, color: PdfColors.black),
                      pw.SizedBox(height: 2),
                      pw.Text('Aprobator',
                          style: const pw.TextStyle(fontSize: 7)),
                    ],
                  ),
                ),
              ],
            ),
          ];
        },
      ),
    );

    final bytes = await doc.save();
    final safeNumber =
        order.orderNumber.replaceAll(RegExp(r'[^A-Za-z0-9_\-]'), '_');
    return PdfSaveService.savePdf(
      repository: repository,
      bytes: bytes,
      fileName: 'ordin_deplasare_$safeNumber.pdf',
      category: PdfDocumentCategory.travelOrders,
      outputDirectory: outputDirectory,
    );
  }

  static String _date(DateTime value) {
    return '${value.day.toString().padLeft(2, '0')}.${value.month.toString().padLeft(2, '0')}.${value.year}';
  }

  static String _dateTime(DateTime value) {
    final date = _date(value);
    final time =
        '${value.hour.toString().padLeft(2, '0')}:${value.minute.toString().padLeft(2, '0')}';
    return '$date $time';
  }

  static String _resolvedValue(String value, {String fallback = '-'}) {
    final trimmed = value.trim();
    if (trimmed.isNotEmpty) {
      return trimmed;
    }
    final fallbackTrimmed = fallback.trim();
    return fallbackTrimmed.isEmpty ? '-' : fallbackTrimmed;
  }

  static pw.MemoryImage? _tryDecodeBase64(String value) {
    if (value.trim().isEmpty) {
      return null;
    }
    try {
      final bytes = UriData.parse(value).contentAsBytes();
      return pw.MemoryImage(bytes);
    } catch (_) {
      try {
        final bytes = Uint8List.fromList(const Base64Decoder().convert(value));
        return pw.MemoryImage(bytes);
      } catch (_) {
        return null;
      }
    }
  }

  static pw.Widget _compactSection(String title, List<pw.Widget> rows) {
    return pw.Container(
      padding: const pw.EdgeInsets.all(6),
      decoration: pw.BoxDecoration(
        border: pw.Border.all(color: PdfColors.grey400, width: 0.5),
        borderRadius: pw.BorderRadius.circular(3),
      ),
      child: pw.Column(
        crossAxisAlignment: pw.CrossAxisAlignment.start,
        children: [
          pw.Text(
            title,
            style: pw.TextStyle(
              fontWeight: pw.FontWeight.bold,
              fontSize: 9,
            ),
          ),
          pw.SizedBox(height: 3),
          ...rows,
        ],
      ),
    );
  }

  static pw.Widget _compactRow(String label, String value,
      {bool bold = false}) {
    return pw.Padding(
      padding: const pw.EdgeInsets.only(bottom: 2),
      child: pw.Row(
        crossAxisAlignment: pw.CrossAxisAlignment.start,
        children: [
          pw.SizedBox(
            width: 80,
            child: pw.Text(
              label,
              style: pw.TextStyle(
                fontWeight: bold ? pw.FontWeight.bold : pw.FontWeight.normal,
                fontSize: 7.5,
              ),
            ),
          ),
          pw.Expanded(
            child: pw.Text(
              value.trim(),
              style: pw.TextStyle(
                fontWeight: bold ? pw.FontWeight.bold : pw.FontWeight.normal,
                fontSize: 7.5,
              ),
            ),
          ),
        ],
      ),
    );
  }
}
