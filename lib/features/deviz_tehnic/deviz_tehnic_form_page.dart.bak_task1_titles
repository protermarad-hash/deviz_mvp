  /// Preia stocul SmartBill din cache (auto la deschidere).
  Future<void> _loadSmartBillStock() async {
    try {
      final profile = await widget.appRepository.loadCompanyProfile();
      final settings = profile.smartBillSettings;
      if (!settings.isConsumptionConfigured) return;
      final stock = await _stockCacheService.syncIfStale(settings);
      if (!mounted) return;
      setState(() => _smartbillStock = stock);
    } catch (_) {
      // Silențios — stocul rămâne gol dacă SmartBill nu e disponibil
    }
  }

  Future<void> _loadMaterialCatalog() async {
    try {
      final results = await Future.wait([
        _materialsService.listMaterials(),
        _templateRepo.listLocal(),
      ]);
      final materials = results[0] as List<MasterMaterial>;
      final templates = results[1] as List<DevizArticolTemplate>;
      if (!mounted) return;
      setState(() {
        _materialCatalog = materials;
        _templateCatalog = templates;
        _sugestii = _buildSugestii(materials, templates);
      });
    } catch (_) {}
  }

  static List<_Sugestie> _buildSugestii(
    List<MasterMaterial> materials,
    List<DevizArticolTemplate> templates,
  ) {
    final result = <_Sugestie>[];
    // Template-urile primele (au toate 4 prețuri)
    for (final t in templates) {
      result.add(_Sugestie.fromTemplate(t));
    }
    // Materialele care nu sunt deja ca template
    final templateNames =
        templates.map((t) => t.denumire.trim().toLowerCase()).toSet();
    for (final m in materials) {
      if (!templateNames.contains(m.name.trim().toLowerCase())) {
        result.add(_Sugestie.fromMaterial(m));
      }
    }
    return result;
  }

  Future<void> _actualizatePretiriDinCatalog() async {
    if (_materialCatalog.isEmpty) return;
    var updated = 0;
    for (final a in _articole) {
      final denumire = a.denumireCtrl.text.trim().toLowerCase();
      if (denumire.isEmpty) continue;
      // Caută mai întâi în template-uri (au și Man/Utilaj/Transport)
      final tpl = _templateCatalog
          .where((t) => t.denumire.trim().toLowerCase() == denumire)
          .firstOrNull;
      if (tpl != null) {
        final oldMat = a.mat;
        final oldMan = a.man;
        if (tpl.pretUnitarMat > 0) a.matCtrl.text = _fmtV(tpl.pretUnitarMat);
        if (tpl.pretUnitarMan > 0) a.manCtrl.text = _fmtV(tpl.pretUnitarMan);
        if (tpl.pretUnitarUtilaj > 0) a.utilajCtrl.text = _fmtV(tpl.pretUnitarUtilaj);
        if (tpl.pretUnitarTransport > 0) a.transportCtrl.text = _fmtV(tpl.pretUnitarTransport);
        if (a.mat != oldMat || a.man != oldMan) updated++;
        continue;
      }
      // Fallback: caută în materiale (doar pretMat)
      final mat = _materialCatalog
          .where((m) => m.name.trim().toLowerCase() == denumire)
          .firstOrNull;
      if (mat != null && mat.price > 0 && mat.price != a.mat) {
        a.matCtrl.text = _fmtV(mat.price);
        updated++;
      }
    }
    setState(() {});
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(updated > 0
          ? 'Au fost actualizate $updated articole din catalog.'
          : 'Toate prețurile sunt deja la zi.'),
    ));
  }


  static String _fmtPct(double v) =>
      v == v.truncateToDouble() ? v.toInt().toString() : v.toStringAsFixed(2);

  Future<void> _loadCompanyDefaults() async {
    try {
      final profile = await widget.appRepository.loadCompanyProfile();
      if (!mounted) return;
      setState(() {
        _tvaCtrl.text = _fmtPct(profile.defaultVatPercent);
        _profitCtrl.text = _fmtPct(profile.defaultProfitPercent);
        if (profile.defaultOverheadPercent > 0) {
          _regieCtrl.text = _fmtPct(profile.defaultOverheadPercent);
        }
        // Înlocuiește email-ul cu numele real din profilul firmei (persoana de contact)
        final current = _intocmitDeCtrl.text.trim();
        if (current.contains('@') && profile.contactName.trim().isNotEmpty) {
          _intocmitDeCtrl.text = profile.contactName.trim();
        } else if (current.isEmpty && profile.contactName.trim().isNotEmpty) {
          _intocmitDeCtrl.text = profile.contactName.trim();
        }
      });
    } catch (_) {
      // Fallback la valorile hardcodate din controllers
    }
  }

  /// La document NOU: citește tipul implicit (cross-device), setează `_tipDocument`,
  /// apoi generează numărul corespunzător seriei.
  Future<void> _loadDefaultTipThenNumber() async {
    try {
      final defaultTip = await widget.repository.loadDefaultTipDocument();
      if (!mounted) return;
      setState(() => _tipDocument = defaultTip);
      await _loadNextNumber(defaultTip);
    } catch (_) {
      await _loadNextNumber();
    }
  }

  Future<void> _loadNextNumber([DevizTehnicTipDocument? tip]) async {
    try {
      final n = await widget.repository.nextNumber(tip ?? _tipDocument);
      if (mounted) setState(() => _numarCtrl.text = n);
    } catch (_) {}
  }

  @override
  void dispose() {
    _numarCtrl.dispose();
    _titluCtrl.dispose();
    _obiectivCtrl.dispose();
    _intocmitDeCtrl.dispose();
    _noteCtrl.dispose();
    _regieCtrl.dispose();
    _profitCtrl.dispose();
    _tvaCtrl.dispose();
    _zileCtrl.dispose();
    for (final a in _articole) {
      a.dispose();
    }
    super.dispose();
  }

  double get _regie => double.tryParse(_regieCtrl.text) ?? 9;
  double get _profit => double.tryParse(_profitCtrl.text) ?? 10;
  double get _tva => double.tryParse(_tvaCtrl.text) ?? 21;

  List<DevizTehnicArticol> get _buildArticole =>
      _articole.map((a) => a.toModel()).toList();

  double get _totalMat =>
      _buildArticole.fold(0, (s, a) => s + a.valoareMat);
  double get _totalMan =>
      _buildArticole.fold(0, (s, a) => s + a.valoareMan);
  double get _totalUtilaj =>
      _buildArticole.fold(0, (s, a) => s + a.valoareUtilaj);
  double get _totalTransport =>
      _buildArticole.fold(0, (s, a) => s + a.valoareTransport);
  double get _totalDirect =>
      _totalMat + _totalMan + _totalUtilaj + _totalTransport;
  double get _regieVal => _totalDirect * _regie / 100;
  double get _profitVal => (_totalDirect + _regieVal) * _profit / 100;
  double get _totalFaraTva => _totalDirect + _regieVal + _profitVal;
  double get _tvaVal => _totalFaraTva * _tva / 100;
  double get _totalCuTva => _totalFaraTva + _tvaVal;

