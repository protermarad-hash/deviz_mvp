  @override
  void initState() {
    super.initState();
    final ex = widget.existing;
    if (ex != null) {
      _numarCtrl.text = ex.numar;
      _titluCtrl.text = ex.titlu;
      _obiectivCtrl.text = ex.obiectiv;
      _intocmitDeCtrl.text = ex.intocmitDe;
      _noteCtrl.text = ex.note;
      _regieCtrl.text = _fmtPct(ex.regiePercent);
      _profitCtrl.text = _fmtPct(ex.profitPercent);
      _tvaCtrl.text = _fmtPct(ex.tvaPercent);
      _zileCtrl.text = ex.zileValabilitate.toString();
      _selectedClientId = ex.clientId.isEmpty ? null : ex.clientId;
      _selectedClientName = ex.clientName;
      _dataEmiterii = ex.dataEmiterii;
      _articole = ex.articole.map(_ArticolState.fromModel).toList();
      // Câmpuri noi
      _tipDocument = ex.tipDocument;
      _status = ex.status;
      _priceDisplay = ex.priceDisplay;
      _registryEntryId = ex.registryEntryId;
      _registryNumber = ex.registryNumber;
      _registeredAt = ex.registeredAt;
    } else {
      _intocmitDeCtrl.text = widget.currentUserName;
      _articole = [_ArticolState()];
      _loadDefaultTipThenNumber();
      _loadCompanyDefaults();
    }
    _loadMaterialCatalog();
    _loadSmartBillStock();
