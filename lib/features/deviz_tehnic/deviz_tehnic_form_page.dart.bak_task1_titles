  /// Trimite pe email: generează PDF (dacă e nevoie) și deschide dialogul de email.
  Future<void> _sendEmail() async {
    String pdfPath = '';
    try {
      final record = _buildRecord();
      pdfPath = await DevizTehnicPdfService.export(
        repository: widget.appRepository,
        deviz: record,
      );
    } catch (_) {
      // PDF opțional — dialogul funcționează și fără
    }

    if (!mounted) return;
    CompanyProfile company;
    try {
      company = await widget.appRepository.loadCompanyProfile();
    } catch (_) {
      company = const CompanyProfile();
    }
    if (!mounted) return;

    final record = _buildRecord();
    // Preia emailul clientului selectat (dacă există)
    String clientEmail = '';
    if (_selectedClientId != null) {
      final client = widget.clients
          .where((c) => c.id == _selectedClientId)
          .firstOrNull;
      clientEmail = client?.email ?? '';
    }

    await showDialog<bool>(
      context: context,
      builder: (_) => DevizTehnicEmailDialog(
        deviz: record,
        company: company,
        currentUserName: widget.currentUserName,
        recipientEmail: clientEmail,
