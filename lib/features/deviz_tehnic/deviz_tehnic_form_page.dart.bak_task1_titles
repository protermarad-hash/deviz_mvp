  /// Înregistrează documentul în Registratură.
  Future<void> _registerInRegistry() async {
    // Salvează mai întâi dacă e document nou
    if (widget.existing == null) {
      if (!_formKey.currentState!.validate()) return;
    }

    final record = _buildRecord();
    if (record.numar.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text(
              'Completează numărul documentului înainte de înregistrare.'),
        ),
      );
      return;
    }

    // Verifică dacă e deja înregistrat
    if (_registryEntryId.isNotEmpty) {
      final ok = await showDialog<bool>(
        context: context,
        builder: (ctx) => AlertDialog(
          title: const Text('Deja înregistrat'),
          content: Text(
              'Documentul este deja înregistrat în Registratură cu nr. $_registryNumber.\nDorești să înregistrezi din nou?'),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(ctx, false),
              child: const Text('Nu'),
            ),
            FilledButton(
              onPressed: () => Navigator.pop(ctx, true),
              child: const Text('Da, înregistrează din nou'),
            ),
          ],
        ),
      );
      if (ok != true || !mounted) return;
    }

    setState(() => _saving = true);
    try {
      final svc = RegistryService(widget.appRepository);
      final entry = await svc.registerEstimate(
        estimateId: widget.existing?.id ?? '',
        documentNumber: record.numar,
        title:
            record.titlu.isNotEmpty ? record.titlu : record.tipDocument.label,
        clientId: record.clientId,
        recipientName: record.clientName,
        documentDate: record.dataEmiterii,
      );

      // Actualizează câmpurile de registratură în starea locală
      setState(() {
        _registryEntryId = entry.id;
        _registryNumber = entry.registryNumber;
        _registeredAt = entry.registeredAt;
        // Auto-schimbă statusul la "trimis" dacă era draft
        if (_status == DevizTehnicStatus.draft) {
          _status = DevizTehnicStatus.trimis;
        }
        _saving = false;
      });

      // Salvează automat record-ul cu noile câmpuri
      if (widget.existing != null) {
        final updatedRecord = _buildRecord();
        await widget.repository.save(updatedRecord);
      }

      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(
              'Înregistrat în Registratură cu nr. ${entry.registryNumber}'),
          backgroundColor: Colors.green,
        ),
      );
    } catch (e) {
      if (!mounted) return;
      setState(() => _saving = false);
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Eroare la înregistrare: $e')),
      );
    }
  }

  /// Emite bon de consum în SmartBill cu materialele din deviz.
  Future<void> _emiteBonConsum() async {
    // Construiește lista materialelor (articole cu mat > 0 sau toate)
    final materiale = <BonConsumArticol>[];
    for (final a in _articole) {
      final denumire = a.denumireCtrl.text.trim();
      if (denumire.isEmpty) continue;
      final cant = a.cant;
      if (cant <= 0) continue;
      materiale.add(BonConsumArticol(
        denumire: denumire,
        cantitate: cant,
        um: a.umCtrl.text.trim().isEmpty ? 'buc' : a.umCtrl.text.trim(),
        pretUnitar: a.mat,
      ));
    }

    if (materiale.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('Nu există articole cu cantitate în deviz.'),
        ),
      );
      return;
    }

    // Preia setările SmartBill
    CompanyProfile profile;
    try {
      profile = await widget.appRepository.loadCompanyProfile();
    } catch (_) {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('Nu s-a putut accesa profilul firmei.'),
        ),
      );
      return;
    }

    final settings = profile.smartBillSettings;
    if (!settings.isConfigured) {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text(
              'SmartBill nu este configurat. Mergi la Setări → SmartBill.'),
        ),
      );
      return;
    }

    if (!mounted) return;
    final record = _buildRecord();
    final titlu = record.numar.isNotEmpty
        ? '${record.tipDocument.label} ${record.numar}'
        : record.titlu.isNotEmpty
            ? record.titlu
            : record.tipDocument.label;

    final response = await showDialog<SmartBillConsumptionNoteResponse>(
      context: context,
      builder: (_) => SmartBillBonConsumDialog(
        settings: settings,
        articole: materiale,
        documentTitle: titlu,
        stockMap: _smartbillStock,
      ),
    );

    if (response != null && mounted) {
      final label = response.documentLabel.isNotEmpty
          ? response.documentLabel
          : 'emis cu succes';
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Bon de consum $label emis în SmartBill.'),
          backgroundColor: Colors.green.shade700,
          duration: const Duration(seconds: 5),
        ),
      );
    }
  }

  DevizTehnicRecord _buildRecord() {
    final now = DateTime.now();
    final ex = widget.existing;
    return DevizTehnicRecord(
      id: ex?.id ?? '',
      numar: _numarCtrl.text.trim(),
      titlu: _titluCtrl.text.trim(),
      obiectiv: _obiectivCtrl.text.trim(),
      clientId: _selectedClientId ?? '',
      clientName: _selectedClientName,
      dataEmiterii: _dataEmiterii,
      zileValabilitate: int.tryParse(_zileCtrl.text) ?? 30,
      articole: _buildArticole,
      regiePercent: _regie,
      profitPercent: _profit,
      tvaPercent: _tva,
      intocmitDe: _intocmitDeCtrl.text.trim(),
      note: _noteCtrl.text.trim(),
      createdAt: ex?.createdAt ?? now,
      updatedAt: now,
      createdByUserId: widget.currentUserId,
      // Câmpuri noi
      tipDocument: _tipDocument,
      status: _status,
      priceDisplay: _priceDisplay,
      registryEntryId: _registryEntryId,
      registryNumber: _registryNumber,
      registeredAt: _registeredAt,
    );
  }

  Future<void> _save() async {
    if (!_formKey.currentState!.validate()) return;
    if (_articole.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Adaugă cel puțin un articol.')),
      );
      return;
    }
    setState(() => _saving = true);
    try {
      final record = _buildRecord();
      // Salvează materialele și template-urile de norme (fără duplicare)
      for (final a in _articole) {
        final denumire = a.denumireCtrl.text.trim();
        final um = a.umCtrl.text.trim().isEmpty ? 'buc' : a.umCtrl.text.trim();
        if (denumire.isEmpty) continue;
        // Salvează în nomenclator materiale dacă are pretMat
        if (a.mat > 0) {
          await _materialsService.upsertFromOfferMaterial(
            name: denumire,
            unit: um,
            price: a.mat,
          );
        }
        // Salvează în baza de norme dacă are cel puțin Man/Utilaj/Transport
        if (a.man > 0 || a.utilaj > 0 || a.transport > 0) {
          final existing = _templateRepo.findByName(denumire, _templateCatalog);
          final now = DateTime.now();
          final tpl = DevizArticolTemplate(
            id: existing?.id ?? 'tpl-${now.microsecondsSinceEpoch}',
            denumire: denumire,
            um: um,
            pretUnitarMat: a.mat > 0 ? a.mat : (existing?.pretUnitarMat ?? 0),
            pretUnitarMan: a.man > 0 ? a.man : (existing?.pretUnitarMan ?? 0),
            pretUnitarUtilaj: a.utilaj > 0 ? a.utilaj : (existing?.pretUnitarUtilaj ?? 0),
            pretUnitarTransport: a.transport > 0 ? a.transport : (existing?.pretUnitarTransport ?? 0),
            lastUpdated: now,
            folositDeCateOri: (existing?.folositDeCateOri ?? 0) + 1,
          );
          await _templateRepo.upsertLocal(tpl);
          try {
            await _templateRepo.upsertToFirebase(tpl);
          } catch (_) {}
        }
      }
      final saved = await widget.repository.save(record);
      if (!mounted) return;
      Navigator.of(context).pop(saved);
    } catch (e) {
      if (!mounted) return;
      setState(() => _saving = false);
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Eroare la salvare: $e')),
      );
    }
  }

  void _addArticol() {
    setState(() => _articole.add(_ArticolState()));
  }

  void _removeArticol(int index) {
    setState(() {
      _articole[index].dispose();
      _articole.removeAt(index);
    });
  }

  void _moveArticol(int from, int to) {
    if (to < 0 || to >= _articole.length) return;
    setState(() {
      final item = _articole.removeAt(from);
      _articole.insert(to, item);
    });
  }

