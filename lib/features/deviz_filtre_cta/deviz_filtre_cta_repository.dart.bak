import 'dart:convert';

import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:flutter/foundation.dart';
import 'package:shared_preferences/shared_preferences.dart';

import '../../core/cloud/firebase_bootstrap.dart';
import '../../core/cloud/firebase_collections.dart';
import '../../core/cloud/offline_sync_runtime.dart';
import 'deviz_filtre_cta_models.dart';

/// Repository pentru devize filtre CTA — Firebase + cache local + offline queue.
/// Pattern obligatoriu (CLAUDE.md):
///   1. Scriere locală (funcționează offline)
///   2. Queue OBLIGATORIU (sincronizare automată la revenire internet)
///   3. Firebase direct (best-effort)
class DevizFiltreCtaRepository {
  static const _prefKey = 'devize_filtre_cta_cache';

  CollectionReference<Map<String, dynamic>> get _col =>
      FirebaseFirestore.instance
          .collection(FirebaseCollections.devizeFiltreCta);

  bool get _isCloudAvailable => FirebaseBootstrap.isInitialized;

  // ── Cache local ──────────────────────────────────────────────────────────

  Future<List<DevizFiltreCta>> listLocal() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      final raw = prefs.getString(_prefKey);
      if (raw == null || raw.isEmpty) return [];
      final list = jsonDecode(raw) as List;
      return list
          .map((e) =>
              DevizFiltreCta.fromMap(Map<String, dynamic>.from(e as Map)))
          .toList();
    } catch (_) {
      return [];
    }
  }

  Future<void> _saveLocal(List<DevizFiltreCta> records) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString(
      _prefKey,
      jsonEncode(records.map((r) => r.toMap()).toList()),
    );
  }

  Future<void> _updateLocalCache(DevizFiltreCta record) async {
    final locals = await listLocal();
    final idx = locals.indexWhere((r) => r.id == record.id);
    if (idx >= 0) {
      locals[idx] = record;
    } else {
      locals.insert(0, record);
    }
    await _saveLocal(locals);
  }

  // ── List (cloud + local merge) ───────────────────────────────────────────

  Future<List<DevizFiltreCta>> list() async {
    final localItems = await listLocal();

    if (!_isCloudAvailable) return _sorted(localItems);

    debugPrint('[FiltreCTA] list(): isInit=${FirebaseBootstrap.isInitialized} '
        'isOnline=${FirebaseBootstrap.isOnline} '
        'localCache=${localItems.length} docs');

    try {
      final snap = await _col.get();
      final cloudItems = snap.docs
          .map((d) => DevizFiltreCta.fromMap({...d.data(), 'id': d.id}))
          .toList();

      debugPrint('[FiltreCTA] Firestore returned ${cloudItems.length} docs');

      final cloudIds = cloudItems.map((r) => r.id).toSet();
      final localOnly =
          localItems.where((r) => !cloudIds.contains(r.id)).toList();

      for (final r in localOnly) {
        await OfflineSyncRuntime.instance.queueFiltreCtaUpsert(r.toMap());
      }

      final merged = [...cloudItems, ...localOnly];
      await _saveLocal(merged);
      return _sorted(merged);
    } catch (e) {
      debugPrint('[FiltreCTA] Eroare Firestore list(): $e');
      return _sorted(localItems);
    }
  }

  List<DevizFiltreCta> _sorted(List<DevizFiltreCta> items) {
    final copy = [...items];
    copy.sort((a, b) => b.updatedAt.compareTo(a.updatedAt));
    return copy;
  }

  // ── Save (upsert) ────────────────────────────────────────────────────────

  Future<DevizFiltreCta> save(DevizFiltreCta record) async {
    DevizFiltreCta toSave;

    if (record.id.isEmpty || record.id.startsWith('local-')) {
      if (_isCloudAvailable) {
        try {
          final map = record.toMap()..remove('id');
          final ref = await _col.add(map);
          toSave =
              DevizFiltreCta.fromMap({...record.toMap(), 'id': ref.id});
        } catch (e) {
          debugPrint('[FiltreCTA] Eroare add Firestore: $e');
          toSave = DevizFiltreCta.fromMap({
            ...record.toMap(),
            'id': 'local-${DateTime.now().millisecondsSinceEpoch}',
          });
        }
      } else {
        toSave = DevizFiltreCta.fromMap({
          ...record.toMap(),
          'id': 'local-${DateTime.now().millisecondsSinceEpoch}',
        });
      }
    } else {
      toSave = record;
    }

    // 1. Salvare locală
    await _updateLocalCache(toSave);

    // 2. Queue OBLIGATORIU
    await OfflineSyncRuntime.instance.queueFiltreCtaUpsert(toSave.toMap());

    // 3. Firebase direct (best-effort)
    if (_isCloudAvailable && !toSave.id.startsWith('local-')) {
      try {
        final map = toSave.toMap()..remove('id');
        await _col.doc(toSave.id).set(map, SetOptions(merge: true));
      } catch (_) {}
    }

    return toSave;
  }

  // ── Delete ───────────────────────────────────────────────────────────────

  Future<void> delete(String id) async {
    // 1. Ștergere locală
    final locals = await listLocal();
    await _saveLocal(locals.where((r) => r.id != id).toList());

    // 2. Queue delete OBLIGATORIU
    await OfflineSyncRuntime.instance.queueFiltreCtaDelete(id);

    // 3. Firebase direct (best-effort)
    if (_isCloudAvailable && !id.startsWith('local-')) {
      try {
        await _col.doc(id).delete();
      } catch (_) {}
    }
  }

  // ── Numerotare automată ──────────────────────────────────────────────────

  Future<String> nextNumber() async {
    final year = DateTime.now().year;
    const prefix = 'CTA';
    final prefixYear = '$prefix-$year-';
    final prefixYearNext = '$prefix-${year + 1}-';

    try {
      final localItems = await listLocal();
      final localNums = localItems
          .where((r) => r.numar.startsWith(prefixYear))
          .map((r) {
            final parts = r.numar.split('-');
            return parts.length >= 3 ? int.tryParse(parts.last) ?? 0 : 0;
          })
          .toList();

      if (_isCloudAvailable) {
        try {
          final snap = await _col
              .where('numar', isGreaterThanOrEqualTo: prefixYear)
              .where('numar', isLessThan: prefixYearNext)
              .get();
          final cloudNums = snap.docs.map((d) {
            final n = (d.data()['numar'] ?? '').toString();
            final parts = n.split('-');
            return parts.length >= 3 ? int.tryParse(parts.last) ?? 0 : 0;
          }).toList();
          localNums.addAll(cloudNums);
        } catch (_) {}
      }

      final maxNum =
          localNums.isEmpty ? 0 : localNums.reduce((a, b) => a > b ? a : b);
      final next = (maxNum + 1).toString().padLeft(4, '0');
      return '$prefixYear$next';
    } catch (_) {
      return '${prefixYear}0001';
    }
  }
}
