  factory OfferRecord.fromMap(Map<String, dynamic> map) {
    DateTime parseDate(dynamic raw, DateTime fallback) {
      if (raw == null) return fallback;
      final parsed = DateTime.tryParse(raw.toString().trim());
      return parsed ?? fallback;
    }

    DateTime? parseOptionalDate(dynamic raw) {
      if (raw == null) return null;
      final text = raw.toString().trim();
      if (text.isEmpty) return null;
      return DateTime.tryParse(text);
    }

    double asDouble(dynamic raw, [double fallback = 0]) {
      if (raw == null) return fallback;
      if (raw is num) return raw.toDouble();
      return double.tryParse(raw.toString().replaceAll(',', '.').trim()) ??
          fallback;
    }

    String pick(List<String> keys) {
      for (final key in keys) {
        final value = (map[key] ?? '').toString().trim();
        if (value.isNotEmpty) return value;
      }
      return '';
    }

    final now = DateTime.now();
    final id = pick(const <String>['id', 'offer_id']);

    final rawLines = map['lines'];
    final lines = rawLines is List
        ? rawLines
            .whereType<Map>()
            .map((row) => OfferLineItem.fromMap(Map<String, dynamic>.from(row)))
            .toList(growable: false)
        : const <OfferLineItem>[];
    final rawClauses = map['commercial_clauses'] ?? map['commercialClauses'];
    final rawPartners = map['partners'];
    final rawPartnerWorkers = map['partner_workers'] ?? map['partnerWorkers'];
    final rawPartnerVehicles =
        map['partner_vehicles'] ?? map['partnerVehicles'];
    final rawSmartBillEstimate =
        map['smartbill_estimate'] ?? map['smartBillEstimate'];
    final rawSmartBillInvoice =
        map['smartbill_invoice'] ?? map['smartBillInvoice'];
    final commercialClauses = rawClauses is List
        ? rawClauses
            .whereType<Map>()
            .map(
              (row) =>
                  OfferCommercialClause.fromMap(Map<String, dynamic>.from(row)),
            )
            .toList(growable: false)
        : const <OfferCommercialClause>[];
    final partners = rawPartners is List
        ? rawPartners
            .whereType<Map>()
            .map((row) => OfferPartner.fromMap(Map<String, dynamic>.from(row)))
            .toList(growable: false)
        : const <OfferPartner>[];
    final partnerWorkers = rawPartnerWorkers is List
        ? rawPartnerWorkers
            .whereType<Map>()
            .map((row) =>
                OfferPartnerWorker.fromMap(Map<String, dynamic>.from(row)))
            .toList(growable: false)
        : const <OfferPartnerWorker>[];
    final partnerVehicles = rawPartnerVehicles is List
        ? rawPartnerVehicles
            .whereType<Map>()
            .map((row) =>
                OfferPartnerVehicle.fromMap(Map<String, dynamic>.from(row)))
            .toList(growable: false)
        : const <OfferPartnerVehicle>[];
    final smartBillEstimate = rawSmartBillEstimate is Map<String, dynamic>
        ? OfferSmartBillDocumentState.fromMap(
            rawSmartBillEstimate,
            fallbackDocumentType: OfferSmartBillDocumentType.estimate,
          )
        : rawSmartBillEstimate is Map
            ? OfferSmartBillDocumentState.fromMap(
                Map<String, dynamic>.from(rawSmartBillEstimate),
                fallbackDocumentType: OfferSmartBillDocumentType.estimate,
              )
            : const OfferSmartBillDocumentState(
                documentType: OfferSmartBillDocumentType.estimate,
              );
    final smartBillInvoice = rawSmartBillInvoice is Map<String, dynamic>
        ? OfferSmartBillDocumentState.fromMap(
            rawSmartBillInvoice,
            fallbackDocumentType: OfferSmartBillDocumentType.invoice,
          )
        : rawSmartBillInvoice is Map
            ? OfferSmartBillDocumentState.fromMap(
                Map<String, dynamic>.from(rawSmartBillInvoice),
                fallbackDocumentType: OfferSmartBillDocumentType.invoice,
              )
            : const OfferSmartBillDocumentState(
                documentType: OfferSmartBillDocumentType.invoice,
              );

    final regiePercent =
        asDouble(map['regie_percent'] ?? map['regiePercent'], 0);
    final profitPercent =
        asDouble(map['profit_percent'] ?? map['profitPercent'], 0);
    final vatPercent = asDouble(map['vat_percent'], 21);
    final computed = computeTotals(
      lines: lines,
      vatPercent: vatPercent,
      regiePercent: regiePercent,
      profitPercent: profitPercent,
    );
    final exchangeRateSource = OfferExchangeRateSource.fromValue(
      (map['exchange_rate_source'] ?? map['exchangeRateSource'])?.toString(),
    );
    final bnrRate = asDouble(map['bnr_rate'] ?? map['bnrRate']);
    final manualRate = asDouble(map['manual_rate'] ?? map['manualRate']);
    final exchangeCommissionPercent = asDouble(
      map['exchange_commission_percent'] ?? map['exchangeCommissionPercent'],
    );
    final double baseRate = exchangeRateSource == OfferExchangeRateSource.bnr
        ? bnrRate
        : manualRate;
    final double computedEffectiveExchangeRate = baseRate > 0
        ? baseRate * (1.0 + (exchangeCommissionPercent / 100.0))
        : 0.0;
    final double effectiveExchangeRate = asDouble(
      map['effective_exchange_rate'] ?? map['effectiveExchangeRate'],
      computedEffectiveExchangeRate,
    );

    return OfferRecord(
      id: id.isEmpty ? 'offer-${now.microsecondsSinceEpoch}' : id,
      offerNumber: pick(const <String>['offer_number', 'number']),
      title: pick(const <String>['title', 'offer_title']),
      clientId: pick(const <String>['client_id']),
      clientName: pick(const <String>['client_name']),
      clientCui: pick(const <String>['client_cui']),
      clientAddress: pick(const <String>['client_address']),
      clientPhone: pick(const <String>['client_phone']),
      clientEmail: pick(const <String>['client_email']),
      departmentId: pick(const <String>['department_id']),
      departmentName: pick(const <String>['department_name']),
      contactPersonId: pick(const <String>['contact_person_id']),
      contactPersonName: pick(const <String>[
        'contact_person_name',
        'contact_name',
      ]),
      contactPersonEmail: pick(const <String>['contact_person_email']),
      contactPersonPhone: pick(const <String>['contact_person_phone']),
      clientSignatureBase64: pick(const <String>[
        'client_signature_base64',
        'clientSignatureBase64',
      ]),
      issuerSignatureBase64: pick(const <String>[
        'issuer_signature_base64',
        'issuerSignatureBase64',
      ]),
      pdfPath: pick(const <String>['pdf_path', 'pdfPath']),
      beneficiaryClientId: pick(const <String>[
        'beneficiary_client_id',
        'beneficiaryClientId',
      ]),
      beneficiaryName: pick(const <String>[
        'beneficiary_name',
        'beneficiaryName',
      ]),
      commercialRecipientClientId: pick(const <String>[
        'commercial_recipient_client_id',
        'commercialRecipientClientId',
        'payer_client_id',
        'payerClientId',
      ]),
      commercialRecipientName: pick(const <String>[
        'commercial_recipient_name',
        'commercialRecipientName',
        'payer_name',
        'payerName',
      ]),
      complaintId: pick(const <String>['complaint_id', 'complaintId']),
      complaintNumber:
          pick(const <String>['complaint_number', 'complaintNumber']),
      appointmentId: pick(const <String>['appointment_id', 'appointmentId']),
      equipmentType: pick(const <String>['equipment_type', 'equipmentType']),
      equipmentBrand: pick(const <String>['equipment_brand', 'equipmentBrand']),
      equipmentModel: pick(const <String>['equipment_model', 'equipmentModel']),
      outdoorUnitSerial: pick(
        const <String>['outdoor_unit_serial', 'outdoorUnitSerial'],
      ),
      indoorUnitSerials: pick(
        const <String>['indoor_unit_serials', 'indoorUnitSerials'],
      ),
      equipmentDetails: pick(
        const <String>['equipment_details', 'equipmentDetails'],
      ),
      agreementAcceptedAt: parseOptionalDate(
        map['agreement_accepted_at'] ?? map['agreementAcceptedAt'],
      ),
      jobId: pick(const <String>['job_id']),
      jobCode: pick(const <String>['job_code']),
      jobTitle: pick(const <String>['job_title']),
      status: OfferStatus.fromValue(map['status']?.toString()),
      issueDate: parseDate(
        map['issue_date'] ?? map['offer_date'],
        now,
      ),
      validUntil: parseOptionalDate(map['valid_until']),
      currency: pick(const <String>['currency']).isEmpty
          ? 'RON'
          : pick(const <String>['currency']),
      exchangeRateSource: exchangeRateSource,
      bnrRate: bnrRate,
      manualRate: manualRate,
      exchangeCommissionPercent: exchangeCommissionPercent,
      effectiveExchangeRate: effectiveExchangeRate,
      notes: pick(const <String>['notes']),
      materialSubtotal:
          asDouble(map['material_subtotal'], computed.materialSubtotal),
      laborSubtotal: asDouble(map['labor_subtotal'], computed.laborSubtotal),
      subtotalDirect: asDouble(
        map['subtotal_direct'] ?? map['subtotalDirect'],
        computed.subtotalDirect,
      ),
      regiePercent: regiePercent,
      regieValue: asDouble(
        map['regie_value'] ?? map['regieValue'],
        computed.regieValue,
      ),
      profitPercent: profitPercent,
      profitValue: asDouble(
        map['profit_value'] ?? map['profitValue'],
        computed.profitValue,
      ),
      subtotalComercial: asDouble(
        map['subtotal_comercial'] ?? map['subtotalComercial'],
        computed.subtotalComercial,
      ),
      subtotal: asDouble(map['subtotal'], computed.subtotalComercial),
      vatPercent: vatPercent,
      vatValue: asDouble(map['vat_value'], computed.vatValue),
      totalValue: asDouble(map['total_value'], computed.totalValue),
      lines: lines,
      priceDisplayMode: OfferPriceDisplayMode.fromValue(
        (map['price_display_mode'] ?? map['priceDisplayMode'])?.toString(),
      ),
      partners: partners,
      partnerWorkers: partnerWorkers,
      partnerVehicles: partnerVehicles,
      commercialClauses: commercialClauses,
      createdAt: parseDate(map['created_at'], now),
      updatedAt: parseDate(map['updated_at'], now),
      createdByUserId: pick(const <String>['created_by_user_id']),
      createdByUserEmail: pick(const <String>['created_by_user_email']),
      registryEntryId:
          pick(const <String>['registry_entry_id', 'registryEntryId']),
      registryNumber: pick(const <String>['registry_number', 'registryNumber']),
      registeredAt: parseOptionalDate(
        map['registered_at'] ?? map['registeredAt'],
      ),
      convertedToJobId: pick(const <String>['converted_to_job_id']),
      convertedAt: parseOptionalDate(map['converted_at']),
      convertedByUserId: pick(const <String>['converted_by_user_id']),
      smartBillEstimate: smartBillEstimate,
      smartBillInvoice: smartBillInvoice,
      acceptanceClauses: () {
        final raw = map['acceptance_clauses'] ?? map['acceptanceClauses'];
        if (raw is List) {
          return raw
              .whereType<Map<String, dynamic>>()
              .map(OfferAcceptanceClause.fromMap)
              .toList(growable: false);
        }
        return const <OfferAcceptanceClause>[];
      }(),
      acceptanceFormSignatureBase64: (map['acceptance_form_signature_base64']
              ?? map['acceptanceFormSignatureBase64']
              ?? '') as String,
      acceptanceFormSignedAt: parseOptionalDate(
        map['acceptance_form_signed_at'] ?? map['acceptanceFormSignedAt'],
      ),
      tipDocument: TipDocumentDeviz.fromValue(
        (map['tip_document'] ?? map['tipDocument'])?.toString(),
      ),
      hasAcceptancePage: (map['has_acceptance_page'] ?? map['hasAcceptancePage']) == true,
    );
  }
}

List<OfferLineItem> buildCommercialOfferLines(
  List<OfferLineItem> sourceLines, {
  // laborLabel și laborUnit păstrate pentru compatibilitate, dar nu mai sunt folosite
  String laborLabel = 'Manopera',
  String laborUnit = 'poz',
}) {
  final sorted = [...sourceLines]
    ..sort((a, b) => a.sortOrder.compareTo(b.sortOrder));
  final result = <OfferLineItem>[];
  var order = 1;

  for (final line in sorted) {
    // Manopera cu resurse: afișăm fiecare linie cu numele și descrierea date
    // de utilizator, fără să agregăm și fără texte generate automat.
    // Prețul afișat = totalul efectiv al liniei.
    if (line.lineType == OfferLineType.manopera &&
        line.laborSourceMode == OfferLaborSourceMode.resources) {
      result.add(
        line.copyWith(
          sortOrder: order,
          quantity: 1,
          unitPrice: line.effectiveLineTotal,
          lineTotal: line.effectiveLineTotal,
          // Descrierea rămâne cea dată de utilizator (poate fi goală)
        ),
      );
      order += 1;
      continue;
    }
    result.add(
      line.copyWith(
        sortOrder: order,
        lineTotal: line.effectiveLineTotal,
      ),
    );
    order += 1;
  }

  return result;
}

List<OfferLineItem> buildInternalLaborDetailLines(
    List<OfferLineItem> sourceLines) {
  final labor = sourceLines
      .where(
        (line) =>
            line.lineType == OfferLineType.manopera &&
            line.laborSourceMode == OfferLaborSourceMode.resources,
      )
      .map((line) => line.copyWith(lineTotal: line.effectiveLineTotal))
      .toList(growable: false);
  labor.sort((a, b) => a.sortOrder.compareTo(b.sortOrder));
  return labor;
}
