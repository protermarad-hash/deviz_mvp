enum OfferPriceDisplayMode {
  withoutVat,
  withVat,
  both;

  String get value {
    switch (this) {
      case OfferPriceDisplayMode.withoutVat:
        return 'without_vat';
      case OfferPriceDisplayMode.withVat:
        return 'with_vat';
      case OfferPriceDisplayMode.both:
        return 'both';
    }
  }

  String get label {
    switch (this) {
      case OfferPriceDisplayMode.withoutVat:
        return 'Fără TVA';
      case OfferPriceDisplayMode.withVat:
        return 'Cu TVA';
      case OfferPriceDisplayMode.both:
        return 'Ambele';
    }
  }

  bool get showsWithoutVat =>
      this == OfferPriceDisplayMode.withoutVat ||
      this == OfferPriceDisplayMode.both;

  bool get showsWithVat =>
      this == OfferPriceDisplayMode.withVat ||
      this == OfferPriceDisplayMode.both;

  static OfferPriceDisplayMode fromValue(String? raw) {
    final value = (raw ?? '').trim().toLowerCase();
    return OfferPriceDisplayMode.values.firstWhere(
      (item) => item.value == value,
      orElse: () => OfferPriceDisplayMode.both,
    );
  }
}

class OfferLineItem {
  const OfferLineItem({
    required this.id,
    required this.name,
    required this.description,
    required this.unit,
    required this.quantity,
    required this.unitPrice,
    required this.lineTotal,
    required this.sortOrder,
    required this.lineType,
    this.materialId = '',
    this.laborSourceMode = OfferLaborSourceMode.resources,
    this.laborTemplateId = '',
    this.laborHours = 0,
    this.laborHourlyRate = 0,
    this.laborPerDiemDays = 0,
    this.laborPerDiemPerDay = 0,
    this.laborLodgingNights = 0,
    this.laborLodgingPerNight = 0,
    this.laborPersonal = const <OfferLaborResourceUsage>[],
    this.laborVehicles = const <OfferLaborResourceUsage>[],
    this.laborToolPackages = const <OfferLaborResourceUsage>[],
  });

  final String id;
  final String name;
  final String description;
  final String unit;
  final double quantity;
  final double unitPrice;
  final double lineTotal;
  final int sortOrder;
  final OfferLineType lineType;
  final String materialId;
  final OfferLaborSourceMode laborSourceMode;
  final String laborTemplateId;

  final double laborHours;
  final double laborHourlyRate;
  final double laborPerDiemDays;
  final double laborPerDiemPerDay;
  final double laborLodgingNights;
  final double laborLodgingPerNight;
  final List<OfferLaborResourceUsage> laborPersonal;
  final List<OfferLaborResourceUsage> laborVehicles;
  final List<OfferLaborResourceUsage> laborToolPackages;

  bool get hasLaborResourceDetails =>
      laborPersonal.isNotEmpty ||
      laborVehicles.isNotEmpty ||
      laborToolPackages.isNotEmpty;

  double get effectiveLineTotal {
    if (lineType == OfferLineType.manopera) {
      if (laborSourceMode == OfferLaborSourceMode.standard) {
        return OfferLaborCalculator.roundPriceUpToTen(quantity * unitPrice);
      }
      return OfferLaborCalculator.roundPriceUpToTen(
        OfferLaborCalculator.computeFromResources(
          personal: hasLaborResourceDetails
              ? laborPersonal
              : <OfferLaborResourceUsage>[
                  OfferLaborResourceUsage(
                    resourceId: '',
                    name: '',
                    hours: laborHours,
                    days: 0,
                    hourlyRate: laborHourlyRate,
                    dailyRate: 0,
                  ),
                ],
          autoturisme: hasLaborResourceDetails
              ? laborVehicles
              : const <OfferLaborResourceUsage>[],
          pacheteScule: hasLaborResourceDetails
              ? laborToolPackages
              : const <OfferLaborResourceUsage>[],
          perDiemDays: laborPerDiemDays,
          perDiemPerDay: laborPerDiemPerDay,
          lodgingNights: laborLodgingNights,
          lodgingPerNight: laborLodgingPerNight,
        ).total,
      );
    }
    return OfferLaborCalculator.roundPriceUpToTen(quantity * unitPrice);
  }

  OfferLineItem copyWith({
    String? id,
    String? name,
    String? description,
    String? unit,
    double? quantity,
    double? unitPrice,
    double? lineTotal,
    int? sortOrder,
    OfferLineType? lineType,
    String? materialId,
    OfferLaborSourceMode? laborSourceMode,
    String? laborTemplateId,
    double? laborHours,
    double? laborHourlyRate,
    double? laborPerDiemDays,
    double? laborPerDiemPerDay,
    double? laborLodgingNights,
    double? laborLodgingPerNight,
    List<OfferLaborResourceUsage>? laborPersonal,
    List<OfferLaborResourceUsage>? laborVehicles,
    List<OfferLaborResourceUsage>? laborToolPackages,
  }) {
    final nextType = lineType ?? this.lineType;
    final nextQty = quantity ?? this.quantity;
    final nextPrice = unitPrice ?? this.unitPrice;
    final nextLaborHours = laborHours ?? this.laborHours;
    final nextLaborRate = laborHourlyRate ?? this.laborHourlyRate;
    final nextLaborPerDiemDays = laborPerDiemDays ?? this.laborPerDiemDays;
    final nextLaborPerDiemPerDay =
        laborPerDiemPerDay ?? this.laborPerDiemPerDay;
    final nextLaborNights = laborLodgingNights ?? this.laborLodgingNights;
    final nextLaborLodgingPerNight =
        laborLodgingPerNight ?? this.laborLodgingPerNight;
    final nextLaborPersonal = laborPersonal ?? this.laborPersonal;
    final nextLaborVehicles = laborVehicles ?? this.laborVehicles;
    final nextLaborToolPackages = laborToolPackages ?? this.laborToolPackages;
    final hasResourceDetails = nextLaborPersonal.isNotEmpty ||
        nextLaborVehicles.isNotEmpty ||
        nextLaborToolPackages.isNotEmpty;

    final computed = nextType == OfferLineType.manopera
        ? OfferLaborCalculator.computeFromResources(
            personal: hasResourceDetails
                ? nextLaborPersonal
                : <OfferLaborResourceUsage>[
                    OfferLaborResourceUsage(
                      resourceId: '',
                      name: '',
                      hours: nextLaborHours,
                      days: 0,
                      hourlyRate: nextLaborRate,
                      dailyRate: 0,
                    ),
                  ],
            autoturisme: hasResourceDetails
                ? nextLaborVehicles
                : const <OfferLaborResourceUsage>[],
            pacheteScule: hasResourceDetails
                ? nextLaborToolPackages
                : const <OfferLaborResourceUsage>[],
            perDiemDays: nextLaborPerDiemDays,
            perDiemPerDay: nextLaborPerDiemPerDay,
            lodgingNights: nextLaborNights,
            lodgingPerNight: nextLaborLodgingPerNight,
          ).total
        : nextQty * nextPrice;

    return OfferLineItem(
      id: id ?? this.id,
      name: name ?? this.name,
      description: description ?? this.description,
      unit: unit ?? this.unit,
      quantity: nextQty,
      unitPrice: nextPrice,
      lineTotal: lineTotal ?? computed,
      sortOrder: sortOrder ?? this.sortOrder,
      lineType: nextType,
      materialId: materialId ?? this.materialId,
      laborSourceMode: laborSourceMode ?? this.laborSourceMode,
      laborTemplateId: laborTemplateId ?? this.laborTemplateId,
      laborHours: nextLaborHours,
      laborHourlyRate: nextLaborRate,
      laborPerDiemDays: nextLaborPerDiemDays,
      laborPerDiemPerDay: nextLaborPerDiemPerDay,
      laborLodgingNights: nextLaborNights,
      laborLodgingPerNight: nextLaborLodgingPerNight,
      laborPersonal: nextLaborPersonal,
      laborVehicles: nextLaborVehicles,
      laborToolPackages: nextLaborToolPackages,
    );
  }

  Map<String, dynamic> toMap() {
    return <String, dynamic>{
      'id': id,
      'name': name,
      'description': description,
      'unit': unit,
      'quantity': quantity,
      'unit_price': unitPrice,
      'line_total': lineTotal,
      'sort_order': sortOrder,
      'line_type': lineType.value,
      'material_id': materialId,
      'labor_source_mode': laborSourceMode.value,
      'labor_template_id': laborTemplateId,
      'labor_hours': laborHours,
      'labor_hourly_rate': laborHourlyRate,
      'labor_per_diem_days': laborPerDiemDays,
      'labor_per_diem_per_day': laborPerDiemPerDay,
      'labor_lodging_nights': laborLodgingNights,
      'labor_lodging_per_night': laborLodgingPerNight,
      'labor_personal':
          laborPersonal.map((item) => item.toMap()).toList(growable: false),
      'labor_vehicles':
          laborVehicles.map((item) => item.toMap()).toList(growable: false),
      'labor_tool_packages':
          laborToolPackages.map((item) => item.toMap()).toList(growable: false),
    };
  }

  factory OfferLineItem.fromMap(Map<String, dynamic> map) {
    double asDouble(dynamic raw) {
      if (raw == null) return 0;
      if (raw is num) return raw.toDouble();
      return double.tryParse(raw.toString().replaceAll(',', '.').trim()) ?? 0;
    }

    int asInt(dynamic raw) {
      if (raw == null) return 0;
      if (raw is int) return raw;
      if (raw is num) return raw.toInt();
      return int.tryParse(raw.toString().trim()) ?? 0;
    }

    final type = OfferLineType.fromValue(map['line_type'] ?? map['lineType']);
    final laborSourceMode = OfferLaborSourceMode.fromValue(
      map['labor_source_mode'] ?? map['laborSourceMode'],
    );
    final quantity = asDouble(map['quantity']);
    final unitPrice = asDouble(map['unit_price'] ?? map['unitPrice']);
    final laborHours = asDouble(map['labor_hours'] ?? map['laborHours']);
    final laborHourlyRate =
        asDouble(map['labor_hourly_rate'] ?? map['laborHourlyRate']);
    final laborPerDiemDays =
        asDouble(map['labor_per_diem_days'] ?? map['laborPerDiemDays']);
    final laborPerDiemPerDay = asDouble(
      map['labor_per_diem_per_day'] ?? map['laborPerDiemPerDay'],
    );
    final laborLodgingNights =
        asDouble(map['labor_lodging_nights'] ?? map['laborLodgingNights']);
    final laborLodgingPerNight = asDouble(
      map['labor_lodging_per_night'] ?? map['laborLodgingPerNight'],
    );
    List<OfferLaborResourceUsage> parseResourceList(dynamic raw) {
      if (raw is! List) return const <OfferLaborResourceUsage>[];
      return raw
          .whereType<Map>()
          .map((item) => OfferLaborResourceUsage.fromMap(
                Map<String, dynamic>.from(item),
              ))
          .toList(growable: false);
    }

    final laborPersonal = parseResourceList(
      map['labor_personal'] ?? map['laborPersonal'],
    );
    final laborVehicles = parseResourceList(
      map['labor_vehicles'] ?? map['laborVehicles'],
    );
    final laborToolPackages = parseResourceList(
      map['labor_tool_packages'] ?? map['laborToolPackages'],
    );
    final hasResourceDetails = laborPersonal.isNotEmpty ||
        laborVehicles.isNotEmpty ||
        laborToolPackages.isNotEmpty;

    final computed = type == OfferLineType.manopera
        ? (laborSourceMode == OfferLaborSourceMode.standard
            ? quantity * unitPrice
            : OfferLaborCalculator.computeFromResources(
                personal: hasResourceDetails
                    ? laborPersonal
                    : <OfferLaborResourceUsage>[
                        OfferLaborResourceUsage(
                          resourceId: '',
                          name: '',
                          hours: laborHours,
                          days: 0,
                          hourlyRate: laborHourlyRate,
                          dailyRate: 0,
                        ),
                      ],
                autoturisme: hasResourceDetails
                    ? laborVehicles
                    : const <OfferLaborResourceUsage>[],
                pacheteScule: hasResourceDetails
                    ? laborToolPackages
                    : const <OfferLaborResourceUsage>[],
                perDiemDays: laborPerDiemDays,
                perDiemPerDay: laborPerDiemPerDay,
                lodgingNights: laborLodgingNights,
                lodgingPerNight: laborLodgingPerNight,
              ).total)
        : quantity * unitPrice;

    final lineTotalRaw = map['line_total'] ?? map['lineTotal'];
    final lineTotal = lineTotalRaw == null ? computed : asDouble(lineTotalRaw);

    return OfferLineItem(
      id: (map['id'] ?? '').toString().trim(),
      name: (map['name'] ?? '').toString(),
      description: (map['description'] ?? '').toString(),
      unit: (map['unit'] ?? '').toString(),
      quantity: quantity,
      unitPrice: unitPrice,
      lineTotal: lineTotal,
      sortOrder: asInt(map['sort_order'] ?? map['sortOrder']),
      lineType: type,
      materialId: (map['material_id'] ?? map['materialId'] ?? '').toString(),
      laborSourceMode: laborSourceMode,
      laborTemplateId:
          (map['labor_template_id'] ?? map['laborTemplateId'] ?? '').toString(),
      laborHours: laborHours,
      laborHourlyRate: laborHourlyRate,
      laborPerDiemDays: laborPerDiemDays,
      laborPerDiemPerDay: laborPerDiemPerDay,
      laborLodgingNights: laborLodgingNights,
      laborLodgingPerNight: laborLodgingPerNight,
      laborPersonal: laborPersonal,
      laborVehicles: laborVehicles,
      laborToolPackages: laborToolPackages,
    );
  }
}

class OfferCommercialClause {
  const OfferCommercialClause({
    required this.id,
    required this.title,
    required this.content,
    this.templateId = '',
    this.category = '',
    this.sortOrder = 0,
  });

  final String id;
  final String title;
  final String content;
  final String templateId;
  final String category;
  final int sortOrder;

  OfferCommercialClause copyWith({
    String? id,
    String? title,
    String? content,
    String? templateId,
    String? category,
    int? sortOrder,
  }) {
    return OfferCommercialClause(
      id: id ?? this.id,
      title: title ?? this.title,
      content: content ?? this.content,
      templateId: templateId ?? this.templateId,
      category: category ?? this.category,
      sortOrder: sortOrder ?? this.sortOrder,
    );
  }

  Map<String, dynamic> toMap() {
    return <String, dynamic>{
      'id': id,
      'title': title,
      'content': content,
      'template_id': templateId,
      'category': category,
      'sort_order': sortOrder,
    };
  }

  factory OfferCommercialClause.fromMap(Map<String, dynamic> map) {
    int asInt(dynamic raw) {
      if (raw == null) return 0;
      if (raw is int) return raw;
      if (raw is num) return raw.toInt();
      return int.tryParse(raw.toString().trim()) ?? 0;
    }

    return OfferCommercialClause(
      id: (map['id'] ?? '').toString().trim(),
      title: (map['title'] ?? '').toString(),
      content: (map['content'] ?? '').toString(),
      templateId: (map['template_id'] ?? map['templateId'] ?? '').toString(),
      category: (map['category'] ?? '').toString(),
      sortOrder: asInt(map['sort_order'] ?? map['sortOrder']),
    );
  }
}

class OfferTotals {
  const OfferTotals({
    required this.materialSubtotal,
    required this.laborSubtotal,
    required this.subtotalDirect,
    required this.regiePercent,
    required this.regieValue,
    required this.profitPercent,
    required this.profitValue,
    required this.subtotalComercial,
    required this.vatPercent,
    required this.vatValue,
    required this.totalValue,
  });

  final double materialSubtotal;
  final double laborSubtotal;
  final double subtotalDirect;
  final double regiePercent;
  final double regieValue;
  final double profitPercent;
  final double profitValue;
  final double subtotalComercial;
  final double vatPercent;
  final double vatValue;
  final double totalValue;

  // Backward-compatible alias used in older UI labels.
  double get subtotal => subtotalComercial;
}

class OfferRecord {
  const OfferRecord({
    required this.id,
    required this.offerNumber,
    required this.title,
    required this.clientId,
    required this.clientName,
    this.clientCui = '',
    this.clientAddress = '',
    this.clientPhone = '',
    this.clientEmail = '',
    this.departmentId = '',
    this.departmentName = '',
    this.contactPersonId = '',
    this.contactPersonName = '',
    this.contactPersonEmail = '',
    this.contactPersonPhone = '',
    this.clientSignatureBase64 = '',
    this.issuerSignatureBase64 = '',
    this.pdfPath = '',
    this.beneficiaryClientId = '',
    this.beneficiaryName = '',
    this.commercialRecipientClientId = '',
    this.commercialRecipientName = '',
    this.complaintId = '',
    this.complaintNumber = '',
    this.appointmentId = '',
    this.equipmentType = '',
    this.equipmentBrand = '',
    this.equipmentModel = '',
    this.outdoorUnitSerial = '',
    this.indoorUnitSerials = '',
    this.equipmentDetails = '',
    this.agreementAcceptedAt,
    required this.jobId,
    required this.jobCode,
    required this.jobTitle,
    required this.status,
    required this.issueDate,
    required this.validUntil,
    required this.currency,
    required this.exchangeRateSource,
    required this.bnrRate,
    required this.manualRate,
    required this.exchangeCommissionPercent,
    required this.effectiveExchangeRate,
    required this.notes,
    required this.materialSubtotal,
    required this.laborSubtotal,
    required this.subtotalDirect,
    required this.regiePercent,
    required this.regieValue,
    required this.profitPercent,
    required this.profitValue,
    required this.subtotalComercial,
    required this.subtotal,
    required this.vatPercent,
    required this.vatValue,
    required this.totalValue,
    required this.lines,
    this.priceDisplayMode = OfferPriceDisplayMode.both,
    this.partners = const <OfferPartner>[],
    this.partnerWorkers = const <OfferPartnerWorker>[],
    this.partnerVehicles = const <OfferPartnerVehicle>[],
    this.commercialClauses = const <OfferCommercialClause>[],
    required this.createdAt,
    required this.updatedAt,
    required this.createdByUserId,
    required this.createdByUserEmail,
    this.registryEntryId = '',
    this.registryNumber = '',
    this.registeredAt,
    this.convertedToJobId = '',
    this.convertedAt,
    this.convertedByUserId = '',
    this.smartBillEstimate = const OfferSmartBillDocumentState(
      documentType: OfferSmartBillDocumentType.estimate,
    ),
    this.smartBillInvoice = const OfferSmartBillDocumentState(
      documentType: OfferSmartBillDocumentType.invoice,
    ),
    this.acceptanceClauses = const <OfferAcceptanceClause>[],
    this.acceptanceFormSignatureBase64 = '',
    this.acceptanceFormSignedAt,
    this.tipDocument = TipDocumentDeviz.devizLucrari,
    this.hasAcceptancePage = false,
  });

  final String id;
  final String offerNumber;
  final String title;
  final String clientId;
  final String clientName;
  /// Date de identificare client (auto-completate din ClientRecord la selectare)
  final String clientCui;
  final String clientAddress;
  final String clientPhone;
  final String clientEmail;
  final String departmentId;
  final String departmentName;
  final String contactPersonId;
  final String contactPersonName;
  final String contactPersonEmail;
  final String contactPersonPhone;
  final String clientSignatureBase64;
  final String issuerSignatureBase64;
  final String pdfPath;
  final String beneficiaryClientId;
  final String beneficiaryName;
  final String commercialRecipientClientId;
  final String commercialRecipientName;
  final String complaintId;
  final String complaintNumber;
  final String appointmentId;
  final String equipmentType;
  final String equipmentBrand;
  final String equipmentModel;
  final String outdoorUnitSerial;
  final String indoorUnitSerials;
  final String equipmentDetails;
  final DateTime? agreementAcceptedAt;
  final String jobId;
  final String jobCode;
  final String jobTitle;
