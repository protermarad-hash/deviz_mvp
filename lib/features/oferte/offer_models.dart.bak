      'client_name': clientName,
      'client_cui': clientCui,
      'client_address': clientAddress,
      'client_phone': clientPhone,
      'client_email': clientEmail,
      'department_id': departmentId,
      'department_name': departmentName,
      'contact_person_id': contactPersonId,
      'contact_person_name': contactPersonName,
      'contact_person_email': contactPersonEmail,
      'contact_person_phone': contactPersonPhone,
      'client_signature_base64': clientSignatureBase64,
      'issuer_signature_base64': issuerSignatureBase64,
      'pdf_path': pdfPath,
      'beneficiary_client_id': beneficiaryClientId,
      'beneficiary_name': beneficiaryName,
      'commercial_recipient_client_id': commercialRecipientClientId,
      'commercial_recipient_name': commercialRecipientName,
      'complaint_id': complaintId,
      'complaint_number': complaintNumber,
      'appointment_id': appointmentId,
      'equipment_type': equipmentType,
      'equipment_brand': equipmentBrand,
      'equipment_model': equipmentModel,
      'outdoor_unit_serial': outdoorUnitSerial,
      'indoor_unit_serials': indoorUnitSerials,
      'equipment_details': equipmentDetails,
      'agreement_accepted_at': agreementAcceptedAt?.toIso8601String(),
      'job_id': jobId,
      'job_code': jobCode,
      'job_title': jobTitle,
      'status': status.value,
      'issue_date': issueDate.toIso8601String(),
      'valid_until': validUntil?.toIso8601String(),
      'currency': currency,
      'exchange_rate_source': exchangeRateSource.value,
      'bnr_rate': bnrRate,
      'manual_rate': manualRate,
      'exchange_commission_percent': exchangeCommissionPercent,
      'effective_exchange_rate': effectiveExchangeRate,
      'notes': notes,
      'material_subtotal': materialSubtotal,
      'labor_subtotal': laborSubtotal,
      'subtotal_direct': subtotalDirect,
      'regie_percent': regiePercent,
      'regie_value': regieValue,
      'profit_percent': profitPercent,
      'profit_value': profitValue,
      'subtotal_comercial': subtotalComercial,
