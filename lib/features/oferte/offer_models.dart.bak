      'price_display_mode': priceDisplayMode.value,
      'lines': lines.map((line) => line.toMap()).toList(growable: false),
      'partners': partners.map((item) => item.toMap()).toList(growable: false),
      'partner_workers':
          partnerWorkers.map((item) => item.toMap()).toList(growable: false),
      'partner_vehicles':
          partnerVehicles.map((item) => item.toMap()).toList(growable: false),
      'commercial_clauses':
          commercialClauses.map((item) => item.toMap()).toList(growable: false),
      'created_at': createdAt.toIso8601String(),
      'updated_at': updatedAt.toIso8601String(),
      'created_by_user_id': createdByUserId,
