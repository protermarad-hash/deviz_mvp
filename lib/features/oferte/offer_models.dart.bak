enum OfferStatus {
  draft,
  sent,
  awaiting,
  accepted,
  rejected,
  cancelled;

  String get value {
    switch (this) {
      case OfferStatus.draft:
        return 'draft';
      case OfferStatus.sent:
        return 'sent';
      case OfferStatus.awaiting:
        return 'awaiting';
      case OfferStatus.accepted:
        return 'accepted';
      case OfferStatus.rejected:
        return 'rejected';
      case OfferStatus.cancelled:
        return 'cancelled';
    }
  }

  String get label {
    switch (this) {
      case OfferStatus.draft:
        return 'Draft';
      case OfferStatus.sent:
        return 'Trimisa';
      case OfferStatus.awaiting:
        return 'In asteptare';
      case OfferStatus.accepted:
        return 'Acceptata';
      case OfferStatus.rejected:
        return 'Respinsa';
      case OfferStatus.cancelled:
        return 'Anulata';
    }
  }

  static OfferStatus fromValue(String? raw) {
    final value = (raw ?? '').trim().toLowerCase();
    return OfferStatus.values.firstWhere(
      (item) => item.value == value,
      orElse: () => OfferStatus.draft,
    );
  }
}

