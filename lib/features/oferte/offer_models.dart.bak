  final double manualRate;
  final double exchangeCommissionPercent;
  final double effectiveExchangeRate;
  final String notes;
  final double materialSubtotal;
  final double laborSubtotal;
  final double subtotalDirect;
  final double regiePercent;
  final double regieValue;
  final double profitPercent;
  final double profitValue;
  final double subtotalComercial;
  final double subtotal;
  final double vatPercent;
  final double vatValue;
  final double totalValue;
  final List<OfferLineItem> lines;
  final OfferPriceDisplayMode priceDisplayMode;
  final List<OfferPartner> partners;
  final List<OfferPartnerWorker> partnerWorkers;
  final List<OfferPartnerVehicle> partnerVehicles;
  final List<OfferCommercialClause> commercialClauses;
  final DateTime createdAt;
  final DateTime updatedAt;
  final String createdByUserId;
  final String createdByUserEmail;
  final String registryEntryId;
  final String registryNumber;
  final DateTime? registeredAt;
  final String convertedToJobId;
  final DateTime? convertedAt;
  final String convertedByUserId;
  final OfferSmartBillDocumentState smartBillEstimate;
  final OfferSmartBillDocumentState smartBillInvoice;
  final List<OfferAcceptanceClause> acceptanceClauses;
  final String acceptanceFormSignatureBase64;
  final DateTime? acceptanceFormSignedAt;
  final TipDocumentDeviz tipDocument;
  /// Indică dacă PDF-ul ofertei conține pagina de acceptare (adăugată automat la ultimul export).
  final bool hasAcceptancePage;

  bool get isAcceptanceSigned => acceptanceFormSignedAt != null && acceptanceFormSignatureBase64.isNotEmpty;

  bool get isConverted => convertedToJobId.trim().isNotEmpty;

  String get lifecycleLabel => isConverted ? 'Convertita' : status.label;

  static OfferTotals computeTotals({
    required List<OfferLineItem> lines,
    required double vatPercent,
    double regiePercent = 0,
    double profitPercent = 0,
  }) {
    var materialSubtotal = 0.0;
    var laborSubtotal = 0.0;
    for (final line in lines) {
      final total = line.effectiveLineTotal;
      if (line.lineType == OfferLineType.manopera) {
        laborSubtotal += total;
      } else {
        materialSubtotal += total;
      }
    }
    final subtotalDirect = materialSubtotal + laborSubtotal;
    final regieValue = subtotalDirect * regiePercent / 100;
    final profitValue = subtotalDirect * profitPercent / 100;
    var subtotalComercial = subtotalDirect + regieValue + profitValue;

    // Round commercial subtotal UP to nearest 10
    subtotalComercial =
        OfferLaborCalculator.roundPriceUpToTen(subtotalComercial);

    var vatValue = subtotalComercial * vatPercent / 100;
    var totalValue = subtotalComercial + vatValue;

    // Round final total UP to nearest 10
    totalValue = OfferLaborCalculator.roundPriceUpToTen(totalValue);

    return OfferTotals(
      materialSubtotal: materialSubtotal,
      laborSubtotal: laborSubtotal,
      subtotalDirect: subtotalDirect,
      regiePercent: regiePercent,
      regieValue: regieValue,
      profitPercent: profitPercent,
      profitValue: profitValue,
      subtotalComercial: subtotalComercial,
      vatPercent: vatPercent,
      vatValue: vatValue,
      totalValue: totalValue,
    );
  }

  OfferRecord copyWith({
    String? id,
    String? offerNumber,
    String? title,
    String? clientId,
    String? clientName,
    String? clientCui,
    String? clientAddress,
    String? clientPhone,
    String? clientEmail,
    String? departmentId,
    String? departmentName,
    String? contactPersonId,
    String? contactPersonName,
    String? contactPersonEmail,
    String? contactPersonPhone,
    String? clientSignatureBase64,
    String? issuerSignatureBase64,
    String? pdfPath,
    String? beneficiaryClientId,
    String? beneficiaryName,
    String? commercialRecipientClientId,
    String? commercialRecipientName,
    String? complaintId,
    String? complaintNumber,
    String? appointmentId,
    String? equipmentType,
    String? equipmentBrand,
    String? equipmentModel,
    String? outdoorUnitSerial,
    String? indoorUnitSerials,
    String? equipmentDetails,
    DateTime? agreementAcceptedAt,
    bool clearAgreementAcceptedAt = false,
    String? jobId,
    String? jobCode,
    String? jobTitle,
    OfferStatus? status,
    DateTime? issueDate,
    DateTime? validUntil,
    bool clearValidUntil = false,
    String? currency,
    OfferExchangeRateSource? exchangeRateSource,
    double? bnrRate,
    double? manualRate,
    double? exchangeCommissionPercent,
    double? effectiveExchangeRate,
    String? notes,
    double? materialSubtotal,
    double? laborSubtotal,
    double? subtotalDirect,
    double? regiePercent,
    double? regieValue,
    double? profitPercent,
    double? profitValue,
    double? subtotalComercial,
    double? subtotal,
    double? vatPercent,
    double? vatValue,
    double? totalValue,
    List<OfferLineItem>? lines,
    OfferPriceDisplayMode? priceDisplayMode,
    List<OfferPartner>? partners,
    List<OfferPartnerWorker>? partnerWorkers,
    List<OfferPartnerVehicle>? partnerVehicles,
    List<OfferCommercialClause>? commercialClauses,
    DateTime? createdAt,
    DateTime? updatedAt,
    String? createdByUserId,
    String? createdByUserEmail,
    String? registryEntryId,
    String? registryNumber,
    DateTime? registeredAt,
    bool clearRegisteredAt = false,
    String? convertedToJobId,
    DateTime? convertedAt,
    bool clearConvertedAt = false,
    String? convertedByUserId,
    OfferSmartBillDocumentState? smartBillEstimate,
    OfferSmartBillDocumentState? smartBillInvoice,
    List<OfferAcceptanceClause>? acceptanceClauses,
    String? acceptanceFormSignatureBase64,
    DateTime? acceptanceFormSignedAt,
    bool clearAcceptanceFormSignedAt = false,
    TipDocumentDeviz? tipDocument,
    bool? hasAcceptancePage,
  }) {
    final nextLines = lines ?? this.lines;
    final nextRegiePercent = regiePercent ?? this.regiePercent;
    final nextProfitPercent = profitPercent ?? this.profitPercent;
    final nextVatPercent = vatPercent ?? this.vatPercent;
    final computed = computeTotals(
      lines: nextLines,
      vatPercent: nextVatPercent,
      regiePercent: nextRegiePercent,
      profitPercent: nextProfitPercent,
    );
    return OfferRecord(
      id: id ?? this.id,
      offerNumber: offerNumber ?? this.offerNumber,
      title: title ?? this.title,
      clientId: clientId ?? this.clientId,
      clientName: clientName ?? this.clientName,
      clientCui: clientCui ?? this.clientCui,
      clientAddress: clientAddress ?? this.clientAddress,
      clientPhone: clientPhone ?? this.clientPhone,
      clientEmail: clientEmail ?? this.clientEmail,
      departmentId: departmentId ?? this.departmentId,
      departmentName: departmentName ?? this.departmentName,
      contactPersonId: contactPersonId ?? this.contactPersonId,
      contactPersonName: contactPersonName ?? this.contactPersonName,
      contactPersonEmail: contactPersonEmail ?? this.contactPersonEmail,
      contactPersonPhone: contactPersonPhone ?? this.contactPersonPhone,
      clientSignatureBase64:
          clientSignatureBase64 ?? this.clientSignatureBase64,
      issuerSignatureBase64:
          issuerSignatureBase64 ?? this.issuerSignatureBase64,
      pdfPath: pdfPath ?? this.pdfPath,
      beneficiaryClientId: beneficiaryClientId ?? this.beneficiaryClientId,
      beneficiaryName: beneficiaryName ?? this.beneficiaryName,
      commercialRecipientClientId:
          commercialRecipientClientId ?? this.commercialRecipientClientId,
      commercialRecipientName:
          commercialRecipientName ?? this.commercialRecipientName,
      complaintId: complaintId ?? this.complaintId,
      complaintNumber: complaintNumber ?? this.complaintNumber,
      appointmentId: appointmentId ?? this.appointmentId,
      equipmentType: equipmentType ?? this.equipmentType,
      equipmentBrand: equipmentBrand ?? this.equipmentBrand,
      equipmentModel: equipmentModel ?? this.equipmentModel,
      outdoorUnitSerial: outdoorUnitSerial ?? this.outdoorUnitSerial,
      indoorUnitSerials: indoorUnitSerials ?? this.indoorUnitSerials,
      equipmentDetails: equipmentDetails ?? this.equipmentDetails,
      agreementAcceptedAt: clearAgreementAcceptedAt
          ? null
          : (agreementAcceptedAt ?? this.agreementAcceptedAt),
      jobId: jobId ?? this.jobId,
      jobCode: jobCode ?? this.jobCode,
      jobTitle: jobTitle ?? this.jobTitle,
      status: status ?? this.status,
      issueDate: issueDate ?? this.issueDate,
      validUntil: clearValidUntil ? null : (validUntil ?? this.validUntil),
      currency: currency ?? this.currency,
      exchangeRateSource: exchangeRateSource ?? this.exchangeRateSource,
      bnrRate: bnrRate ?? this.bnrRate,
      manualRate: manualRate ?? this.manualRate,
      exchangeCommissionPercent:
          exchangeCommissionPercent ?? this.exchangeCommissionPercent,
      effectiveExchangeRate:
          effectiveExchangeRate ?? this.effectiveExchangeRate,
      notes: notes ?? this.notes,
      materialSubtotal: materialSubtotal ?? computed.materialSubtotal,
      laborSubtotal: laborSubtotal ?? computed.laborSubtotal,
      subtotalDirect: subtotalDirect ?? computed.subtotalDirect,
      regiePercent: nextRegiePercent,
      regieValue: regieValue ?? computed.regieValue,
      profitPercent: nextProfitPercent,
      profitValue: profitValue ?? computed.profitValue,
      subtotalComercial: subtotalComercial ?? computed.subtotalComercial,
      subtotal: subtotal ?? computed.subtotalComercial,
      vatPercent: nextVatPercent,
      vatValue: vatValue ?? computed.vatValue,
      totalValue: totalValue ?? computed.totalValue,
      lines: nextLines,
      priceDisplayMode: priceDisplayMode ?? this.priceDisplayMode,
      partners: partners ?? this.partners,
      partnerWorkers: partnerWorkers ?? this.partnerWorkers,
      partnerVehicles: partnerVehicles ?? this.partnerVehicles,
      commercialClauses: commercialClauses ?? this.commercialClauses,
      createdAt: createdAt ?? this.createdAt,
      updatedAt: updatedAt ?? this.updatedAt,
      createdByUserId: createdByUserId ?? this.createdByUserId,
      createdByUserEmail: createdByUserEmail ?? this.createdByUserEmail,
      registryEntryId: registryEntryId ?? this.registryEntryId,
      registryNumber: registryNumber ?? this.registryNumber,
      registeredAt:
          clearRegisteredAt ? null : (registeredAt ?? this.registeredAt),
      convertedToJobId: convertedToJobId ?? this.convertedToJobId,
      convertedAt: clearConvertedAt ? null : (convertedAt ?? this.convertedAt),
      convertedByUserId: convertedByUserId ?? this.convertedByUserId,
      smartBillEstimate: smartBillEstimate ?? this.smartBillEstimate,
      smartBillInvoice: smartBillInvoice ?? this.smartBillInvoice,
      acceptanceClauses: acceptanceClauses ?? this.acceptanceClauses,
      acceptanceFormSignatureBase64:
          acceptanceFormSignatureBase64 ?? this.acceptanceFormSignatureBase64,
      acceptanceFormSignedAt: clearAcceptanceFormSignedAt
          ? null
          : (acceptanceFormSignedAt ?? this.acceptanceFormSignedAt),
      tipDocument: tipDocument ?? this.tipDocument,
      hasAcceptancePage: hasAcceptancePage ?? this.hasAcceptancePage,
    );
  }

