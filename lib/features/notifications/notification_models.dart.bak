      userId: (map['user_id'] ?? map['userId'] ?? '').toString().trim(),
      userEmail:
          (map['user_email'] ?? map['userEmail'] ?? '').toString().trim(),
      token: (map['token'] ?? '').toString().trim(),
      platform: (map['platform'] ?? '').toString().trim(),
      deviceLabel:
          (map['device_label'] ?? map['deviceLabel'] ?? '').toString().trim(),
      isActive: parseBool(map['is_active'] ?? map['isActive']),
      createdAt: parseNullableDate(map['created_at'] ?? map['createdAt']),
      updatedAt: parseDate(map['updated_at'] ?? map['updatedAt']),
      lastSeenAt: parseNullableDate(map['last_seen_at'] ?? map['lastSeenAt']),
    );
  }
}
