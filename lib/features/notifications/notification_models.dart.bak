      sourceModule:
          (map['source_module'] ?? map['sourceModule'] ?? '').toString().trim(),
      sourceEntityId: (map['source_entity_id'] ?? map['sourceEntityId'] ?? '')
          .toString()
          .trim(),
      status: (map['status'] ?? 'queued').toString().trim(),
      attemptCount: int.tryParse(
            (map['attempt_count'] ?? map['attemptCount'] ?? '0').toString(),
          ) ??
          0,
      createdAt: parseDate(map['created_at'] ?? map['createdAt']),
      lastAttemptAt:
          parseNullableDate(map['last_attempt_at'] ?? map['lastAttemptAt']),
      processedAt: parseNullableDate(map['processed_at'] ?? map['processedAt']),
      errorMessage:
          (map['error_message'] ?? map['errorMessage'] ?? '').toString(),
      providerMessageId:
          (map['provider_message_id'] ?? map['providerMessageId'] ?? '')
              .toString()
              .trim(),
      metadata: parseMap(map['metadata']),
      attachments: (map['attachments'] is List)
          ? List<Map<String, dynamic>>.from(
              (map['attachments'] as List)
                  .whereType<Map>()
                  .map((m) => Map<String, dynamic>.from(m)),
            )
          : const <Map<String, dynamic>>[],
      inlineAssets: (map['inline_assets'] is List)
          ? List<Map<String, dynamic>>.from(
              (map['inline_assets'] as List)
                  .whereType<Map>()
                  .map((m) => Map<String, dynamic>.from(m)),
            )
          : const <Map<String, dynamic>>[],
    );
  }
}

