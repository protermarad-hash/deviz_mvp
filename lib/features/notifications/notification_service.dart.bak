    );
  }

  List<AppNotificationRecord> _filterNotifications(
    List<AppNotificationRecord> source,
    String recipientUserId,
    bool includeRead,
  ) {
    final filtered = source.where((item) {
      if (item.recipientUserId.trim() != recipientUserId) {
        return false;
      }
      if (!includeRead && item.isRead) {
        return false;
      }
      return true;
    }).toList(growable: false)
      ..sort(_compareNotifications);
    return filtered;
  }

  int _compareNotifications(
    AppNotificationRecord a,
    AppNotificationRecord b,
  ) {
    return b.createdAt.compareTo(a.createdAt);
  }

  int _comparePreferences(
    NotificationPreferenceRecord a,
    NotificationPreferenceRecord b,
  ) {
    final event = a.eventType.value.compareTo(b.eventType.value);
    if (event != 0) return event;
    final user = a.userId.compareTo(b.userId);
    if (user != 0) return user;
    return a.roleKey.compareTo(b.roleKey);
  }

  int _compareEmailQueue(
    NotificationEmailQueueRecord a,
    NotificationEmailQueueRecord b,
  ) {
    return b.createdAt.compareTo(a.createdAt);
  }

  int _comparePushQueue(
    NotificationPushQueueRecord a,
    NotificationPushQueueRecord b,
  ) {
    return b.createdAt.compareTo(a.createdAt);
  }

  int _compareDeviceTokens(
    NotificationDeviceTokenRecord a,
    NotificationDeviceTokenRecord b,
  ) {
    return b.updatedAt.compareTo(a.updatedAt);
  }
}

class _ResolvedNotificationRecipient {
  const _ResolvedNotificationRecipient({
    required this.userId,
    required this.name,
    required this.email,
    required this.roleKey,
    required this.teamId,
    required this.employeeId,
  });

  final String userId;
  final String name;
  final String email;
  final String roleKey;
  final String teamId;
  final String employeeId;
}
