    final decoded = jsonDecode(raw);
    if (decoded is! List) return const <NotificationEmailQueueRecord>[];
    return decoded
        .whereType<Map>()
        .map((item) => NotificationEmailQueueRecord.fromMap(
              Map<String, dynamic>.from(item),
            ))
        .toList(growable: false);
  }

