    if (request.approvalStatus == FieldSalesRequestApprovalStatus.trimisa) {
      await _dispatchApprovalRequestNotification(request);
    }
    await _load();
  }

  Future<void> _dispatchApprovalRequestNotification(
    FieldSalesRequestRecord request,
  ) async {
    await _notificationService.dispatchEvent(
      NotificationDispatchRequest(
        eventType: NotificationEventType.approvalRequested,
        title: 'Cerere aprobare discount si vanzare din teren',
        message:
            '${request.clientName.trim().isEmpty ? '-' : request.clientName.trim()} | Tip: ${request.requestType.label} | Discount: ${request.requestedDiscountPercent.toStringAsFixed(2)}% | Valoare: ${_money(request.requestedTotalValue, request.currency)}',
        sourceModule: 'field_sales',
        sourceEntityId: request.id,
        sourceLabel: request.clientName.trim().isEmpty
            ? request.requestType.label
            : request.clientName.trim(),
        recipientRoleKeys: const <String>['admin', 'office'],
        recipientUserIds: request.requestedByUserId.trim().isEmpty
            ? const <String>[]
            : <String>[request.requestedByUserId.trim()],
        metadata: <String, dynamic>{
          'approval_status': request.approvalStatus.value,
          'lead_id': request.leadId,
          'discount_percent': request.requestedDiscountPercent,
          'requested_products_count': request.requestedProducts.length,
          'requested_services_count': request.requestedServicePresets.length,
        },
      ),
    );
  }

  Future<void> _submitRequestForApproval(FieldSalesRequestRecord item) async {
    if (item.approvalStatus != FieldSalesRequestApprovalStatus.draft) return;
    final updated = item.copyWith(
      approvalStatus: FieldSalesRequestApprovalStatus.trimisa,
      updatedAt: DateTime.now(),
    );
    await _service.saveRequest(updated);
    await _dispatchApprovalRequestNotification(updated);
    await _load();
  }

  Future<void> _updateRequestStatus(
    FieldSalesRequestRecord item,
    FieldSalesRequestApprovalStatus status,
  ) async {
    final updated = item.copyWith(
      approvalStatus: status,
      approvedByUserId: _currentUserId,
      approvedAt: DateTime.now(),
    );
    await _service.saveRequest(updated);
    await _notificationService.dispatchEvent(
      NotificationDispatchRequest(
        eventType: status == FieldSalesRequestApprovalStatus.aprobata
            ? NotificationEventType.approvalApproved
            : NotificationEventType.approvalRejected,
        title: status == FieldSalesRequestApprovalStatus.aprobata
            ? 'Cerere aprobata'
            : 'Cerere respinsa',
        message:
            '${updated.clientName.trim().isEmpty ? '-' : updated.clientName.trim()} | Tip: ${updated.requestType.label} | Status: ${updated.approvalStatus.label}',
        sourceModule: 'field_sales',
        sourceEntityId: updated.id,
        sourceLabel: updated.clientName.trim().isEmpty
            ? updated.requestType.label
            : updated.clientName.trim(),
        recipientUserIds: updated.requestedByUserId.trim().isEmpty
            ? const <String>[]
            : <String>[updated.requestedByUserId.trim()],
        metadata: <String, dynamic>{
          'approval_status': updated.approvalStatus.value,
          'approved_by_user_id': _currentUserId,
        },
      ),
    );
    await _load();
  }

  @override
  Widget build(BuildContext context) {
    return DefaultTabController(
      length: 3,
      child: Scaffold(
        appBar: AppBar(
          title: const Text('Agent teren / Vanzari'),
          bottom: const TabBar(
            tabs: [
              Tab(text: 'Catalog'),
              Tab(text: 'Lead-uri'),
              Tab(text: 'Cereri'),
            ],
          ),
          actions: [
            TextButton.icon(
              onPressed: _loading ? null : _openFieldSalesAiAssistant,
              icon: const Icon(Icons.auto_awesome_outlined),
              label: const Text('Asistent AI'),
            ),
            IconButton(
              tooltip: 'Client rapid',
              onPressed: _loading ? null : _createQuickClient,
              icon: const Icon(Icons.person_add_alt_1_outlined),
            ),
            IconButton(
              tooltip: 'Lead nou',
              onPressed: _loading ? null : _createLead,
              icon: const Icon(Icons.add_business_outlined),
            ),
            IconButton(
              tooltip: 'Reincarca',
              onPressed: _loading ? null : _load,
              icon: const Icon(Icons.refresh),
            ),
          ],
        ),
        body: _loading
            ? const Center(child: CircularProgressIndicator())
            : Column(
                children: [
                  if (_message != null)
                    Padding(
                      padding: const EdgeInsets.fromLTRB(16, 16, 16, 0),
                      child: Card(
                        child: Padding(
                          padding: const EdgeInsets.all(12),
                          child: Text(_message!),
                        ),
                      ),
                    ),
                  Expanded(
                    child: TabBarView(
                      children: [
                        _buildCatalogTab(context),
                        _buildLeadsTab(context),
                        _buildRequestsTab(context),
                      ],
                    ),
                  ),
                ],
              ),
      ),
    );
  }

  Widget _buildCatalogTab(BuildContext context) {
    final selectedPriceList = _selectedFieldPriceList;
    return Padding(
      padding: const EdgeInsets.all(16),
      child: Column(
        children: [
          Wrap(
            spacing: 12,
            runSpacing: 12,
            children: [
              SizedBox(
                width: 280,
                child: TextField(
                  controller: _catalogSearchController,
                  decoration: const InputDecoration(
                    labelText: 'Cauta produse',
                    prefixIcon: Icon(Icons.search),
                  ),
                ),
              ),
              if (!_restrictToStandardPriceList)
                SizedBox(
                  width: 320,
                  child: DropdownButtonFormField<String>(
                    initialValue: _normalizedSelectedPriceListId.isEmpty
                        ? (_availableFieldPriceLists.isEmpty
                            ? null
                            : _availableFieldPriceLists.first.id)
                        : _normalizedSelectedPriceListId,
                    decoration: const InputDecoration(
                      labelText: 'Lista comerciala',
                    ),
                    items: _availableFieldPriceLists
                        .map(
                          (item) => DropdownMenuItem<String>(
                            value: item.id,
                            child: Text(item.name),
                          ),
                        )
                        .toList(growable: false),
                    onChanged: (value) async {
                      if (value == null) return;
                      setState(() {
                        _selectedPriceListId = value;
                      });
                      await _refreshCatalog();
                    },
                  ),
                )
              else
                Chip(
                  label: Text(
                    selectedPriceList == null
                        ? 'Lista standard indisponibila'
                        : 'Lista standard: ${selectedPriceList.name}',
                  ),
                ),
              Chip(
                label: Text(
                  'Afisare comerciala only: fara costuri interne',
                ),
              ),
              Chip(
                label: Text(
                  _availableFieldPriceLists.isEmpty
                      ? 'Fara lista comerciala activa'
                      : 'Lista activa: ${selectedPriceList?.name ?? _availableFieldPriceLists.first.name}',
                ),
              ),
            ],
          ),
          const SizedBox(height: 16),
          Expanded(
            child: ListView.separated(
              itemCount: _filteredCatalogItems.length,
              separatorBuilder: (_, __) => const SizedBox(height: 10),
              itemBuilder: (context, index) {
                final item = _filteredCatalogItems[index];
                final product = item.product;
                return Card(
                  child: Padding(
                    padding: const EdgeInsets.all(12),
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          product.name,
                          style: Theme.of(context)
                              .textTheme
                              .titleMedium
                              ?.copyWith(fontWeight: FontWeight.w600),
                        ),
                        const SizedBox(height: 6),
                        Text(
                          '${product.category.trim().isEmpty ? '-' : product.category} | ${product.brand.trim().isEmpty ? '-' : product.brand} | ${product.model.trim().isEmpty ? '-' : product.model}',
                        ),
                        if (product.commercialDescription
                            .trim()
                            .isNotEmpty) ...[
                          const SizedBox(height: 6),
                          Text(product.commercialDescription.trim()),
                        ],
                        const SizedBox(height: 8),
                        Wrap(
                          spacing: 8,
                          runSpacing: 8,
                          children: [
                            Chip(
                              label: Text(
                                'Pret: ${item.salePrice > 0 ? _money(item.salePrice, item.currency) : 'Pret indisponibil'}',
                              ),
                            ),
                            Chip(
                              label: Text(
                                item.priceList == null
                                    ? 'Fara lista activa'
                                    : item.hasPriceEntry
                                        ? 'Baza pret: ${item.priceList!.name}'
                                        : 'Fara pret in lista activa',
                              ),
                            ),
                            Chip(
                              label: Text(_stockSummary(item)),
                            ),
                            Chip(
                              label: Text(
                                'Status: ${product.stockStatus.label}',
                              ),
                            ),
                            Chip(
                              label: Text(
                                'Livrare: ${product.deliveryLeadTimeText.trim().isEmpty ? '-' : product.deliveryLeadTimeText.trim()}',
                              ),
                            ),
                            Chip(
                              label: Text(
                                'Imagini ${product.imagePaths.length} | PDF ${product.pdfPaths.length}',
                              ),
                            ),
                            if (product.sku.trim().isNotEmpty)
                              Chip(label: Text('SKU ${product.sku.trim()}')),
                          ],
                        ),
                      ],
                    ),
                  ),
                );
              },
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildLeadsTab(BuildContext context) {
    final leads = _visibleLeads;
    return Padding(
      padding: const EdgeInsets.all(16),
      child: Row(
        children: [
          Expanded(
            flex: 2,
            child: Column(
              children: [
                Row(
                  children: [
                    Expanded(
                      child: TextField(
                        controller: _leadSearchController,
                        decoration: const InputDecoration(
                          labelText: 'Cauta lead-uri',
                          prefixIcon: Icon(Icons.search),
                        ),
                      ),
                    ),
                    const SizedBox(width: 12),
                    FilledButton.icon(
                      onPressed: _createLead,
                      icon: const Icon(Icons.add),
                      label: const Text('Lead nou'),
                    ),
                  ],
                ),
                const SizedBox(height: 12),
                Expanded(
                  child: leads.isEmpty
                      ? const Center(
                          child: Text('Nu exista lead-uri relevante.'))
                      : ListView.separated(
                          itemCount: leads.length,
                          separatorBuilder: (_, __) =>
                              const SizedBox(height: 8),
                          itemBuilder: (context, index) {
                            final item = leads[index];
                            final selected = _selectedLead?.id == item.id;
                            return Card(
                              color: selected
                                  ? Theme.of(context)
                                      .colorScheme
                                      .primaryContainer
                                  : null,
                              child: ListTile(
                                onTap: () {
                                  setState(() {
                                    _selectedLead = item;
                                  });
                                },
                                title: Text(
                                  item.clientName.trim().isEmpty
                                      ? item.contactName
                                      : item.clientName,
                                ),
                                subtitle: Text(
                                  '${item.interestedInType.label} | ${item.status.label}\n${item.phone.trim().isEmpty ? '-' : item.phone}',
                                ),
                                isThreeLine: true,
                              ),
                            );
                          },
                        ),
                ),
              ],
            ),
          ),
          const SizedBox(width: 16),
          Expanded(
            flex: 3,
            child: Card(
              child: Padding(
                padding: const EdgeInsets.all(16),
                child: _selectedLead == null
                    ? const Center(
                        child:
                            Text('Selecteaza un lead pentru actiuni rapide.'),
                      )
                    : _buildLeadDetails(context, _selectedLead!),
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildLeadDetails(BuildContext context, FieldLeadRecord lead) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          lead.clientName.trim().isEmpty ? lead.contactName : lead.clientName,
          style: Theme.of(context)
              .textTheme
              .titleLarge
              ?.copyWith(fontWeight: FontWeight.w600),
        ),
        const SizedBox(height: 8),
        Text(
          'Interes: ${lead.interestedInType.label} | Status: ${lead.status.label}',
        ),
        const SizedBox(height: 6),
        Text(
          'Contact: ${lead.contactName.trim().isEmpty ? '-' : lead.contactName} | Tel: ${lead.phone.trim().isEmpty ? '-' : lead.phone} | Email: ${lead.email.trim().isEmpty ? '-' : lead.email}',
        ),
        const SizedBox(height: 6),
        Text('Adresa: ${lead.address.trim().isEmpty ? '-' : lead.address}'),
        const SizedBox(height: 6),
        Text('Observatii: ${lead.notes.trim().isEmpty ? '-' : lead.notes}'),
        const SizedBox(height: 12),
        Wrap(
          spacing: 8,
          runSpacing: 8,
          children: [
            OutlinedButton.icon(
              onPressed: _createQuickClient,
              icon: const Icon(Icons.person_add_alt_1_outlined),
              label: const Text('Client rapid'),
            ),
            FilledButton.icon(
              onPressed: _createAppointmentFromLead,
              icon: const Icon(Icons.event_available_outlined),
              label: const Text('Programare'),
            ),
            FilledButton.tonalIcon(
              onPressed: _createSalesRequest,
              icon: const Icon(Icons.approval_outlined),
              label: const Text('Mini-oferta / cerere'),
            ),
          ],
        ),
        if (lead.interestedProductIds.isNotEmpty) ...[
          const SizedBox(height: 16),
          Text(
            'Produse de interes: ${lead.interestedProductIds.length}',
            style: Theme.of(context).textTheme.titleSmall,
          ),
        ],
      ],
    );
  }

  Widget _buildRequestsTab(BuildContext context) {
    final rows = _visibleRequests;
    return Padding(
      padding: const EdgeInsets.all(16),
      child: Column(
        children: [
          Row(
            children: [
              FilledButton.icon(
                onPressed: _createSalesRequest,
                icon: const Icon(Icons.add_task_outlined),
                label: const Text('Mini-oferta noua'),
              ),
            ],
          ),
          const SizedBox(height: 12),
          Expanded(
            child: rows.isEmpty
                ? const Center(child: Text('Nu exista cereri inregistrate.'))
                : ListView.separated(
                    itemCount: rows.length,
                    separatorBuilder: (_, __) => const SizedBox(height: 10),
                    itemBuilder: (context, index) {
                      final item = rows[index];
                      final canDecide = _canSeeAll &&
                          item.approvalStatus ==
                              FieldSalesRequestApprovalStatus.trimisa;
                      final canConvert = item.approvalStatus ==
                              FieldSalesRequestApprovalStatus.aprobata &&
                          !item.isConverted;
                      return Card(
                        child: Padding(
                          padding: const EdgeInsets.all(14),
                          child: Column(
                            crossAxisAlignment: CrossAxisAlignment.start,
                            children: [
                              Text(
                                item.clientName.trim().isEmpty
                                    ? item.requestType.label
                                    : item.clientName,
                                style: Theme.of(context)
                                    .textTheme
                                    .titleMedium
                                    ?.copyWith(fontWeight: FontWeight.w600),
                              ),
                              const SizedBox(height: 6),
                              Text(
                                '${item.requestType.label} | ${item.approvalStatus.label} | ${_money(item.requestedTotalValue, item.currency)}',
                              ),
                              const SizedBox(height: 8),
                              Wrap(
                                spacing: 8,
                                runSpacing: 8,
                                children: [
                                  if (item.isConverted)
                                    Chip(
                                      label: Text(
                                        'Convertita: ${item.convertedEntityLabel.trim().isEmpty ? item.convertedEntityType : item.convertedEntityLabel}',
                                      ),
                                    )
                                  else
                                    const Chip(label: Text('Neconvertita')),
                                  if (item.requestedPriceListId
                                      .trim()
                                      .isNotEmpty)
                                    Chip(
                                      label: Text(
                                        'Lista: ${item.requestedPriceListId.trim()}',
                                      ),
                                    ),
                                  if (item.requestedProductIds.isNotEmpty)
                                    Chip(
                                      label: Text(
                                        'Produse: ${item.requestedProductIds.length}',
                                      ),
                                    ),
                                  if (item.requestedServicePresets.isNotEmpty)
                                    Chip(
                                      label: Text(
                                        'Servicii: ${item.requestedServicePresets.length}',
                                      ),
                                    ),
                                  if (item.requestedDiscountPercent > 0)
                                    Chip(
                                      label: Text(
                                        'Discount: ${item.requestedDiscountPercent.toStringAsFixed(2)}%',
                                      ),
                                    ),
                                ],
                              ),
                              const SizedBox(height: 6),
                              Text(
                                'Ceruta de: ${item.requestedByName.trim().isEmpty ? '-' : item.requestedByName} | ${_formatDateTime(item.createdAt)}',
                              ),
                              const SizedBox(height: 10),
                              Wrap(
                                spacing: 8,
                                runSpacing: 8,
                                children: [
                                  FilledButton.tonalIcon(
                                    onPressed: () => _generateRequestPdf(item),
                                    icon: const Icon(
                                      Icons.picture_as_pdf_outlined,
                                    ),
                                    label: const Text('Genereaza PDF'),
                                  ),
                                  OutlinedButton.icon(
                                    onPressed: () => _generateRequestPdf(
                                      item,
                                      saveAs: true,
                                    ),
                                    icon: const Icon(Icons.save_alt_outlined),
                                    label: const Text('Save As'),
                                  ),
                                  OutlinedButton.icon(
                                    onPressed: () => _generateRequestPdf(
                                      item,
                                      share: true,
                                    ),
                                    icon: const Icon(Icons.share_outlined),
                                    label: const Text('Share'),
                                  ),
                                  if (item.generatedDocumentFileName
                                      .trim()
                                      .isNotEmpty)
                                    Chip(
                                      label: Text(
                                        'PDF: ${item.generatedDocumentFileName.trim()}',
                                      ),
                                    ),
                                ],
                              ),
                              if (item.notes.trim().isNotEmpty) ...[
                                const SizedBox(height: 6),
                                Text(item.notes.trim()),
                              ],
                              if (item.approvalStatus ==
                                  FieldSalesRequestApprovalStatus.draft) ...[
                                const SizedBox(height: 10),
                                FilledButton.icon(
                                  onPressed: () =>
                                      _submitRequestForApproval(item),
                                  icon: const Icon(Icons.approval_outlined),
                                  label: const Text('Trimite spre aprobare'),
                                ),
                              ],
                              if (canDecide) ...[
                                const SizedBox(height: 10),
                                Wrap(
                                  spacing: 8,
                                  children: [
                                    FilledButton.tonal(
                                      onPressed: () => _updateRequestStatus(
                                        item,
                                        FieldSalesRequestApprovalStatus
                                            .aprobata,
                                      ),
                                      child: const Text('Aproba'),
                                    ),
                                    OutlinedButton(
                                      onPressed: () => _updateRequestStatus(
                                        item,
                                        FieldSalesRequestApprovalStatus
                                            .respinsa,
                                      ),
                                      child: const Text('Respinge'),
                                    ),
                                  ],
                                ),
                              ],
                              if (canConvert) ...[
                                const SizedBox(height: 10),
                                Wrap(
                                  spacing: 8,
                                  runSpacing: 8,
                                  children: [
                                    if (item.requestType ==
                                            FieldSalesRequestType.programare ||
                                        item.requestType ==
                                            FieldSalesRequestType.serviciu)
                                      FilledButton.icon(
                                        onPressed: () =>
                                            _convertRequestToAppointment(item),
                                        icon: const Icon(
                                          Icons.event_available_outlined,
                                        ),
                                        label: const Text(
                                          'Converteste in programare',
                                        ),
                                      ),
                                    if (item.requestType ==
                                            FieldSalesRequestType.oferta ||
                                        item.requestType ==
                                            FieldSalesRequestType.vanzareProdus)
                                      FilledButton.tonalIcon(
                                        onPressed: () =>
                                            _convertRequestToOffer(item),
                                        icon: const Icon(
                                          Icons.request_quote_outlined,
                                        ),
                                        label:
                                            const Text('Converteste in oferta'),
                                      ),
                                    if (item.requestType ==
                                        FieldSalesRequestType.vanzareProdus)
                                      OutlinedButton.icon(
                                        onPressed: () =>
                                            _convertRequestToSale(item),
                                        icon: const Icon(
                                          Icons.point_of_sale_outlined,
                                        ),
                                        label: const Text(
                                          'Converteste in vanzare / rezervare',
                                        ),
                                      ),
                                  ],
                                ),
                              ],
                              if (item.isConverted) ...[
                                const SizedBox(height: 10),
                                Wrap(
                                  spacing: 8,
                                  children: [
                                    OutlinedButton.icon(
                                      onPressed: () =>
                                          _openConvertedSource(item),
                                      icon: const Icon(Icons.open_in_new),
                                      label: const Text('Deschide sursa'),
                                    ),
                                  ],
                                ),
                              ],
                            ],
                          ),
                        ),
                      );
                    },
                  ),
          ),
        ],
      ),
    );
  }
}

class _FieldLeadDialog extends StatefulWidget {
  const _FieldLeadDialog({
    required this.clients,
    required this.catalogItems,
    required this.currentUserId,
    required this.initialSourceModule,
  });

  final List<ClientRecord> clients;
  final List<FieldCommercialProductView> catalogItems;
  final String currentUserId;
  final String initialSourceModule;

  @override
  State<_FieldLeadDialog> createState() => _FieldLeadDialogState();
}

class _FieldLeadDialogState extends State<_FieldLeadDialog> {
  final _clientNameController = TextEditingController();
  final _contactNameController = TextEditingController();
  final _phoneController = TextEditingController();
  final _emailController = TextEditingController();
  final _addressController = TextEditingController();
  final _notesController = TextEditingController();
  String? _clientId;
  FieldLeadInterestType _interestType = FieldLeadInterestType.produs;
  final Set<String> _selectedProductIds = <String>{};

  @override
  void dispose() {
    _clientNameController.dispose();
    _contactNameController.dispose();
    _phoneController.dispose();
    _emailController.dispose();
    _addressController.dispose();
    _notesController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: const Text('Lead / oportunitate noua'),
      content: SizedBox(
        width: 720,
        child: SingleChildScrollView(
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              DropdownButtonFormField<String?>(
                initialValue: _clientId,
                decoration: const InputDecoration(labelText: 'Client existent'),
                items: [
                  const DropdownMenuItem<String?>(
                    value: null,
                    child: Text('Fara client asociat'),
                  ),
                  ...widget.clients.map(
                    (item) => DropdownMenuItem<String?>(
                      value: item.id,
                      child: Text(item.name),
                    ),
                  ),
                ],
                onChanged: (value) {
                  setState(() {
                    _clientId = value;
                  });
                  if (value == null) return;
                  for (final item in widget.clients) {
                    if (item.id == value) {
                      _clientNameController.text = item.name;
                      _contactNameController.text = item.contactPerson;
                      _phoneController.text = item.phone;
                      _emailController.text = item.email;
                      _addressController.text = item.address;
                      break;
                    }
                  }
                },
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _clientNameController,
                decoration:
                    const InputDecoration(labelText: 'Client / companie'),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _contactNameController,
                decoration:
                    const InputDecoration(labelText: 'Persoana contact'),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _phoneController,
                decoration: const InputDecoration(labelText: 'Telefon'),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _emailController,
                decoration: const InputDecoration(labelText: 'Email'),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _addressController,
                decoration: const InputDecoration(labelText: 'Adresa'),
              ),
              const SizedBox(height: 12),
              DropdownButtonFormField<FieldLeadInterestType>(
                initialValue: _interestType,
                decoration: const InputDecoration(labelText: 'Interes'),
                items: FieldLeadInterestType.values
                    .map(
                      (item) => DropdownMenuItem<FieldLeadInterestType>(
                        value: item,
                        child: Text(item.label),
                      ),
                    )
                    .toList(growable: false),
                onChanged: (value) {
                  if (value == null) return;
                  setState(() {
                    _interestType = value;
                  });
                },
              ),
              if (_interestType == FieldLeadInterestType.produs) ...[
                const SizedBox(height: 12),
                Align(
                  alignment: Alignment.centerLeft,
                  child: Text(
                    'Produse de interes',
                    style: Theme.of(context).textTheme.titleSmall,
                  ),
                ),
                const SizedBox(height: 8),
                Wrap(
                  spacing: 8,
                  runSpacing: 8,
                  children: widget.catalogItems
                      .take(20)
                      .map(
                        (item) => FilterChip(
                          selected:
                              _selectedProductIds.contains(item.product.id),
                          label: Text(item.product.name),
                          onSelected: (selected) {
                            setState(() {
                              if (selected) {
                                _selectedProductIds.add(item.product.id);
                              } else {
                                _selectedProductIds.remove(item.product.id);
                              }
                            });
                          },
                        ),
                      )
                      .toList(growable: false),
                ),
              ],
              const SizedBox(height: 12),
              TextField(
                controller: _notesController,
                minLines: 3,
                maxLines: 4,
                decoration: const InputDecoration(labelText: 'Observatii'),
              ),
            ],
          ),
        ),
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.of(context).pop(),
          child: const Text('Renunță'),
        ),
        FilledButton(
          onPressed: () {
            final now = DateTime.now();
            Navigator.of(context).pop(
              FieldLeadRecord(
                id: 'field-lead-${now.microsecondsSinceEpoch}',
                clientId: (_clientId ?? '').trim(),
                clientName: _clientNameController.text.trim(),
                contactName: _contactNameController.text.trim(),
                phone: _phoneController.text.trim(),
                email: _emailController.text.trim(),
                address: _addressController.text.trim(),
                sourceModule: widget.initialSourceModule,
                sourceEntityId: '',
                sourceLabel: 'Lead teren',
                interestedInType: _interestType,
                interestedProductIds:
                    _selectedProductIds.toList(growable: false),
                notes: _notesController.text.trim(),
                status: FieldLeadStatus.nou,
                assignedUserId: widget.currentUserId.trim(),
                createdByUserId: widget.currentUserId.trim(),
                createdAt: now,
                updatedAt: now,
              ),
            );
          },
          child: const Text('Salveaza lead'),
        ),
      ],
    );
  }
}

class _QuickClientDialog extends StatefulWidget {
  const _QuickClientDialog({
    required this.repository,
    this.existingLead,
  });

  final AppDataRepository repository;
  final FieldLeadRecord? existingLead;

  @override
  State<_QuickClientDialog> createState() => _QuickClientDialogState();
}

class _QuickClientDialogState extends State<_QuickClientDialog> {
  late final TextEditingController _nameController = TextEditingController(
    text: widget.existingLead?.clientName ?? '',
  );
  late final TextEditingController _contactController = TextEditingController(
    text: widget.existingLead?.contactName ?? '',
  );
  late final TextEditingController _phoneController = TextEditingController(
    text: widget.existingLead?.phone ?? '',
  );
  late final TextEditingController _emailController = TextEditingController(
    text: widget.existingLead?.email ?? '',
  );
  late final TextEditingController _addressController = TextEditingController(
    text: widget.existingLead?.address ?? '',
  );
  final TextEditingController _cityController = TextEditingController();
  final TextEditingController _countyController = TextEditingController();
  late final TextEditingController _notesController = TextEditingController(
    text: widget.existingLead?.notes ?? '',
  );

  @override
  void dispose() {
    _nameController.dispose();
    _contactController.dispose();
    _phoneController.dispose();
    _emailController.dispose();
    _addressController.dispose();
    _cityController.dispose();
    _countyController.dispose();
    _notesController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: const Text('Client rapid'),
      content: SizedBox(
        width: 620,
        child: SingleChildScrollView(
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              TextField(
                controller: _nameController,
                decoration: const InputDecoration(labelText: 'Nume client'),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _contactController,
                decoration:
                    const InputDecoration(labelText: 'Persoana contact'),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _phoneController,
                decoration: const InputDecoration(labelText: 'Telefon'),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _emailController,
                decoration: const InputDecoration(labelText: 'Email'),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _addressController,
                decoration: const InputDecoration(labelText: 'Adresa'),
              ),
              const SizedBox(height: 12),
              Row(
                children: [
                  Expanded(
                    child: TextField(
                      controller: _cityController,
                      decoration: const InputDecoration(labelText: 'Oras'),
                    ),
                  ),
                  const SizedBox(width: 12),
                  Expanded(
                    child: TextField(
                      controller: _countyController,
                      decoration: const InputDecoration(labelText: 'Judet'),
                    ),
                  ),
                ],
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _notesController,
                minLines: 2,
                maxLines: 3,
                decoration: const InputDecoration(labelText: 'Observatii'),
              ),
            ],
          ),
        ),
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.of(context).pop(),
          child: const Text('Renunță'),
        ),
        FilledButton(
          onPressed: () async {
            final code = await widget.repository.nextClientCode();
            final now = DateTime.now();
            if (!context.mounted) return;
            Navigator.of(context).pop(
              ClientRecord(
                id: 'field-client-${now.microsecondsSinceEpoch}',
                clientCode: code,
                type: ClientType.persoanaFizica,
                name: _nameController.text.trim(),
                contactPerson: _contactController.text.trim(),
                phone: _phoneController.text.trim(),
                email: _emailController.text.trim(),
                address: _addressController.text.trim(),
                city: _cityController.text.trim(),
                county: _countyController.text.trim(),
                notes: _notesController.text.trim(),
                isActive: true,
                createdAt: now,
                updatedAt: now,
              ),
            );
          },
          child: const Text('Salveaza client'),
        ),
      ],
    );
  }
}

class _FieldAppointmentDialog extends StatefulWidget {
  const _FieldAppointmentDialog({
    required this.lead,
    required this.currentUserId,
    required this.currentUserEmail,
    required this.currentTeamId,
  });

  final FieldLeadRecord lead;
  final String currentUserId;
  final String currentUserEmail;
  final String currentTeamId;

  @override
  State<_FieldAppointmentDialog> createState() =>
      _FieldAppointmentDialogState();
}

class _FieldAppointmentDialogState extends State<_FieldAppointmentDialog> {
  late DateTime _start = DateTime.now().add(const Duration(days: 1));
  late DateTime _end = _start.add(const Duration(hours: 1));
  late final TextEditingController _titleController = TextEditingController(
    text: widget.lead.interestedInType == FieldLeadInterestType.programare
        ? 'Programare teren'
        : 'Vizita comerciala',
  );
  late final TextEditingController _notesController = TextEditingController(
    text: widget.lead.notes,
  );

  @override
  void dispose() {
    _titleController.dispose();
    _notesController.dispose();
    super.dispose();
  }

  String _timeLabel(DateTime value) =>
      '${value.hour.toString().padLeft(2, '0')}:${value.minute.toString().padLeft(2, '0')}';

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: const Text('Programare din teren'),
      content: SizedBox(
        width: 520,
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            TextField(
              controller: _titleController,
              decoration: const InputDecoration(labelText: 'Motiv / scop'),
            ),
            const SizedBox(height: 12),
            ListTile(
              contentPadding: EdgeInsets.zero,
              title: const Text('Data si ora start'),
              subtitle: Text(_start.toString()),
              trailing: const Icon(Icons.event_outlined),
              onTap: () async {
                final pickedDate = await showDatePicker(
                  context: context,
                  initialDate: _start,
                  firstDate: DateTime.now().subtract(const Duration(days: 1)),
                  lastDate: DateTime.now().add(const Duration(days: 365)),
                );
                if (pickedDate == null || !context.mounted) return;
                final pickedTime = await showTimePicker(
                  context: context,
                  initialTime: TimeOfDay.fromDateTime(_start),
                );
                if (pickedTime == null) return;
                setState(() {
                  _start = DateTime(
                    pickedDate.year,
                    pickedDate.month,
                    pickedDate.day,
                    pickedTime.hour,
                    pickedTime.minute,
                  );
                  if (!_end.isAfter(_start)) {
                    _end = _start.add(const Duration(hours: 1));
                  }
                });
              },
            ),
            ListTile(
              contentPadding: EdgeInsets.zero,
              title: const Text('Data si ora final'),
              subtitle: Text(_end.toString()),
              trailing: const Icon(Icons.schedule_outlined),
              onTap: () async {
                final pickedDate = await showDatePicker(
                  context: context,
                  initialDate: _end,
                  firstDate: _start,
                  lastDate: DateTime.now().add(const Duration(days: 365)),
                );
                if (pickedDate == null || !context.mounted) return;
                final pickedTime = await showTimePicker(
                  context: context,
                  initialTime: TimeOfDay.fromDateTime(_end),
                );
                if (pickedTime == null) return;
                setState(() {
                  _end = DateTime(
                    pickedDate.year,
                    pickedDate.month,
                    pickedDate.day,
                    pickedTime.hour,
                    pickedTime.minute,
                  );
                });
              },
            ),
            const SizedBox(height: 12),
            TextField(
              controller: _notesController,
              minLines: 2,
              maxLines: 4,
              decoration: const InputDecoration(labelText: 'Observatii'),
            ),
          ],
        ),
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.of(context).pop(),
          child: const Text('Renunță'),
        ),
        FilledButton(
          onPressed: () {
            final lead = widget.lead;
            final clientId = lead.clientId.trim();
            Navigator.of(context).pop(
              Appointment(
                id: 'field-appointment-${DateTime.now().microsecondsSinceEpoch}',
                clientId: clientId,
                clientName: lead.clientName.trim(),
                contactPerson: lead.contactName.trim(),
                contactPhone: lead.phone.trim(),
                contactEmail: lead.email.trim(),
                title: _titleController.text.trim(),
                location: lead.address.trim(),
                scheduledDate: DateTime(_start.year, _start.month, _start.day),
                startTime: _timeLabel(_start),
                endTime: _timeLabel(_end),
                startDateTime: _start,
                endDateTime: _end,
                type: 'field_sales',
                priority: 'normala',
                status: 'planificata',
                teamId: widget.currentTeamId.trim(),
                assignedTeamIds: widget.currentTeamId.trim().isEmpty
                    ? const <String>[]
                    : <String>[widget.currentTeamId.trim()],
                assignedUserId: widget.currentUserId.trim(),
                assignedUserEmail: widget.currentUserEmail.trim(),
                notes: _notesController.text.trim(),
              ),
            );
          },
          child: const Text('Creeaza programarea'),
        ),
      ],
    );
  }
}

class _FieldSalesRequestDialog extends StatefulWidget {
  const _FieldSalesRequestDialog({
    required this.repository,
    required this.fieldSalesService,
    required this.lead,
    required this.catalogItems,
    required this.priceLists,
    required this.initialPriceListId,
    required this.restrictToStandardOnly,
    required this.currentUserId,
    required this.currentUserName,
  });

  final AppDataRepository repository;
  final FieldSalesService fieldSalesService;
  final FieldLeadRecord? lead;
  final List<FieldCommercialProductView> catalogItems;
  final List<PriceListRecord> priceLists;
  final String initialPriceListId;
  final bool restrictToStandardOnly;
  final String currentUserId;
  final String currentUserName;

  @override
  State<_FieldSalesRequestDialog> createState() =>
      _FieldSalesRequestDialogState();
}

class _FieldSalesRequestDialogState extends State<_FieldSalesRequestDialog> {
  AiAssistantService get _aiAssistantService =>
      AiAssistantService(repository: widget.repository);
  final OfferStandardCatalogService _laborTemplateService =
      OfferStandardCatalogService();
  final TextEditingController _searchController = TextEditingController();
  final TextEditingController _notesController = TextEditingController();
  String? _selectedPriceListId;
  List<FieldCommercialProductView> _catalogItems =
      const <FieldCommercialProductView>[];
  List<OfferLaborTemplate> _laborTemplates = const <OfferLaborTemplate>[];
  final List<FieldSalesProductSelection> _selectedProducts =
      <FieldSalesProductSelection>[];
  final List<FieldSalesServicePresetSelection> _selectedServices =
      <FieldSalesServicePresetSelection>[];
  double _discountPercent = 0;
  bool _catalogLoading = false;
  bool _laborTemplatesLoading = false;

  @override
  void initState() {
    super.initState();
    _catalogItems = widget.catalogItems;
    if (widget.initialPriceListId.trim().isNotEmpty) {
      _selectedPriceListId = widget.initialPriceListId.trim();
    } else if (widget.priceLists.isNotEmpty) {
      _selectedPriceListId = widget.priceLists.first.id;
    }
    final normalizedPriceListId =
        widget.fieldSalesService.normalizeRequestedPriceListId(
      _selectedPriceListId ?? '',
      widget.priceLists,
      restrictToStandardOnly: widget.restrictToStandardOnly,
    );
    _selectedPriceListId = normalizedPriceListId.isEmpty
        ? (widget.priceLists.isEmpty ? null : widget.priceLists.first.id)
        : normalizedPriceListId;
    _loadLaborTemplates();
  }

  @override
  void dispose() {
    _searchController.dispose();
    _notesController.dispose();
    super.dispose();
  }

  List<FieldCommercialProductView> get _filteredCatalogItems {
    final query = _searchController.text.trim().toLowerCase();
    if (query.isEmpty) {
      return _catalogItems;
    }
    return _catalogItems.where((item) {
      final product = item.product;
      return product.name.toLowerCase().contains(query) ||
          product.brand.toLowerCase().contains(query) ||
          product.model.toLowerCase().contains(query) ||
          product.sku.toLowerCase().contains(query) ||
          product.category.toLowerCase().contains(query);
    }).toList(growable: false);
  }

  List<OfferLaborTemplate> get _activeLaborTemplates {
    final items = _laborTemplates.where((item) => item.isActive).toList();
    items.sort((a, b) {
      final categoryCompare = a.category.toLowerCase().compareTo(
            b.category.toLowerCase(),
          );
      if (categoryCompare != 0) return categoryCompare;
      return a.name.toLowerCase().compareTo(b.name.toLowerCase());
    });
    return items;
  }

  List<OfferLaborTemplate> get _visibleLaborTemplates {
    final active = _activeLaborTemplates;
    if (active.isNotEmpty) {
      return active;
    }
    final fallback = _laborTemplateService
        .recommendedLaborTemplates()
        .where((item) => item.isActive)
        .toList(growable: false);
    return [...fallback]..sort((a, b) {
        final categoryCompare = a.category.toLowerCase().compareTo(
              b.category.toLowerCase(),
            );
        if (categoryCompare != 0) return categoryCompare;
        return a.name.toLowerCase().compareTo(b.name.toLowerCase());
      });
  }

  List<String> get _serviceCategories {
    final values = <String>{
      'montaj',
      'traseu_frigorific',
      'pif',
      'servicii_baza',
    };
    for (final item in _visibleLaborTemplates) {
      final category = item.category.trim();
      if (category.isNotEmpty) {
        values.add(category);
      }
    }
    return values.toList(growable: false)..sort();
  }

  String _serviceCategoryLabel(String raw) {
    switch (raw.trim().toLowerCase()) {
      case 'montaj':
        return 'Montaj';
      case 'traseu_frigorific':
        return 'Traseu frigorific';
      case 'pif':
      case 'punere_in_functiune':
        return 'PIF';
      case 'servicii_baza':
        return 'Alte servicii de baza';
      default:
        return raw.trim().isEmpty ? 'Altele' : raw.trim();
    }
  }

  List<String> _suggestionTokens(String raw) {
    return raw
        .split(RegExp(r'[;,\n]+'))
        .map((item) => item.trim().toLowerCase())
        .where((item) => item.isNotEmpty)
        .toList(growable: false);
  }

  String get _selectedProductsSuggestionText {
    final parts = <String>[];
    for (final selection in _selectedProducts) {
      parts.add(selection.productName.toLowerCase());
      final row = _catalogItems
          .where((item) => item.product.id == selection.productId)
          .cast<FieldCommercialProductView?>()
          .firstWhere((_) => true, orElse: () => null);
      if (row == null) continue;
      parts.add(row.product.brand.toLowerCase());
      parts.add(row.product.model.toLowerCase());
      parts.add(row.product.category.toLowerCase());
      parts.add(row.product.commercialDescription.toLowerCase());
      parts.add(row.product.description.toLowerCase());
    }
    return parts.where((item) => item.trim().isNotEmpty).join(' ');
  }

  bool _isTemplateSuggested(OfferLaborTemplate template) {
    final tokens = _suggestionTokens(template.suggestedProductKeywords);
    if (tokens.isEmpty) return false;
    final haystack = _selectedProductsSuggestionText;
    if (haystack.trim().isEmpty) return false;
    return tokens.any(haystack.contains);
  }

  List<OfferLaborTemplate> get _suggestedTemplates {
    final items = _visibleLaborTemplates
        .where(_isTemplateSuggested)
        .toList(growable: false);
    return items;
  }

  List<OfferLaborTemplate> _templatesForCategory(String category) {
    final normalized = category.trim().toLowerCase();
    return _visibleLaborTemplates.where((item) {
      return item.category.trim().toLowerCase() == normalized;
    }).toList(growable: false);
  }

  Future<void> _loadLaborTemplates() async {
    setState(() => _laborTemplatesLoading = true);
    final items = await _laborTemplateService.listLaborTemplates();
    if (!mounted) return;
    setState(() {
      _laborTemplates = items;
      _laborTemplatesLoading = false;
    });
  }

  Future<void> _openLaborTemplatesManager() async {
    final saved = await showDialog<bool>(
      context: context,
      builder: (context) => _FieldSalesLaborTemplatesDialog(
        items: _laborTemplates,
        onSave: (item) => _laborTemplateService.upsertLaborTemplate(item),
        onImportRecommended: () =>
            _laborTemplateService.mergeRecommendedLaborTemplates(),
      ),
    );
    if (saved != true) {
      return;
    }
    await _loadLaborTemplates();
    if (!mounted) {
      return;
    }
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Text('Catalogul de manopera standard a fost actualizat.'),
      ),
    );
  }

  double get _productsSubtotal =>
      _selectedProducts.fold<double>(0, (sum, item) => sum + item.lineTotal);

  double get _servicesSubtotal =>
      _selectedServices.fold<double>(0, (sum, item) => sum + item.lineTotal);

  double get _subtotal => _productsSubtotal + _servicesSubtotal;

  double get _discountValue => _subtotal * (_discountPercent / 100);

  double get _total => _subtotal - _discountValue;

  PriceListRecord? get _selectedPriceListRecord {
    final id = widget.fieldSalesService.normalizeRequestedPriceListId(
      (_selectedPriceListId ?? '').trim(),
      widget.priceLists,
      restrictToStandardOnly: widget.restrictToStandardOnly,
    );
    if (id.isEmpty) return null;
    for (final item in widget.priceLists) {
      if (item.id == id) return item;
    }
    return null;
  }

  Future<void> _refreshDialogCatalog() async {
    setState(() => _catalogLoading = true);
    final items = await widget.fieldSalesService.buildCommercialCatalog(
      priceListId: widget.fieldSalesService.normalizeRequestedPriceListId(
        (_selectedPriceListId ?? '').trim(),
        widget.priceLists,
        restrictToStandardOnly: widget.restrictToStandardOnly,
      ),
      restrictToStandardOnly: widget.restrictToStandardOnly,
    );
    if (!mounted) return;
    final indexed = <String, FieldCommercialProductView>{
      for (final item in items) item.product.id: item,
    };
    setState(() {
      _selectedPriceListId =
          widget.fieldSalesService.normalizeRequestedPriceListId(
        (_selectedPriceListId ?? '').trim(),
        widget.priceLists,
        restrictToStandardOnly: widget.restrictToStandardOnly,
      );
      _catalogItems = items;
      for (var index = 0; index < _selectedProducts.length; index++) {
        final current = indexed[_selectedProducts[index].productId];
        if (current == null) continue;
        _selectedProducts[index] = _selectedProducts[index].copyWith(
          productName: current.product.name,
          unitPrice: current.salePrice,
          currency: current.currency,
        );
      }
      _catalogLoading = false;
    });
  }

  AiAssistantRuntimeContext _buildFieldSalesAiContext() {
    final lead = widget.lead;
    final selectedCatalogRows = _catalogItems.where((item) {
      return _selectedProducts.any((row) => row.productId == item.product.id);
    }).toList(growable: false);
    final productsPayload = (selectedCatalogRows.isEmpty
            ? _catalogItems.take(6).toList(growable: false)
            : selectedCatalogRows)
        .map(
          (item) => <String, dynamic>{
            ...item.product.toMap(),
            'sale_price': item.salePrice,
            'currency': item.currency,
            'available_stock_quantity': item.availableStockQuantity,
            'price_list_name': item.priceList?.name ?? '',
            'has_price_entry': item.hasPriceEntry,
          },
        )
        .toList(growable: false);
    return AiAssistantRuntimeContext(
      contextType: AiAssistantContextType.fieldSales,
      module: 'field_sales',
      entityId: lead?.id ?? 'field-sales-request-draft',
      entityLabel: lead?.clientName.trim().isNotEmpty == true
          ? lead!.clientName.trim()
          : 'Mini-oferta rapida',
      userId: widget.currentUserId,
      contextLabel: lead == null
          ? 'Agent teren / cerere rapida'
          : 'Agent teren / lead ${lead.clientName.trim().isEmpty ? lead.contactName : lead.clientName}',
      primaryData: <String, dynamic>{
        'type': 'field_sales_request',
        'lead_id': lead?.id ?? '',
        'client_name': lead?.clientName ?? '',
        'contact_name': lead?.contactName ?? '',
        'phone': lead?.phone ?? '',
        'email': lead?.email ?? '',
        'address': lead?.address ?? '',
        'notes': _notesController.text.trim(),
        'selected_price_list_id':
            widget.fieldSalesService.normalizeRequestedPriceListId(
          (_selectedPriceListId ?? '').trim(),
          widget.priceLists,
          restrictToStandardOnly: widget.restrictToStandardOnly,
        ),
        'selected_price_list_name': _selectedPriceListRecord?.name ?? '',
        'requested_products': _selectedProducts
            .map((item) => item.toMap())
            .toList(growable: false),
        'requested_services': _selectedServices
            .map((item) => item.toMap())
            .toList(growable: false),
        'requested_subtotal_value': _subtotal,
        'requested_discount_percent': _discountPercent,
        'requested_discount_value': _discountValue,
        'requested_total_value': _total,
        'currency': _requestCurrency,
      },
      relatedData: <String, dynamic>{
        'field_sales_request': <String, dynamic>{
          'lead_id': lead?.id ?? '',
          'client_name': lead?.clientName ?? '',
          'requested_products': _selectedProducts
              .map((item) => item.toMap())
              .toList(growable: false),
          'requested_services': _selectedServices
              .map((item) => item.toMap())
              .toList(growable: false),
          'requested_total_value': _total,
          'currency': _requestCurrency,
        },
        'lead': lead?.toMap() ?? <String, dynamic>{},
        'client': <String, dynamic>{
          'client_name': lead?.clientName ?? '',
          'contact_name': lead?.contactName ?? '',
          'phone': lead?.phone ?? '',
          'email': lead?.email ?? '',
        },
        'products': productsPayload,
      },
      insertionTargets: const <AiAssistantInsertionTarget>[
        AiAssistantInsertionTarget(
          key: 'field_sales_request_notes',
          label: 'Observatii cerere',
          description: 'Insereaza draftul in observatiile mini-ofertei.',
          insertMode: AiAssistantInsertMode.replace,
        ),
      ],
    );
  }

  Future<void> _openFieldSalesAiAssistant() async {
    await AiAssistantSheet.show(
      context: context,
      title: 'Asistent AI agent teren',
      service: _aiAssistantService,
      runtimeContext: _buildFieldSalesAiContext(),
      actions: AiAssistantActionCatalog.actionsFor(
        AiAssistantContextType.fieldSales,
      ),
      onInsertDraft: _applyFieldSalesAiDraft,
    );
  }

  Future<bool> _applyFieldSalesAiDraft(String targetKey, String content) async {
    if (targetKey != 'field_sales_request_notes') return false;
    setState(() {
      _notesController.text = content.trim();
    });
    return true;
  }

  String get _requestCurrency {
    final values = _selectedProducts
        .map((item) => item.currency.trim())
        .where((item) => item.isNotEmpty)
        .toSet();
    if (values.length == 1) return values.first;
    return 'RON';
  }

  FieldSalesRequestType get _resolvedRequestType {
    if (_selectedProducts.isNotEmpty) {
      return FieldSalesRequestType.vanzareProdus;
    }
    return FieldSalesRequestType.oferta;
  }

  void _toggleProduct(FieldCommercialProductView item, bool selected) {
    setState(() {
      _selectedProducts.removeWhere((row) => row.productId == item.product.id);
      if (selected) {
        _selectedProducts.add(
          FieldSalesProductSelection(
            productId: item.product.id,
            productName: item.product.name,
            quantity: 1,
            unitPrice: item.salePrice,
            currency: item.currency,
          ),
        );
      }
    });
  }

  void _toggleServicePreset(
    OfferLaborTemplate preset,
    bool selected,
  ) {
    setState(() {
      final selectionCode = preset.id.trim().isEmpty
          ? preset.name.trim().toLowerCase()
          : preset.id.trim();
      _selectedServices.removeWhere((row) => row.code == selectionCode);
      if (selected) {
        _selectedServices.add(
          FieldSalesServicePresetSelection(
            code: selectionCode,
            label: preset.name.trim().isEmpty ? 'Serviciu' : preset.name.trim(),
            category: preset.category.trim(),
            laborTemplateId: preset.id.trim(),
            unit: preset.unit.trim().isEmpty ? 'serv' : preset.unit.trim(),
            quantity: preset.defaultQuantity <= 0 ? 1 : preset.defaultQuantity,
            unitPrice:
                preset.defaultUnitPrice < 0 ? 0 : preset.defaultUnitPrice,
            currency: 'RON',
            notes: preset.notes.trim(),
            includedServices: preset.includedServices.trim(),
          ),
        );
      }
    });
  }

  Future<void> _editProductSelection(
      FieldSalesProductSelection selection) async {
    final quantityController = TextEditingController(
      text: selection.quantity.toStringAsFixed(2),
    );
    try {
      final saved = await showDialog<FieldSalesProductSelection>(
        context: context,
        builder: (context) => AlertDialog(
          title: Text(selection.productName),
          content: SizedBox(
            width: 420,
            child: TextField(
              controller: quantityController,
              keyboardType:
                  const TextInputType.numberWithOptions(decimal: true),
              decoration: const InputDecoration(labelText: 'Cantitate'),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('Renunță'),
            ),
            FilledButton(
              onPressed: () {
                final quantity = double.tryParse(
                      quantityController.text.trim().replaceAll(',', '.'),
                    ) ??
                    selection.quantity;
                Navigator.of(context).pop(
                  selection.copyWith(quantity: quantity <= 0 ? 1 : quantity),
                );
              },
              child: const Text('Salveaza'),
            ),
          ],
        ),
      );
      if (saved == null) return;
      setState(() {
        final index = _selectedProducts.indexWhere(
          (item) => item.productId == saved.productId,
        );
        if (index >= 0) {
          _selectedProducts[index] = saved;
        }
      });
    } finally {
      quantityController.dispose();
    }
  }

  Future<void> _editServiceSelection(
    FieldSalesServicePresetSelection selection,
  ) async {
    final isManualService = selection.laborTemplateId.trim().isEmpty;
    final labelController = TextEditingController(text: selection.label);
    final unitController = TextEditingController(text: selection.unit);
    final quantityController = TextEditingController(
      text: selection.quantity.toStringAsFixed(2),
    );
    final unitPriceController = TextEditingController(
      text: selection.unitPrice.toStringAsFixed(2),
    );
    final notesController = TextEditingController(text: selection.notes);
    try {
      final saved = await showDialog<FieldSalesServicePresetSelection>(
        context: context,
        builder: (context) => AlertDialog(
          title: Text(
            isManualService ? 'Serviciu prestat' : selection.label,
          ),
          content: SizedBox(
            width: 480,
            child: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                if (isManualService) ...[
                  TextField(
                    controller: labelController,
                    decoration: const InputDecoration(
                      labelText: 'Denumire serviciu',
                    ),
                  ),
                  const SizedBox(height: 12),
                  TextField(
                    controller: unitController,
                    decoration: const InputDecoration(
                      labelText: 'UM',
                      helperText: 'Ex: serv, ora, buc',
                    ),
                  ),
                  const SizedBox(height: 12),
                ],
                if (selection.category.trim().isNotEmpty)
                  Align(
                    alignment: Alignment.centerLeft,
                    child: Padding(
                      padding: const EdgeInsets.only(bottom: 8),
                      child: Text(
                        'Categorie: ${_serviceCategoryLabel(selection.category)}',
                      ),
                    ),
                  ),
                if (selection.includedServices.trim().isNotEmpty)
                  Align(
                    alignment: Alignment.centerLeft,
                    child: Padding(
                      padding: const EdgeInsets.only(bottom: 8),
                      child: Text(
                        'Inclus: ${selection.includedServices.trim()}',
                      ),
                    ),
                  ),
                if (selection.notes.trim().isNotEmpty)
                  Align(
                    alignment: Alignment.centerLeft,
                    child: Padding(
                      padding: const EdgeInsets.only(bottom: 8),
                      child: Text(
                        'Conditii comerciale: ${selection.notes.trim()}',
                      ),
                    ),
                  ),
                TextField(
                  controller: quantityController,
                  keyboardType:
                      const TextInputType.numberWithOptions(decimal: true),
                  decoration: const InputDecoration(labelText: 'Cantitate'),
                ),
                const SizedBox(height: 12),
                if (isManualService)
                  TextField(
                    controller: unitPriceController,
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                    decoration: const InputDecoration(
                      labelText: 'Pret unitar',
                    ),
                  )
                else
                  TextField(
                    controller: TextEditingController(
                      text:
                          '${selection.unitPrice.toStringAsFixed(2)} ${selection.currency}',
                    ),
                    enabled: false,
                    decoration: const InputDecoration(
                      labelText: 'Pret unitar presetat',
                    ),
                  ),
                if (isManualService) ...[
                  const SizedBox(height: 12),
                  TextField(
                    controller: notesController,
                    minLines: 2,
                    maxLines: 4,
                    decoration: const InputDecoration(
                      labelText: 'Detalii serviciu',
                    ),
                  ),
                ],
              ],
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('Renunță'),
            ),
            FilledButton(
              onPressed: () {
                final label = labelController.text.trim();
                final quantity = double.tryParse(
                      quantityController.text.trim().replaceAll(',', '.'),
                    ) ??
                    selection.quantity;
                final unitPrice = double.tryParse(
                      unitPriceController.text.trim().replaceAll(',', '.'),
                    ) ??
                    selection.unitPrice;
                Navigator.of(context).pop(
                  selection.copyWith(
                    label: isManualService && label.isNotEmpty
                        ? label
                        : selection.label,
                    unit:
                        isManualService && unitController.text.trim().isNotEmpty
                            ? unitController.text.trim()
                            : selection.unit,
                    quantity: quantity <= 0 ? 1 : quantity,
                    unitPrice: isManualService && unitPrice >= 0
                        ? unitPrice
                        : selection.unitPrice,
                    notes: isManualService
                        ? notesController.text.trim()
                        : selection.notes,
                  ),
                );
              },
              child: const Text('Salveaza'),
            ),
          ],
        ),
      );
      if (saved == null) return;
      setState(() {
        final index = _selectedServices.indexWhere(
          (item) => item.code == saved.code,
        );
        if (index >= 0) {
          _selectedServices[index] = saved;
        }
      });
    } finally {
      labelController.dispose();
      unitController.dispose();
      quantityController.dispose();
      unitPriceController.dispose();
      notesController.dispose();
    }
  }

  void _upsertServiceSelection(FieldSalesServicePresetSelection selection) {
    setState(() {
      final index = _selectedServices.indexWhere(
        (item) => item.code == selection.code,
      );
      if (index >= 0) {
        _selectedServices[index] = selection;
      } else {
        _selectedServices.add(selection);
      }
    });
  }

  Future<void> _openManualServiceEditor() async {
    final now = DateTime.now();
    final draft = FieldSalesServicePresetSelection(
      code: 'manual-service-${now.microsecondsSinceEpoch}',
      label: 'Serviciu prestat',
      category: 'manual',
      unit: 'serv',
      quantity: 1,
      unitPrice: 0,
      currency: _requestCurrency,
    );
    final labelController = TextEditingController(text: draft.label);
    final unitController = TextEditingController(text: draft.unit);
    final quantityController = TextEditingController(
      text: draft.quantity.toStringAsFixed(2),
    );
    final unitPriceController = TextEditingController(
      text: draft.unitPrice.toStringAsFixed(2),
    );
    final notesController = TextEditingController();
    try {
      final saved = await showDialog<FieldSalesServicePresetSelection>(
        context: context,
        builder: (context) => AlertDialog(
          title: const Text('Adauga serviciu prestat'),
          content: SizedBox(
            width: 480,
            child: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                TextField(
                  controller: labelController,
                  decoration: const InputDecoration(
                    labelText: 'Denumire serviciu',
                  ),
                ),
                const SizedBox(height: 12),
                TextField(
                  controller: unitController,
                  decoration: const InputDecoration(
                    labelText: 'UM',
                    helperText: 'Ex: serv, ora, buc',
                  ),
                ),
                const SizedBox(height: 12),
                TextField(
                  controller: quantityController,
                  keyboardType:
                      const TextInputType.numberWithOptions(decimal: true),
                  decoration: const InputDecoration(labelText: 'Cantitate'),
                ),
                const SizedBox(height: 12),
                TextField(
                  controller: unitPriceController,
                  keyboardType:
                      const TextInputType.numberWithOptions(decimal: true),
                  decoration: const InputDecoration(labelText: 'Pret unitar'),
                ),
                const SizedBox(height: 12),
                TextField(
                  controller: notesController,
                  minLines: 2,
                  maxLines: 4,
                  decoration: const InputDecoration(
                    labelText: 'Detalii serviciu',
                  ),
                ),
              ],
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('Renunță'),
            ),
            FilledButton(
              onPressed: () {
                final label = labelController.text.trim();
                if (label.isEmpty) {
                  return;
                }
                final quantity = double.tryParse(
                      quantityController.text.trim().replaceAll(',', '.'),
                    ) ??
                    1;
                final unitPrice = double.tryParse(
                      unitPriceController.text.trim().replaceAll(',', '.'),
                    ) ??
                    0;
                Navigator.of(context).pop(
                  draft.copyWith(
                    label: label,
                    unit: unitController.text.trim().isEmpty
                        ? 'serv'
                        : unitController.text.trim(),
                    quantity: quantity <= 0 ? 1 : quantity,
                    unitPrice: unitPrice < 0 ? 0 : unitPrice,
                    notes: notesController.text.trim(),
                  ),
                );
              },
              child: const Text('Adauga'),
            ),
          ],
        ),
      );
      if (saved == null) {
        return;
      }
      _upsertServiceSelection(saved);
    } finally {
      labelController.dispose();
      unitController.dispose();
      quantityController.dispose();
      unitPriceController.dispose();
      notesController.dispose();
    }
  }

  void _removeServiceSelection(String code) {
    setState(() {
      _selectedServices.removeWhere((item) => item.code == code);
    });
  }

  Widget _buildServiceTemplateChip(OfferLaborTemplate template) {
    final selectionCode = template.id.trim().isEmpty
        ? template.name.trim().toLowerCase()
        : template.id.trim();
    final selected =
        _selectedServices.any((item) => item.code == selectionCode);
    final priceLabel =
        '${template.defaultUnitPrice.toStringAsFixed(2)} RON/${template.unit.trim().isEmpty ? 'serv' : template.unit.trim()}';
    return FilterChip(
      selected: selected,
      label: Text('${template.name} • $priceLabel'),
      tooltip: [
        if (template.description.trim().isNotEmpty) template.description.trim(),
        if (template.includedServices.trim().isNotEmpty)
          'Inclus: ${template.includedServices.trim()}',
        if (template.notes.trim().isNotEmpty)
          'Conditii: ${template.notes.trim()}',
      ].join('\n'),
      onSelected: (value) {
        _toggleServicePreset(template, value);
        if (value) {
          final current = _selectedServices.firstWhere(
            (item) => item.code == selectionCode,
          );
          _editServiceSelection(current);
        }
      },
    );
  }

  @override
  Widget build(BuildContext context) {
    final lead = widget.lead;
    final viewportSize = MediaQuery.sizeOf(context);
    final dialogContentHeight = math.min(viewportSize.height * 0.78, 760.0);
    final dialogContentWidth = math.min(viewportSize.width * 0.96, 920.0);
    final productListHeight = math.max(
      180.0,
      math.min(dialogContentHeight * 0.34, 320.0),
    );
    final priceListControl = widget.priceLists.isEmpty
        ? Card(
            margin: EdgeInsets.zero,
            color: Theme.of(context).colorScheme.errorContainer,
            child: const Padding(
              padding: EdgeInsets.all(12),
              child: Text(
                'Nu exista lista comerciala activa. Fluxul nu este blocat, dar produsele fara pret configurat vor aparea explicit ca Pret indisponibil.',
              ),
            ),
          )
        : widget.restrictToStandardOnly
            ? Align(
                alignment: Alignment.centerLeft,
                child: Chip(
                  label: Text(
                    _selectedPriceListRecord == null
                        ? 'Lista standard indisponibila'
                        : 'Lista standard: ${_selectedPriceListRecord!.name}',
                  ),
                ),
              )
            : DropdownButtonFormField<String>(
                initialValue: _selectedPriceListId,
                decoration:
                    const InputDecoration(labelText: 'Lista comerciala'),
                items: widget.priceLists
                    .map(
                      (item) => DropdownMenuItem<String>(
                        value: item.id,
                        child: Text(item.name),
                      ),
                    )
                    .toList(growable: false),
                onChanged: (value) async {
                  if (value == null) return;
                  setState(() => _selectedPriceListId = value);
                  await _refreshDialogCatalog();
                },
              );
    return AlertDialog(
      title: const Text('Mini-oferta rapida / aprobare finala'),
      content: SizedBox(
        width: dialogContentWidth,
        height: dialogContentHeight,
        child: SingleChildScrollView(
          child: Column(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Text(
                lead == null
                    ? 'Cererea nu este legata de un lead selectat.'
                    : 'Lead: ${lead.clientName.trim().isEmpty ? lead.contactName : lead.clientName}',
              ),
              const SizedBox(height: 6),
              Text(
                'Pretul comercial, stocul si mini-oferta se pot folosi local. Aprobarea se cere doar la trimiterea finala.',
                style: Theme.of(context).textTheme.bodySmall,
              ),
              const SizedBox(height: 8),
              Align(
                alignment: Alignment.centerLeft,
                child: OutlinedButton.icon(
                  onPressed: _openFieldSalesAiAssistant,
                  icon: const Icon(Icons.auto_awesome_outlined),
                  label: const Text('Asistent AI'),
                ),
              ),
              const SizedBox(height: 12),
              priceListControl,
              const SizedBox(height: 12),
              if (_selectedPriceListRecord != null)
                Align(
                  alignment: Alignment.centerLeft,
                  child: Chip(
                    label: Text(
                      'Lista activa: ${_selectedPriceListRecord!.name} (${_selectedPriceListRecord!.currency})',
                    ),
                  ),
                ),
              if (_catalogLoading) ...[
                const SizedBox(height: 8),
                const LinearProgressIndicator(),
              ],
              const SizedBox(height: 8),
              TextField(
                controller: _searchController,
                onChanged: (_) => setState(() {}),
                decoration: const InputDecoration(
                  labelText: 'Cauta produs pentru mini-oferta',
                  prefixIcon: Icon(Icons.search),
                ),
              ),
              const SizedBox(height: 12),
              Text(
                'Produse',
                style: Theme.of(context).textTheme.titleSmall,
              ),
              const SizedBox(height: 8),
              ConstrainedBox(
                constraints: BoxConstraints(maxHeight: productListHeight),
                child: ListView(
                  shrinkWrap: true,
                  children: _filteredCatalogItems.take(40).map((item) {
                    final selected = _selectedProducts.any(
                      (row) => row.productId == item.product.id,
                    );
                    return CheckboxListTile(
                      value: selected,
                      onChanged: (value) => _toggleProduct(item, value == true),
                      title: Text(item.product.name),
                      subtitle: Text(
                        'Pret: ${item.salePrice > 0 ? '${item.salePrice.toStringAsFixed(2)} ${item.currency}' : 'Pret indisponibil'}'
                        ' | ${item.priceList == null ? 'Fara lista activa' : (item.hasPriceEntry ? 'Lista: ${item.priceList!.name}' : 'Fara pret in lista activa')}'
                        ' | Stoc: ${item.availableStockQuantity.toStringAsFixed(2)} ${item.product.unit}'
                        ' | ${item.product.stockStatus.label}'
                        ' | Livrare: ${item.product.deliveryLeadTimeText.trim().isEmpty ? '-' : item.product.deliveryLeadTimeText.trim()}',
                      ),
                      controlAffinity: ListTileControlAffinity.leading,
                      contentPadding: EdgeInsets.zero,
                      secondary: selected
                          ? IconButton(
                              onPressed: () {
                                final current = _selectedProducts.firstWhere(
                                  (row) => row.productId == item.product.id,
                                );
                                _editProductSelection(current);
                              },
                              icon: const Icon(Icons.edit_outlined),
                            )
                          : null,
                    );
                  }).toList(growable: false),
                ),
              ),
              const SizedBox(height: 12),
              Text(
                'Servicii presetate',
                style: Theme.of(context).textTheme.titleSmall,
              ),
              const SizedBox(height: 8),
              Align(
                alignment: Alignment.centerLeft,
                child: Wrap(
                  spacing: 8,
                  runSpacing: 8,
                  children: [
                    OutlinedButton.icon(
                      onPressed: _openLaborTemplatesManager,
                      icon: const Icon(Icons.playlist_add_check_outlined),
                      label: const Text('Catalog manopera standard'),
                    ),
                    OutlinedButton.icon(
                      onPressed: _openManualServiceEditor,
                      icon: const Icon(Icons.add_task_outlined),
                      label: const Text('Adauga serviciu prestat'),
                    ),
                  ],
                ),
              ),
              const SizedBox(height: 8),
              if (_laborTemplatesLoading)
                const LinearProgressIndicator()
              else if (_activeLaborTemplates.isEmpty)
                Card(
                  margin: EdgeInsets.zero,
                  child: Padding(
                    padding: const EdgeInsets.all(12),
                    child: Text(
                      'Nu exista inca sabloane salvate de tine. Se afiseaza lista presetata standard pana configurezi preturile si serviciile tale din modulul Oferte.',
                      style: Theme.of(context).textTheme.bodySmall,
                    ),
                  ),
                )
              else
                const SizedBox.shrink(),
              if (!_laborTemplatesLoading &&
                  _visibleLaborTemplates.isNotEmpty) ...[
                if (_suggestedTemplates.isNotEmpty) ...[
                  Text(
                    'Sugestii dupa produsele selectate',
                    style: Theme.of(context).textTheme.bodySmall,
                  ),
                  const SizedBox(height: 6),
                  Wrap(
                    spacing: 8,
                    runSpacing: 8,
                    children: _suggestedTemplates
                        .map(_buildServiceTemplateChip)
                        .toList(growable: false),
                  ),
                  const SizedBox(height: 12),
                ],
                ..._serviceCategories.map((category) {
                  final templates = _templatesForCategory(category);
                  if (templates.isEmpty) {
                    return const SizedBox.shrink();
                  }
                  return Padding(
                    padding: const EdgeInsets.only(bottom: 12),
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          _serviceCategoryLabel(category),
                          style: Theme.of(context).textTheme.bodyMedium,
                        ),
                        const SizedBox(height: 6),
                        Wrap(
                          spacing: 8,
                          runSpacing: 8,
                          children: templates
                              .map(_buildServiceTemplateChip)
                              .toList(growable: false),
                        ),
                      ],
                    ),
                  );
                }),
              ],
              if (_selectedProducts.isNotEmpty ||
                  _selectedServices.isNotEmpty) ...[
                const SizedBox(height: 16),
                Text(
                  'Mini-oferta',
                  style: Theme.of(context).textTheme.titleSmall,
                ),
                const SizedBox(height: 8),
                ..._selectedProducts.map(
                  (item) => ListTile(
                    contentPadding: EdgeInsets.zero,
                    title: Text(item.productName),
                    subtitle: Text(
                      '${item.quantity.toStringAsFixed(2)} x ${item.unitPrice.toStringAsFixed(2)} ${item.currency} = ${item.lineTotal.toStringAsFixed(2)} ${item.currency}',
                    ),
                    trailing: IconButton(
                      onPressed: () => _editProductSelection(item),
                      icon: const Icon(Icons.edit_outlined),
                    ),
                  ),
                ),
                ..._selectedServices.map(
                  (item) => ListTile(
                    contentPadding: EdgeInsets.zero,
                    title: Text(item.label),
                    subtitle: Text(
                      [
                        '${item.quantity.toStringAsFixed(2)} x ${item.unitPrice.toStringAsFixed(2)} ${item.currency} = ${item.lineTotal.toStringAsFixed(2)} ${item.currency}',
                        if (item.includedServices.trim().isNotEmpty)
                          'Inclus: ${item.includedServices.trim()}',
                        if (item.notes.trim().isNotEmpty)
                          'Conditii: ${item.notes.trim()}',
                      ].join('\n'),
                    ),
                    trailing: Wrap(
                      spacing: 4,
                      children: [
                        IconButton(
                          onPressed: () => _editServiceSelection(item),
                          icon: const Icon(Icons.edit_outlined),
                        ),
                        IconButton(
                          onPressed: () => _removeServiceSelection(item.code),
                          icon: const Icon(Icons.delete_outline),
                        ),
                      ],
                    ),
                  ),
                ),
              ],
              const SizedBox(height: 12),
              Slider(
                value: _discountPercent,
                min: 0,
                max: _FieldSalesPageState._maxDirectDiscountPercent,
                divisions: 24,
                label: '${_discountPercent.toStringAsFixed(1)}%',
                onChanged: (value) {
                  setState(() => _discountPercent = value);
                },
              ),
              Text(
                'Discount direct permis fara aprobare separata: 0% - ${_FieldSalesPageState._maxDirectDiscountPercent.toStringAsFixed(0)}%',
              ),
              const SizedBox(height: 8),
              Card(
                margin: EdgeInsets.zero,
                child: Padding(
                  padding: const EdgeInsets.all(12),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text(
                          'Subtotal: ${_subtotal.toStringAsFixed(2)} $_requestCurrency'),
                      const SizedBox(height: 4),
                      Text(
                        'Discount ${_discountPercent.toStringAsFixed(2)}%: ${_discountValue.toStringAsFixed(2)} $_requestCurrency',
                      ),
                      const SizedBox(height: 4),
                      Text(
                        'Total propus: ${_total.toStringAsFixed(2)} $_requestCurrency',
                        style: Theme.of(context).textTheme.titleSmall,
                      ),
                    ],
                  ),
                ),
              ),
              const SizedBox(height: 12),
              TextField(
                controller: _notesController,
                minLines: 2,
                maxLines: 4,
                decoration: const InputDecoration(labelText: 'Observatii'),
              ),
            ],
          ),
        ),
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.of(context).pop(),
          child: const Text('Renunță'),
        ),
        OutlinedButton(
          onPressed: () =>
              _submitRequest(FieldSalesRequestApprovalStatus.draft),
          child: const Text('Salveaza mini-oferta'),
        ),
        FilledButton(
          onPressed: () =>
              _submitRequest(FieldSalesRequestApprovalStatus.trimisa),
          child: const Text('Trimite cerere aprobare discount si vanzare'),
        ),
      ],
    );
  }

  void _submitRequest(FieldSalesRequestApprovalStatus status) {
    if (_selectedProducts.isEmpty && _selectedServices.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text(
            'Adauga cel putin un produs sau un serviciu presetat.',
          ),
        ),
      );
      return;
    }
    final lead = widget.lead;
    final now = DateTime.now();
    Navigator.of(context).pop(
      FieldSalesRequestRecord(
        id: 'field-request-${now.microsecondsSinceEpoch}',
        leadId: lead?.id ?? '',
        clientId: lead?.clientId ?? '',
        clientName: lead?.clientName.trim().isNotEmpty == true
            ? lead!.clientName.trim()
            : (lead?.contactName.trim() ?? ''),
        requestType: _resolvedRequestType,
        requestedProductIds: _selectedProducts
            .map((item) => item.productId)
            .toList(growable: false),
        requestedProducts: _selectedProducts.toList(growable: false),
        requestedServicePresets: _selectedServices.toList(growable: false),
        requestedServiceLabel: _selectedServices
            .map((item) => item.label.trim())
            .where((item) => item.isNotEmpty)
            .join(', '),
        requestedPriceListId:
            widget.fieldSalesService.normalizeRequestedPriceListId(
          (_selectedPriceListId ?? '').trim(),
          widget.priceLists,
          restrictToStandardOnly: widget.restrictToStandardOnly,
        ),
        requestedSubtotalValue: _subtotal,
        requestedDiscountPercent: _discountPercent,
        requestedDiscountValue: _discountValue,
        requestedTotalValue: _total,
        currency: _requestCurrency,
        requestedByUserId: widget.currentUserId.trim(),
        requestedByName: widget.currentUserName.trim(),
        approvalStatus: status,
        notes: _notesController.text.trim(),
        createdAt: now,
        updatedAt: now,
      ),
    );
  }
}

class _FieldSalesLaborTemplatesDialog extends StatefulWidget {
  const _FieldSalesLaborTemplatesDialog({
    required this.items,
    required this.onSave,
    required this.onImportRecommended,
  });

  final List<OfferLaborTemplate> items;
  final Future<void> Function(OfferLaborTemplate item) onSave;
  final Future<int> Function() onImportRecommended;

  @override
  State<_FieldSalesLaborTemplatesDialog> createState() =>
      _FieldSalesLaborTemplatesDialogState();
}

class _FieldSalesLaborTemplatesDialogState
    extends State<_FieldSalesLaborTemplatesDialog> {
  bool _saving = false;

  Future<void> _editTemplate([OfferLaborTemplate? existing]) async {
    final saved = await showDialog<OfferLaborTemplate>(
      context: context,
      builder: (context) =>
          _FieldSalesLaborTemplateEditorDialog(existing: existing),
    );
    if (saved == null || _saving) {
      return;
    }
    setState(() => _saving = true);
    try {
      await widget.onSave(saved);
      if (!mounted) {
        return;
      }
      Navigator.of(context).pop(true);
    } finally {
      if (mounted) {
        setState(() => _saving = false);
      }
    }
  }

  Future<void> _importRecommended() async {
    if (_saving) {
      return;
    }
    setState(() => _saving = true);
    try {
      await widget.onImportRecommended();
      if (!mounted) {
        return;
      }
      Navigator.of(context).pop(true);
    } finally {
      if (mounted) {
        setState(() => _saving = false);
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    final items = [...widget.items]
      ..sort((a, b) => a.name.toLowerCase().compareTo(b.name.toLowerCase()));
    return AlertDialog(
      title: const Text('Catalog manopera standard'),
      content: SizedBox(
        width: 760,
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Align(
              alignment: Alignment.centerRight,
              child: Wrap(
                spacing: 8,
                runSpacing: 8,
                children: [
                  OutlinedButton.icon(
                    onPressed: _saving ? null : _importRecommended,
                    icon: const Icon(Icons.playlist_add_check_outlined),
                    label: const Text('Importa set recomandat'),
                  ),
                  OutlinedButton.icon(
                    onPressed: _saving ? null : () => _editTemplate(),
                    icon: const Icon(Icons.add),
                    label: const Text('Adauga'),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 8),
            Flexible(
              child: items.isEmpty
                  ? const Center(
                      child: Text('Nu exista sabloane de manopera standard.'),
                    )
                  : ListView.separated(
                      shrinkWrap: true,
                      itemCount: items.length,
                      separatorBuilder: (_, __) => const Divider(height: 1),
                      itemBuilder: (context, index) {
                        final item = items[index];
                        return ListTile(
                          title: Text(item.name),
                          subtitle: Text(
                            'Categorie: ${item.category.trim().isEmpty ? '-' : item.category.trim()}\n'
                            '${item.description.trim().isEmpty ? '-' : item.description.trim()}\n'
                            'UM: ${item.unit} • Cantitate implicita: ${item.defaultQuantity.toStringAsFixed(2)} • Pret unitar: ${item.defaultUnitPrice.toStringAsFixed(2)}\n'
                            'Incluse: ${item.includedServices.trim().isEmpty ? '-' : item.includedServices.trim()}\n'
                            'Sugestii produse: ${item.suggestedProductKeywords.trim().isEmpty ? '-' : item.suggestedProductKeywords.trim()}\n'
                            'Status: ${item.isActive ? 'Activ' : 'Inactiv'}',
                          ),
                          trailing: IconButton(
                            tooltip: 'Editeaza',
                            onPressed:
                                _saving ? null : () => _editTemplate(item),
                            icon: const Icon(Icons.edit_outlined),
                          ),
                        );
                      },
                    ),
            ),
          ],
        ),
      ),
      actions: [
        TextButton(
          onPressed: _saving ? null : () => Navigator.of(context).pop(false),
          child: const Text('Inchide'),
        ),
      ],
    );
  }
}

class _FieldSalesLaborTemplateEditorDialog extends StatefulWidget {
  const _FieldSalesLaborTemplateEditorDialog({this.existing});

  final OfferLaborTemplate? existing;

  @override
  State<_FieldSalesLaborTemplateEditorDialog> createState() =>
      _FieldSalesLaborTemplateEditorDialogState();
}

class _FieldSalesLaborTemplateEditorDialogState
    extends State<_FieldSalesLaborTemplateEditorDialog> {
  final _formKey = GlobalKey<FormState>();
  final _nameController = TextEditingController();
  final _categoryController = TextEditingController();
  final _descriptionController = TextEditingController();
  final _unitController = TextEditingController();
  final _quantityController = TextEditingController();
  final _unitPriceController = TextEditingController();
  final _includedServicesController = TextEditingController();
  final _suggestedProductKeywordsController = TextEditingController();
  final _notesController = TextEditingController();
  bool _isActive = true;

  @override
  void initState() {
    super.initState();
    final existing = widget.existing;
    if (existing != null) {
      _nameController.text = existing.name;
      _categoryController.text = existing.category;
      _descriptionController.text = existing.description;
      _unitController.text = existing.unit;
      _quantityController.text = existing.defaultQuantity.toStringAsFixed(2);
      _unitPriceController.text = existing.defaultUnitPrice.toStringAsFixed(2);
      _includedServicesController.text = existing.includedServices;
      _suggestedProductKeywordsController.text =
          existing.suggestedProductKeywords;
      _notesController.text = existing.notes;
      _isActive = existing.isActive;
    } else {
      _categoryController.text = 'servicii_baza';
      _unitController.text = 'ore';
      _quantityController.text = '1';
      _unitPriceController.text = '0';
    }
  }

  @override
  void dispose() {
    _nameController.dispose();
    _categoryController.dispose();
    _descriptionController.dispose();
    _unitController.dispose();
    _quantityController.dispose();
    _unitPriceController.dispose();
    _includedServicesController.dispose();
    _suggestedProductKeywordsController.dispose();
    _notesController.dispose();
    super.dispose();
  }

  double _asDouble(String raw, [double fallback = 0]) {
    return double.tryParse(raw.replaceAll(',', '.').trim()) ?? fallback;
  }

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: Text(
        widget.existing == null
            ? 'Adauga sablon manopera'
            : 'Editeaza sablon manopera',
      ),
      content: SizedBox(
        width: 640,
        child: Form(
          key: _formKey,
          child: SingleChildScrollView(
            child: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                TextFormField(
                  controller: _nameController,
                  decoration: const InputDecoration(labelText: 'Denumire'),
                  validator: (value) {
                    if ((value ?? '').trim().isEmpty) {
                      return 'Completeaza denumirea.';
                    }
                    return null;
                  },
                ),
                const SizedBox(height: 8),
                TextFormField(
                  controller: _categoryController,
                  decoration: const InputDecoration(
                    labelText: 'Categorie serviciu',
                    helperText:
                        'Exemple: montaj, traseu_frigorific, pif, servicii_baza',
                  ),
                ),
                const SizedBox(height: 8),
                TextFormField(
                  controller: _descriptionController,
                  maxLines: 3,
                  decoration: const InputDecoration(labelText: 'Descriere'),
                ),
                const SizedBox(height: 8),
                Row(
                  children: [
                    Expanded(
                      child: TextFormField(
                        controller: _unitController,
                        decoration: const InputDecoration(labelText: 'UM'),
                      ),
                    ),
                    const SizedBox(width: 8),
                    Expanded(
                      child: TextFormField(
                        controller: _quantityController,
                        keyboardType: const TextInputType.numberWithOptions(
                          decimal: true,
                        ),
                        decoration: const InputDecoration(
                          labelText: 'Cantitate implicita',
                        ),
                      ),
                    ),
                    const SizedBox(width: 8),
                    Expanded(
                      child: TextFormField(
                        controller: _unitPriceController,
                        keyboardType: const TextInputType.numberWithOptions(
                          decimal: true,
                        ),
                        decoration: const InputDecoration(
                          labelText: 'Pret unitar implicit',
                        ),
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 8),
                TextFormField(
                  controller: _includedServicesController,
                  maxLines: 3,
                  decoration: const InputDecoration(
                    labelText: 'Servicii incluse implicite',
                  ),
                ),
                const SizedBox(height: 8),
                TextFormField(
                  controller: _suggestedProductKeywordsController,
                  maxLines: 3,
                  decoration: const InputDecoration(
                    labelText: 'Cuvinte-cheie sugestie produse',
                    helperText:
                        'Separate prin virgula: ex. aer conditionat, 12000 btu, inverter',
                  ),
                ),
                const SizedBox(height: 8),
                TextFormField(
                  controller: _notesController,
                  maxLines: 3,
                  decoration: const InputDecoration(
                    labelText: 'Conditii comerciale / note',
                  ),
                ),
                SwitchListTile(
                  contentPadding: EdgeInsets.zero,
                  value: _isActive,
                  onChanged: (value) => setState(() => _isActive = value),
                  title: const Text('Activ'),
                ),
              ],
            ),
          ),
        ),
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.of(context).pop(),
          child: const Text('Renunta'),
        ),
        FilledButton(
          onPressed: () {
            if (!_formKey.currentState!.validate()) {
              return;
            }
            final now = DateTime.now();
            Navigator.of(context).pop(
              OfferLaborTemplate(
                id: widget.existing?.id ??
                    'labor-template-${now.microsecondsSinceEpoch}',
                name: _nameController.text.trim(),
                category: _categoryController.text.trim(),
                description: _descriptionController.text.trim(),
                unit: _unitController.text.trim().isEmpty
                    ? 'ore'
                    : _unitController.text.trim(),
                defaultQuantity: _asDouble(_quantityController.text, 1),
                defaultUnitPrice: _asDouble(_unitPriceController.text, 0),
                isActive: _isActive,
                notes: _notesController.text.trim(),
                includedServices: _includedServicesController.text.trim(),
                suggestedProductKeywords:
                    _suggestedProductKeywordsController.text.trim(),
                createdAt: widget.existing?.createdAt ?? now,
                updatedAt: now,
              ),
            );
          },
          child: const Text('Salveaza'),
        ),
      ],
    );
  }
}
