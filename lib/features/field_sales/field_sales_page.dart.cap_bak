class FieldSalesPage extends StatefulWidget {
  const FieldSalesPage({
    super.key,
    required this.repository,
    this.fieldAuthRoleKey,
    this.fieldAuthUserId,
    this.fieldAuthUserEmail,
    this.fieldAuthTeamId,
  });

  final AppDataRepository repository;
  final String? fieldAuthRoleKey;
  final String? fieldAuthUserId;
  final String? fieldAuthUserEmail;
  final String? fieldAuthTeamId;

  @override
  State<FieldSalesPage> createState() => _FieldSalesPageState();
}

class _FieldSalesPageState extends State<FieldSalesPage> {
  static const double _maxDirectDiscountPercent = 12;
  static const int _maxInlineAttachmentBytes = 550 * 1024;
  AiAssistantService get _aiAssistantService =>
      AiAssistantService(repository: widget.repository);
  final FieldSalesService _service = FieldSalesService();
  final ProductCatalogService _productCatalogService = ProductCatalogService();
  final NotificationCenterService _notificationService =
      NotificationCenterService();
  final LocalOferteRepository _localOferteRepository = LocalOferteRepository();
  final FirebaseOferteRepository? _cloudOferteRepository =
      FirebaseBootstrap.isInitialized ? FirebaseOferteRepository() : null;
  final TextEditingController _catalogSearchController =
      TextEditingController();
  final TextEditingController _leadSearchController = TextEditingController();

  bool _loading = true;
  String? _message;
  AppUser? _currentUser;
  List<ClientRecord> _clients = const <ClientRecord>[];
  List<PriceListRecord> _priceLists = const <PriceListRecord>[];
  List<FieldCommercialProductView> _catalogItems =
      const <FieldCommercialProductView>[];
  List<FieldLeadRecord> _leads = const <FieldLeadRecord>[];
  List<FieldSalesRequestRecord> _requests = const <FieldSalesRequestRecord>[];
  String _selectedPriceListId = '';
  FieldLeadRecord? _selectedLead;

  String get _currentUserId => (widget.fieldAuthUserId ?? '').trim();
  String get _currentUserEmail => (widget.fieldAuthUserEmail ?? '').trim();
  String get _currentTeamId => (widget.fieldAuthTeamId ?? '').trim();
  UserRole? get _resolvedRole => AppRolePolicy.resolve(
        roleKey: widget.fieldAuthRoleKey,
      );
  bool get _canSeeAll =>
      _resolvedRole == null ||
      _resolvedRole == UserRole.admin ||
      _resolvedRole == UserRole.birou ||
      _resolvedRole == UserRole.sefEchipa;
  bool get _restrictToStandardPriceList => !_canSeeAll;

  List<PriceListRecord> get _availableFieldPriceLists {
    if (!_restrictToStandardPriceList) {
      return _priceLists;
    }
    final standardPriceList = _service.resolveStandardPriceList(_priceLists);
    return standardPriceList == null
        ? const <PriceListRecord>[]
        : <PriceListRecord>[standardPriceList];
  }

  String get _normalizedSelectedPriceListId =>
      _service.normalizeRequestedPriceListId(
        _selectedPriceListId,
        _priceLists,
        restrictToStandardOnly: _restrictToStandardPriceList,
      );

  PriceListRecord? get _selectedFieldPriceList {
    final priceListId = _normalizedSelectedPriceListId;
    if (priceListId.isEmpty) return null;
    for (final item in _availableFieldPriceLists) {
      if (item.id == priceListId) {
        return item;
      }
    }
    return null;
  }

  @override
  void initState() {
    super.initState();
    _catalogSearchController.addListener(() => setState(() {}));
    _leadSearchController.addListener(() => setState(() {}));
    _load();
  }

  @override
  void dispose() {
    _catalogSearchController.dispose();
    _leadSearchController.dispose();
    super.dispose();
  }

  Future<void> _load() async {
    setState(() {
      _loading = true;
      _message = null;
    });
    try {
      final results = await Future.wait<dynamic>([
        widget.repository.loadCurrentUser(),
        widget.repository.listClients(),
        _productCatalogService.listPriceLists(),
        _service.listLeads(),
        _service.listRequests(),
      ]);
      _currentUser = results[0] as AppUser?;
      _clients = (results[1] as List<ClientRecord>)
          .where((item) => item.isActive)
          .toList(growable: false)
        ..sort((a, b) => a.name.toLowerCase().compareTo(b.name.toLowerCase()));
      _priceLists = (results[2] as List<PriceListRecord>)
          .where((item) => item.isActive)
          .toList(growable: false);
      _leads = results[3] as List<FieldLeadRecord>;
      _requests = results[4] as List<FieldSalesRequestRecord>;
      _selectedPriceListId = _service.normalizeRequestedPriceListId(
        _selectedPriceListId,
        _priceLists,
        restrictToStandardOnly: _restrictToStandardPriceList,
      );
      _catalogItems = await _service.buildCommercialCatalog(
        priceListId: _selectedPriceListId,
        restrictToStandardOnly: _restrictToStandardPriceList,
      );
      if (_selectedLead != null) {
        for (final lead in _leads) {
          if (lead.id == _selectedLead!.id) {
            _selectedLead = lead;
            break;
          }
        }
      }
    } catch (error) {
      _message = 'Nu am putut incarca modulul de teren: $error';
    } finally {
      if (mounted) {
        setState(() {
          _loading = false;
        });
      }
    }
  }

  List<FieldCommercialProductView> get _filteredCatalogItems {
    final query = _catalogSearchController.text.trim().toLowerCase();
    if (query.isEmpty) {
      return _catalogItems;
    }
    return _catalogItems.where((item) {
      final product = item.product;
      return product.name.toLowerCase().contains(query) ||
          product.brand.toLowerCase().contains(query) ||
          product.model.toLowerCase().contains(query) ||
          product.category.toLowerCase().contains(query) ||
          product.sku.toLowerCase().contains(query) ||
          product.commercialDescription.toLowerCase().contains(query);
    }).toList(growable: false);
  }

  List<FieldLeadRecord> get _visibleLeads {
    final rows = _canSeeAll
        ? _leads
        : _leads.where((item) {
            return item.createdByUserId.trim() == _currentUserId ||
                item.assignedUserId.trim() == _currentUserId;
          }).toList(growable: false);
    final query = _leadSearchController.text.trim().toLowerCase();
    if (query.isEmpty) {
      return rows;
    }
    return rows.where((item) {
      return item.clientName.toLowerCase().contains(query) ||
          item.contactName.toLowerCase().contains(query) ||
          item.phone.toLowerCase().contains(query) ||
          item.email.toLowerCase().contains(query) ||
          item.notes.toLowerCase().contains(query);
    }).toList(growable: false);
  }

  List<FieldSalesRequestRecord> get _visibleRequests {
    return _canSeeAll
        ? _requests
        : _requests
            .where((item) => item.requestedByUserId.trim() == _currentUserId)
            .toList(growable: false);
  }

  String _formatDateTime(DateTime value) {
    final date =
        '${value.day.toString().padLeft(2, '0')}.${value.month.toString().padLeft(2, '0')}.${value.year.toString().padLeft(4, '0')}';
    final time =
        '${value.hour.toString().padLeft(2, '0')}:${value.minute.toString().padLeft(2, '0')}';
    return '$date $time';
  }

  String _money(double value, String currency) =>
      '${value.toStringAsFixed(2)} $currency';

  String _stockSummary(FieldCommercialProductView item) {
    return 'Stoc: ${item.availableStockQuantity.toStringAsFixed(2)} ${item.product.unit}';
  }

  FieldLeadRecord? _findLeadById(String leadId) {
    final id = leadId.trim();
    if (id.isEmpty) return null;
    for (final item in _leads) {
      if (item.id == id) return item;
    }
    return null;
  }

  AiAssistantRuntimeContext _buildFieldSalesModuleAiContext() {
    final lead = _selectedLead;
    final catalogSlice = _filteredCatalogItems.take(8).map((item) {
      return <String, dynamic>{
        ...item.product.toMap(),
        'sale_price': item.salePrice,
        'currency': item.currency,
        'available_stock_quantity': item.availableStockQuantity,
      };
    }).toList(growable: false);
    return AiAssistantRuntimeContext(
      contextType: AiAssistantContextType.fieldSales,
      module: 'field_sales',
      entityId: lead?.id ?? 'field-sales-module',
      entityLabel: lead?.clientName.trim().isNotEmpty == true
          ? lead!.clientName.trim()
          : 'Agent teren',
      userId: _currentUserId,
      contextLabel: lead == null
          ? 'Agent teren / context comercial curent'
          : 'Agent teren / lead ${lead.clientName.trim().isEmpty ? lead.contactName : lead.clientName}',
      primaryData: <String, dynamic>{
        'type': 'field_sales_request',
        'selected_price_list_id': _normalizedSelectedPriceListId,
        'selected_price_list': _availableFieldPriceLists
            .where((item) => item.id == _normalizedSelectedPriceListId)
            .map((item) => item.toMap())
            .cast<Map<String, dynamic>?>()
            .firstWhere((item) => item != null, orElse: () => null),
        'lead': lead?.toMap() ?? <String, dynamic>{},
        'requests_count': _visibleRequests.length,
      },
      relatedData: <String, dynamic>{
        'field_sales_request': <String, dynamic>{
          'lead_id': lead?.id ?? '',
          'client_name': lead?.clientName ?? '',
          'notes': lead?.notes ?? '',
          'selected_price_list_id': _normalizedSelectedPriceListId,
        },
        'lead': lead?.toMap() ?? <String, dynamic>{},
        'client': <String, dynamic>{
          'client_name': lead?.clientName ?? '',
          'contact_name': lead?.contactName ?? '',
          'phone': lead?.phone ?? '',
          'email': lead?.email ?? '',
        },
        'products': catalogSlice,
      },
    );
  }

  Future<void> _openFieldSalesAiAssistant() async {
    await AiAssistantSheet.show(
      context: context,
      title: 'Asistent AI agent teren',
      service: _aiAssistantService,
      runtimeContext: _buildFieldSalesModuleAiContext(),
      actions: AiAssistantActionCatalog.actionsFor(
        AiAssistantContextType.fieldSales,
      ),
    );
  }

  String _resolveClientLabel(FieldSalesRequestRecord request) {
    final lead = _findLeadById(request.leadId);
    final values = <String>[
      request.clientName.trim(),
      lead?.clientName.trim() ?? '',
      lead?.contactName.trim() ?? '',
    ];
    for (final value in values) {
      if (value.isNotEmpty) return value;
    }
    return request.requestType.label;
  }

  String _fileNameFromPath(String path) {
    final normalized = path.replaceAll('\\', '/').trim();
    if (normalized.isEmpty) return '';
    final parts = normalized.split('/');
    return parts.isEmpty ? normalized : parts.last.trim();
  }

  Future<void> _openGeneratedDocument(String filePath) async {
    final result = await DocumentFileService.openFile(filePath);
    if (result.opened || !mounted) {
      return;
    }
    if (DocumentFileService.supportsFolderOpen) {
      await DocumentFileService.openFolderForFile(filePath);
    }
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text('${result.message} Documentul a fost salvat: $filePath'),
      ),
    );
  }

  List<FieldSalesQuotePdfProductRow> _buildRequestPdfProducts(
    FieldSalesRequestRecord request,
  ) {
    final selections = request.requestedProducts.isNotEmpty
        ? request.requestedProducts
        : request.requestedProductIds
            .map((productId) {
              final item = _catalogItemByProductId(productId, request);
              if (item == null) return null;
              return FieldSalesProductSelection(
                productId: item.product.id,
                productName: item.product.name,
                quantity: 1,
                unitPrice: item.salePrice,
                currency: item.currency,
              );
            })
            .whereType<FieldSalesProductSelection>()
            .toList(growable: false);
    return selections.map((selection) {
      final item = _catalogItemByProductId(selection.productId, request);
      final product = item?.product;
      final details = <String>[
        if ((product?.brand.trim() ?? '').isNotEmpty) product!.brand.trim(),
        if ((product?.model.trim() ?? '').isNotEmpty) product!.model.trim(),
        if ((product?.sku.trim() ?? '').isNotEmpty)
          'SKU ${product!.sku.trim()}',
      ].join(' | ');
      return FieldSalesQuotePdfProductRow(
        name: selection.productName.trim().isEmpty
            ? (product?.name.trim().isEmpty == false
                ? product!.name.trim()
                : 'Produs')
            : selection.productName.trim(),
        details: details,
        quantity: selection.quantity,
        unit: (product?.unit.trim().isNotEmpty == true)
            ? product!.unit.trim()
            : 'buc',
        unitPrice: selection.unitPrice,
        lineTotal: selection.lineTotal,
        currency: selection.currency.trim().isEmpty
            ? request.currency
            : selection.currency,
        stockStatus: product?.stockStatus ?? ProductStockStatus.inStock,
        deliveryLeadTimeText: product?.deliveryLeadTimeText ?? '',
      );
    }).toList(growable: false);
  }

  Future<void> _generateRequestPdf(
    FieldSalesRequestRecord request, {
    bool saveAs = false,
    bool share = false,
  }) async {
    try {
      final companyProfile = await widget.repository.loadCompanyProfile();
      final branding = DocumentBrandingData.fromCompanyProfile(companyProfile);
      final lead = _findLeadById(request.leadId);
      final filePath = await FieldSalesQuotePdfService.export(
        repository: widget.repository,
        request: request,
        branding: branding,
        template: companyProfile.pdfExportSettings.visualTemplate,
        agentLabel: request.requestedByName.trim().isEmpty
            ? (_currentUser?.displayName.trim().isEmpty == false
                ? _currentUser!.displayName.trim()
                : _currentUserEmail)
            : request.requestedByName.trim(),
        lead: lead,
        productRows: _buildRequestPdfProducts(request),
        saveAs: saveAs,
      );
      final persisted = request.copyWith(
        generatedDocumentPath: filePath,
        generatedDocumentFileName: _fileNameFromPath(filePath),
        generatedAt: DateTime.now(),
        generatedDocumentType: 'field_sales_quote_pdf',
      );
      await _service.saveRequest(persisted);
      try {
        await widget.repository.registerGeneratedDocument(
          registryType: RegistryType.iesire,
          documentCategory: 'Agent teren',
          documentTitle: 'Oferta rapida ${_resolveClientLabel(request)}',
          documentNumber: persisted.id.trim().isEmpty
              ? 'FSQ-${persisted.createdAt.millisecondsSinceEpoch}'
              : persisted.id.trim(),
          documentDate: persisted.generatedAt,
          issuerName: companyProfile.companyName,
          recipientName: _resolveClientLabel(request),
          clientId: persisted.clientId.trim(),
          filePath: filePath,
          fileName: persisted.generatedDocumentFileName,
          notes:
              'Mini-oferta PDF generata din Agent teren pentru cererea ${persisted.id}.',
          status: 'emis',
        );
      } catch (_) {}
      if (!mounted) return;
      if (share) {
        ClientRecord? client;
        for (final c in _clients) {
          if (c.id == persisted.clientId) {
            client = c;
            break;
          }
        }
        final defaultTo = client?.email.trim() ?? '';
        final subject = 'Mini-oferta ${_resolveClientLabel(request)}';
        final body =
            'Buna ziua,\n\nVa trimitem mini-oferta atasata.\n\nCu stima,';
        final result = await showDialog<Map<String, String>?>(
          context: context,
          builder: (_) => SendDocumentDialog(
            to: defaultTo,
            subject: subject,
            body: body,
          ),
        );
        if (result == null) return;
        final action = result['action'] ?? 'cancel';
        if (action == 'cancel') return;
        if (action == 'mailto') {
          await DocumentFileService.shareFile(
            filePath,
            subject: result['subject'] ?? subject,
            text: result['body'] ?? body,
          );
          if (!mounted) return;
          await _load();
          return;
        }

        if (action == 'queue') {
          try {
            final inlineAssets = <Map<String, dynamic>>[];
            if (companyProfile.logoBase64.trim().isNotEmpty) {
              inlineAssets.add({
                'cid': 'companylogo',
                'filename': 'logo.png',
                'base64': companyProfile.logoBase64.trim(),
                'contentType': 'image/png',
              });
            }
            final notif = NotificationCenterService();
            final attachments = [
              await _buildQueueAttachmentFromFile(
                filePath: filePath,
                fileName: '${request.id}.pdf',
                sourceModule: 'field_sales',
                sourceEntityId: request.id,
              ),
            ];
            final queueItem = await notif.sendEmailNotification(
              recipientEmail: result['to'] ?? defaultTo,
              recipientName: _resolveClientLabel(request),
              subject: result['subject'] ?? subject,
              bodyText: result['body'] ?? body,
              bodyHtml: miniOfferHtml(
                recipientName: result['to'] ?? _resolveClientLabel(request),
                companyName: companyProfile.companyName,
                agentName: persisted.requestedByName.isNotEmpty
                    ? persisted.requestedByName
                    : _currentUser?.displayName ?? '',
                message: result['body'] ?? body,
              ),
              attachments: attachments,
              inlineAssets: inlineAssets,
              sourceModule: 'field_sales',
              sourceEntityId: request.id,
              eventType: NotificationEventType.documentGenerated,
              metadata: {'request_id': request.id},
            );
            if (!mounted) return;
            ScaffoldMessenger.of(context).showSnackBar(
              SnackBar(content: Text('Email pus in coada: ${queueItem.id}')),
            );
            final resolved =
                await notif.waitForEmailQueueFinalStatus(queueItem.id);
            if (!mounted) return;
            final status = (resolved?.status ?? '').trim().toLowerCase();
            if (status == 'sent') {
              ScaffoldMessenger.of(context).showSnackBar(
                SnackBar(
                    content: Text('Email trimis cu succes (${queueItem.id}).')),
              );
            } else if (status == 'failed') {
              final reason = (resolved?.errorMessage ?? '').trim();
              ScaffoldMessenger.of(context).showSnackBar(
                SnackBar(
                  content: Text(
                    reason.isEmpty
                        ? 'Email esuat (${queueItem.id}). Verifica notification_email_queue.'
                        : 'Email esuat: $reason',
                  ),
                ),
              );
            }
            await _load();
          } catch (e) {
            if (!mounted) return;
            ScaffoldMessenger.of(context).showSnackBar(
              SnackBar(content: Text('Eroare la punerea in coada: $e')),
            );
          }
        }
        return;
      }
      await _openGeneratedDocument(filePath);
      await _load();
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(
            share
                ? 'PDF-ul a fost generat si pregatit pentru share.'
                : saveAs
                    ? 'PDF-ul a fost salvat.'
                    : 'PDF-ul mini-ofertei a fost generat.',
          ),
        ),
      );
    } on PdfSaveCanceledException {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Salvarea PDF-ului a fost anulata.')),
      );
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut genera PDF-ul mini-ofertei: $error';
      });
    }
  }

  Future<Map<String, dynamic>> _buildQueueAttachmentFromFile({
    required String filePath,
    required String fileName,
    required String sourceModule,
    required String sourceEntityId,
  }) async {
    final file = File(filePath.trim());
    if (!file.existsSync()) {
      throw StateError('Fisierul atasat nu exista: $filePath');
    }
    final bytes = await file.readAsBytes();
    final normalizedName = _sanitizeAttachmentFileName(fileName);
    if (bytes.length <= _maxInlineAttachmentBytes) {
      return <String, dynamic>{
        'filename': normalizedName,
        'base64': base64Encode(bytes),
        'content_type': 'application/pdf',
        'size_bytes': bytes.length,
      };
    }

    final safeEntity = sourceEntityId.trim().isEmpty
        ? 'unknown'
        : sourceEntityId.trim().replaceAll(RegExp(r'[^A-Za-z0-9._-]+'), '_');
    final storagePath =
        'notification_email_attachments/$sourceModule/$safeEntity/${DateTime.now().millisecondsSinceEpoch}_$normalizedName';
    final ref = FirebaseStorage.instance.ref().child(storagePath);
    await ref.putData(
      bytes,
      SettableMetadata(contentType: 'application/pdf'),
    );
    return <String, dynamic>{
      'filename': normalizedName,
      'storage_path': ref.fullPath,
      'storage_bucket': ref.bucket,
      'content_type': 'application/pdf',
      'size_bytes': bytes.length,
      'encoding': 'firebase_storage',
    };
  }

  String _sanitizeAttachmentFileName(String fileName) {
    final trimmed = fileName.trim();
    if (trimmed.isEmpty) return 'document.pdf';
    return trimmed.replaceAll(RegExp(r'[^A-Za-z0-9._-]+'), '_');
  }

  FieldLeadRecord _buildLeadSeedFromRequest(FieldSalesRequestRecord request) {
    final existingLead = _findLeadById(request.leadId);
    if (existingLead != null) {
      return existingLead;
    }
    final now = DateTime.now();
    return FieldLeadRecord(
      id: request.leadId.trim().isEmpty
          ? 'field-lead-seed-${request.id}'
          : request.leadId.trim(),
      clientId: request.clientId.trim(),
      clientName: request.clientName.trim(),
      contactName: request.clientName.trim(),
      phone: '',
      email: '',
      address: '',
      sourceModule: 'field_sales',
      sourceEntityId: request.id,
      sourceLabel: request.requestType.label,
      interestedInType: switch (request.requestType) {
        FieldSalesRequestType.vanzareProdus => FieldLeadInterestType.produs,
        FieldSalesRequestType.serviciu => FieldLeadInterestType.serviciu,
        FieldSalesRequestType.programare => FieldLeadInterestType.programare,
        FieldSalesRequestType.oferta => FieldLeadInterestType.oferta,
      },
      interestedProductIds: request.requestedProductIds,
      notes: request.notes,
      status: FieldLeadStatus.contactat,
      assignedUserId: request.requestedByUserId.trim(),
      createdByUserId: request.requestedByUserId.trim(),
      createdAt: request.createdAt,
      updatedAt: now,
    );
  }

  Future<List<OfferRecord>> _listOffersResolved() async {
    final cloud = _cloudOferteRepository;
    if (cloud == null) {
      return _localOferteRepository.listOffers();
    }
    try {
      final cloudItems = await cloud.listOffers();
      await _localOferteRepository.replaceOffers(cloudItems);
      return cloudItems;
    } catch (_) {
      return _localOferteRepository.listOffers();
    }
  }

  Future<void> _saveOfferResolved(OfferRecord item) async {
    final cloud = _cloudOferteRepository;
    var queuedOffline = false;
    if (cloud != null) {
      try {
        await cloud.upsertOffer(item);
      } catch (_) {
        queuedOffline = true;
      }
    } else {
      queuedOffline = true;
    }
    await _localOferteRepository.upsertOffer(item);
    if (queuedOffline) {
      await OfflineSyncRuntime.instance.queueOffer(item);
    }
  }

  FieldCommercialProductView? _catalogItemByProductId(
    String productId,
    FieldSalesRequestRecord request,
  ) {
    final id = productId.trim();
    if (id.isEmpty) return null;
    for (final item in _catalogItems) {
      if (item.product.id == id) {
        final priceListId = _service.normalizeRequestedPriceListId(
          request.requestedPriceListId,
          _priceLists,
          restrictToStandardOnly: _restrictToStandardPriceList,
        );
        if (priceListId.isEmpty || item.priceList?.id == priceListId) {
          return item;
        }
      }
    }
    return null;
  }

  Future<void> _markLeadConverted({
    required FieldSalesRequestRecord request,
    required String entityType,
    required String entityId,
    required String entityLabel,
  }) async {
    final lead = _findLeadById(request.leadId);
    if (lead == null) return;
    await _service.saveLead(
      lead.copyWith(
        status: FieldLeadStatus.convertit,
        convertedAt: DateTime.now(),
        convertedByUserId: _currentUserId,
        convertedEntityType: entityType,
        convertedEntityId: entityId,
        convertedEntityLabel: entityLabel,
      ),
    );
  }

  Future<void> _dispatchConversionNotification({
    required FieldSalesRequestRecord request,
    required String entityType,
    required String entityId,
    required String entityLabel,
    required String module,
    required String title,
    required String message,
  }) async {
    await _notificationService.dispatchEvent(
      NotificationDispatchRequest(
        eventType: NotificationEventType.requestConverted,
        title: title,
        message: message,
        sourceModule: module,
        sourceEntityId: entityId,
        sourceLabel: entityLabel,
        recipientRoleKeys: const <String>['admin', 'office'],
        recipientUserIds: request.requestedByUserId.trim().isEmpty
            ? const <String>[]
            : <String>[request.requestedByUserId.trim()],
        metadata: <String, dynamic>{
          'request_id': request.id,
          'lead_id': request.leadId,
          'converted_entity_type': entityType,
          'converted_entity_id': entityId,
        },
      ),
    );
  }

  Future<void> _openConvertedSource(FieldSalesRequestRecord request) async {
    if (!request.isConverted || request.convertedEntityId.trim().isEmpty) {
      setState(() {
        _message = 'Cererea nu are inca o conversie activa.';
      });
      return;
    }
    Widget? page;
    final entityType = request.convertedEntityType.trim().toLowerCase();
    if (entityType == 'appointment') {
      page = ProgramariPage(
        repository: widget.repository,
        fieldAuthRoleKey: widget.fieldAuthRoleKey,
        fieldAuthUserEmail: widget.fieldAuthUserEmail,
        fieldAuthUserId: widget.fieldAuthUserId,
        fieldAuthTeamId: widget.fieldAuthTeamId,
        initialFocusAppointmentId: request.convertedEntityId.trim(),
      );
    } else if (entityType == 'offer') {
      page = OfertePage(
        repository: widget.repository,
        currentUserId: _currentUserId,
        currentUserEmail: _currentUserEmail,
        initialFocusOfferId: request.convertedEntityId.trim(),
      );
    } else if (entityType == 'product_sale' ||
        entityType == 'product_sale_batch') {
      page = ProductCatalogPage(repository: widget.repository);
    }
    if (!mounted || page == null) {
      if (mounted) {
        setState(() {
          _message = 'Sursa conversiei nu are încă deschidere directă.';
        });
      }
      return;
    }
    await Navigator.of(context).push(
      MaterialPageRoute<void>(builder: (_) => page!),
    );
  }

  Future<bool> _confirmConversion(
    String title,
    String message,
  ) async {
    final confirmed = await showDialog<bool>(
      context: context,
      builder: (context) => AlertDialog(
        title: Text(title),
        content: Text(message),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(false),
            child: const Text('Renunță'),
          ),
          FilledButton(
            onPressed: () => Navigator.of(context).pop(true),
            child: const Text('Confirma'),
          ),
        ],
      ),
    );
    return confirmed == true;
  }

  Future<void> _convertRequestToAppointment(
    FieldSalesRequestRecord request,
  ) async {
    if (request.approvalStatus != FieldSalesRequestApprovalStatus.aprobata) {
      setState(() {
        _message = 'Doar cererile aprobate pot fi convertite.';
      });
      return;
    }
    if (request.isConverted) {
      await _openConvertedSource(request);
      return;
    }
    final confirmed = await _confirmConversion(
      'Converteste in programare',
      'Cererea aprobata va crea o programare reala in modulul Programari.',
    );
    if (!confirmed || !mounted) return;
    final leadSeed = _buildLeadSeedFromRequest(request);
    final appointment = await showDialog<Appointment>(
      context: context,
      builder: (context) => _FieldAppointmentDialog(
        lead: leadSeed,
        currentUserId: _currentUserId,
        currentUserEmail: _currentUserEmail,
        currentTeamId: _currentTeamId,
      ),
    );
    if (appointment == null) return;
    await widget.repository.saveAppointment(appointment);
    final updatedRequest = request.copyWith(
      isConverted: true,
      convertedAt: DateTime.now(),
      convertedByUserId: _currentUserId,
      convertedEntityType: 'appointment',
      convertedEntityId: appointment.id,
      convertedEntityLabel: appointment.title.trim().isEmpty
          ? _resolveClientLabel(request)
          : appointment.title.trim(),
    );
    await _service.saveRequest(updatedRequest);
    await _markLeadConverted(
      request: request,
      entityType: 'appointment',
      entityId: appointment.id,
      entityLabel: updatedRequest.convertedEntityLabel,
    );
    await _notificationService.dispatchEvent(
      NotificationDispatchRequest(
        eventType: NotificationEventType.appointmentCreated,
        title: 'Programare generata din cerere aprobata',
        message:
            '${appointment.title} | ${_formatDateTime(appointment.startDateTime ?? appointment.scheduledDate)} | Client: ${_resolveClientLabel(request)}',
        sourceModule: 'programari',
        sourceEntityId: appointment.id,
        sourceLabel: appointment.title,
        recipientRoleKeys: const <String>['admin', 'office'],
        recipientUserIds: request.requestedByUserId.trim().isEmpty
            ? const <String>[]
            : <String>[request.requestedByUserId.trim()],
        recipientEmails: appointment.assignedUserEmail.trim().isEmpty
            ? const <String>[]
            : <String>[appointment.assignedUserEmail.trim()],
        recipientTeamIds: appointment.assignedTeamIds,
        metadata: <String, dynamic>{
          'created_from': 'field_sales_request',
          'request_id': request.id,
          'lead_id': request.leadId,
        },
      ),
    );
    await _dispatchConversionNotification(
      request: request,
      entityType: 'appointment',
      entityId: appointment.id,
      entityLabel: updatedRequest.convertedEntityLabel,
      module: 'programari',
      title: 'Cerere convertita in programare',
      message:
          '${_resolveClientLabel(request)} | Programare confirmata: ${updatedRequest.convertedEntityLabel}',
    );
    await _load();
  }

  Future<void> _convertRequestToOffer(
    FieldSalesRequestRecord request,
  ) async {
    if (request.approvalStatus != FieldSalesRequestApprovalStatus.aprobata) {
      setState(() {
        _message = 'Doar cererile aprobate pot fi convertite.';
      });
      return;
    }
    if (request.isConverted) {
      await _openConvertedSource(request);
      return;
    }
    final confirmed = await _confirmConversion(
      'Converteste in oferta',
      'Cererea aprobata va genera o oferta simpla draft in modulul Oferte.',
    );
    if (!confirmed) return;
    final now = DateTime.now();
    await _listOffersResolved();
    final nextOfferNumber = await widget.repository.nextOfferNumber();
    final lines = <OfferLineItem>[];
    final discountFactor =
        (1 - (request.requestedDiscountPercent / 100)).clamp(0, 1).toDouble();
    var sortOrder = 0;
    final requestProducts = request.requestedProducts.isNotEmpty
        ? request.requestedProducts
        : request.requestedProductIds
            .map((productId) {
              final item = _catalogItemByProductId(productId, request);
              if (item == null) return null;
              return FieldSalesProductSelection(
                productId: item.product.id,
                productName: item.product.name,
                quantity: 1,
                unitPrice: item.salePrice,
                currency: item.currency,
              );
            })
            .whereType<FieldSalesProductSelection>()
            .toList(growable: false);
    for (final product in requestProducts) {
      final item = _catalogItemByProductId(product.productId, request);
      sortOrder += 1;
      final name =
          product.productName.trim().isEmpty ? 'Produs' : product.productName;
      final description = [
        item?.product.brand.trim() ?? '',
        item?.product.model.trim() ?? '',
        item?.product.commercialDescription.trim() ?? '',
        if (product.notes.trim().isNotEmpty) product.notes.trim(),
      ].where((value) => value.isNotEmpty).join(' | ');
      lines.add(
        OfferLineItem(
          id: 'offer-line-${now.microsecondsSinceEpoch}-$sortOrder',
          name: name,
          description: description,
          unit: item?.product.unit.trim().isNotEmpty == true
              ? item!.product.unit.trim()
              : 'buc',
          quantity: product.quantity <= 0 ? 1 : product.quantity,
          unitPrice: product.unitPrice * discountFactor,
          lineTotal: (product.quantity <= 0 ? 1 : product.quantity) *
              (product.unitPrice * discountFactor),
          sortOrder: sortOrder,
          lineType: OfferLineType.material,
          materialId: product.productId,
        ),
      );
    }
    for (final service in request.requestedServicePresets) {
      sortOrder += 1;
      final serviceDetails = <String>[
        if (service.includedServices.trim().isNotEmpty)
          'Inclus: ${service.includedServices.trim()}',
        if (service.notes.trim().isNotEmpty)
          'Conditii comerciale: ${service.notes.trim()}',
      ].join('\n');
      lines.add(
        OfferLineItem(
          id: 'offer-line-${now.microsecondsSinceEpoch}-$sortOrder',
          name:
              service.label.trim().isEmpty ? 'Serviciu' : service.label.trim(),
          description: serviceDetails,
          unit: service.unit.trim().isEmpty ? 'serv' : service.unit.trim(),
          quantity: service.quantity <= 0 ? 1 : service.quantity,
          unitPrice: service.unitPrice * discountFactor,
          lineTotal: (service.quantity <= 0 ? 1 : service.quantity) *
              (service.unitPrice * discountFactor),
          sortOrder: sortOrder,
          lineType: OfferLineType.manopera,
          laborSourceMode: OfferLaborSourceMode.standard,
          laborTemplateId: service.laborTemplateId.trim(),
        ),
      );
    }
    if (lines.isEmpty) {
      final fallbackValue =
          request.requestedTotalValue > 0 ? request.requestedTotalValue : 0.0;
      lines.add(
        OfferLineItem(
          id: 'offer-line-${now.microsecondsSinceEpoch}-1',
          name: request.requestedServiceLabel.trim().isEmpty
              ? 'Oferta simpla din teren'
              : request.requestedServiceLabel.trim(),
          description: request.notes.trim(),
          unit: 'serv',
          quantity: 1,
          unitPrice: fallbackValue,
          lineTotal: fallbackValue,
          sortOrder: 1,
          lineType: OfferLineType.text,
        ),
      );
    }
    final totals = OfferRecord.computeTotals(
      lines: lines,
      vatPercent: 0,
      regiePercent: 0,
      profitPercent: 0,
    );
    final offer = OfferRecord(
      id: 'field-offer-${now.microsecondsSinceEpoch}',
      offerNumber: nextOfferNumber,
      title: 'Oferta teren - ${_resolveClientLabel(request)}',
      clientId: request.clientId.trim(),
      clientName: _resolveClientLabel(request),
      jobId: '',
      jobCode: '',
      jobTitle: '',
      status: OfferStatus.draft,
      issueDate: now,
      validUntil: now.add(const Duration(days: 30)),
      currency: request.currency.trim().isEmpty ? 'RON' : request.currency,
      exchangeRateSource: OfferExchangeRateSource.manual,
      bnrRate: 1,
      manualRate: 1,
      exchangeCommissionPercent: 0,
      effectiveExchangeRate: 1,
      notes: [
        'Generata din cerere teren ${request.id}.',
        if (request.requestedPriceListId.trim().isNotEmpty)
          'Lista comerciala: ${request.requestedPriceListId.trim()}',
        if (request.requestedDiscountPercent > 0)
          'Discount direct teren: ${request.requestedDiscountPercent.toStringAsFixed(2)}%',
        if (request.notes.trim().isNotEmpty) request.notes.trim(),
      ].join('\n'),
      materialSubtotal: totals.materialSubtotal,
      laborSubtotal: totals.laborSubtotal,
      subtotalDirect: totals.subtotalDirect,
      regiePercent: totals.regiePercent,
      regieValue: totals.regieValue,
      profitPercent: totals.profitPercent,
      profitValue: totals.profitValue,
      subtotalComercial: totals.subtotalComercial,
      subtotal: totals.subtotalComercial,
      vatPercent: totals.vatPercent,
      vatValue: totals.vatValue,
      totalValue: totals.totalValue,
      lines: lines,
      createdAt: now,
      updatedAt: now,
      createdByUserId: _currentUserId,
      createdByUserEmail: _currentUserEmail,
    );
    await _saveOfferResolved(offer);
    final updatedRequest = request.copyWith(
      isConverted: true,
      convertedAt: now,
      convertedByUserId: _currentUserId,
      convertedEntityType: 'offer',
      convertedEntityId: offer.id,
      convertedEntityLabel: offer.offerNumber.trim(),
    );
    await _service.saveRequest(updatedRequest);
    await _markLeadConverted(
      request: request,
      entityType: 'offer',
      entityId: offer.id,
      entityLabel: offer.offerNumber.trim(),
    );
    await _dispatchConversionNotification(
      request: request,
      entityType: 'offer',
      entityId: offer.id,
      entityLabel: offer.offerNumber.trim(),
      module: 'oferte',
      title: 'Oferta generata din teren',
      message:
          '${_resolveClientLabel(request)} | Oferta draft ${offer.offerNumber} a fost generata.',
    );
    await _load();
  }

  Future<void> _convertRequestToSale(
    FieldSalesRequestRecord request,
  ) async {
    if (request.approvalStatus != FieldSalesRequestApprovalStatus.aprobata) {
      setState(() {
        _message = 'Doar cererile aprobate pot fi convertite.';
      });
      return;
    }
    if (request.isConverted) {
      await _openConvertedSource(request);
      return;
    }
    final requestProducts = request.requestedProducts.isNotEmpty
        ? request.requestedProducts
        : request.requestedProductIds
            .map((productId) {
              final item = _catalogItemByProductId(productId, request);
              if (item == null) return null;
              return FieldSalesProductSelection(
                productId: item.product.id,
                productName: item.product.name,
                quantity: 1,
                unitPrice: item.salePrice,
                currency: item.currency,
              );
            })
            .whereType<FieldSalesProductSelection>()
            .toList(growable: false);
    if (requestProducts.isEmpty) {
      setState(() {
        _message =
            'Cererea nu are produse selectate, deci nu poate genera rezervare.';
      });
      return;
    }
    final confirmed = await _confirmConversion(
      'Converteste in vanzare / rezervare',
      'Cererea aprobata va genera rezervari reale in Catalog produse.',
    );
    if (!confirmed) return;
    final now = DateTime.now();
    final sales = <ProductSaleRecord>[];
    for (final product in requestProducts) {
      final catalogItem = _catalogItemByProductId(product.productId, request);
      if (catalogItem == null) continue;
      final sale = ProductSaleRecord(
        id: 'field-sale-${now.microsecondsSinceEpoch}-${sales.length + 1}',
        productId: catalogItem.product.id,
        productName: product.productName.trim().isEmpty
            ? catalogItem.product.name
            : product.productName.trim(),
        clientId: request.clientId.trim(),
        clientName: _resolveClientLabel(request),
        saleStatus: ProductSaleStatus.rezervat,
        saleDate: now,
        notes: [
          'Rezervare generata din cerere teren ${request.id}.',
          if (request.requestedPriceListId.trim().isNotEmpty)
            'Lista comerciala: ${request.requestedPriceListId.trim()}',
          if (request.requestedDiscountPercent > 0)
            'Discount direct teren: ${request.requestedDiscountPercent.toStringAsFixed(2)}%',
          'Pret propus: ${_money(product.unitPrice, product.currency)} x ${(product.quantity <= 0 ? 1 : product.quantity).toStringAsFixed(2)}',
          if (request.notes.trim().isNotEmpty) request.notes.trim(),
        ].join('\n'),
        createdAt: now,
        updatedAt: now,
      );
      await _productCatalogService.saveSale(sale);
      sales.add(sale);
    }
    if (sales.isEmpty) {
      setState(() {
        _message =
            'Nu am gasit produse comerciale valide pentru a genera rezervarea.';
      });
      return;
    }
    final entityType =
        sales.length == 1 ? 'product_sale' : 'product_sale_batch';
    final entityLabel = sales.length == 1
        ? sales.first.productName.trim()
        : '${sales.length} rezervari produse';
    final updatedRequest = request.copyWith(
      isConverted: true,
      convertedAt: now,
      convertedByUserId: _currentUserId,
      convertedEntityType: entityType,
      convertedEntityId: sales.first.id,
      convertedEntityLabel: entityLabel,
    );
    await _service.saveRequest(updatedRequest);
    await _markLeadConverted(
      request: request,
      entityType: entityType,
      entityId: sales.first.id,
      entityLabel: entityLabel,
    );
    await _dispatchConversionNotification(
      request: request,
      entityType: entityType,
      entityId: sales.first.id,
      entityLabel: entityLabel,
      module: 'product_catalog',
      title: 'Rezervare produs generata din teren',
      message:
          '${_resolveClientLabel(request)} | ${sales.length} produs(e) rezervate din cerere aprobata.',
    );
    await _load();
  }

  Future<void> _refreshCatalog() async {
    final items = await _service.buildCommercialCatalog(
      priceListId: _normalizedSelectedPriceListId,
      restrictToStandardOnly: _restrictToStandardPriceList,
    );
    if (!mounted) return;
    setState(() {
      _selectedPriceListId = _normalizedSelectedPriceListId;
      _catalogItems = items;
    });
  }

