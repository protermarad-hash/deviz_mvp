        title: 'Programare creata din teren',
        message:
            '${appointment.title} | ${_formatDateTime(appointment.startDateTime ?? appointment.scheduledDate)} | Contact: ${appointment.contactPerson.trim().isEmpty ? '-' : appointment.contactPerson.trim()}',
        sourceModule: 'programari',
        sourceEntityId: appointment.id,
        sourceLabel: appointment.title,
        recipientRoleKeys: const <String>['admin', 'office'],
        recipientUserIds: appointment.assignedUserId.trim().isEmpty
            ? const <String>[]
            : <String>[appointment.assignedUserId.trim()],
        recipientEmails: appointment.assignedUserEmail.trim().isEmpty
            ? const <String>[]
            : <String>[appointment.assignedUserEmail.trim()],
        recipientTeamIds: appointment.assignedTeamIds,
        metadata: <String, dynamic>{
          'created_from': 'field_sales',
          'lead_id': lead.id,
        },
      ),
    );
    await _load();
  }

  Future<void> _createSalesRequest() async {
    final request = await showDialog<FieldSalesRequestRecord>(
      context: context,
      builder: (context) => _FieldSalesRequestDialog(
        repository: widget.repository,
        fieldSalesService: _service,
        lead: _selectedLead,
        catalogItems: _catalogItems,
        priceLists: _availableFieldPriceLists,
        initialPriceListId: _normalizedSelectedPriceListId,
        restrictToStandardOnly: _restrictToStandardPriceList,
        currentUserId: _currentUserId,
        currentUserName: _currentUser?.displayName.trim().isNotEmpty == true
            ? _currentUser!.displayName.trim()
            : _currentUserEmail,
      ),
    );
    if (request == null) return;
