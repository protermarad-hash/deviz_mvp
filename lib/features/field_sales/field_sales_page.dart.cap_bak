        message:
            '${lead.clientName.trim().isEmpty ? lead.contactName : lead.clientName} | Interes: ${lead.interestedInType.label} | Contact: ${lead.contactName.trim().isEmpty ? '-' : lead.contactName.trim()}',
        sourceModule: 'field_sales',
        sourceEntityId: lead.id,
        sourceLabel: lead.clientName.trim().isEmpty
            ? lead.contactName.trim()
            : lead.clientName.trim(),
        recipientRoleKeys: const <String>['admin', 'office'],
        recipientUserIds: lead.assignedUserId.trim().isEmpty
