  Future<void> _editLeaveRequest([HrLeaveRequest? existing]) async {
    if (!_canEditOperationalHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti edita cererile de concediu.',
      );
      return;
    }
    if (_profiles.isEmpty || _leaveTypes.isEmpty) {
      setState(() {
        _message = 'Sunt necesare profiluri HR si tipuri de concediu.';
      });
      return;
    }
    final now = DateTime.now();
    String profileId = existing?.hrEmployeeProfileId.isNotEmpty == true
        ? existing!.hrEmployeeProfileId
        : _profiles.first.id;
    HrEmployeeProfile selectedProfile = _profiles.firstWhere(
      (item) => item.id.trim() == profileId.trim(),
      orElse: () => _profiles.first,
    );
    String leaveTypeCode = existing?.leaveTypeCode.isNotEmpty == true
        ? existing!.leaveTypeCode
        : _leaveTypes.first.code;
    DateTime startDate = existing?.startDate ?? _selectedMonthStart;
    DateTime endDate = existing?.endDate ?? _selectedMonthStart;
    final calendarDaysController = TextEditingController(
      text: existing == null ? '1' : existing.calendarDays.toStringAsFixed(0),
    );
    final workingDaysController = TextEditingController(
      text: existing == null ? '1' : existing.workingDays.toStringAsFixed(0),
    );
    final medicalCodeController =
        TextEditingController(text: existing?.medicalCode ?? '');
    final documentRefController =
        TextEditingController(text: existing?.documentRef ?? '');
    final approvedByController =
        TextEditingController(text: existing?.approvedByUserId ?? '');
    final reviewNotesController =
        TextEditingController(text: existing?.reviewNotes ?? '');
    final notesController = TextEditingController(text: existing?.notes ?? '');
    String status = existing?.status ?? 'draft';
    final confirmed = await showDialog<bool>(
      context: context,
      builder: (context) => StatefulBuilder(
        builder: (context, setLocalState) => AlertDialog(
          title: Text(
            existing == null ? 'Adauga concediu' : 'Editeaza concediu',
          ),
          content: SizedBox(
            width: 500,
            child: SingleChildScrollView(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  DropdownButtonFormField<String>(
                    initialValue: profileId,
                    decoration:
                        const InputDecoration(labelText: 'Angajat / profil HR'),
                    items: _profiles
                        .map(
                          (item) => DropdownMenuItem<String>(
                            value: item.id,
                            child: Text(item.fullName),
                          ),
                        )
                        .toList(growable: false),
                    onChanged: (value) {
                      if (value == null) return;
                      final next = _profiles.firstWhere(
                        (item) => item.id.trim() == value.trim(),
                        orElse: () => selectedProfile,
                      );
                      setLocalState(() {
                        profileId = value;
                        selectedProfile = next;
                      });
                    },
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: leaveTypeCode,
                    decoration:
                        const InputDecoration(labelText: 'Tip concediu'),
                    items: _leaveTypes
                        .where((item) => item.isActive)
                        .map(
                          (item) => DropdownMenuItem<String>(
                            value: item.code,
                            child: Text('${item.code} - ${item.name}'),
                          ),
                        )
                        .toList(growable: false),
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => leaveTypeCode = value);
                      }
                    },
                  ),
                  Align(
                    alignment: Alignment.centerLeft,
                    child: Text(
                      'Interval: ${startDate.day.toString().padLeft(2, '0')}.${startDate.month.toString().padLeft(2, '0')}.${startDate.year} - ${endDate.day.toString().padLeft(2, '0')}.${endDate.month.toString().padLeft(2, '0')}.${endDate.year}',
                    ),
                  ),
                  Wrap(
                    spacing: 8,
                    children: [
                      TextButton(
                        onPressed: () async {
                          final picked = await showDatePicker(
                            context: context,
                            initialDate: startDate,
                            firstDate: DateTime(2020),
                            lastDate: DateTime(2100),
                          );
                          if (picked != null) {
                            setLocalState(() => startDate = picked);
                          }
                        },
                        child: const Text('Data început'),
                      ),
                      TextButton(
                        onPressed: () async {
                          final picked = await showDatePicker(
                            context: context,
                            initialDate: endDate,
                            firstDate: DateTime(2020),
                            lastDate: DateTime(2100),
                          );
                          if (picked != null) {
                            setLocalState(() => endDate = picked);
                          }
                        },
                        child: const Text('Data sfarsit'),
                      ),
                    ],
                  ),
                  TextFormField(
                    controller: calendarDaysController,
                    decoration:
                        const InputDecoration(labelText: 'Zile calendaristice'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  TextFormField(
                    controller: workingDaysController,
                    decoration:
                        const InputDecoration(labelText: 'Zile lucratoare'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  TextFormField(
                    controller: medicalCodeController,
                    decoration: const InputDecoration(labelText: 'Cod medical'),
                  ),
                  TextFormField(
                    controller: documentRefController,
                    decoration:
                        const InputDecoration(labelText: 'Document referinta'),
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: status,
                    decoration: const InputDecoration(labelText: 'Status'),
                    items: const [
                      DropdownMenuItem(value: 'draft', child: Text('Ciorna')),
                      DropdownMenuItem(
                        value: 'submitted',
                        child: Text('Trimis'),
                      ),
                      DropdownMenuItem(
                        value: 'approved',
                        child: Text('Aprobat'),
                      ),
                      DropdownMenuItem(
                        value: 'needs_review',
                        child: Text('Necesita revizie'),
                      ),
                      DropdownMenuItem(
                        value: 'rejected',
                        child: Text('Respins'),
                      ),
                      DropdownMenuItem(
                        value: 'cancelled',
                        child: Text('Anulat'),
                      ),
                    ],
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => status = value);
                      }
                    },
                  ),
                  TextFormField(
                    controller: approvedByController,
                    decoration: const InputDecoration(labelText: 'Aprobat de'),
                  ),
                  TextFormField(
                    controller: reviewNotesController,
                    decoration:
                        const InputDecoration(labelText: 'Note revizie'),
                    minLines: 2,
                    maxLines: 4,
                  ),
                  TextFormField(
                    controller: notesController,
                    decoration: const InputDecoration(labelText: 'Note'),
                    minLines: 2,
                    maxLines: 4,
                  ),
                ],
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(false),
              child: const Text('Renunță'),
            ),
            FilledButton(
              onPressed: () => Navigator.of(context).pop(true),
              child: const Text('Salveaza'),
            ),
          ],
        ),
      ),
    );
    if (confirmed != true) return;
    if (selectedProfile.employeeId.trim().isEmpty) {
      setState(() {
        _message = 'Cererea trebuie legata de un angajat.';
      });
      return;
    }
    if (leaveTypeCode.trim().isEmpty) {
      setState(() {
        _message = 'Tipul de concediu este obligatoriu.';
      });
      return;
    }
    if (endDate.isBefore(startDate)) {
      setState(() {
        _message = 'Data de sfârșit nu poate fi înainte de data de început.';
      });
      return;
    }
    double parseNonNegative(String raw, {double fallback = 0}) {
      final value =
          double.tryParse(raw.trim().replaceAll(',', '.')) ?? fallback;
      return value < 0 ? 0 : value;
    }

    final request = HrLeaveRequest(
      id: existing?.id ??
          'hr-leave-${selectedProfile.employeeId.trim()}-${DateTime.now().millisecondsSinceEpoch}',
      employeeId: selectedProfile.employeeId,
      hrEmployeeProfileId: selectedProfile.id,
      leaveTypeCode: leaveTypeCode.trim(),
      startDate: startDate,
      endDate: endDate,
      calendarDays: parseNonNegative(calendarDaysController.text, fallback: 1),
      workingDays: parseNonNegative(workingDaysController.text, fallback: 1),
      medicalCode: medicalCodeController.text.trim(),
      documentRef: documentRefController.text.trim(),
      status: status.trim().isEmpty ? 'draft' : status.trim(),
      submittedAt: existing?.submittedAt,
      submittedByUserId: existing?.submittedByUserId ?? '',
      approvedAt: existing?.approvedAt,
      approvedByUserId: approvedByController.text.trim(),
      reviewedAt: existing?.reviewedAt,
      reviewedByUserId: existing?.reviewedByUserId ?? '',
      reviewNotes: reviewNotesController.text.trim(),
      notes: notesController.text.trim(),
      createdAt: existing?.createdAt ?? now,
      updatedAt: now,
    );
    try {
      final hasOverlap = await _leaveService.hasOverlap(request);
      if (hasOverlap) {
        if (!mounted) return;
        setState(() {
          _message =
              'Exista deja o cerere de concediu activa pe intervalul selectat.';
        });
        return;
      }
      await _leaveService.upsertLeaveRequest(request);
      await _reload();
      await _refreshLeaveSummary();
      if (!mounted) return;
      setState(() {
        _message = existing == null
            ? 'Cererea de concediu a fost salvata.'
            : 'Cererea de concediu a fost actualizata.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut salva cererea de concediu: $error';
      });
    }
  }

  String _employeeName(String employeeId) {
    return _profileByEmployeeId[employeeId.trim()]
                ?.fullName
                .trim()
                .isNotEmpty ==
            true
        ? _profileByEmployeeId[employeeId.trim()]!.fullName.trim()
        : employeeId;
  }

  String _employeeRole(String employeeId) {
    for (final item in _employees) {
      if (item.id.trim() == employeeId.trim()) {
        final role = item.role.trim();
        return role.isEmpty ? '-' : role;
      }
    }
    return '-';
  }

  HrContract? _activeContractForEmployee(String employeeId) {
    final valid = _contracts
        .where(
          (item) =>
              item.employeeId.trim() == employeeId.trim() &&
              item.appliesTo(_selectedMonthStart),
        )
        .toList(growable: false);
    if (valid.isEmpty) return null;
    valid.sort((a, b) => b.startDate.compareTo(a.startDate));
    return valid.first;
  }

  List<HrAttendanceEntry> get _monthAttendanceEntries {
    final month = _selectedMonthStart;
    final rows = _attendanceEntries.where((item) {
      final date = DateTime(item.date.year, item.date.month, item.date.day);
      if (date.year != month.year || date.month != month.month) {
        return false;
      }
      if (_attendanceEmployeeFilter.trim().isNotEmpty &&
          item.employeeId.trim() != _attendanceEmployeeFilter.trim()) {
        return false;
      }
      return true;
    }).toList(growable: false);
    rows.sort((a, b) {
      final byDate = b.date.compareTo(a.date);
      if (byDate != 0) return byDate;
      return _employeeName(a.employeeId).compareTo(_employeeName(b.employeeId));
    });
    return rows;
  }

  Future<void> _refreshAttendanceSummary() async {
    if (_attendanceEmployeeFilter.trim().isEmpty) {
      if (!mounted) return;
      setState(() {
        _attendanceSummary = null;
      });
      return;
    }
    final summary = await _attendanceService.summarizeMonth(
      employeeId: _attendanceEmployeeFilter.trim(),
      month: _selectedMonthStart,
    );
    if (!mounted) return;
    setState(() {
      _attendanceSummary = summary;
    });
  }

  String _formatMoney(double value) => value.toStringAsFixed(2);

  double _asDouble(dynamic raw) {
    if (raw is num) return raw.toDouble();
    return double.tryParse((raw ?? '').toString().replaceAll(',', '.')) ?? 0;
  }

  String _specialPayrollStatus(HrPayslip item) {
    if ((item.sourceRefs['is_childcare_leave_active'] ?? false) == true) {
      return 'CCC';
    }
    final medicalCodes = item.sourceRefs['medical_leave_codes'];
    if (medicalCodes is List && medicalCodes.isNotEmpty) {
      return 'Concediu medical';
    }
    return '-';
  }

  double _mealTicketTotalForPayslip(HrPayslip item) {
    final mealTickets =
        (item.breakdown['meal_tickets'] as Map?)?.cast<String, dynamic>() ??
            const <String, dynamic>{};
    return _asDouble(mealTickets['total_value']);
  }

  double _mealTicketEligibleDaysForPayslip(HrPayslip item) {
    final mealTickets =
        (item.breakdown['meal_tickets'] as Map?)?.cast<String, dynamic>() ??
            const <String, dynamic>{};
    return _asDouble(mealTickets['eligible_days']);
  }

  double _mealTicketValuePerDayForPayslip(HrPayslip item) {
    final mealTickets =
        (item.breakdown['meal_tickets'] as Map?)?.cast<String, dynamic>() ??
            const <String, dynamic>{};
    return _asDouble(mealTickets['value_per_day']);
  }

  String _formatDateTime(DateTime value) {
    final date =
        '${value.day.toString().padLeft(2, '0')}.${value.month.toString().padLeft(2, '0')}.${value.year.toString().padLeft(4, '0')}';
    final time =
        '${value.hour.toString().padLeft(2, '0')}:${value.minute.toString().padLeft(2, '0')}';
    return '$date $time';
  }

  String _formatMonth(DateTime value) =>
      '${value.month.toString().padLeft(2, '0')}.${value.year.toString().padLeft(4, '0')}';

  String _formatDate(DateTime value) =>
      '${value.day.toString().padLeft(2, '0')}.${value.month.toString().padLeft(2, '0')}.${value.year.toString().padLeft(4, '0')}';

  String _prettyMap(Map<String, dynamic> data) {
    if (data.isEmpty) return '-';
    final buffer = StringBuffer();
    for (final entry in data.entries) {
      buffer.writeln('${entry.key}: ${entry.value}');
    }
    return buffer.toString().trimRight();
  }

  Future<void> _editHrProfile([HrEmployeeProfile? existing]) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti administra profilurile HR.',
      );
      return;
    }
    if (_employees.isEmpty) {
      setState(() {
        _message = 'Nu exista angajati disponibili pentru profil HR.';
      });
      return;
    }
    final now = DateTime.now();
    String employeeId = existing?.employeeId.isNotEmpty == true
        ? existing!.employeeId
        : _employees.first.id;
    MasterEmployee selectedEmployee = _employees.firstWhere(
      (item) => item.id.trim() == employeeId.trim(),
      orElse: () => _employees.first,
    );
    bool isActive = existing?.isActive ?? selectedEmployee.active;
    final fullNameController = TextEditingController(
      text: existing?.fullName ?? selectedEmployee.name,
    );
    final teamController = TextEditingController(
      text: existing?.teamId ?? selectedEmployee.teamId,
    );
    final countryController = TextEditingController(
      text: existing?.taxResidenceCountry ?? 'RO',
    );
    final bankController =
        TextEditingController(text: existing?.bankAccount ?? '');
    final notesController = TextEditingController(text: existing?.notes ?? '');
    final confirmed = await showDialog<bool>(
      context: context,
      builder: (context) => StatefulBuilder(
        builder: (context, setLocalState) => AlertDialog(
          title: Text(
            existing == null ? 'Adauga profil HR' : 'Editeaza profil HR',
          ),
          content: SizedBox(
            width: 480,
            child: SingleChildScrollView(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  DropdownButtonFormField<String>(
                    initialValue: employeeId,
                    decoration: const InputDecoration(labelText: 'Angajat'),
                    items: _employees
                        .map(
                          (item) => DropdownMenuItem<String>(
                            value: item.id,
                            child: Text(item.name),
                          ),
                        )
                        .toList(growable: false),
                    onChanged: (value) {
                      if (value == null) return;
                      final next = _employees.firstWhere(
                        (item) => item.id.trim() == value.trim(),
                        orElse: () => selectedEmployee,
                      );
                      setLocalState(() {
                        employeeId = value;
                        selectedEmployee = next;
                        fullNameController.text = next.name;
                        teamController.text = next.teamId;
                        isActive = next.active;
                      });
                    },
                  ),
                  TextFormField(
                    controller: fullNameController,
                    decoration:
                        const InputDecoration(labelText: 'Nume complet'),
                  ),
                  TextFormField(
                    controller: teamController,
                    decoration: const InputDecoration(labelText: 'Echipa'),
                  ),
                  SwitchListTile(
                    contentPadding: EdgeInsets.zero,
                    title: const Text('Activ'),
                    value: isActive,
                    onChanged: (value) => setLocalState(() => isActive = value),
                  ),
                  TextFormField(
                    controller: countryController,
                    decoration: const InputDecoration(
                        labelText: 'Tara rezidenta fiscala'),
                  ),
                  TextFormField(
                    controller: bankController,
                    decoration: const InputDecoration(labelText: 'Cont bancar'),
                  ),
                  TextFormField(
                    controller: notesController,
                    decoration: const InputDecoration(labelText: 'Note'),
                    minLines: 2,
                    maxLines: 4,
                  ),
                ],
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(false),
              child: const Text('Renunță'),
            ),
            FilledButton(
              onPressed: () => Navigator.of(context).pop(true),
              child: const Text('Salveaza'),
            ),
          ],
        ),
      ),
    );
    if (confirmed != true) return;
    if (employeeId.trim().isEmpty) {
      setState(() {
        _message = 'Profilul HR trebuie legat de un angajat existent.';
      });
      return;
    }
    final employee = _employees.firstWhere(
      (item) => item.id.trim() == employeeId.trim(),
      orElse: () => selectedEmployee,
    );
    final seed = HrEmployeeProfile.fromEmployeeRecord(
      EmployeeRecord(
        id: employee.id,
        name: employee.name,
        role: employee.role,
        hourlyRate: employee.effectiveTarifOrar,
        internalHourlyCost: employee.effectiveTarifOrar,
        monthlySalaryOptional: employee.costLunar,
        perDiemPerDay: employee.dailyAllowance,
        lodgingPerDay: employee.defaultLodgingCost,
        active: employee.active,
        notes: '',
      ),
      teamId: employee.teamId,
      timestamp: existing?.createdAt ?? now,
    );
    final record = seed.copyWith(
      id: existing?.id ?? seed.id,
      fullName: fullNameController.text.trim().isEmpty
          ? employee.name.trim()
          : fullNameController.text.trim(),
      teamId: teamController.text.trim(),
      isActive: isActive,
      taxResidenceCountry: countryController.text.trim().isEmpty
          ? 'RO'
          : countryController.text.trim(),
      bankAccount: bankController.text.trim(),
      notes: notesController.text.trim(),
      createdAt: existing?.createdAt ?? seed.createdAt,
      updatedAt: now,
    );
    try {
      await _employeeService.upsertProfile(record);
      await _reload();
      if (!mounted) return;
      setState(() {
        _message = existing == null
            ? 'Profilul HR a fost salvat.'
            : 'Profilul HR a fost actualizat.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut salva profilul HR: $error';
      });
    }
  }

  List<HrLeaveRequest> get _monthLeaveRequests {
    final month = _selectedMonthStart;
    final rows = _leaveRequests.where((item) {
      if (item.startDate.year != month.year &&
          item.endDate.year != month.year) {
        return false;
      }
      final startsInMonth = item.startDate.year == month.year &&
          item.startDate.month == month.month;
      final endsInMonth =
          item.endDate.year == month.year && item.endDate.month == month.month;
      final spansMonth = item.startDate.isBefore(month) &&
          item.endDate.isAfter(DateTime(month.year, month.month + 1, 0));
      if (!(startsInMonth || endsInMonth || spansMonth)) {
        return false;
      }
      if (_leaveEmployeeFilter.trim().isNotEmpty &&
          item.employeeId.trim() != _leaveEmployeeFilter.trim()) {
        return false;
      }
      if (_leaveTypeFilter.trim().isNotEmpty &&
          item.leaveTypeCode.trim() != _leaveTypeFilter.trim()) {
        return false;
      }
      return true;
    }).toList(growable: false);
    rows.sort((a, b) {
      final byDate = a.startDate.compareTo(b.startDate);
      if (byDate != 0) return byDate;
      return _employeeName(a.employeeId).compareTo(_employeeName(b.employeeId));
    });
    return rows;
  }

  Future<void> _refreshLeaveSummary() async {
    if (_leaveEmployeeFilter.trim().isEmpty) {
      if (!mounted) return;
      setState(() {
        _leaveSummary = null;
      });
      return;
    }
    final summary = await _leaveService.summarizeInterval(
      employeeId: _leaveEmployeeFilter.trim(),
      dateFrom: DateTime(_selectedMonth.year, _selectedMonth.month, 1),
      dateTo: DateTime(_selectedMonth.year, _selectedMonth.month + 1, 0),
    );
    if (!mounted) return;
    setState(() {
      _leaveSummary = summary;
    });
  }

  Future<void> _openPayrollMonth(
    DateTime month, {
    GlobalKey? targetKey,
  }) async {
    final normalized = DateTime(month.year, month.month, 1);
    setState(() {
      _selectedMonth = normalized;
    });
    await _reload();
    if (targetKey != null && mounted) {
      await _scrollToSection(targetKey);
    }
  }

  HrLeaveType? _leaveTypeByCode(String code) {
    for (final item in _leaveTypes) {
      if (item.code.trim() == code.trim()) return item;
    }
    return null;
  }

  List<HrPayrollInputSnapshot> get _conflictSnapshots {
    return _snapshots.where((item) {
      final refs = item.sourceRefs;
      final ignored = refs['ignored_leave_attendance_entry_ids'];
      final conflicts = refs['leave_attendance_conflict_entry_ids'];
      final ignoredCount = ignored is List ? ignored.length : 0;
      final conflictCount = conflicts is List ? conflicts.length : 0;
      return ignoredCount > 0 || conflictCount > 0;
    }).toList(growable: false)
      ..sort((a, b) =>
          _employeeName(a.employeeId).compareTo(_employeeName(b.employeeId)));
  }

  List<String> _stringListFromSourceRef(dynamic raw) {
    if (raw is! List) return const <String>[];
    return raw
        .map((item) => item.toString().trim())
        .where((item) => item.isNotEmpty)
        .toList(growable: false);
  }

  HrAttendanceEntry? _attendanceById(String id) {
    final target = id.trim();
    if (target.isEmpty) return null;
    for (final item in _attendanceEntries) {
      if (item.id.trim() == target) return item;
    }
    return null;
  }

  HrLeaveRequest? _leaveRequestById(String id) {
    final target = id.trim();
    if (target.isEmpty) return null;
    for (final item in _leaveRequests) {
      if (item.id.trim() == target) return item;
    }
    return null;
  }

  void _focusAttendanceForEmployee(String employeeId) {
    setState(() {
      _attendanceEmployeeFilter = employeeId.trim();
    });
    _refreshAttendanceSummary();
  }

  void _focusLeaveForEmployee(String employeeId) {
    setState(() {
      _leaveEmployeeFilter = employeeId.trim();
      _leaveTypeFilter = '';
    });
    _refreshLeaveSummary();
  }

  HrEmployeeProfile? _profileForEmployee(String employeeId) {
    final target = employeeId.trim();
    for (final item in _profiles) {
      if (item.employeeId.trim() == target) return item;
    }
    return null;
  }

  List<HrAttendanceEntry> _attendanceForEmployee(String employeeId) {
    final target = employeeId.trim();
    return _monthAttendanceEntries
        .where((item) => item.employeeId.trim() == target)
        .toList(growable: false);
  }

  List<HrLeaveRequest> _leavesForEmployee(String employeeId) {
    final target = employeeId.trim();
    return _monthLeaveRequests
        .where((item) => item.employeeId.trim() == target)
        .toList(growable: false);
  }

  List<HrBonus> _bonusesForEmployee(String employeeId) {
    final target = employeeId.trim();
    return _monthBonuses
        .where((item) => item.employeeId.trim() == target)
        .toList(growable: false);
  }

  List<HrDeduction> _deductionsForEmployee(String employeeId) {
    final target = employeeId.trim();
    return _monthDeductions
        .where((item) => item.employeeId.trim() == target)
        .toList(growable: false);
  }

  List<HrAdvance> _advancesForEmployee(String employeeId) {
    final target = employeeId.trim();
    return _monthAdvances
        .where((item) => item.employeeId.trim() == target)
        .toList(growable: false);
  }

  List<HrGarnishment> _garnishmentsForEmployee(String employeeId) {
    final target = employeeId.trim();
    return _monthGarnishments
        .where((item) => item.employeeId.trim() == target)
        .toList(growable: false);
  }

  HrPayslip? _latestPayslipForEmployee(String employeeId) {
    final target = employeeId.trim();
    final rows = _payslips
        .where((item) => item.employeeId.trim() == target)
        .toList(growable: false);
    if (rows.isEmpty) return null;
    rows.sort((a, b) {
      final byMonth = b.payrollMonth.compareTo(a.payrollMonth);
      if (byMonth != 0) return byMonth;
      return b.generatedAt.compareTo(a.generatedAt);
    });
    return rows.first;
  }

  void _showEmployeeHrSheet(String employeeId) {
    final employee = _employees.cast<MasterEmployee?>().firstWhere(
          (item) => item?.id.trim() == employeeId.trim(),
          orElse: () => null,
        );
    final profile = _profileForEmployee(employeeId);
    final contract = _activeContractForEmployee(employeeId);
    final attendanceRows = _attendanceForEmployee(employeeId);
    final leaveRows = _leavesForEmployee(employeeId);
    final bonusRows = _bonusesForEmployee(employeeId);
    final deductionRows = _deductionsForEmployee(employeeId);
    final advanceRows = _advancesForEmployee(employeeId);
    final garnishmentRows = _garnishmentsForEmployee(employeeId);
    final payslip = _latestPayslipForEmployee(employeeId);

    final workedHours = attendanceRows.fold<double>(
      0,
      (sum, item) => sum + item.workedHours,
    );
    final overtimeHours = attendanceRows.fold<double>(
      0,
      (sum, item) => sum + item.overtimeHours,
    );
    final nightHours = attendanceRows.fold<double>(
      0,
      (sum, item) => sum + item.nightHours,
    );
    final leaveHours = attendanceRows.fold<double>(
      0,
      (sum, item) => sum + item.leaveHours,
    );

    Widget section(String title, List<Widget> children) {
      return Container(
        width: double.infinity,
        margin: const EdgeInsets.only(bottom: 12),
        padding: const EdgeInsets.all(12),
        decoration: BoxDecoration(
          border: Border.all(color: Theme.of(context).dividerColor),
          borderRadius: BorderRadius.circular(8),
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(title, style: Theme.of(context).textTheme.titleSmall),
            const SizedBox(height: 8),
            ...children,
          ],
        ),
      );
    }

    Widget line(String label, String value) => Padding(
          padding: const EdgeInsets.only(bottom: 6),
          child: Text('$label: $value'),
        );

    List<Widget> leaveLines = leaveRows.isEmpty
        ? [line('Concedii', 'Nu exista cereri in luna selectata.')]
        : leaveRows
            .map(
              (item) => line(
                item.leaveTypeCode,
                '${_formatDate(item.startDate)} - ${_formatDate(item.endDate)} | '
                '${_formatMoney(item.workingDays)} zile lucr. | ${_orDash(item.status)}',
              ),
            )
            .toList(growable: false);

    List<Widget> variableLines(
      String emptyLabel,
      List<String> rows,
    ) {
      if (rows.isEmpty) {
        return [line(emptyLabel, 'Nu exista in luna selectata.')];
      }
      return rows.map((item) => line('-', item)).toList(growable: false);
    }

    showDialog<void>(
      context: context,
      builder: (context) => AlertDialog(
        title: Text('Fisa angajat HR - ${_employeeName(employeeId)}'),
        content: SizedBox(
          width: 820,
          child: SingleChildScrollView(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                section('Date generale', [
                  line(
                      'Nume',
                      profile?.fullName.trim().isNotEmpty == true
                          ? profile!.fullName
                          : _employeeName(employeeId)),
                  line('Echipa',
                      _orDash(profile?.teamId ?? employee?.teamId ?? '')),
                  line(
                    'Status',
                    (profile?.isActive ?? employee?.active ?? false)
                        ? 'activ'
                        : 'inactiv',
                  ),
                  line(
                    'Rezidenta fiscala',
                    _orDash(profile?.taxResidenceCountry ?? ''),
                  ),
                  line('Cont bancar', _orDash(profile?.bankAccount ?? '')),
                ]),
                section('Contract activ', [
                  line('Tip contract', _orDash(contract?.contractType ?? '')),
                  line('Functie', _orDash(contract?.jobTitle ?? '')),
                  line(
                    'Norma',
                    contract == null
                        ? '-'
                        : '${_formatMoney(contract.employmentNormHoursPerDay)} h/zi | '
                            '${_formatMoney(contract.employmentNormHoursPerWeek)} h/sapt.',
                  ),
                  line(
                    'Salariu brut',
                    contract == null
                        ? '-'
                        : '${_formatMoney(contract.baseSalaryGross)} ${contract.currency}',
                  ),
                  line(
                    'Perioada',
                    contract == null
                        ? '-'
                        : '${_formatDate(contract.startDate)} - '
                            '${contract.endDate == null ? '-' : _formatDate(contract.endDate!)}',
                  ),
                  line('Status', _orDash(contract?.status ?? '')),
                ]),
                section('Pontaj pe luna selectata', [
                  line('Ore lucrate', _formatMoney(workedHours)),
                  line('Ore suplimentare', _formatMoney(overtimeHours)),
                  line('Ore de noapte', _formatMoney(nightHours)),
                  line('Ore concediu', _formatMoney(leaveHours)),
                ]),
                section('Concedii pe luna selectata', leaveLines),
                section(
                  'Componente variabile pe luna selectata',
                  [
                    ...variableLines(
                      'Bonusuri',
                      bonusRows
                          .map(
                            (item) =>
                                '${_orDash(item.bonusType)} | ${_formatMoney(item.amount)} ${item.currency} | ${_orDash(item.status)}',
                          )
                          .toList(growable: false),
                    ),
                    ...variableLines(
                      'Retineri',
                      deductionRows
                          .map(
                            (item) =>
                                '${_orDash(item.deductionType)} | ${_formatMoney(item.amountValue)} ${item.currency} | ${_orDash(item.status)}',
                          )
                          .toList(growable: false),
                    ),
                    ...variableLines(
                      'Avansuri',
                      advanceRows
                          .map(
                            (item) =>
                                '${_formatMoney(item.amount)} ${item.currency} | ${_orDash(item.status)}',
                          )
                          .toList(growable: false),
                    ),
                    ...variableLines(
                      'Popriri',
                      garnishmentRows
                          .map(
                            (item) =>
                                '${_orDash(item.garnishmentType)} | ${_formatMoney(item.amountValue)} ${item.currency} | ${_orDash(item.status)}',
                          )
                          .toList(growable: false),
                    ),
                  ],
                ),
                section('Ultimul fluturas de salariu disponibil', [
                  line(
                    'Luna',
                    payslip == null ? '-' : _formatMonth(payslip.payrollMonth),
                  ),
                  line(
                    'Net final',
                    payslip == null
                        ? '-'
                        : '${_formatMoney(payslip.netFinal)} ${payslip.currency}',
                  ),
                  line('Status', _orDash(payslip?.status ?? '')),
                ]),
              ],
            ),
          ),
        ),
        actions: [
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _focusAttendanceForEmployee(employeeId);
              _scrollToSection(_attendanceSectionKey);
            },
            child: const Text('Deschide pontaj'),
          ),
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _focusLeaveForEmployee(employeeId);
              _scrollToSection(_leaveSectionKey);
            },
            child: const Text('Deschide concedii'),
          ),
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _scrollToSection(_overviewSectionKey);
            },
            child: const Text('Deschide salarizare'),
          ),
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('Închide'),
          ),
        ],
      ),
    );
  }

  List<MasterEmployee> get _activeEmployees {
    final rows =
        _employees.where((item) => item.active).toList(growable: false);
    rows.sort((a, b) => a.name.compareTo(b.name));
    return rows;
  }

  List<MasterEmployee> get _employeesWithoutHrProfile {
    return _activeEmployees
        .where(
          (item) => !_profiles.any(
            (profile) => profile.employeeId.trim() == item.id.trim(),
          ),
        )
        .toList(growable: false);
  }

  List<HrEmployeeProfile> get _profilesWithoutActiveContract {
    return _profiles
        .where((item) => item.isActive)
        .where((item) => _activeContractForEmployee(item.employeeId) == null)
        .toList(growable: false)
      ..sort((a, b) => a.fullName.compareTo(b.fullName));
  }

  List<String> get _employeesWithUnapprovedAttendance {
    final ids = <String>{};
    for (final item in _monthAttendanceEntries) {
      final status = item.status.trim().toLowerCase();
      if (status == 'approved' ||
          status == 'rejected' ||
          status == 'cancelled') {
        continue;
      }
      ids.add(item.employeeId.trim());
    }
    final rows = ids.toList(growable: false)
      ..sort((a, b) => _employeeName(a).compareTo(_employeeName(b)));
    return rows;
  }

  List<String> get _employeesWithUnapprovedLeaves {
    final ids = <String>{};
    for (final item in _monthLeaveRequests) {
      final status = item.status.trim().toLowerCase();
      if (status == 'approved' ||
          status == 'rejected' ||
          status == 'cancelled') {
        continue;
      }
      ids.add(item.employeeId.trim());
    }
    final rows = ids.toList(growable: false)
      ..sort((a, b) => _employeeName(a).compareTo(_employeeName(b)));
    return rows;
  }

  List<String> get _employeesWithConflicts {
    final ids = _conflictSnapshots
        .map((item) => item.employeeId.trim())
        .where((item) => item.isNotEmpty)
        .toSet()
        .toList(growable: false)
      ..sort((a, b) => _employeeName(a).compareTo(_employeeName(b)));
    return ids;
  }

  List<HrPayrollRun> get _payrollHistoryRuns {
    final rows = _allRuns.toList(growable: false)
      ..sort((a, b) => b.payrollMonth.compareTo(a.payrollMonth));
    return rows;
  }

  List<HrPayslip> _payslipsForMonth(DateTime month) {
    final normalized = DateTime(month.year, month.month, 1);
    return _allPayslips
        .where(
          (item) =>
              item.payrollMonth.year == normalized.year &&
              item.payrollMonth.month == normalized.month,
        )
        .toList(growable: false);
  }

  List<HrPayrollAccountingReport> _accountingReportsForMonth(DateTime month) {
    final normalized = DateTime(month.year, month.month, 1);
    return _allAccountingReports
        .where(
          (item) =>
              item.payrollMonth.year == normalized.year &&
              item.payrollMonth.month == normalized.month,
        )
        .toList(growable: false);
  }

  List<MasterEmployee> get _eligibleEmployeesForPayroll {
    final blocked = <String>{
      ..._employeesWithoutHrProfile.map((item) => item.id.trim()),
      ..._profilesWithoutActiveContract.map((item) => item.employeeId.trim()),
      ..._employeesWithUnapprovedAttendance,
      ..._employeesWithUnapprovedLeaves,
      ..._employeesWithConflicts,
    };
    return _activeEmployees
        .where((item) => !blocked.contains(item.id.trim()))
        .toList(growable: false);
  }

  List<String> get _blockedEmployeesForPayroll {
    final ids = <String>{
      ..._employeesWithoutHrProfile.map((item) => item.id.trim()),
      ..._profilesWithoutActiveContract.map((item) => item.employeeId.trim()),
      ..._employeesWithUnapprovedAttendance,
      ..._employeesWithUnapprovedLeaves,
      ..._employeesWithConflicts,
    }.toList(growable: false)
      ..sort((a, b) => _employeeName(a).compareTo(_employeeName(b)));
    return ids;
  }

  Future<void> _scrollToSection(GlobalKey key) async {
    final context = key.currentContext;
    if (context == null) return;
    await Scrollable.ensureVisible(
      context,
      duration: const Duration(milliseconds: 250),
      curve: Curves.easeInOut,
      alignment: 0.08,
    );
  }

  String _shortNames(Iterable<String> names, {int max = 5}) {
    final rows = names
        .map((item) => item.trim())
        .where((item) => item.isNotEmpty)
        .toList(growable: false);
    if (rows.isEmpty) return '-';
    if (rows.length <= max) return rows.join(', ');
    return '${rows.take(max).join(', ')} +${rows.length - max}';
  }

  Future<void> _editHrContract([HrContract? existing]) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti administra contractele HR.',
      );
      return;
    }
    if (_profiles.isEmpty) {
      setState(() {
        _message = 'Adauga mai intai un profil HR.';
      });
      return;
    }
    final now = DateTime.now();
    String profileId = existing?.hrEmployeeProfileId.isNotEmpty == true
        ? existing!.hrEmployeeProfileId
        : _profiles.first.id;
    HrEmployeeProfile selectedProfile = _profiles.firstWhere(
      (item) => item.id.trim() == profileId.trim(),
      orElse: () => _profiles.first,
    );
    String contractType = existing?.contractType ?? 'cim';
    String jobTitle =
        existing?.jobTitle ?? _employeeRole(selectedProfile.employeeId);
    String currency = existing?.currency ?? 'RON';
    String status = existing?.status ?? 'active';
    String jurisdiction = existing?.payrollRuleJurisdiction ?? 'RO';
    bool isChildcareLeave = existing?.isChildcareLeave ?? false;
    final hoursDayController = TextEditingController(
      text: (existing?.employmentNormHoursPerDay ?? 8).toStringAsFixed(2),
    );
    final hoursWeekController = TextEditingController(
      text: (existing?.employmentNormHoursPerWeek ?? 40).toStringAsFixed(2),
    );
    final salaryController = TextEditingController(
      text: existing == null ? '' : existing.baseSalaryGross.toStringAsFixed(2),
    );
    DateTime startDate = existing?.startDate ?? _selectedMonthStart;
    DateTime? endDate = existing?.endDate;
    DateTime? childcareLeaveStartDate = existing?.childcareLeaveStartDate;
    DateTime? childcareLeaveEndDate = existing?.childcareLeaveEndDate;
    final confirmed = await showDialog<bool>(
      context: context,
      builder: (context) => StatefulBuilder(
        builder: (context, setLocalState) => AlertDialog(
          title:
              Text(existing == null ? 'Adauga contract' : 'Editeaza contract'),
          content: SizedBox(
            width: 500,
            child: SingleChildScrollView(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  DropdownButtonFormField<String>(
                    initialValue: profileId,
                    decoration: const InputDecoration(labelText: 'Profil HR'),
                    items: _profiles
                        .map(
                          (item) => DropdownMenuItem<String>(
                            value: item.id,
                            child: Text(item.fullName),
                          ),
                        )
                        .toList(growable: false),
                    onChanged: (value) {
                      if (value == null) return;
                      final next = _profiles.firstWhere(
                        (item) => item.id.trim() == value.trim(),
                        orElse: () => selectedProfile,
                      );
                      setLocalState(() {
                        profileId = value;
                        selectedProfile = next;
                        if (existing == null) {
                          jobTitle = _employeeRole(next.employeeId);
                        }
                      });
                    },
                  ),
                  TextFormField(
                    initialValue: contractType,
                    decoration:
                        const InputDecoration(labelText: 'Tip contract'),
                    onChanged: (value) => contractType = value,
                  ),
                  TextFormField(
                    initialValue: jobTitle,
                    decoration: const InputDecoration(labelText: 'Functie'),
                    onChanged: (value) => jobTitle = value,
                  ),
                  TextFormField(
                    controller: hoursDayController,
                    decoration:
                        const InputDecoration(labelText: 'Norma ore/zi'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  TextFormField(
                    controller: hoursWeekController,
                    decoration:
                        const InputDecoration(labelText: 'Norma ore/saptamana'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  TextFormField(
                    controller: salaryController,
                    decoration: const InputDecoration(
                        labelText: 'Salariu brut de baza'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: currency,
                    decoration: const InputDecoration(labelText: 'Moneda'),
                    items: const [
                      DropdownMenuItem(value: 'RON', child: Text('RON')),
                      DropdownMenuItem(value: 'EUR', child: Text('EUR')),
                    ],
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => currency = value);
                      }
                    },
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: status,
                    decoration: const InputDecoration(labelText: 'Status'),
                    items: const [
                      DropdownMenuItem(value: 'active', child: Text('Activ')),
                      DropdownMenuItem(value: 'draft', child: Text('Ciorna')),
                      DropdownMenuItem(
                          value: 'inactive', child: Text('Inactiv')),
                      DropdownMenuItem(
                        value: 'terminated',
                        child: Text('Incetat'),
                      ),
                    ],
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => status = value);
                      }
                    },
                  ),
                  TextFormField(
                    initialValue: jurisdiction,
                    decoration: const InputDecoration(
                        labelText: 'Jurisdictie salarizare'),
                    onChanged: (value) => jurisdiction = value,
                  ),
                  const SizedBox(height: 8),
                  CheckboxListTile(
                    value: isChildcareLeave,
                    contentPadding: EdgeInsets.zero,
                    title: const Text('Concediu crestere copil (CCC)'),
                    subtitle: const Text(
                      'Pe lunile din interval, pontajul se completeaza automat cu CCC, iar salarizarea ramane la venit 0.',
                    ),
                    onChanged: (value) {
                      setLocalState(() {
                        isChildcareLeave = value ?? false;
                        if (!isChildcareLeave) {
                          childcareLeaveStartDate = null;
                          childcareLeaveEndDate = null;
                        }
                      });
                    },
                  ),
                  if (isChildcareLeave) ...[
                    Align(
                      alignment: Alignment.centerLeft,
                      child: Text(
                        'CCC început: ${childcareLeaveStartDate == null ? '-' : _formatMonth(childcareLeaveStartDate!)}',
                      ),
                    ),
                    Wrap(
                      spacing: 8,
                      children: [
                        TextButton(
                          onPressed: () async {
                            final picked = await showDatePicker(
                              context: context,
                              initialDate: childcareLeaveStartDate ?? startDate,
                              firstDate: DateTime(2020),
                              lastDate: DateTime(2100),
                            );
                            if (picked != null) {
                              setLocalState(() {
                                childcareLeaveStartDate = picked;
                              });
                            }
                          },
                          child: const Text('Alege data început CCC'),
                        ),
                        TextButton(
                          onPressed: () => setLocalState(
                              () => childcareLeaveStartDate = null),
                          child: const Text('Șterge'),
                        ),
                      ],
                    ),
                    Align(
                      alignment: Alignment.centerLeft,
                      child: Text(
                        'CCC sfarsit: ${childcareLeaveEndDate == null ? '-' : _formatMonth(childcareLeaveEndDate!)}',
                      ),
                    ),
                    Wrap(
                      spacing: 8,
                      children: [
                        TextButton(
                          onPressed: () async {
                            final picked = await showDatePicker(
                              context: context,
                              initialDate: childcareLeaveEndDate ??
                                  childcareLeaveStartDate ??
                                  startDate,
                              firstDate: DateTime(2020),
                              lastDate: DateTime(2100),
                            );
                            if (picked != null) {
                              setLocalState(() {
                                childcareLeaveEndDate = picked;
                              });
                            }
                          },
                          child: const Text('Alege data sfarsit CCC'),
                        ),
                        TextButton(
                          onPressed: () =>
                              setLocalState(() => childcareLeaveEndDate = null),
                          child: const Text('Fara sfarsit'),
                        ),
                      ],
                    ),
                  ],
                  const SizedBox(height: 8),
                  Align(
                    alignment: Alignment.centerLeft,
                    child: Text('Data început: ${_formatMonth(startDate)}'),
                  ),
                  TextButton(
                    onPressed: () async {
                      final picked = await showDatePicker(
                        context: context,
                        initialDate: startDate,
                        firstDate: DateTime(2020),
                        lastDate: DateTime(2100),
                      );
                      if (picked != null) {
                        setLocalState(() => startDate = picked);
                      }
                    },
                    child: const Text('Alege data început'),
                  ),
                  Align(
                    alignment: Alignment.centerLeft,
                    child: Text(
                      'Data sfârșit: ${endDate == null ? '-' : _formatMonth(endDate!)}',
                    ),
                  ),
                  Wrap(
                    spacing: 8,
                    children: [
                      TextButton(
                        onPressed: () async {
                          final picked = await showDatePicker(
                            context: context,
                            initialDate: endDate ?? startDate,
                            firstDate: DateTime(2020),
                            lastDate: DateTime(2100),
                          );
                          if (picked != null) {
                            setLocalState(() => endDate = picked);
                          }
                        },
                        child: const Text('Alege data sfarsit'),
                      ),
                      TextButton(
                        onPressed: () => setLocalState(() => endDate = null),
                        child: const Text('Fara sfarsit'),
                      ),
                    ],
                  ),
                ],
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(false),
              child: const Text('Renunță'),
            ),
            FilledButton(
              onPressed: () => Navigator.of(context).pop(true),
              child: const Text('Salveaza'),
            ),
          ],
        ),
      ),
    );
    if (confirmed != true) return;
    if (profileId.trim().isEmpty) {
      setState(() {
        _message = 'Contractul trebuie legat de un profil HR.';
      });
      return;
    }
    final salary =
        double.tryParse(salaryController.text.trim().replaceAll(',', '.')) ?? 0;
    if (salary <= 0) {
      setState(() {
        _message = 'Salariul brut de baza este obligatoriu.';
      });
      return;
    }
    if (isChildcareLeave && childcareLeaveStartDate == null) {
      setState(() {
        _message = 'Pentru CCC, data de început este obligatorie.';
      });
      return;
    }
    final hoursDay =
        double.tryParse(hoursDayController.text.trim().replaceAll(',', '.')) ??
            0;
    final hoursWeek = double.tryParse(
          hoursWeekController.text.trim().replaceAll(',', '.'),
        ) ??
        0;
    final record = HrContract(
      id: existing?.id ??
          'hr-contract-${selectedProfile.employeeId.trim()}-${DateTime.now().millisecondsSinceEpoch}',
      hrEmployeeProfileId: selectedProfile.id,
      employeeId: selectedProfile.employeeId,
      contractType: contractType.trim().isEmpty ? 'cim' : contractType.trim(),
      jobTitle: jobTitle.trim(),
      employmentNormHoursPerDay: hoursDay <= 0 ? 8 : hoursDay,
      employmentNormHoursPerWeek: hoursWeek <= 0 ? 40 : hoursWeek,
      baseSalaryGross: salary,
      currency: currency.trim().isEmpty ? 'RON' : currency.trim(),
      startDate: startDate,
      endDate: endDate,
      isChildcareLeave: isChildcareLeave,
      childcareLeaveStartDate: childcareLeaveStartDate,
      childcareLeaveEndDate: childcareLeaveEndDate,
      status: status.trim().isEmpty ? 'active' : status.trim(),
      payrollRuleJurisdiction:
          jurisdiction.trim().isEmpty ? 'RO' : jurisdiction.trim(),
      payrollRuleScopeDefaults: existing?.payrollRuleScopeDefaults ??
          const <String>['payroll', 'leave', 'medical_leave'],
      registryEntryId: existing?.registryEntryId ?? '',
      registryNumber: existing?.registryNumber ?? '',
      registeredAt: existing?.registeredAt,
      createdAt: existing?.createdAt ?? now,
      updatedAt: now,
    );
    try {
      HrContract savedRecord = record;
      await _employeeService.upsertContract(savedRecord);

      String successMessage = existing == null
          ? 'Contractul HR a fost salvat.'
          : 'Contractul HR a fost actualizat.';

      if (existing == null && savedRecord.registryEntryId.trim().isEmpty) {
        try {
          final entry = await _registryService.registerContract(
            contractId: savedRecord.id,
            documentNumber: savedRecord.id,
            title:
                'Contract HR ${_employeeName(savedRecord.employeeId)} - ${_orDash(savedRecord.jobTitle)}',
            recipientName: _employeeName(savedRecord.employeeId),
            documentDate: savedRecord.startDate,
            notes:
                'Contract HR nou inregistrat automat din modulul HR payroll.',
          );
          savedRecord = savedRecord.copyWith(
            registryEntryId: entry.id,
            registryNumber: entry.registryNumber,
            registeredAt: entry.registeredAt,
            updatedAt: DateTime.now(),
          );
          await _employeeService.upsertContract(savedRecord);
          successMessage =
              'Contractul HR a fost salvat si inregistrat in Registratura (${entry.registryNumber}).';
        } catch (registryError) {
          successMessage =
              'Contractul HR a fost salvat, dar inregistrarea in Registratura a esuat: $registryError';
        }
      }

      await _reload();
      if (!mounted) return;
      setState(() {
        _message = successMessage;
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut salva contractul HR: $error';
      });
    }
  }

  Widget _buildPayrollOverview() {
    final employeeCount = _payslips.length;
    final totalGross =
        _payslips.fold<double>(0, (sum, item) => sum + item.grossTotal);
    final totalCas =
        _payslips.fold<double>(0, (sum, item) => sum + item.casAmount);
    final totalCass =
        _payslips.fold<double>(0, (sum, item) => sum + item.cassAmount);
    final totalIncomeTax =
        _payslips.fold<double>(0, (sum, item) => sum + item.incomeTaxAmount);
    final totalDeductions =
        _payslips.fold<double>(0, (sum, item) => sum + item.deductionTotal);
    final totalNet =
        _payslips.fold<double>(0, (sum, item) => sum + item.netFinal);
    final totalMealTickets = _payslips.fold<double>(
        0, (sum, item) => sum + _mealTicketTotalForPayslip(item));

    Widget totalsChip(String label, double value) {
      return Chip(
        label: Text('$label: ${_formatMoney(value)}'),
      );
    }

    return Container(
        key: _overviewSectionKey,
        child: Card(
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Stat de plata - sumar',
                  style: Theme.of(context).textTheme.titleMedium,
                ),
                const SizedBox(height: 8),
                Align(
                  alignment: Alignment.centerLeft,
                  child: Wrap(
                    spacing: 8,
                    runSpacing: 8,
                    children: [
                      TextButton.icon(
                        onPressed: _exportMonthlyPayrollStatementPdf,
                        icon: const Icon(Icons.picture_as_pdf_outlined),
                        label: const Text('Export stat de plata PDF'),
                      ),
                      TextButton.icon(
                        onPressed: () =>
                            _exportMonthlyPayrollStatementPdf(saveAs: true),
                        icon: const Icon(Icons.save_as_outlined),
                        label: const Text('Salveaza ca...'),
                      ),
                      TextButton.icon(
                        onPressed: () =>
                            _exportMonthlyPayrollStatementPdf(share: true),
                        icon: const Icon(Icons.share_outlined),
                        label: const Text('Partajeaza'),
                      ),
                    ],
                  ),
                ),
                const SizedBox(height: 12),
                if (_payslips.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 12),
                    child: Text(
                        'Nu exista date de stat de plata pentru luna selectata.'),
                  )
                else ...[
                  SingleChildScrollView(
                    scrollDirection: Axis.horizontal,
                    child: DataTable(
                      columns: const [
                        DataColumn(label: Text('Angajat')),
                        DataColumn(label: Text('Functie')),
                        DataColumn(label: Text('Ore')),
                        DataColumn(label: Text('Brut total')),
                        DataColumn(label: Text('CAS')),
                        DataColumn(label: Text('CASS')),
                        DataColumn(label: Text('Impozit')),
                        DataColumn(label: Text('Tichete masa')),
                        DataColumn(label: Text('Retineri')),
                        DataColumn(label: Text('Net final')),
                        DataColumn(label: Text('Status')),
                      ],
                      rows: _payslips
                          .map(
                            (item) => DataRow(
                              cells: [
                                DataCell(Text(_employeeName(item.employeeId))),
                                DataCell(Text(_employeeRole(item.employeeId))),
                                DataCell(
                                  Text(
                                    '${_formatMoney(
                                      _asDouble(
                                        ((item.breakdown[
                                                        'attendance_leave_inputs']
                                                    as Map?)
                                                ?.cast<String, dynamic>() ??
                                            const <String,
                                                dynamic>{})['worked_hours'],
                                      ),
                                    )} h',
                                  ),
                                ),
                                DataCell(Text(_formatMoney(item.grossTotal))),
                                DataCell(Text(_formatMoney(item.casAmount))),
                                DataCell(Text(_formatMoney(item.cassAmount))),
                                DataCell(
                                    Text(_formatMoney(item.incomeTaxAmount))),
                                DataCell(
                                  Text(
                                    '${_formatMoney(_mealTicketTotalForPayslip(item))} (${_formatMoney(_mealTicketEligibleDaysForPayslip(item))} x ${_formatMoney(_mealTicketValuePerDayForPayslip(item))})',
                                  ),
                                ),
                                DataCell(
                                    Text(_formatMoney(item.deductionTotal))),
                                DataCell(Text(_formatMoney(item.netFinal))),
                                DataCell(Text(item.status.trim().isEmpty
                                    ? '-'
                                    : item.status)),
                              ],
                            ),
                          )
                          .toList(growable: false),
                    ),
                  ),
                  const SizedBox(height: 12),
                  Wrap(
                    spacing: 8,
                    runSpacing: 8,
                    children: [
                      Chip(label: Text('Angajati: $employeeCount')),
                      totalsChip('Total brut', totalGross),
                      totalsChip('Total CAS', totalCas),
                      totalsChip('Total CASS', totalCass),
                      totalsChip('Total impozit', totalIncomeTax),
                      totalsChip('Total tichete', totalMealTickets),
                      totalsChip('Total retineri', totalDeductions),
                      totalsChip('Total net', totalNet),
                    ],
                  ),
                ],
              ],
            ),
          ),
        ));
  }

  Widget _buildPayrollLockInfo() {
    final run = _run;
    if (run == null) {
      return const SizedBox.shrink();
    }
    final isLocked = run.isLocked;
    return Card(
      child: Padding(
        padding: const EdgeInsets.all(12),
        child: Row(
          children: [
            Icon(
              isLocked ? Icons.lock_outline : Icons.lock_open_outlined,
            ),
            const SizedBox(width: 8),
            Expanded(
              child: Text(
                isLocked
                    ? 'Luna salarizare este blocata. Blocata la ${_formatDateTime(run.lockedAt ?? run.updatedAt)}.'
                    : 'Luna salarizare este deblocata. Regenerarea si recalcularea sunt permise.',
              ),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildPayrollHistory() {
    final rows = _payrollHistoryRuns;
    final lockedCount = rows.where((item) => item.isLocked).length;
    final latestMonth = rows.isEmpty ? null : rows.first.payrollMonth;

    return Card(
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(
              'Istoric salarizare',
              style: Theme.of(context).textTheme.titleMedium,
            ),
            const SizedBox(height: 12),
            Wrap(
              spacing: 8,
              runSpacing: 8,
              children: [
                Chip(label: Text('Luni generate: ${rows.length}')),
                Chip(
                  label: Text(
                    'Ultima luna: ${latestMonth == null ? '-' : _formatMonth(latestMonth)}',
                  ),
                ),
                Chip(label: Text('Luni locked: $lockedCount')),
              ],
            ),
            const SizedBox(height: 12),
            if (rows.isEmpty)
              const Padding(
                padding: EdgeInsets.symmetric(vertical: 12),
                child: Text('Nu exista luni generate in istoric.'),
              )
            else
              ...rows.map((item) {
                final monthPayslips = _payslipsForMonth(item.payrollMonth);
                final monthReports =
                    _accountingReportsForMonth(item.payrollMonth);
                final hasStatement = monthPayslips.isNotEmpty;
                return Padding(
                  padding: const EdgeInsets.symmetric(vertical: 4),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text(
                        _formatMonth(item.payrollMonth),
                        style: Theme.of(context).textTheme.bodyMedium?.copyWith(
                              fontWeight: FontWeight.bold,
                            ),
                      ),
                      const SizedBox(height: 2),
                      Text(
                        'Run ${item.status} | ${item.employeeIds.length} angajați | '
                        'generat ${_formatDateTime(item.generatedAt)} | '
                        'centralizator ${monthReports.isEmpty ? 'nu' : 'da'} | '
                        'stat de plată ${hasStatement ? 'da' : 'nu'} | '
                        'fluturași ${monthPayslips.length}',
                        style: Theme.of(context).textTheme.bodySmall,
                      ),
                      const SizedBox(height: 4),
                      Wrap(
                        spacing: 8,
                        runSpacing: 4,
                        children: [
                          TextButton(
                            onPressed: () =>
                                _openPayrollMonth(item.payrollMonth),
                            child: const Text('Deschide luna'),
                          ),
                          TextButton(
                            onPressed: monthReports.isEmpty
                                ? null
                                : () => _openPayrollMonth(
                                      item.payrollMonth,
                                      targetKey: _accountingReportsSectionKey,
                                    ),
                            child: const Text('Vezi centralizator'),
                          ),
                          TextButton(
                            onPressed: hasStatement
                                ? () => _openPayrollMonth(
                                      item.payrollMonth,
                                      targetKey: _overviewSectionKey,
                                    )
                                : null,
                            child: const Text('Vezi stat de plată'),
                          ),
                          TextButton(
                            onPressed: monthPayslips.isEmpty
                                ? null
                                : () => _openPayrollMonth(
                                      item.payrollMonth,
                                      targetKey: _payslipsSectionKey,
                                    ),
                            child: const Text('Vezi fluturași de salariu'),
                          ),
                        ],
                      ),
                      const Divider(),
                    ],
                  ),
                );
              }),
          ],
        ),
      ),
    );
  }

  Widget _buildHeader() {
    final isLocked = _run?.isLocked == true;
    final roleLabel = (_currentRole ?? UserRole.admin).label;
    return Card(
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Wrap(
          crossAxisAlignment: WrapCrossAlignment.center,
          spacing: 12,
          runSpacing: 12,
          children: [
            OutlinedButton.icon(
              onPressed: _loading || _generating ? null : _pickMonth,
              icon: const Icon(Icons.calendar_month_outlined),
              label: Text('Luna: ${_formatMonth(_selectedMonth)}'),
            ),
            FilledButton.icon(
              onPressed: _generating || isLocked || !_canManageSensitiveHr
                  ? null
                  : _generatePayroll,
              icon: const Icon(Icons.playlist_add_check_circle_outlined),
              label: Text(
                  _generating ? 'Se genereaza...' : 'Genereaza salarizare'),
            ),
            OutlinedButton.icon(
              onPressed: _loading ? null : _syncFromMonthlyTimesheet,
              icon: const Icon(Icons.sync_alt_outlined),
              label: const Text('Preia din pontaj'),
            ),
            OutlinedButton.icon(
              onPressed:
                  _generatingAccounting || isLocked || !_canManageSensitiveHr
                      ? null
                      : _generateAccountingReport,
              icon: const Icon(Icons.summarize_outlined),
              label: Text(
                _generatingAccounting
                    ? 'Se genereaza centralizatorul...'
                    : 'Genereaza centralizator contabilitate',
              ),
            ),
            OutlinedButton.icon(
              onPressed: _loading ? null : _openMonthlyTimesheet,
              icon: const Icon(Icons.table_chart_outlined),
              label: const Text('Pontaj lunar tabelar'),
            ),
            OutlinedButton.icon(
              onPressed: _loading ? null : _reload,
              icon: const Icon(Icons.refresh_outlined),
              label: const Text('Reincarca'),
            ),
            OutlinedButton.icon(
              onPressed: _run == null || !_canManageSensitiveHr
                  ? null
                  : _togglePayrollLock,
              icon: Icon(
                isLocked ? Icons.lock_open_outlined : Icons.lock_outline,
              ),
              label: Text(isLocked ? 'Deblocheaza luna' : 'Blocheaza luna'),
            ),
            Chip(
              avatar: const Icon(Icons.verified_user_outlined, size: 18),
              label: Text('Rol: $roleLabel'),
            ),
            Chip(
              avatar: const Icon(Icons.storage_outlined, size: 18),
              label: Text('Sursa: ${_runService.dataSourceLabel}'),
            ),
            if ((_runService.fallbackReason ?? '').isNotEmpty)
              Chip(
                avatar: const Icon(Icons.cloud_off_outlined, size: 18),
                label: Text('Fallback: ${_runService.fallbackReason}'),
              ),
            Chip(
              avatar: const Icon(Icons.table_chart_outlined, size: 18),
              label: Text(
                'Pontaj importat: ${_timesheetImportedSnapshotsForMonth.length}',
              ),
            ),
            if (_run != null)
              Chip(
                avatar: Icon(
                  _run!.isLocked ? Icons.lock_outline : Icons.task_alt_outlined,
                  size: 18,
                ),
                label: Text(
                  'Run: ${_run!.status} • ${_run!.employeeIds.length} angajati',
                ),
              ),
            if (!_canViewFinancialHr)
              const Chip(
                avatar: Icon(Icons.lock_outline, size: 18),
                label: Text('Acces HR limitat'),
              ),
          ],
        ),
      ),
    );
  }

  Widget _buildPayrollResults() {
    final isLocked = _run?.isLocked == true;
    return Container(
        key: _validationSectionKey,
        child: Card(
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Rezultate salarizare',
                  style: Theme.of(context).textTheme.titleMedium,
                ),
                const SizedBox(height: 12),
                if (_results.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 12),
                    child: Text(
                        'Nu exista rezultate salarizare pentru luna selectata.'),
                  )
                else
                  ..._results.map(
                    (item) => ListTile(
                      contentPadding: EdgeInsets.zero,
                      title: Text(_employeeName(item.employeeId)),
                      subtitle: Text(
                        'Brut ${_formatMoney(item.grossTotalTaxable)} | CAS ${_formatMoney(item.employeeCasAmount)} | '
                        'CASS ${_formatMoney(item.employeeCassAmount)} | Impozit ${_formatMoney(item.incomeTaxAmount)} | '
                        'Net ${_formatMoney(item.netFinal)} | '
                        'Tichete ${_formatMoney(_asDouble(((item.breakdown['meal_tickets'] as Map?)?.cast<String, dynamic>() ?? const <String, dynamic>{})['total_value']))}',
                      ),
                      trailing: Wrap(
                        spacing: 8,
                        children: [
                          Text(
                            _formatDateTime(item.calculatedAt),
                            style: Theme.of(context).textTheme.bodySmall,
                          ),
                          IconButton(
                            tooltip: 'Vezi fisa',
                            onPressed: () =>
                                _showEmployeeHrSheet(item.employeeId),
                            icon: const Icon(Icons.badge_outlined),
                          ),
                          IconButton(
                            tooltip: 'Recalculeaza',
                            onPressed: isLocked
                                ? null
                                : () => _recalculateEmployee(item.employeeId),
                            icon: const Icon(Icons.refresh_outlined),
                          ),
                          IconButton(
                            tooltip: 'Vezi detalii',
                            onPressed: () => _showBreakdown(
                              'Payroll ${_employeeName(item.employeeId)}',
                              item.breakdown,
                              item.sourceRefs,
                            ),
                            icon: const Icon(Icons.visibility_outlined),
                          ),
                        ],
                      ),
                    ),
                  ),
              ],
            ),
          ),
        ));
  }

  Widget _buildPayslips() {
    return Container(
        key: _payslipsSectionKey,
        child: Card(
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Fluturasi de salariu generati',
                  style: Theme.of(context).textTheme.titleMedium,
                ),
                const SizedBox(height: 12),
                if (_payslips.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 12),
                    child: Text(
                        'Nu exista fluturasi de salariu pentru luna selectata.'),
                  )
                else
                  ..._payslips.map(
                    (item) => ListTile(
                      contentPadding: EdgeInsets.zero,
                      title: Text(_employeeName(item.employeeId)),
                      subtitle: Text(
                        'Luna ${_formatMonth(item.payrollMonth)} | Net ${_formatMoney(item.netFinal)} | '
                        'Tichete ${_formatMoney(_mealTicketTotalForPayslip(item))} | '
                        'Status ${item.status}',
                      ),
                      trailing: Wrap(
                        spacing: 8,
                        children: [
                          Text(
                            _formatDateTime(item.generatedAt),
                            style: Theme.of(context).textTheme.bodySmall,
                          ),
                          IconButton(
                            tooltip: 'Vezi fisa',
                            onPressed: () =>
                                _showEmployeeHrSheet(item.employeeId),
                            icon: const Icon(Icons.badge_outlined),
                          ),
                          IconButton(
                            tooltip: 'Export PDF',
                            onPressed: () => _exportPayslipPdf(item),
                            icon: const Icon(Icons.picture_as_pdf_outlined),
                          ),
                          IconButton(
                            tooltip: 'Salveaza ca...',
                            onPressed: () =>
                                _exportPayslipPdf(item, saveAs: true),
                            icon: const Icon(Icons.save_as_outlined),
                          ),
                          IconButton(
                            tooltip: 'Partajeaza',
                            onPressed: () =>
                                _exportPayslipPdf(item, share: true),
                            icon: const Icon(Icons.share_outlined),
                          ),
                          IconButton(
                            tooltip: 'Vezi detalii',
                            onPressed: () => _showPayslipDetails(item),
                            icon: const Icon(Icons.receipt_long_outlined),
                          ),
                        ],
                      ),
                    ),
                  ),
              ],
            ),
          ),
        ));
  }

  Widget _buildAccountingReports() {
    return Container(
        key: _accountingReportsSectionKey,
        child: Card(
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Centralizatoare contabilitate',
                  style: Theme.of(context).textTheme.titleMedium,
                ),
                const SizedBox(height: 12),
                if (_accountingReports.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 12),
                    child: Text(
                      'Nu exista centralizatoare de contabilitate pentru luna selectata.',
                    ),
                  )
                else
                  ..._accountingReports.map(
                    (item) {
                      final isApproved = item.status.trim() == 'approved';
                      return ListTile(
                        contentPadding: EdgeInsets.zero,
                        title: Text(
                          'Luna ${_formatMonth(item.payrollMonth)} • ${item.employeeCount} angajati',
                        ),
                        subtitle: Text(
                          'Brut ${_formatMoney((item.totals['gross_total'] as num?)?.toDouble() ?? 0)} | '
                          'CAS ${_formatMoney((item.totals['cas_amount'] as num?)?.toDouble() ?? 0)} | '
                          'CASS ${_formatMoney((item.totals['cass_amount'] as num?)?.toDouble() ?? 0)} | '
                          'Impozit ${_formatMoney((item.totals['income_tax_amount'] as num?)?.toDouble() ?? 0)} | '
                          'Net ${_formatMoney((item.totals['net_final'] as num?)?.toDouble() ?? 0)} | '
                          'Status ${item.status}',
                        ),
                        trailing: Wrap(
                          spacing: 8,
                          children: [
                            Text(
                              _formatDateTime(item.generatedAt),
                              style: Theme.of(context).textTheme.bodySmall,
                            ),
                            if (!isApproved)
                              TextButton(
                                onPressed: () =>
                                    _approveAccountingReport(item.id),
                                child: const Text('Aproba'),
                              ),
                            if (!isApproved)
                              TextButton(
                                onPressed: () =>
                                    _markAccountingReportNeedsReview(item.id),
                                child: const Text('Necesita revizie'),
                              ),
                            IconButton(
                              tooltip: 'Export PDF',
                              onPressed: () => _exportAccountingReportPdf(item),
                              icon: const Icon(Icons.picture_as_pdf_outlined),
                            ),
                            IconButton(
                              tooltip: 'Vezi detalii',
                              onPressed: () => _showBreakdown(
                                'Centralizator contabilitate ${_formatMonth(item.payrollMonth)}',
                                item.totals,
                                <String, dynamic>{
                                  'payroll_run_id': item.payrollRunId,
                                  'currency': item.currency,
                                  'line_items': item.lineItems,
                                  'approved_at':
                                      item.approvedAt?.toIso8601String() ?? '',
                                  'approved_by_user_id': item.approvedByUserId,
                                  'reviewed_at':
                                      item.reviewedAt?.toIso8601String() ?? '',
                                  'reviewed_by_user_id': item.reviewedByUserId,
                                  'review_notes': item.reviewNotes,
                                },
                              ),
                              icon: const Icon(Icons.list_alt_outlined),
                            ),
                          ],
                        ),
                      );
                    },
                  ),
              ],
            ),
          ),
        ));
  }

  Widget _buildVariablePayroll() {
    Widget sectionHeader(String title, VoidCallback onAdd) {
      return Row(
        children: [
          Expanded(
            child: Text(title, style: Theme.of(context).textTheme.titleSmall),
          ),
          TextButton.icon(
            onPressed: onAdd,
            icon: const Icon(Icons.add_circle_outline),
            label: const Text('Adauga'),
          ),
        ],
      );
    }

    Widget emptyText(String value) {
      return Padding(
        padding: const EdgeInsets.only(top: 4, bottom: 8),
        child: Text(value, style: Theme.of(context).textTheme.bodySmall),
      );
    }

    return Card(
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(
              'Componente variabile',
              style: Theme.of(context).textTheme.titleMedium,
            ),
            const SizedBox(height: 12),
            sectionHeader('Bonusuri', () => _editBonus()),
            if (_monthBonuses.isEmpty)
              emptyText('Nu exista bonusuri pentru luna selectata.')
            else
              ..._monthBonuses.map(
                (item) => ListTile(
                  dense: true,
                  contentPadding: EdgeInsets.zero,
                  title: Text(_employeeName(item.employeeId)),
                  subtitle: Text(
                    '${_orDash(item.bonusType)} | ${_formatMoney(item.amount)} ${item.currency} | ${_orDash(item.taxableMode)} | ${_orDash(item.status)}',
                  ),
                  trailing: IconButton(
                    tooltip: 'Editeaza',
                    onPressed: () => _editBonus(item),
                    icon: const Icon(Icons.edit_outlined),
                  ),
                ),
              ),
            const Divider(height: 24),
            sectionHeader('Retineri', () => _editDeduction()),
            if (_monthDeductions.isEmpty)
              emptyText('Nu exista retineri pentru luna selectata.')
            else
              ..._monthDeductions.map(
                (item) => ListTile(
                  dense: true,
                  contentPadding: EdgeInsets.zero,
                  title: Text(_employeeName(item.employeeId)),
                  subtitle: Text(
                    '${_orDash(item.deductionType)} | ${_formatMoney(item.amountValue)} ${item.currency} | ${_orDash(item.amountType)} | prioritate ${item.legalPriority} | ${_orDash(item.status)}',
                  ),
                  trailing: IconButton(
                    tooltip: 'Editeaza',
                    onPressed: () => _editDeduction(item),
                    icon: const Icon(Icons.edit_outlined),
                  ),
                ),
              ),
            const Divider(height: 24),
            sectionHeader('Avansuri', () => _editAdvance()),
            if (_monthAdvances.isEmpty)
              emptyText('Nu exista avansuri pentru luna selectata.')
            else
              ..._monthAdvances.map(
                (item) => ListTile(
                  dense: true,
                  contentPadding: EdgeInsets.zero,
                  title: Text(_employeeName(item.employeeId)),
                  subtitle: Text(
                    '${_formatMoney(item.amount)} ${item.currency} | recuperare ${_orDash(item.recoveryMode)} | ${_orDash(item.status)}',
                  ),
                  trailing: IconButton(
                    tooltip: 'Editeaza',
                    onPressed: () => _editAdvance(item),
                    icon: const Icon(Icons.edit_outlined),
                  ),
                ),
              ),
            const Divider(height: 24),
            sectionHeader('Popriri', () => _editGarnishment()),
            if (_monthGarnishments.isEmpty)
              emptyText('Nu exista popriri pentru luna selectata.')
            else
              ..._monthGarnishments.map(
                (item) => ListTile(
                  dense: true,
                  contentPadding: EdgeInsets.zero,
                  title: Text(_employeeName(item.employeeId)),
                  subtitle: Text(
                    '${_orDash(item.garnishmentType)} | ${_formatMoney(item.amountValue)} ${item.currency} | ${_orDash(item.amountType)} | prioritate ${item.legalPriority} | ${_orDash(item.status)}',
                  ),
                  trailing: IconButton(
                    tooltip: 'Editeaza',
                    onPressed: () => _editGarnishment(item),
                    icon: const Icon(Icons.edit_outlined),
                  ),
                ),
              ),
          ],
        ),
      ),
    );
  }

  Widget _buildPayrollValidationDashboard() {
    Widget itemCard({
      required String title,
      required int count,
      required String names,
      required VoidCallback onOpen,
    }) {
      return Container(
        width: 280,
        padding: const EdgeInsets.all(12),
        decoration: BoxDecoration(
          border: Border.all(color: Theme.of(context).dividerColor),
          borderRadius: BorderRadius.circular(8),
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(title, style: Theme.of(context).textTheme.titleSmall),
            const SizedBox(height: 8),
            Text('Numar: $count'),
            const SizedBox(height: 4),
            Text(
              names,
              style: Theme.of(context).textTheme.bodySmall,
            ),
            const SizedBox(height: 8),
            Align(
              alignment: Alignment.centerLeft,
              child: TextButton(
                onPressed: onOpen,
                child: const Text('Deschide'),
              ),
            ),
          ],
        ),
      );
    }

    final missingProfiles = _employeesWithoutHrProfile;
    final missingContracts = _profilesWithoutActiveContract;
    final unapprovedAttendance = _employeesWithUnapprovedAttendance;
    final unapprovedLeaves = _employeesWithUnapprovedLeaves;
    final conflicts = _employeesWithConflicts;
    final eligible = _eligibleEmployeesForPayroll;
    final blocked = _blockedEmployeesForPayroll;

    return Card(
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(
              'Validare înainte de salarizare',
              style: Theme.of(context).textTheme.titleMedium,
            ),
            const SizedBox(height: 12),
            Wrap(
              spacing: 12,
              runSpacing: 12,
              children: [
                itemCard(
                  title: 'Angajati fara profil HR',
                  count: missingProfiles.length,
                  names: _shortNames(missingProfiles.map((item) => item.name)),
                  onOpen: () => _scrollToSection(_hrAdminSectionKey),
                ),
                itemCard(
                  title: 'Profiluri fara contract activ',
                  count: missingContracts.length,
                  names: _shortNames(
                    missingContracts
                        .map((item) => _employeeName(item.employeeId)),
                  ),
                  onOpen: () => _scrollToSection(_hrAdminSectionKey),
                ),
                itemCard(
                  title: 'Pontaj neaprobat',
                  count: unapprovedAttendance.length,
                  names: _shortNames(
                      unapprovedAttendance.map((item) => _employeeName(item))),
                  onOpen: () => _scrollToSection(_attendanceSectionKey),
                ),
                itemCard(
                  title: 'Concedii neaprobate',
                  count: unapprovedLeaves.length,
                  names: _shortNames(
                      unapprovedLeaves.map((item) => _employeeName(item))),
                  onOpen: () => _scrollToSection(_leaveSectionKey),
                ),
                itemCard(
                  title: 'Conflicte concedii / pontaj',
                  count: conflicts.length,
                  names:
                      _shortNames(conflicts.map((item) => _employeeName(item))),
                  onOpen: () => _scrollToSection(_conflictsSectionKey),
                ),
                itemCard(
                  title: 'Angajati eligibili',
                  count: eligible.length,
                  names: _shortNames(eligible.map((item) => item.name)),
                  onOpen: () => _scrollToSection(_overviewSectionKey),
                ),
                itemCard(
                  title: 'Angajati blocati',
                  count: blocked.length,
                  names:
                      _shortNames(blocked.map((item) => _employeeName(item))),
                  onOpen: () => _scrollToSection(_hrAdminSectionKey),
                ),
              ],
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildHrAdmin() {
    return Container(
        key: _hrAdminSectionKey,
        child: Card(
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Administrare HR',
                  style: Theme.of(context).textTheme.titleMedium,
                ),
                const SizedBox(height: 12),
                Row(
                  children: [
                    Expanded(
                      child: Text(
                        'Profiluri HR',
                        style: Theme.of(context).textTheme.titleSmall,
                      ),
                    ),
                    TextButton.icon(
                      onPressed: _canManageSensitiveHr ? _editHrProfile : null,
                      icon: const Icon(Icons.add_circle_outline),
                      label: const Text('Adauga profil HR'),
                    ),
                  ],
                ),
                if (_profiles.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 8),
                    child: Text('Nu exista profiluri HR.'),
                  )
                else
                  ..._profiles.map((item) {
                    final activeContract =
                        _activeContractForEmployee(item.employeeId);
                    return ListTile(
                      dense: true,
                      contentPadding: EdgeInsets.zero,
                      title: Text(item.fullName.trim().isEmpty
                          ? item.employeeId
                          : item.fullName),
                      subtitle: Text(
                        'Angajat ${item.employeeId} | Echipa ${_orDash(item.teamId)} | '
                        'Status ${item.isActive ? 'activ' : 'inactiv'} | '
                        'Contract activ ${activeContract == null ? 'nu' : 'da'}',
                      ),
                      trailing: Wrap(
                        spacing: 8,
                        children: [
                          IconButton(
                            tooltip: 'Vezi fisa',
                            onPressed: () =>
                                _showEmployeeHrSheet(item.employeeId),
                            icon: const Icon(Icons.badge_outlined),
                          ),
                          IconButton(
                            tooltip: 'Editeaza profil HR',
                            onPressed: _canManageSensitiveHr
                                ? () => _editHrProfile(item)
                                : null,
                            icon: const Icon(Icons.edit_outlined),
                          ),
                        ],
                      ),
                    );
                  }),
                const Divider(height: 24),
                Row(
                  children: [
                    Expanded(
                      child: Text(
                        'Contracte HR',
                        style: Theme.of(context).textTheme.titleSmall,
                      ),
                    ),
                    TextButton.icon(
                      onPressed: _canManageSensitiveHr ? _editHrContract : null,
                      icon: const Icon(Icons.add_circle_outline),
                      label: const Text('Adauga contract'),
                    ),
                  ],
                ),
                if (_contracts.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 8),
                    child: Text('Nu exista contracte HR.'),
                  )
                else
                  ..._contracts.map(
                    (item) => ListTile(
                      dense: true,
                      contentPadding: EdgeInsets.zero,
                      title: Text(_employeeName(item.employeeId)),
                      subtitle: Text(
                        '${_orDash(item.contractType)} | ${_orDash(item.jobTitle)} | '
                        '${_formatMoney(item.baseSalaryGross)} ${item.currency} | '
                        'început ${_formatMonth(item.startDate)} | status ${_orDash(item.status)} | '
                        '${item.isChildcareLeave ? 'CCC ${item.childcareLeaveStartDate == null ? '' : 'din ${_formatMonth(item.childcareLeaveStartDate!)}'}${item.childcareLeaveEndDate == null ? '' : ' pana ${_formatMonth(item.childcareLeaveEndDate!)}'} | ' : ''}'
                        'Registratura ${item.registryNumber.trim().isEmpty ? 'neinregistrat' : item.registryNumber}'
                        '${item.registeredAt == null ? '' : ' | inregistrat ${_formatDateTime(item.registeredAt!)}'}',
                      ),
                      trailing: Wrap(
                        spacing: 8,
                        children: [
                          if (item.registryNumber.trim().isNotEmpty)
                            Chip(label: Text(item.registryNumber.trim())),
                          IconButton(
                            tooltip: 'Editeaza contract',
                            onPressed: _canManageSensitiveHr
                                ? () => _editHrContract(item)
                                : null,
                            icon: const Icon(Icons.edit_outlined),
                          ),
                        ],
                      ),
                    ),
                  ),
              ],
            ),
          ),
        ));
  }

  Widget _buildAttendance() {
    return Container(
        key: _attendanceSectionKey,
        child: Card(
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Expanded(
                      child: Text(
                        'Pontaj',
                        style: Theme.of(context).textTheme.titleMedium,
                      ),
                    ),
                    TextButton.icon(
                      onPressed: _canEditOperationalHr ? _editAttendance : null,
                      icon: const Icon(Icons.add_circle_outline),
                      label: const Text('Adauga pontaj'),
                    ),
                    const SizedBox(width: 8),
                    TextButton.icon(
                      onPressed: _attendanceEmployeeFilter.trim().isEmpty
                          ? null
                          : () => _exportAttendanceReportForEmployee(
                                _attendanceEmployeeFilter.trim(),
                              ),
                      icon: const Icon(Icons.picture_as_pdf_outlined),
                      label: const Text('Genereaza raport pontaj'),
                    ),
                  ],
                ),
                const SizedBox(height: 12),
                Wrap(
                  spacing: 12,
                  runSpacing: 12,
                  children: [
                    SizedBox(
                      width: 260,
                      child: DropdownButtonFormField<String>(
                        initialValue: _attendanceEmployeeFilter.trim().isEmpty
                            ? null
                            : _attendanceEmployeeFilter,
                        decoration:
                            const InputDecoration(labelText: 'Filtru angajat'),
                        items: [
                          const DropdownMenuItem<String>(
                            value: '',
                            child: Text('Toti angajatii'),
                          ),
                          ..._profiles.map(
                            (item) => DropdownMenuItem<String>(
                              value: item.employeeId,
                              child: Text(item.fullName),
                            ),
                          ),
                        ],
                        onChanged: (value) async {
                          setState(() {
                            _attendanceEmployeeFilter = value ?? '';
                          });
                          await _refreshAttendanceSummary();
                        },
                      ),
                    ),
                    Chip(
                      avatar: const Icon(Icons.storage_outlined, size: 18),
                      label:
                          Text('Sursa: ${_attendanceService.dataSourceLabel}'),
                    ),
                    if ((_attendanceService.fallbackReason ?? '').isNotEmpty)
                      Chip(
                        avatar: const Icon(Icons.cloud_off_outlined, size: 18),
                        label: Text(
                          'Fallback: ${_attendanceService.fallbackReason}',
                        ),
                      ),
                  ],
                ),
                if (_attendanceEmployeeFilter.trim().isNotEmpty &&
                    _attendanceSummary != null) ...[
                  const SizedBox(height: 12),
                  Wrap(
                    spacing: 8,
                    runSpacing: 8,
                    children: [
                      Chip(
                        label: Text(
                          'Ore lucrate: ${_formatMoney(_attendanceSummary!.workedHours)}',
                        ),
                      ),
                      Chip(
                        label: Text(
                          'Ore suplimentare: ${_formatMoney(_attendanceSummary!.overtimeHours)}',
                        ),
                      ),
                      Chip(
                        label: Text(
                          'Ore noapte: ${_formatMoney(_attendanceSummary!.nightHours)}',
                        ),
                      ),
                      Chip(
                        label: Text(
                          'Ore concediu: ${_formatMoney(_attendanceSummary!.leaveHours)}',
                        ),
                      ),
                    ],
                  ),
                ],
                const SizedBox(height: 12),
                if (_monthAttendanceEntries.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 8),
                    child: Text(
                        'Nu exista intrari de pontaj pentru filtrul curent.'),
                  )
                else
                  ..._monthAttendanceEntries.map(
                    (item) {
                      final normalizedStatus = item.status.trim().toLowerCase();
                      final canEdit = normalizedStatus != 'approved' &&
                          normalizedStatus != 'rejected';
                      return ListTile(
                        dense: true,
                        contentPadding: EdgeInsets.zero,
                        title: Text(
                          '${_employeeName(item.employeeId)} | ${item.date.day.toString().padLeft(2, '0')}.${item.date.month.toString().padLeft(2, '0')}.${item.date.year}',
                        ),
                        subtitle: Text(
                          'Lucrate ${_formatMoney(item.workedHours)} | Supl. ${_formatMoney(item.overtimeHours)} | '
                          'Noapte ${_formatMoney(item.nightHours)} | Concediu ${_formatMoney(item.leaveHours)} | '
                          'Status ${_orDash(item.status)} | Sursa ${_orDash(item.sourceType)}',
                        ),
                        trailing: Wrap(
                          spacing: 8,
                          children: [
                            if (normalizedStatus == 'draft' ||
                                normalizedStatus == 'needs_review')
                              TextButton(
                                onPressed: _canEditOperationalHr
                                    ? () => _submitAttendanceEntry(item.id)
                                    : null,
                                child: const Text('Trimite'),
                              ),
                            if (normalizedStatus == 'submitted' ||
                                normalizedStatus == 'needs_review')
                              TextButton(
                                onPressed: _canApproveOperationalHr
                                    ? () => _approveAttendanceEntry(item.id)
                                    : null,
                                child: const Text('Aproba'),
                              ),
                            if (normalizedStatus == 'submitted')
                              TextButton(
                                onPressed: _canApproveOperationalHr
                                    ? () =>
                                        _markAttendanceEntryNeedsReview(item.id)
                                    : null,
                                child: const Text('Necesita revizie'),
                              ),
                            if (normalizedStatus == 'submitted' ||
                                normalizedStatus == 'needs_review')
                              TextButton(
                                onPressed: _canApproveOperationalHr
                                    ? () => _rejectAttendanceEntry(item.id)
                                    : null,
                                child: const Text('Respinge'),
                              ),
                            IconButton(
                              tooltip: 'Editeaza pontaj',
                              onPressed: canEdit && _canEditOperationalHr
                                  ? () => _editAttendance(item)
                                  : null,
                              icon: const Icon(Icons.edit_outlined),
                            ),
                          ],
                        ),
                      );
                    },
                  ),
              ],
            ),
          ),
        ));
  }

  Widget _buildLeaveRequests() {
    return Container(
        key: _leaveSectionKey,
        child: Card(
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Expanded(
                      child: Text(
                        'Concedii',
                        style: Theme.of(context).textTheme.titleMedium,
                      ),
                    ),
                    TextButton.icon(
                      onPressed:
                          _canEditOperationalHr ? _editLeaveRequest : null,
                      icon: const Icon(Icons.add_circle_outline),
                      label: const Text('Adauga concediu'),
                    ),
                    const SizedBox(width: 8),
                    TextButton.icon(
                      onPressed: _exportApprovedLeaveMonthlyReport,
                      icon: const Icon(Icons.picture_as_pdf_outlined),
                      label: const Text('Genereaza raport concedii'),
                    ),
                  ],
                ),
                const SizedBox(height: 12),
                Wrap(
                  spacing: 12,
                  runSpacing: 12,
                  children: [
                    SizedBox(
                      width: 240,
                      child: DropdownButtonFormField<String>(
                        initialValue: _leaveEmployeeFilter.trim().isEmpty
                            ? null
                            : _leaveEmployeeFilter,
                        decoration:
                            const InputDecoration(labelText: 'Filtru angajat'),
                        items: [
                          const DropdownMenuItem<String>(
                            value: '',
                            child: Text('Toti angajatii'),
                          ),
                          ..._profiles.map(
                            (item) => DropdownMenuItem<String>(
                              value: item.employeeId,
                              child: Text(item.fullName),
                            ),
                          ),
                        ],
                        onChanged: (value) async {
                          setState(() {
                            _leaveEmployeeFilter = value ?? '';
                          });
                          await _refreshLeaveSummary();
                        },
                      ),
                    ),
                    SizedBox(
                      width: 220,
                      child: DropdownButtonFormField<String>(
                        initialValue: _leaveTypeFilter.trim().isEmpty
                            ? null
                            : _leaveTypeFilter,
                        decoration: const InputDecoration(
                            labelText: 'Filtru tip concediu'),
                        items: [
                          const DropdownMenuItem<String>(
                            value: '',
                            child: Text('Toate tipurile'),
                          ),
                          ..._leaveTypes.map(
                            (item) => DropdownMenuItem<String>(
                              value: item.code,
                              child: Text(item.code),
                            ),
                          ),
                        ],
                        onChanged: (value) {
                          setState(() {
                            _leaveTypeFilter = value ?? '';
                          });
                        },
                      ),
                    ),
                    Chip(
                      avatar: const Icon(Icons.storage_outlined, size: 18),
                      label: Text('Sursa: ${_leaveService.dataSourceLabel}'),
                    ),
                    if ((_leaveService.fallbackReason ?? '').isNotEmpty)
                      Chip(
                        avatar: const Icon(Icons.cloud_off_outlined, size: 18),
                        label:
                            Text('Fallback: ${_leaveService.fallbackReason}'),
                      ),
                  ],
                ),
                if (_leaveEmployeeFilter.trim().isNotEmpty &&
                    _leaveSummary != null) ...[
                  const SizedBox(height: 12),
                  Wrap(
                    spacing: 8,
                    runSpacing: 8,
                    children: [
                      Chip(
                        label: Text(
                          'Total zile lucratoare: ${_formatMoney(_leaveSummary!.totalWorkingDays)}',
                        ),
                      ),
                      Chip(
                        label: Text(
                          'Total zile calendaristice: ${_formatMoney(_leaveSummary!.totalCalendarDays)}',
                        ),
                      ),
                      ..._leaveSummary!.workingDaysByType.entries.map(
                        (entry) => Chip(
                          label: Text(
                              '${entry.key}: ${_formatMoney(entry.value)} zile'),
                        ),
                      ),
                    ],
                  ),
                ],
                const SizedBox(height: 12),
                if (_monthLeaveRequests.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 8),
                    child: Text(
                        'Nu exista cereri de concediu pentru filtrul curent.'),
                  )
                else
                  ..._monthLeaveRequests.map(
                    (item) {
                      final normalizedStatus = item.status.trim().toLowerCase();
                      final canEdit = normalizedStatus != 'approved' &&
                          normalizedStatus != 'rejected';
                      return ListTile(
                        dense: true,
                        contentPadding: EdgeInsets.zero,
                        title: Text(
                          '${_employeeName(item.employeeId)} | ${item.leaveTypeCode}',
                        ),
                        subtitle: Text(
                          '${item.startDate.day.toString().padLeft(2, '0')}.${item.startDate.month.toString().padLeft(2, '0')}.${item.startDate.year} - '
                          '${item.endDate.day.toString().padLeft(2, '0')}.${item.endDate.month.toString().padLeft(2, '0')}.${item.endDate.year} | '
                          '${_formatMoney(item.calendarDays)} zile cal. | ${_formatMoney(item.workingDays)} zile lucr. | '
                          'Status ${_orDash(item.status)} | Doc ${_orDash(item.documentRef)} | Cod ${_orDash(item.medicalCode)}',
                        ),
                        trailing: Wrap(
                          spacing: 8,
                          children: [
                            if (normalizedStatus == 'draft' ||
                                normalizedStatus == 'needs_review')
                              TextButton(
                                onPressed: _canEditOperationalHr
                                    ? () => _submitLeaveRequest(item.id)
                                    : null,
                                child: const Text('Trimite'),
                              ),
                            if (normalizedStatus == 'submitted' ||
                                normalizedStatus == 'needs_review')
                              TextButton(
                                onPressed: _canApproveOperationalHr
                                    ? () => _approveLeaveRequest(item.id)
                                    : null,
                                child: const Text('Aproba'),
                              ),
                            if (normalizedStatus == 'submitted')
                              TextButton(
                                onPressed: _canApproveOperationalHr
                                    ? () =>
                                        _markLeaveRequestNeedsReview(item.id)
                                    : null,
                                child: const Text('Necesita revizie'),
                              ),
                            if (normalizedStatus == 'submitted' ||
                                normalizedStatus == 'needs_review')
                              TextButton(
                                onPressed: _canApproveOperationalHr
                                    ? () => _rejectLeaveRequest(item.id)
                                    : null,
                                child: const Text('Respinge'),
                              ),
                            IconButton(
                              tooltip: 'Genereaza cerere',
                              onPressed: () => _exportLeaveRequestPdf(item),
                              icon: const Icon(Icons.picture_as_pdf_outlined),
                            ),
                            IconButton(
                              tooltip: 'Editeaza concediu',
                              onPressed: canEdit && _canEditOperationalHr
                                  ? () => _editLeaveRequest(item)
                                  : null,
                              icon: const Icon(Icons.edit_outlined),
                            ),
                          ],
                        ),
                      );
                    },
                  ),
              ],
            ),
          ),
        ));
  }

  void _showLeaveAttendanceConflictDetails(HrPayrollInputSnapshot snapshot) {
    final ignoredIds = _stringListFromSourceRef(
      snapshot.sourceRefs['ignored_leave_attendance_entry_ids'],
    );
    final conflictIds = _stringListFromSourceRef(
      snapshot.sourceRefs['leave_attendance_conflict_entry_ids'],
    );
    final leaveIds =
        _stringListFromSourceRef(snapshot.sourceRefs['leave_request_ids']);

    Widget section(String title, List<Widget> children) {
      return Container(
        width: double.infinity,
        margin: const EdgeInsets.only(bottom: 12),
        padding: const EdgeInsets.all(12),
        decoration: BoxDecoration(
          border: Border.all(color: Theme.of(context).dividerColor),
          borderRadius: BorderRadius.circular(8),
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(title, style: Theme.of(context).textTheme.titleSmall),
            const SizedBox(height: 8),
            ...children,
          ],
        ),
      );
    }

    Widget line(String text) => Padding(
          padding: const EdgeInsets.only(bottom: 6),
          child: Text(text),
        );

    String attendanceLabel(String id) {
      final item = _attendanceById(id);
      if (item == null) return 'ID pontaj: $id';
      return '${item.date.day.toString().padLeft(2, '0')}.${item.date.month.toString().padLeft(2, '0')}.${item.date.year} | '
          'lucrate ${_formatMoney(item.workedHours)} | supl. ${_formatMoney(item.overtimeHours)} | '
          'noapte ${_formatMoney(item.nightHours)} | concediu ${_formatMoney(item.leaveHours)} | '
          'status ${_orDash(item.status)} | sursa ${_orDash(item.sourceType)} | id ${item.id}';
    }

    String leaveLabel(String id) {
      final item = _leaveRequestById(id);
      if (item == null) return 'ID concediu: $id';
      return '${item.leaveTypeCode} | ${item.startDate.day.toString().padLeft(2, '0')}.${item.startDate.month.toString().padLeft(2, '0')}.${item.startDate.year}'
          ' - ${item.endDate.day.toString().padLeft(2, '0')}.${item.endDate.month.toString().padLeft(2, '0')}.${item.endDate.year}'
          ' | ${_formatMoney(item.workingDays)} zile lucr. | status ${_orDash(item.status)} | id ${item.id}';
    }

    showDialog<void>(
      context: context,
      builder: (context) => AlertDialog(
        title: Text(
          'Conflicte concedii / pontaj - ${_employeeName(snapshot.employeeId)}',
        ),
        content: SizedBox(
          width: 760,
          child: SingleChildScrollView(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                section('Mesaj', [
                  line(
                    snapshot.notes.trim().isEmpty
                        ? 'Concediile sunt sursa oficiala pentru componenta de concediu in payroll.'
                        : snapshot.notes.trim(),
                  ),
                  line(
                    'Mod sursa concediu: ${snapshot.sourceRefs['leave_source_mode'] ?? 'monthly_timesheet_authoritative'}',
                  ),
                ]),
                section(
                  'Intrari de pontaj ignorate pentru concediu',
                  ignoredIds.isEmpty
                      ? [line('Nu exista intrari ignorate.')]
                      : ignoredIds
                          .map((id) => line(attendanceLabel(id)))
                          .toList(),
                ),
                section(
                  'Intrari de pontaj in conflict cu zile de concediu',
                  conflictIds.isEmpty
                      ? [line('Nu exista conflicte cu ore lucrate.')]
                      : conflictIds
                          .map((id) => line(attendanceLabel(id)))
                          .toList(),
                ),
                section(
                  'Cereri de concediu implicate',
                  leaveIds.isEmpty
                      ? [line('Nu exista referinte la cereri de concediu.')]
                      : leaveIds.map((id) => line(leaveLabel(id))).toList(),
                ),
              ],
            ),
          ),
        ),
        actions: [
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _exportAttendanceReportForEmployee(snapshot.employeeId);
            },
            child: const Text('Raport pontaj'),
          ),
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _focusAttendanceForEmployee(snapshot.employeeId);
              setState(() {
                _message =
                    'Filtrul de pontaj a fost setat pe ${_employeeName(snapshot.employeeId)}.';
              });
            },
            child: const Text('Deschide pontaj'),
          ),
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _focusLeaveForEmployee(snapshot.employeeId);
              setState(() {
                _message =
                    'Filtrul de concedii a fost setat pe ${_employeeName(snapshot.employeeId)}.';
              });
            },
            child: const Text('Deschide concediu'),
          ),
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('Închide'),
          ),
        ],
      ),
    );
  }

  Widget _buildLeaveAttendanceConflicts() {
    final rows = _conflictSnapshots;
    return Container(
        key: _conflictsSectionKey,
        child: Card(
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Conflicte concedii / pontaj',
                  style: Theme.of(context).textTheme.titleMedium,
                ),
                const SizedBox(height: 12),
                if (rows.isEmpty)
                  const Padding(
                    padding: EdgeInsets.symmetric(vertical: 8),
                    child: Text(
                      'Nu exista conflicte concedii / pontaj pentru luna selectata.',
                    ),
                  )
                else
                  ...rows.map((item) {
                    final ignoredIds = _stringListFromSourceRef(
                      item.sourceRefs['ignored_leave_attendance_entry_ids'],
                    );
                    final conflictIds = _stringListFromSourceRef(
                      item.sourceRefs['leave_attendance_conflict_entry_ids'],
                    );
                    final count = ignoredIds.length + conflictIds.length;
                    final shortMessage = conflictIds.isNotEmpty
                        ? 'Exista pontaj cu ore lucrate pe zile de concediu.'
                        : 'Exista intrari de pontaj ignorate pentru componenta de concediu.';
                    return ListTile(
                      contentPadding: EdgeInsets.zero,
                      title: Text(_employeeName(item.employeeId)),
                      subtitle: Text(
                        'Luna ${_formatMonth(item.payrollMonth)} | $count conflicte | $shortMessage',
                      ),
                      trailing: TextButton(
                        onPressed: () =>
                            _showLeaveAttendanceConflictDetails(item),
                        child: const Text('Vezi conflicte'),
                      ),
                    );
                  }),
              ],
            ),
          ),
        ));
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: RefreshIndicator(
        onRefresh: _reload,
        child: ListView(
          padding: const EdgeInsets.all(16),
          children: [
            _buildHeader(),
            if (_run != null) ...[
              const SizedBox(height: 12),
              _buildPayrollLockInfo(),
            ],
            if (_message != null) ...[
              const SizedBox(height: 12),
              Card(
                child: Padding(
                  padding: const EdgeInsets.all(12),
                  child: Text(_message!),
                ),
              ),
            ],
            const SizedBox(height: 12),
            if (_loading)
              const Card(
                child: Padding(
                  padding: EdgeInsets.all(24),
                  child: Center(child: CircularProgressIndicator()),
                ),
              )
            else ...[
              if (_canManageSensitiveHr) ...[
                _buildHrAdmin(),
                const SizedBox(height: 12),
                _buildPayrollValidationDashboard(),
                const SizedBox(height: 12),
              ] else
                Card(
                  child: Padding(
                    padding: const EdgeInsets.all(12),
                    child: Text(
                      !_canAccessHrModule
                          ? 'Acces restrictionat: rolul curent nu poate folosi modulul HR.'
                          : _canUseEmployeeSelfService
                              ? 'Self-service HR este disponibil pentru utilizatorul curent.'
                              : _canApproveOperationalHr
                                  ? 'Acces limitat in HR: poti lucra operational pe pontaj si concedii, fara salarii si documente financiare.'
                                  : _employeeHrSelfServiceEnabled
                                      ? 'Self-service HR este pregatit, dar nu este disponibil pentru rolul curent.'
                                      : 'Acces self-service HR pentru angajați este pregătit tehnic, dar rămâne dezactivat.',
                    ),
                  ),
                ),
              const SizedBox(height: 12),
              _buildAttendance(),
              const SizedBox(height: 12),
              _buildLeaveRequests(),
              const SizedBox(height: 12),
              _buildLeaveAttendanceConflicts(),
              if (_canViewFinancialHr) ...[
                const SizedBox(height: 12),
                _buildPayrollOverview(),
                const SizedBox(height: 12),
                _buildPayrollHistory(),
                const SizedBox(height: 12),
                _buildPayrollResults(),
                const SizedBox(height: 12),
                _buildPayslips(),
                const SizedBox(height: 12),
                _buildVariablePayroll(),
                const SizedBox(height: 12),
                _buildAccountingReports(),
              ],
            ],
          ],
        ),
      ),
    );
  }
}

enum _TimesheetImportStatus {
  noChanges,
  update,
  missingInTimesheet,
  missingInPayroll,
  ccc,
  noContract,
  noProfile;

  String get label {
    switch (this) {
      case _TimesheetImportStatus.noChanges:
        return 'fara modificari';
      case _TimesheetImportStatus.update:
        return 'se actualizeaza';
      case _TimesheetImportStatus.missingInTimesheet:
        return 'lipseste in pontaj';
      case _TimesheetImportStatus.missingInPayroll:
        return 'lipseste in payroll';
      case _TimesheetImportStatus.ccc:
        return 'CCC';
      case _TimesheetImportStatus.noContract:
        return 'fara contract activ';
      case _TimesheetImportStatus.noProfile:
        return 'fara profil HR';
    }
  }

  int get sortOrder {
    switch (this) {
      case _TimesheetImportStatus.noContract:
        return 0;
      case _TimesheetImportStatus.noProfile:
        return 1;
      case _TimesheetImportStatus.missingInTimesheet:
        return 2;
      case _TimesheetImportStatus.ccc:
        return 3;
      case _TimesheetImportStatus.missingInPayroll:
        return 4;
      case _TimesheetImportStatus.update:
        return 5;
      case _TimesheetImportStatus.noChanges:
        return 6;
    }
  }

  (Color, Color) colors(ColorScheme scheme) {
    switch (this) {
      case _TimesheetImportStatus.noChanges:
        return (scheme.surfaceContainerHighest, scheme.surfaceContainer);
      case _TimesheetImportStatus.update:
        return (scheme.primaryContainer, scheme.primaryContainer);
      case _TimesheetImportStatus.missingInTimesheet:
      case _TimesheetImportStatus.noContract:
      case _TimesheetImportStatus.noProfile:
        return (scheme.errorContainer, scheme.errorContainer);
      case _TimesheetImportStatus.missingInPayroll:
        return (scheme.secondaryContainer, scheme.secondaryContainer);
      case _TimesheetImportStatus.ccc:
        return (scheme.tertiaryContainer, scheme.tertiaryContainer);
    }
  }
}

class _TimesheetImportPreviewRow {
  const _TimesheetImportPreviewRow({
    required this.employeeId,
    required this.employeeName,
    required this.status,
    required this.snapshot,
    required this.timesheetRow,
    required this.profile,
    required this.contract,
    required this.currentWorkedHours,
    required this.newWorkedHours,
    required this.currentCoDays,
    required this.newCoDays,
    required this.currentCmDays,
    required this.newCmDays,
    required this.currentOtherLeaveDays,
    required this.newOtherLeaveDays,
    required this.currentLeaveHoursPaid,
    required this.newLeaveHoursPaid,
    required this.currentLeaveHoursUnpaid,
    required this.newLeaveHoursUnpaid,
    required this.codeCounts,
    required this.invDays,
    required this.absDays,
    required this.matDays,
    required this.stDays,
    required this.altDays,
    required this.cccDays,
    required this.isChildcareLeaveActive,
  });

  final String employeeId;
  final String employeeName;
  final _TimesheetImportStatus status;
  final HrPayrollInputSnapshot? snapshot;
  final MonthlyTimesheetEmployeeRow? timesheetRow;
  final HrEmployeeProfile? profile;
  final HrContract? contract;
  final double currentWorkedHours;
  final double newWorkedHours;
  final double currentCoDays;
  final double newCoDays;
  final double currentCmDays;
  final double newCmDays;
  final double currentOtherLeaveDays;
  final double newOtherLeaveDays;
  final double currentLeaveHoursPaid;
  final double newLeaveHoursPaid;
  final double currentLeaveHoursUnpaid;
  final double newLeaveHoursUnpaid;
  final Map<String, int> codeCounts;
  final double invDays;
  final double absDays;
  final double matDays;
  final double stDays;
  final double altDays;
  final double cccDays;
  final bool isChildcareLeaveActive;
}
