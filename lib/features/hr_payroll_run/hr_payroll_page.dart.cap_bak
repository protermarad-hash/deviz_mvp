class HrPayrollPage extends StatefulWidget {
  const HrPayrollPage({
    super.key,
    required this.repository,
    this.fieldAuthRoleKey,
  });

  // Valoarea plafonului zilnic legal implicit pentru tichete de masa (RON).
  // Sursa: HG 1507/2024 – valabil 2025/2026 pana la actualizare HG.
  static const double kDefaultMealTicketDailyCapRon = 40.96;

  final AppDataRepository repository;
  final String? fieldAuthRoleKey;

  @override
  State<HrPayrollPage> createState() => _HrPayrollPageState();
}

class _HrPayrollPageState extends State<HrPayrollPage> {
  late final HrPayrollRunCatalogService _runService;
  final HrPayrollCalculationCatalogService _calculationService =
      HrPayrollCalculationCatalogService();
  final HrPayrollInputCatalogService _payrollInputService =
      HrPayrollInputCatalogService();
  final HrEmployeeCatalogService _employeeService = HrEmployeeCatalogService();
  final HrAttendanceCatalogService _attendanceService =
      HrAttendanceCatalogService();
  final HrLeaveCatalogService _leaveService = HrLeaveCatalogService();
  final HrVariablePayrollCatalogService _variablePayrollService =
      HrVariablePayrollCatalogService();
  RegistryService get _registryService => RegistryService(widget.repository);
  final GlobalKey _validationSectionKey = GlobalKey();
  final GlobalKey _hrAdminSectionKey = GlobalKey();
  final GlobalKey _attendanceSectionKey = GlobalKey();
  final GlobalKey _leaveSectionKey = GlobalKey();
  final GlobalKey _conflictsSectionKey = GlobalKey();
  final GlobalKey _overviewSectionKey = GlobalKey();
  final GlobalKey _payslipsSectionKey = GlobalKey();
  final GlobalKey _accountingReportsSectionKey = GlobalKey();

  DateTime _selectedMonth = DateTime(DateTime.now().year, DateTime.now().month);
  bool _loading = true;
  bool _generating = false;
  bool _generatingAccounting = false;
  String? _message;
  HrPayrollRun? _run;
  List<HrPayrollRun> _allRuns = const <HrPayrollRun>[];
  List<HrPayrollCalculationResult> _results =
      const <HrPayrollCalculationResult>[];
  List<HrPayrollInputSnapshot> _snapshots = const <HrPayrollInputSnapshot>[];
  List<HrAttendanceEntry> _attendanceEntries = const <HrAttendanceEntry>[];
  List<HrLeaveType> _leaveTypes = const <HrLeaveType>[];
  List<HrLeaveRequest> _leaveRequests = const <HrLeaveRequest>[];
  List<HrPayslip> _payslips = const <HrPayslip>[];
  List<HrPayslip> _allPayslips = const <HrPayslip>[];
  List<HrPayrollAccountingReport> _accountingReports =
      const <HrPayrollAccountingReport>[];
  List<HrPayrollAccountingReport> _allAccountingReports =
      const <HrPayrollAccountingReport>[];
  List<HrBonus> _bonuses = const <HrBonus>[];
  List<HrDeduction> _deductions = const <HrDeduction>[];
  List<HrAdvance> _advances = const <HrAdvance>[];
  List<HrGarnishment> _garnishments = const <HrGarnishment>[];
  List<HrEmployeeProfile> _profiles = const <HrEmployeeProfile>[];
  List<HrContract> _contracts = const <HrContract>[];
  List<MasterEmployee> _employees = const <MasterEmployee>[];
  Map<String, HrEmployeeProfile> _profileByEmployeeId =
      const <String, HrEmployeeProfile>{};
  String _attendanceEmployeeFilter = '';
  HrAttendanceMonthlySummary? _attendanceSummary;
  String _leaveEmployeeFilter = '';
  String _leaveTypeFilter = '';
  HrLeaveIntervalSummary? _leaveSummary;

  AppSessionController? _sessionControllerMaybe(BuildContext context) {
    final element =
        context.getElementForInheritedWidgetOfExactType<AppSessionScope>();
    final widget = element?.widget;
    if (widget is AppSessionScope) {
      return widget.notifier;
    }
    return null;
  }

  UserRole? get _currentRole => AppRolePolicy.resolve(
        appRole: _sessionControllerMaybe(context)?.currentUser?.role,
        roleKey: widget.fieldAuthRoleKey,
      );

  bool get _canAccessHrModule => HrAccessPolicy.canAccessHrModule(_currentRole);

  bool get _canViewFinancialHr =>
      HrAccessPolicy.canViewFinancialHr(_currentRole);

  bool get _canManageSensitiveHr =>
      HrAccessPolicy.canManageSensitiveHr(_currentRole);

  bool get _canApproveOperationalHr =>
      HrAccessPolicy.canApproveOperationalHr(_currentRole);

  bool get _canEditOperationalHr =>
      HrAccessPolicy.canEditOperationalHr(_currentRole);

  bool get _employeeHrSelfServiceEnabled =>
      HrAccessPolicy.employeeHrSelfServiceEnabled;

  bool get _canUseEmployeeSelfService =>
      HrAccessPolicy.canUseEmployeeSelfService(_currentRole);

  AppUser? get _currentUser => _sessionControllerMaybe(context)?.currentUser;

  void _showRestrictedMessage(String message) {
    if (!mounted) return;
    setState(() {
      _message = message;
    });
  }

  Future<void> _openMonthlyTimesheet() async {
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (context) => HrMonthlyTimesheetPage(
          repository: widget.repository,
          currentUser: _currentUser,
        ),
      ),
    );
  }

  @override
  void initState() {
    super.initState();
    _runService = HrPayrollRunCatalogService(repository: widget.repository);
    _reload();
  }

  Future<List<MasterEmployee>> _listEmployeesResolved() async {
    if (!FirebaseBootstrap.isInitialized) {
      return MasterLocalStore.readEmployees();
    }
    try {
      final rows = await FirebaseAngajatiRepository().listEmployees();
      await MasterLocalStore.writeEmployees(rows);
      return rows;
    } catch (_) {
      return MasterLocalStore.readEmployees();
    }
  }

  Future<void> _reload() async {
    setState(() {
      _loading = true;
      _message = null;
    });
    try {
      final month = DateTime(_selectedMonth.year, _selectedMonth.month, 1);
      final profiles = await _employeeService.listProfiles();
      final contracts = await _employeeService.listContracts();
      final employees = await _listEmployeesResolved();
      final allRuns = await _runService.listRuns();
      final attendanceEntries = await _attendanceService.listEntries();
      final leaveTypes = await _leaveService.listLeaveTypes();
      final leaveRequests = await _leaveService.listLeaveRequests();
      final snapshots = await _payrollInputService.listSnapshotsForMonth(month);
      final run = await _runService.findRunForMonth(month);
      final results = await _calculationService.listResultsForMonth(month);
      final allPayslips = await _runService.listPayslips();
      final payslips = await _runService.listPayslipsForMonth(month);
      final allAccountingReports = await _runService.listAccountingReports();
      final accountingReports =
          await _runService.listAccountingReportsForMonth(month);
      final bonuses = await _variablePayrollService.listBonuses();
      final deductions = await _variablePayrollService.listDeductions();
      final advances = await _variablePayrollService.listAdvances();
      final garnishments = await _variablePayrollService.listGarnishments();
      if (!mounted) return;
      final defaultAttendanceEmployee =
          _attendanceEmployeeFilter.trim().isNotEmpty
              ? _attendanceEmployeeFilter.trim()
              : (profiles.isNotEmpty ? profiles.first.employeeId.trim() : '');
      final defaultLeaveEmployee = _leaveEmployeeFilter.trim().isNotEmpty
          ? _leaveEmployeeFilter.trim()
          : (profiles.isNotEmpty ? profiles.first.employeeId.trim() : '');
      HrAttendanceMonthlySummary? attendanceSummary;
      HrLeaveIntervalSummary? leaveSummary;
      if (defaultAttendanceEmployee.isNotEmpty) {
        attendanceSummary = await _attendanceService.summarizeMonth(
          employeeId: defaultAttendanceEmployee,
          month: month,
        );
      }
      if (defaultLeaveEmployee.isNotEmpty) {
        leaveSummary = await _leaveService.summarizeInterval(
          employeeId: defaultLeaveEmployee,
          dateFrom: DateTime(month.year, month.month, 1),
          dateTo: DateTime(month.year, month.month + 1, 0),
        );
      }
      setState(() {
        _run = run;
        _allRuns = allRuns;
        _results = results;
        _snapshots = snapshots;
        _attendanceEntries = attendanceEntries;
        _leaveTypes = leaveTypes;
        _leaveRequests = leaveRequests;
        _allPayslips = allPayslips;
        _payslips = payslips;
        _allAccountingReports = allAccountingReports;
        _accountingReports = accountingReports;
        _bonuses = bonuses;
        _deductions = deductions;
        _advances = advances;
        _garnishments = garnishments;
        _profiles = profiles;
        _contracts = contracts;
        _employees = employees;
        _profileByEmployeeId = <String, HrEmployeeProfile>{
          for (final item in profiles) item.employeeId.trim(): item,
        };
        _attendanceEmployeeFilter = defaultAttendanceEmployee;
        _attendanceSummary = attendanceSummary;
        _leaveEmployeeFilter = defaultLeaveEmployee;
        _leaveSummary = leaveSummary;
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut incarca salarizarea: $error';
      });
    } finally {
      if (mounted) {
        setState(() {
          _loading = false;
        });
      }
    }
  }

  Future<void> _generateAccountingReport() async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti genera centralizatorul contabil.',
      );
      return;
    }
    setState(() {
      _generatingAccounting = true;
      _message = null;
    });
    try {
      await _runService.generateAccountingReportForMonth(
        payrollMonth: _selectedMonth,
      );
      await _reload();
      if (!mounted) return;
      setState(() {
        _message =
            'Centralizator contabilitate generat pentru ${_formatMonth(_selectedMonth)}.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut genera centralizatorul: $error';
      });
    } finally {
      if (mounted) {
        setState(() {
          _generatingAccounting = false;
        });
      }
    }
  }

  Future<void> _togglePayrollLock() async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti bloca sau debloca luna salarizare.',
      );
      return;
    }
    final run = _run;
    if (run == null) {
      setState(() {
        _message = 'Nu exista rulare salarizare pentru luna selectata.';
      });
      return;
    }
    setState(() {
      _message = null;
    });
    try {
      if (run.isLocked) {
        await _runService.unlockPayrollMonth(payrollMonth: _selectedMonth);
      } else {
        await _runService.lockPayrollMonth(payrollMonth: _selectedMonth);
      }
      await _reload();
      if (!mounted) return;
      setState(() {
        _message = run.isLocked
            ? 'Luna salarizare a fost deblocata.'
            : 'Luna salarizare a fost blocata.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut actualiza blocarea lunii: $error';
      });
    }
  }

  Future<void> _approveAccountingReport(String reportId) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti aproba centralizatorul.',
      );
      return;
    }
    setState(() {
      _message = null;
    });
    try {
      await _runService.approveAccountingReport(reportId: reportId);
      await _reload();
      if (!mounted) return;
      setState(() {
        _message = 'Centralizatorul a fost aprobat.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut aproba centralizatorul: $error';
      });
    }
  }

  Future<void> _markAccountingReportNeedsReview(String reportId) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti marca centralizatorul pentru revizie.',
      );
      return;
    }
    setState(() {
      _message = null;
    });
    try {
      await _runService.markAccountingReportNeedsReview(reportId: reportId);
      await _reload();
      if (!mounted) return;
      setState(() {
        _message = 'Centralizatorul a fost marcat pentru revizie.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut marca centralizatorul pentru revizie: $error';
      });
    }
  }

  Future<void> _exportAccountingReportPdf(
      HrPayrollAccountingReport report) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti exporta centralizatorul contabil.',
      );
      return;
    }
    setState(() {
      _message = null;
    });
    try {
      final path = await HrPayrollAccountingReportPdfService.export(
        repository: widget.repository,
        report: report,
      );
      await _openGeneratedDocument(path);
      if (!mounted) return;
      setState(() {
        _message = 'Centralizator PDF exportat si deschis: $path';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut exporta PDF-ul: $error';
      });
    }
  }

  Future<void> _exportPayslipPdf(
    HrPayslip payslip, {
    bool share = false,
    bool saveAs = false,
  }) async {
    setState(() {
      _message = null;
    });
    try {
      final path = await HrPayslipPdfService.export(
        repository: widget.repository,
        payslip: payslip,
        employeeName: _employeeName(payslip.employeeId),
        saveAs: saveAs,
      );
      if (share) {
        await DocumentFileService.shareFile(
          path,
          subject:
              'Fluturas salariu ${_employeeName(payslip.employeeId)} ${_formatMonth(payslip.payrollMonth)}',
          text: 'Fluturas salariu generat din aplicatie.',
        );
      } else {
        await _openGeneratedDocument(path);
      }
      if (!mounted) return;
      setState(() {
        _message = share
            ? 'Fluturasul a fost generat si pregatit pentru partajare.'
            : saveAs
                ? 'Fluturasul a fost salvat (Salveaza ca...) si deschis: $path'
                : 'Fluturasul a fost exportat si deschis: $path';
      });
    } on PdfSaveCanceledException {
      if (!mounted) return;
      setState(() {
        _message = 'Salvarea fluturasului a fost anulata.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut exporta PDF-ul fluturasului: $error';
      });
    }
  }

  Future<void> _openGeneratedDocument(String filePath) async {
    final result = await DocumentFileService.openFile(filePath);
    if (!mounted || result.opened) {
      return;
    }
    if (DocumentFileService.supportsFolderOpen) {
      await DocumentFileService.openFolderForFile(filePath);
    }
    if (!mounted) {
      return;
    }
    setState(() {
      _message = '${result.message} Documentul a fost salvat la: $filePath';
    });
  }

  Future<void> _pickMonth() async {
    final picked = await showDatePicker(
      context: context,
      initialDate: _selectedMonth,
      firstDate: DateTime(2020),
      lastDate: DateTime(2100),
      helpText: 'Alege luna salarizare',
      fieldHintText: 'll/zz/aaaa',
    );
    if (picked == null) return;
    setState(() {
      _selectedMonth = DateTime(picked.year, picked.month, 1);
    });
    await _reload();
  }

  Map<String, bool> _mealTicketEligibilityRulesForSnapshot(
    HrPayrollInputSnapshot? snapshot,
  ) {
    return MealTicketEligibilityRules.normalize(
      snapshot?.mealTicketEligibilityRules ??
          MealTicketEligibilityRules.defaults,
    );
  }

  Map<String, double> _emptyMealTicketEligibilityBreakdown() {
    return <String, double>{
      for (final entry in MealTicketEligibilityRules.defaults.entries)
        entry.key: 0.0,
    };
  }

  Map<String, double> _mealTicketEligibilityBreakdownFromTimesheetRow(
    MonthlyTimesheetEmployeeRow? row,
  ) {
    final breakdown = _emptyMealTicketEligibilityBreakdown();
    if (row == null) {
      return breakdown;
    }
    for (final value in row.dayValues.values) {
      if (MonthlyTimesheetValueParser.hoursFromValue(value) > 0) {
        breakdown['worked_hours'] = (breakdown['worked_hours'] ?? 0.0) + 1.0;
        continue;
      }
      final code = MonthlyTimesheetValueParser.codeFromValue(value);
      if (code.isEmpty) {
        continue;
      }
      breakdown[code] = (breakdown[code] ?? 0.0) + 1.0;
    }
    return breakdown;
  }

  double _mealTicketEligibleDaysFromBreakdown(
    Map<String, double> breakdown,
    Map<String, bool> rules,
  ) {
    final normalizedRules = MealTicketEligibilityRules.normalize(rules);
    var total = 0.0;
    for (final entry in normalizedRules.entries) {
      if (!entry.value) {
        continue;
      }
      total += breakdown[entry.key] ?? 0.0;
    }
    return total;
  }

  Map<String, double> _mealTicketEligibilityBreakdownForSnapshot(
    HrPayrollInputSnapshot snapshot,
    HrContract contract, {
    MonthlyTimesheetEmployeeRow? timesheetRow,
  }) {
    final breakdown = _emptyMealTicketEligibilityBreakdown();
    if (contract.hasChildcareLeaveOverlapInMonth(snapshot.payrollMonth)) {
      breakdown['CCC'] = 1.0;
      return breakdown;
    }
    if (timesheetRow != null) {
      return _mealTicketEligibilityBreakdownFromTimesheetRow(timesheetRow);
    }
    final fromAttendance =
        _asDouble(snapshot.sourceRefs['attendance_worked_day_count']);
    if (fromAttendance > 0) {
      breakdown['worked_hours'] = fromAttendance;
      return breakdown;
    }
    final hoursPerDay = contract.employmentNormHoursPerDay > 0
        ? contract.employmentNormHoursPerDay
        : 8.0;
    if (hoursPerDay <= 0) {
      return breakdown;
    }
    breakdown['worked_hours'] =
        (snapshot.workedHours / hoursPerDay).roundToDouble();
    return breakdown;
  }

  String _mealTicketRuleLabel(String code) {
    switch (code) {
      case 'worked_hours':
        return 'Zile lucrate';
      case 'CO':
        return 'CO';
      case 'CM':
        return 'CM';
      case 'INV':
        return 'INV';
      case 'ABS':
        return 'ABS';
      case 'MAT':
        return 'MAT';
      case 'ST':
        return 'ST';
      case 'ALT':
        return 'ALT';
      case 'CCC':
        return 'CCC';
      default:
        return code;
    }
  }

  String _mealTicketRulesSummary(Map<String, bool> rules) {
    final normalizedRules = MealTicketEligibilityRules.normalize(rules);
    final included = normalizedRules.entries
        .where((entry) => entry.value)
        .map((entry) => _mealTicketRuleLabel(entry.key))
        .toList(growable: false);
    final excluded = normalizedRules.entries
        .where((entry) => !entry.value)
        .map((entry) => _mealTicketRuleLabel(entry.key))
        .toList(growable: false);
    final includedText = included.isEmpty ? '-' : included.join(', ');
    final excludedText = excluded.isEmpty ? '-' : excluded.join(', ');
    return 'Include: $includedText | Exclude: $excludedText';
  }

  String _mealTicketBreakdownSummary(Map<String, double> breakdown) {
    final parts = <String>[];
    for (final entry in breakdown.entries) {
      if (entry.value <= 0) {
        continue;
      }
      parts.add(
          '${_mealTicketRuleLabel(entry.key)} ${entry.value.toStringAsFixed(0)}');
    }
    return parts.isEmpty ? '-' : parts.join(', ');
  }

  Map<String, double> _resolveMealTicketAmounts({
    required bool enabled,
    required String mode,
    required double monthlyBudget,
    required double configuredEligibleDays,
    required double eligibleDays,
    required double fixedValuePerDay,
  }) {
    if (!enabled) {
      return const <String, double>{
        'value_per_day': 0.0,
        'total_value': 0.0,
      };
    }
    final valuePerDay = mode == 'fixed_value_per_ticket'
        ? fixedValuePerDay
        : configuredEligibleDays > 0
            ? monthlyBudget / configuredEligibleDays
            : 0.0;
    return <String, double>{
      'value_per_day': valuePerDay,
      'total_value': valuePerDay * eligibleDays,
    };
  }

  Future<void> _syncFromMonthlyTimesheet() async {
    if (!_canEditOperationalHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti prelua date din pontajul lunar.',
      );
      return;
    }
    final month = _selectedMonthStart;
    final currentUserId =
        _sessionControllerMaybe(context)?.currentUser?.id ?? '';
    final timesheets = await widget.repository.listMonthlyTimesheets();
    MonthlyTimesheetRecord? timesheet;
    for (final item in timesheets) {
      if (item.year == month.year && item.month == month.month) {
        timesheet = item.normalizeForMonth();
        break;
      }
    }
    if (timesheet == null) {
      if (!mounted) return;
      setState(() {
        _message =
            'Nu exista pontaj lunar tabelar pentru ${_formatMonth(month)}.';
      });
      return;
    }
    if (!mounted) return;

    final previewRows = await _buildTimesheetImportPreviewRows(
      timesheet: timesheet,
      month: month,
    );
    final shouldContinue = await _showTimesheetImportPreviewDialog(
      month: month,
      timesheet: timesheet,
      rows: previewRows,
    );
    if (shouldContinue != true) {
      return;
    }

    setState(() {
      _loading = true;
      _message = null;
    });
    try {
      var updatedCount = 0;
      var createdCount = 0;
      final skippedNoProfile = <String>[];
      final skippedNoContract = <String>[];
      final missingInTimesheet = <String>[];

      for (final preview in previewRows) {
        switch (preview.status) {
          case _TimesheetImportStatus.missingInTimesheet:
            missingInTimesheet.add(preview.employeeId);
            continue;
          case _TimesheetImportStatus.noProfile:
            skippedNoProfile.add(preview.employeeId);
            continue;
          case _TimesheetImportStatus.noContract:
            skippedNoContract.add(preview.employeeId);
            continue;
          case _TimesheetImportStatus.noChanges:
            continue;
          case _TimesheetImportStatus.update:
          case _TimesheetImportStatus.missingInPayroll:
          case _TimesheetImportStatus.ccc:
            break;
        }
        final row = preview.timesheetRow;
        final profile = preview.profile;
        final contract = preview.contract;
        if (row == null || profile == null || contract == null) {
          continue;
        }
        var snapshot = preview.snapshot ??
            await _payrollInputService.generateMonthlySnapshotForEmployee(
              employeeId: preview.employeeId,
              payrollMonth: month,
              generatedByUserId: currentUserId,
              notes: 'Snapshot initial generat pentru preluarea din pontaj.',
              timesheetRow: row,
            );
        if (snapshot == null) {
          skippedNoContract.add(preview.employeeId);
          continue;
        }
        final mealTicketEligibilityRules =
            _mealTicketEligibilityRulesForSnapshot(snapshot);
        final mealTicketEligibilityBreakdown =
            _mealTicketEligibilityBreakdownForSnapshot(
          snapshot,
          contract,
          timesheetRow: row,
        );
        final mealTicketEligibleDays = _mealTicketEligibleDaysFromBreakdown(
          mealTicketEligibilityBreakdown,
          mealTicketEligibilityRules,
        );
        final importedMonthlyBudget = row.mealTicketBudgetRon > 0
            ? row.mealTicketBudgetRon
            : (snapshot.mealTicketsMonthlyBudget > 0
                ? snapshot.mealTicketsMonthlyBudget
                : (mealTicketEligibleDays > 0
                    ? HrPayrollPage.kDefaultMealTicketDailyCapRon *
                        mealTicketEligibleDays
                    : 0.0));
        final importedMealTicketsEnabled =
            !preview.isChildcareLeaveActive && mealTicketEligibleDays > 0
                ? true
                : (row.mealTicketBudgetRon > 0
                    ? true
                    : snapshot.mealTicketsEnabled);
        final effectiveValuePerDay = snapshot.mealTicketValuePerDay > 0
            ? snapshot.mealTicketValuePerDay
            : HrPayrollPage.kDefaultMealTicketDailyCapRon;
        final mealTicketAmounts = _resolveMealTicketAmounts(
          enabled: importedMealTicketsEnabled,
          mode: snapshot.mealTicketCalculationMode,
          monthlyBudget: importedMonthlyBudget,
          configuredEligibleDays: snapshot.mealTicketConfiguredEligibleDays > 0
              ? snapshot.mealTicketConfiguredEligibleDays
              : mealTicketEligibleDays,
          eligibleDays: mealTicketEligibleDays,
          fixedValuePerDay: effectiveValuePerDay,
        );
        final updated = snapshot.copyWith(
          contractId: contract.id,
          hrEmployeeProfileId: profile.id,
          payrollMonth: month,
          workedHours: preview.newWorkedHours,
          leaveHoursPaid: preview.newLeaveHoursPaid,
          leaveHoursUnpaid: preview.newLeaveHoursUnpaid,
          vacationWorkingDays: preview.newCoDays,
          medicalLeaveWorkingDays: preview.newCmDays,
          otherLeaveWorkingDays: preview.newOtherLeaveDays,
          baseSalaryGross:
              preview.isChildcareLeaveActive ? 0 : snapshot.baseSalaryGross,
          bonusEntries: preview.isChildcareLeaveActive
              ? const <Map<String, dynamic>>[]
              : snapshot.bonusEntries,
          deductionEntries: preview.isChildcareLeaveActive
              ? const <Map<String, dynamic>>[]
              : snapshot.deductionEntries,
          allowanceEntries: preview.isChildcareLeaveActive
              ? const <Map<String, dynamic>>[]
              : snapshot.allowanceEntries,
          mealTicketsEnabled: preview.isChildcareLeaveActive
              ? false
              : importedMealTicketsEnabled,
          mealTicketsMonthlyBudget:
              preview.isChildcareLeaveActive ? 0.0 : importedMonthlyBudget,
          mealTicketEligibleDays:
              preview.isChildcareLeaveActive ? 0.0 : mealTicketEligibleDays,
          mealTicketsTotalValue: preview.isChildcareLeaveActive
              ? 0.0
              : (mealTicketAmounts['total_value'] ?? 0.0),
          mealTicketValuePerDay: preview.isChildcareLeaveActive
              ? 0.0
              : (mealTicketAmounts['value_per_day'] ?? 0.0),
          mealTicketEligibilityRules: mealTicketEligibilityRules,
          mealTicketEligibilityBreakdown: preview.isChildcareLeaveActive
              ? <String, double>{
                  for (final entry
                      in MealTicketEligibilityRules.defaults.entries)
                    entry.key: entry.key == 'CCC' ? 1.0 : 0.0,
                }
              : mealTicketEligibilityBreakdown,
          sourceRefs: <String, dynamic>{
            ...snapshot.sourceRefs,
            'is_childcare_leave_active': preview.isChildcareLeaveActive,
            'monthly_timesheet_record_id': timesheet.id,
            'monthly_timesheet_employee_id': row.employeeId,
            'monthly_timesheet_imported_at': DateTime.now().toIso8601String(),
            'meal_ticket_eligibility_rules': mealTicketEligibilityRules,
            'meal_ticket_eligibility_breakdown': preview.isChildcareLeaveActive
                ? <String, double>{
                    for (final entry
                        in MealTicketEligibilityRules.defaults.entries)
                      entry.key: entry.key == 'CCC' ? 1.0 : 0.0,
                  }
                : mealTicketEligibilityBreakdown,
            'meal_ticket_fiscal_treatment':
                snapshot.sourceRefs['meal_ticket_fiscal_treatment'] ??
                    'exempt_cas_subject_cass_subject_income_tax_10pct',
            'monthly_timesheet_counts': <String, dynamic>{
              'worked_hours': preview.newWorkedHours,
              'CO': preview.newCoDays,
              'CM': preview.newCmDays,
              'CCC': preview.cccDays,
              'INV': preview.invDays,
              'ABS': preview.absDays,
              'MAT': preview.matDays,
              'ST': preview.stDays,
              'ALT': preview.altDays,
            },
          },
          notes: _mergeImportedTimesheetNote(
            preview.isChildcareLeaveActive
                ? [snapshot.notes, '[CCC activ] snapshot pastrat la venit 0.']
                    .where((item) => item.trim().isNotEmpty)
                    .join('\n')
                : snapshot.notes,
            monthLabel: _formatMonth(month),
            workedHours: preview.newWorkedHours,
            codeCounts: preview.codeCounts,
          ),
          updatedAt: DateTime.now(),
        );
        await _payrollInputService.upsertSnapshot(updated);
        await _runService.generatePayslipForEmployeeMonth(
          employeeId: preview.employeeId,
          payrollMonth: month,
          generatedByUserId: currentUserId,
          notes: 'Snapshot actualizat din pontajul lunar.',
          timesheetRow: row,
        );
        if (preview.snapshot == null) {
          createdCount += 1;
        } else {
          updatedCount += 1;
        }
      }

      await _reload();
      if (!mounted) return;
      final parts = <String>[
        'Pontaj preluat pentru ${_formatMonth(month)}.',
        'Actualizate: $updatedCount.',
        'Create: $createdCount.',
      ];
      if (missingInTimesheet.isNotEmpty) {
        parts.add('Fara rand in pontaj: ${missingInTimesheet.length}.');
      }
      if (skippedNoProfile.isNotEmpty) {
        parts.add('Fara profil HR: ${skippedNoProfile.length}.');
      }
      if (skippedNoContract.isNotEmpty) {
        parts.add('Fara contract activ: ${skippedNoContract.length}.');
      }
      setState(() {
        _message = parts.join(' ');
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut prelua din pontaj: $error';
      });
    } finally {
      if (mounted) {
        setState(() {
          _loading = false;
        });
      }
    }
  }

  Future<List<_TimesheetImportPreviewRow>> _buildTimesheetImportPreviewRows({
    required MonthlyTimesheetRecord timesheet,
    required DateTime month,
  }) async {
    final rowByEmployeeId = <String, MonthlyTimesheetEmployeeRow>{
      for (final row in timesheet.rows) row.employeeId.trim(): row,
    };
    final snapshotByEmployeeId = <String, HrPayrollInputSnapshot>{
      for (final item in _snapshots) item.employeeId.trim(): item,
    };
    final targetIds = <String>{
      for (final item in _profiles) item.employeeId.trim(),
      ...rowByEmployeeId.keys,
      ...snapshotByEmployeeId.keys,
    }..removeWhere((item) => item.isEmpty);
    final rows = <_TimesheetImportPreviewRow>[];
    for (final employeeId in targetIds) {
      final row = rowByEmployeeId[employeeId];
      final snapshot = snapshotByEmployeeId[employeeId];
      final profile = _profileForEmployee(employeeId);
      final contract = _activeContractForEmployee(employeeId);
      final codeCounts = row?.codeCounts(
            MonthlyTimesheetCodeOption.defaults.map((option) => option.code),
          ) ??
          {
            for (final option in MonthlyTimesheetCodeOption.defaults)
              option.code: 0,
          };
      final hoursPerDay =
          contract != null && contract.employmentNormHoursPerDay > 0
              ? contract.employmentNormHoursPerDay
              : 8.0;
      final coDays = (codeCounts['CO'] ?? 0).toDouble();
      final cmDays = (codeCounts['CM'] ?? 0).toDouble();
      final invDays = (codeCounts['INV'] ?? 0).toDouble();
      final absDays = (codeCounts['ABS'] ?? 0).toDouble();
      final matDays = (codeCounts['MAT'] ?? 0).toDouble();
      final stDays = (codeCounts['ST'] ?? 0).toDouble();
      final altDays = (codeCounts['ALT'] ?? 0).toDouble();
      final cccDays = (codeCounts['CCC'] ?? 0).toDouble();
      final isChildcareLeaveActive = cccDays > 0 ||
          (contract?.hasChildcareLeaveOverlapInMonth(month) ?? false);
      final newWorkedHours =
          isChildcareLeaveActive ? 0.0 : (row?.totalWorkedHours ?? 0.0);
      final newLeaveHoursPaid = isChildcareLeaveActive
          ? 0.0
          : (coDays + cmDays + matDays) * hoursPerDay;
      final newLeaveHoursUnpaid = isChildcareLeaveActive
          ? 0.0
          : (invDays + absDays + stDays + altDays) * hoursPerDay;
      final newOtherLeaveDays = isChildcareLeaveActive
          ? 0.0
          : invDays + absDays + matDays + stDays + altDays;
      var ticketHasChanges = false;
      if (snapshot != null) {
        final mealTicketEligibilityRules =
            _mealTicketEligibilityRulesForSnapshot(snapshot);
        final mealTicketEligibilityBreakdown = isChildcareLeaveActive
            ? <String, double>{
                for (final entry in MealTicketEligibilityRules.defaults.entries)
                  entry.key: entry.key == 'CCC' ? 1.0 : 0.0,
              }
            : _mealTicketEligibilityBreakdownFromTimesheetRow(row);
        final mealTicketEligibleDays = isChildcareLeaveActive
            ? 0.0
            : _mealTicketEligibleDaysFromBreakdown(
                mealTicketEligibilityBreakdown,
                mealTicketEligibilityRules,
              );
        final importedMonthlyBudget = isChildcareLeaveActive
            ? 0.0
            : (row != null && row.mealTicketBudgetRon > 0
                ? row.mealTicketBudgetRon
                : (snapshot.mealTicketsMonthlyBudget > 0
                    ? snapshot.mealTicketsMonthlyBudget
                    : (mealTicketEligibleDays > 0
                        ? HrPayrollPage.kDefaultMealTicketDailyCapRon *
                            mealTicketEligibleDays
                        : 0.0)));
        final importedMealTicketsEnabled = isChildcareLeaveActive
            ? false
            : mealTicketEligibleDays > 0
                ? true
                : (row != null && row.mealTicketBudgetRon > 0
                    ? true
                    : snapshot.mealTicketsEnabled);
        final effectiveValuePerDay = snapshot.mealTicketValuePerDay > 0
            ? snapshot.mealTicketValuePerDay
            : HrPayrollPage.kDefaultMealTicketDailyCapRon;
        final mealTicketAmounts = _resolveMealTicketAmounts(
          enabled: importedMealTicketsEnabled,
          mode: snapshot.mealTicketCalculationMode,
          monthlyBudget: importedMonthlyBudget,
          configuredEligibleDays: snapshot.mealTicketConfiguredEligibleDays > 0
              ? snapshot.mealTicketConfiguredEligibleDays
              : mealTicketEligibleDays,
          eligibleDays: mealTicketEligibleDays,
          fixedValuePerDay: effectiveValuePerDay,
        );
        ticketHasChanges =
            snapshot.mealTicketsEnabled != importedMealTicketsEnabled ||
                !_sameDouble(
                  snapshot.mealTicketsMonthlyBudget,
                  importedMonthlyBudget,
                ) ||
                !_sameDouble(
                  snapshot.mealTicketEligibleDays,
                  mealTicketEligibleDays,
                ) ||
                !_sameDouble(
                  snapshot.mealTicketValuePerDay,
                  mealTicketAmounts['value_per_day'] ?? 0.0,
                ) ||
                !_sameDouble(
                  snapshot.mealTicketsTotalValue,
                  mealTicketAmounts['total_value'] ?? 0.0,
                );
      }
      final status = _resolveTimesheetImportStatus(
        row: row,
        snapshot: snapshot,
        profile: profile,
        contract: contract,
        isChildcareLeaveActive: isChildcareLeaveActive,
        newWorkedHours: newWorkedHours,
        newCoDays: isChildcareLeaveActive ? 0.0 : coDays,
        newCmDays: isChildcareLeaveActive ? 0.0 : cmDays,
        newOtherLeaveDays: newOtherLeaveDays,
        newLeaveHoursPaid: newLeaveHoursPaid,
        newLeaveHoursUnpaid: newLeaveHoursUnpaid,
        ticketHasChanges: ticketHasChanges,
      );
      rows.add(
        _TimesheetImportPreviewRow(
          employeeId: employeeId,
          employeeName: _employeeName(employeeId),
          status: status,
          snapshot: snapshot,
          timesheetRow: row,
          profile: profile,
          contract: contract,
          currentWorkedHours: snapshot?.workedHours ?? 0,
          newWorkedHours: newWorkedHours,
          currentCoDays: snapshot?.vacationWorkingDays ?? 0,
          newCoDays: isChildcareLeaveActive ? 0.0 : coDays,
          currentCmDays: snapshot?.medicalLeaveWorkingDays ?? 0,
          newCmDays: isChildcareLeaveActive ? 0.0 : cmDays,
          currentOtherLeaveDays: snapshot?.otherLeaveWorkingDays ?? 0,
          newOtherLeaveDays: newOtherLeaveDays,
          currentLeaveHoursPaid: snapshot?.leaveHoursPaid ?? 0,
          newLeaveHoursPaid: newLeaveHoursPaid,
          currentLeaveHoursUnpaid: snapshot?.leaveHoursUnpaid ?? 0,
          newLeaveHoursUnpaid: newLeaveHoursUnpaid,
          codeCounts: codeCounts,
          invDays: invDays,
          absDays: absDays,
          matDays: matDays,
          stDays: stDays,
          altDays: altDays,
          cccDays: cccDays,
          isChildcareLeaveActive: isChildcareLeaveActive,
        ),
      );
    }
    rows.sort((a, b) {
      final byStatus = a.status.sortOrder.compareTo(b.status.sortOrder);
      if (byStatus != 0) return byStatus;
      return a.employeeName
          .toLowerCase()
          .compareTo(b.employeeName.toLowerCase());
    });
    return rows;
  }

  _TimesheetImportStatus _resolveTimesheetImportStatus({
    required MonthlyTimesheetEmployeeRow? row,
    required HrPayrollInputSnapshot? snapshot,
    required HrEmployeeProfile? profile,
    required HrContract? contract,
    required bool isChildcareLeaveActive,
    required double newWorkedHours,
    required double newCoDays,
    required double newCmDays,
    required double newOtherLeaveDays,
    required double newLeaveHoursPaid,
    required double newLeaveHoursUnpaid,
    required bool ticketHasChanges,
  }) {
    if (profile == null) return _TimesheetImportStatus.noProfile;
    if (contract == null) return _TimesheetImportStatus.noContract;
    if (row == null) return _TimesheetImportStatus.missingInTimesheet;
    if (isChildcareLeaveActive) return _TimesheetImportStatus.ccc;
    if (snapshot == null) return _TimesheetImportStatus.missingInPayroll;
    final hasChanges = !_sameDouble(snapshot.workedHours, newWorkedHours) ||
        !_sameDouble(snapshot.vacationWorkingDays, newCoDays) ||
        !_sameDouble(snapshot.medicalLeaveWorkingDays, newCmDays) ||
        !_sameDouble(snapshot.otherLeaveWorkingDays, newOtherLeaveDays) ||
        !_sameDouble(snapshot.leaveHoursPaid, newLeaveHoursPaid) ||
        !_sameDouble(snapshot.leaveHoursUnpaid, newLeaveHoursUnpaid) ||
        ticketHasChanges;
    return hasChanges
        ? _TimesheetImportStatus.update
        : _TimesheetImportStatus.noChanges;
  }

  bool _sameDouble(double a, double b) => (a - b).abs() < 0.0001;

  Future<bool?> _showTimesheetImportPreviewDialog({
    required DateTime month,
    required MonthlyTimesheetRecord timesheet,
    required List<_TimesheetImportPreviewRow> rows,
  }) {
    final updateCount = rows
        .where((item) => item.status == _TimesheetImportStatus.update)
        .length;
    final createCount = rows
        .where((item) => item.status == _TimesheetImportStatus.missingInPayroll)
        .length;
    final missingInTimesheetCount = rows
        .where(
            (item) => item.status == _TimesheetImportStatus.missingInTimesheet)
        .length;
    final noContractCount = rows
        .where((item) => item.status == _TimesheetImportStatus.noContract)
        .length;
    final noProfileCount = rows
        .where((item) => item.status == _TimesheetImportStatus.noProfile)
        .length;
    final cccCount =
        rows.where((item) => item.status == _TimesheetImportStatus.ccc).length;
    final noChangesCount = rows
        .where((item) => item.status == _TimesheetImportStatus.noChanges)
        .length;
    return showDialog<bool>(
      context: context,
      builder: (context) {
        final scheme = Theme.of(context).colorScheme;
        Widget summaryChip(String label, int count, Color color) {
          return Chip(
            label: Text('$label: $count'),
            backgroundColor: color,
          );
        }

        Widget diffLine(String label, double current, double next) {
          final changed = !_sameDouble(current, next);
          return Text(
            '$label: ${_formatMoney(current)} -> ${_formatMoney(next)}',
            style: TextStyle(
                fontWeight: changed ? FontWeight.w700 : FontWeight.w400),
          );
        }

        return AlertDialog(
          title: const Text('Previzualizare import din pontaj'),
          content: SizedBox(
            width: 980,
            child: Column(
              mainAxisSize: MainAxisSize.min,
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text('Luna: ${_formatMonth(month)}'),
                Text('Randuri pontaj: ${timesheet.rows.length}'),
                Text('Instantanee salarizare existente: ${_snapshots.length}'),
                if (_timesheetImportedSnapshotsForMonth.isNotEmpty)
                  Text(
                    'Snapshot-uri deja preluate din pontaj: ${_timesheetImportedSnapshotsForMonth.length}',
                  ),
                const SizedBox(height: 12),
                Wrap(
                  spacing: 8,
                  runSpacing: 8,
                  children: [
                    summaryChip('Se actualizeaza', updateCount,
                        scheme.primaryContainer),
                    summaryChip(
                        'Se creeaza', createCount, scheme.secondaryContainer),
                    summaryChip('Fara modificari', noChangesCount,
                        scheme.surfaceContainerHighest),
                    summaryChip('Lipsa in pontaj', missingInTimesheetCount,
                        scheme.errorContainer),
                    summaryChip('Fara contract', noContractCount,
                        scheme.errorContainer),
                    summaryChip(
                        'Fara profil', noProfileCount, scheme.errorContainer),
                    summaryChip('CCC', cccCount, scheme.tertiaryContainer),
                  ],
                ),
                const SizedBox(height: 12),
                const Text(
                  'Se actualizeaza doar campurile sigure: ore lucrate, zile CO, CM, alte zile agregate si orele de concediu. Bonusurile, retinerile si regulile salariale raman neschimbate.',
                ),
                const SizedBox(height: 12),
                Flexible(
                  child: ListView(
                    shrinkWrap: true,
                    children: rows.map((item) {
                      final colors = item.status.colors(scheme);
                      return Card(
                        color: colors.$1,
                        child: Padding(
                          padding: const EdgeInsets.all(12),
                          child: Column(
                            crossAxisAlignment: CrossAxisAlignment.start,
                            children: [
                              Row(
                                children: [
                                  Expanded(
                                    child: Text(
                                      item.employeeName,
                                      style: const TextStyle(
                                        fontWeight: FontWeight.w700,
                                      ),
                                    ),
                                  ),
                                  Chip(
                                    label: Text(item.status.label),
                                    backgroundColor: colors.$2,
                                  ),
                                  if (item.snapshot != null)
                                    const Chip(label: Text('Snapshot existent'))
                                  else
                                    const Chip(label: Text('Fara snapshot')),
                                ],
                              ),
                              diffLine(
                                'Ore lucrate',
                                item.currentWorkedHours,
                                item.newWorkedHours,
                              ),
                              diffLine(
                                  'CO', item.currentCoDays, item.newCoDays),
                              diffLine(
                                  'CM', item.currentCmDays, item.newCmDays),
                              diffLine(
                                'Other leave',
                                item.currentOtherLeaveDays,
                                item.newOtherLeaveDays,
                              ),
                              diffLine(
                                'Leave paid',
                                item.currentLeaveHoursPaid,
                                item.newLeaveHoursPaid,
                              ),
                              diffLine(
                                'Leave unpaid',
                                item.currentLeaveHoursUnpaid,
                                item.newLeaveHoursUnpaid,
                              ),
                              if (item.status ==
                                  _TimesheetImportStatus.missingInTimesheet)
                                const Text(
                                  'Angajatul exista in payroll, dar lipseste din pontajul lunar selectat.',
                                ),
                              if (item.status ==
                                  _TimesheetImportStatus.missingInPayroll)
                                const Text(
                                  'Angajatul exista in pontaj, dar nu are inca snapshot payroll pentru luna selectata.',
                                ),
                              if (item.status ==
                                  _TimesheetImportStatus.noContract)
                                const Text('Angajat fara contract activ.'),
                              if (item.status ==
                                  _TimesheetImportStatus.noProfile)
                                const Text('Angajat fara profil HR.'),
                              if (item.status == _TimesheetImportStatus.ccc)
                                const Text(
                                  'Angajat in CCC: importul pastreaza salarizarea la venit 0.',
                                ),
                            ],
                          ),
                        ),
                      );
                    }).toList(growable: false),
                  ),
                ),
              ],
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(false),
              child: const Text('Anulează'),
            ),
            FilledButton(
              onPressed: () => Navigator.of(context).pop(true),
              child: const Text('Confirma importul'),
            ),
          ],
        );
      },
    );
  }

  String _mergeImportedTimesheetNote(
    String existingNotes, {
    required String monthLabel,
    required double workedHours,
    required Map<String, int> codeCounts,
  }) {
    final retained = existingNotes
        .split('\n')
        .where(
          (line) =>
              !line.trim().startsWith('[Pontaj lunar importat') &&
              !line.trim().startsWith('CO='),
        )
        .join('\n')
        .trim();
    final importLine =
        '[Pontaj lunar importat $monthLabel] ore=${workedHours.toStringAsFixed(2)}';
    final countsLine = MonthlyTimesheetCodeOption.defaults
        .map((option) => '${option.code}=${codeCounts[option.code] ?? 0}')
        .join(' | ');
    if (retained.isEmpty) {
      return '$importLine\n$countsLine';
    }
    return '$retained\n$importLine\n$countsLine';
  }

  Future<void> _generatePayroll() async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti genera salarizarea.',
      );
      return;
    }
    final blocked = _blockedEmployeesForPayroll;
    if (blocked.isNotEmpty) {
      final shouldContinue = await _showPayrollValidationWarning();
      if (!shouldContinue) {
        return;
      }
    }
    setState(() {
      _generating = true;
      _message = null;
    });
    try {
      await _runService.generatePayrollRunForMonth(
        payrollMonth: _selectedMonth,
      );
      await _reload();
      if (!mounted) return;
      setState(() {
        _message =
            'Salarizare generata pentru ${_formatMonth(_selectedMonth)}.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut genera salarizarea: $error';
      });
    } finally {
      if (mounted) {
        setState(() {
          _generating = false;
        });
      }
    }
  }

  List<String> get _payrollBlockingProblemLabels {
    final labels = <String>[];
    if (_employeesWithoutHrProfile.isNotEmpty) {
      labels.add('angajati fara profil HR');
    }
    if (_profilesWithoutActiveContract.isNotEmpty) {
      labels.add('profiluri fara contract activ');
    }
    if (_employeesWithUnapprovedAttendance.isNotEmpty) {
      labels.add('pontaj neaprobat');
    }
    if (_employeesWithUnapprovedLeaves.isNotEmpty) {
      labels.add('concedii neaprobate');
    }
    if (_employeesWithConflicts.isNotEmpty) {
      labels.add('conflicte concedii / pontaj');
    }
    return labels;
  }

  Future<bool> _showPayrollValidationWarning() async {
    final eligible = _eligibleEmployeesForPayroll;
    final blocked = _blockedEmployeesForPayroll;
    final problemLabels = _payrollBlockingProblemLabels;
    final blockedNames =
        _shortNames(blocked.map((item) => _employeeName(item)), max: 8);
    final result = await showDialog<bool>(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Salarizare blocata de validare'),
        content: SizedBox(
          width: 560,
          child: Column(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Text('Eligibili: ${eligible.length}'),
              Text('Blocati: ${blocked.length}'),
              const SizedBox(height: 12),
              Text(
                'Categorii probleme: ${problemLabels.isEmpty ? '-' : problemLabels.join(', ')}',
              ),
              const SizedBox(height: 8),
              Text('Angajati blocati: $blockedNames'),
              const SizedBox(height: 12),
              const Text(
                'Corectează validarea înainte de a genera salarizarea pentru luna selectată.',
              ),
            ],
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(false),
            child: const Text('Anulează'),
          ),
          TextButton(
            onPressed: () => Navigator.of(context).pop(true),
            child: const Text('Deschide validarea'),
          ),
        ],
      ),
    );
    if (result == true && mounted) {
      await _scrollToSection(_validationSectionKey);
      setState(() {
        _message =
            'Salarizarea nu a fost generata. Exista angajati blocati pentru luna selectata.';
      });
    }
    return false;
  }

  Future<void> _recalculateEmployee(String employeeId) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti recalcula salarizarea.',
      );
      return;
    }
    setState(() {
      _message = null;
    });
    try {
      await _runService.generatePayslipForEmployeeMonth(
        employeeId: employeeId,
        payrollMonth: _selectedMonth,
      );
      await _reload();
      if (!mounted) return;
      setState(() {
        _message =
            'Fluturas de salariu recalculat pentru ${_employeeName(employeeId)}.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message =
            'Nu am putut recalcula salarizarea pentru ${_employeeName(employeeId)}: $error';
      });
    }
  }

  Future<void> _exportAttendanceReportForEmployee(String employeeId) async {
    final rows = _attendanceForEmployee(employeeId);
    final profile = _profileForEmployee(employeeId);
    final employeeName = _employeeName(employeeId);
    try {
      final path = await HrAttendanceReportPdfService.export(
        repository: widget.repository,
        employeeName: employeeName,
        month: _selectedMonthStart,
        entries: rows,
        teamName: profile?.teamId ?? '',
      );
      if (!mounted) return;
      setState(() {
        _message = 'Raportul de pontaj a fost exportat: $path';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut genera raportul de pontaj: $error';
      });
    }
  }

  Future<void> _exportApprovedLeaveMonthlyReport() async {
    final approvedRows = _monthLeaveRequests
        .where((item) => item.status.trim().toLowerCase() == 'approved')
        .toList(growable: false);
    final employeeNamesById = <String, String>{
      for (final item in _profiles)
        item.employeeId.trim(): item.fullName.trim().isEmpty
            ? item.employeeId.trim()
            : item.fullName.trim(),
    };
    for (final item in _employees) {
      employeeNamesById.putIfAbsent(item.id.trim(), () => item.name.trim());
    }
    try {
      final path = await HrLeaveApprovedMonthlyReportPdfService.export(
        repository: widget.repository,
        month: _selectedMonthStart,
        requests: approvedRows,
        employeeNamesById: employeeNamesById,
      );
      if (!mounted) return;
      setState(() {
        _message = 'Raportul centralizat de concedii a fost exportat: $path';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut genera raportul de concedii: $error';
      });
    }
  }

  Future<void> _exportMonthlyPayrollStatementPdf({
    bool share = false,
    bool saveAs = false,
  }) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
        'Acces restrictionat: nu poti exporta statul de plata PDF.',
      );
      return;
    }
    final employeeNamesById = <String, String>{
      for (final item in _profiles)
        item.employeeId.trim(): item.fullName.trim().isEmpty
            ? item.employeeId.trim()
            : item.fullName.trim(),
    };
    for (final item in _employees) {
      employeeNamesById.putIfAbsent(item.id.trim(), () => item.name.trim());
    }
    try {
      final path = await HrPayrollMonthlyStatementPdfService.export(
        repository: widget.repository,
        payrollMonth: _selectedMonthStart,
        payslips: _payslips,
        employeeNamesById: employeeNamesById,
        saveAs: saveAs,
      );
      if (share) {
        await DocumentFileService.shareFile(
          path,
          subject: 'Stat de plata ${_formatMonth(_selectedMonthStart)}',
          text: 'Stat de plata generat din aplicatie.',
        );
      }
      if (!mounted) return;
      setState(() {
        _message = share
            ? 'Statul de plata a fost generat si pregatit pentru partajare.'
            : 'Statul de plata PDF a fost exportat: $path';
      });
    } on PdfSaveCanceledException {
      if (!mounted) return;
      setState(() {
        _message = 'Salvarea statului de plata a fost anulata.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut exporta statul de plata PDF: $error';
      });
    }
  }

  void _showBreakdown(
    String title,
    Map<String, dynamic> breakdown,
    Map<String, dynamic> sourceRefs,
  ) {
    showDialog<void>(
      context: context,
      builder: (context) => AlertDialog(
        title: Text(title),
        content: SizedBox(
          width: 640,
          child: SingleChildScrollView(
            child: SelectableText(
              'Breakdown\n${_prettyMap(breakdown)}\n\nSource refs\n${_prettyMap(sourceRefs)}',
            ),
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('Închide'),
          ),
        ],
      ),
    );
  }

  void _showPayslipDetails(HrPayslip item) {
    final grossComponents =
        (item.breakdown['gross_components'] as Map?)?.cast<String, dynamic>() ??
            const <String, dynamic>{};
    final contract =
        (item.breakdown['contract'] as Map?)?.cast<String, dynamic>() ??
            const <String, dynamic>{};
    final salaryTaxPercentages =
        (item.breakdown['salary_tax_percentages'] as Map?)
                ?.cast<String, dynamic>() ??
            const <String, dynamic>{};
    final employerCosts =
        (item.breakdown['employer_costs'] as Map?)?.cast<String, dynamic>() ??
            const <String, dynamic>{};
    final medicalLeavePolicy = (item.breakdown['medical_leave_policy'] as Map?)
            ?.cast<String, dynamic>() ??
        const <String, dynamic>{};
    final attendanceInputs = (item.breakdown['attendance_leave_inputs'] as Map?)
            ?.cast<String, dynamic>() ??
        const <String, dynamic>{};
    final mealTickets =
        (item.breakdown['meal_tickets'] as Map?)?.cast<String, dynamic>() ??
            const <String, dynamic>{};

    Widget section(String title, List<Widget> children) {
      return Container(
        width: double.infinity,
        margin: const EdgeInsets.only(bottom: 12),
        padding: const EdgeInsets.all(12),
        decoration: BoxDecoration(
          border: Border.all(color: Theme.of(context).dividerColor),
          borderRadius: BorderRadius.circular(8),
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(title, style: Theme.of(context).textTheme.titleSmall),
            const SizedBox(height: 8),
            ...children,
          ],
        ),
      );
    }

    Widget line(String label, String value, {bool emphasized = false}) {
      final style = emphasized
          ? Theme.of(context)
              .textTheme
              .bodyMedium
              ?.copyWith(fontWeight: FontWeight.w700)
          : Theme.of(context).textTheme.bodyMedium;
      return Padding(
        padding: const EdgeInsets.symmetric(vertical: 2),
        child: Row(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            SizedBox(width: 180, child: Text(label)),
            Expanded(child: Text(value, style: style)),
          ],
        ),
      );
    }

    String money(double value) => '${_formatMoney(value)} ${item.currency}';
    String textOrDash(String value) {
      final trimmed = value.trim();
      return trimmed.isEmpty ? '-' : trimmed;
    }

    showDialog<void>(
      context: context,
      builder: (context) => AlertDialog(
        title: Text('Fluturas salariu - ${_employeeName(item.employeeId)}'),
        content: SizedBox(
          width: 760,
          child: SingleChildScrollView(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                section('Date generale', [
                  line('Angajat', _employeeName(item.employeeId)),
                  line('Luna salarizare', _formatMonth(item.payrollMonth)),
                  line(
                    'Functie / contract',
                    textOrDash(
                      '${contract['job_title'] ?? ''}'.trim().isEmpty
                          ? '${contract['contract_type'] ?? ''}'
                          : '${contract['job_title'] ?? ''} / ${contract['contract_type'] ?? ''}',
                    ),
                  ),
                  line('Status', textOrDash(item.status)),
                  line('Generat la', _formatDateTime(item.generatedAt)),
                  line('Status special', _specialPayrollStatus(item)),
                ]),
                section('Venituri', [
                  line(
                    'Salariu brut',
                    money(
                      (grossComponents['base_salary_gross'] as num?)
                              ?.toDouble() ??
                          item.grossTotal,
                    ),
                  ),
                  line(
                    'Bonusuri taxabile',
                    money(
                      (grossComponents['bonuses_taxable'] as num?)
                              ?.toDouble() ??
                          0,
                    ),
                  ),
                  line(
                    'Indemnizatii taxabile',
                    money(
                      (grossComponents['allowances_taxable'] as num?)
                              ?.toDouble() ??
                          0,
                    ),
                  ),
                  line(
                    'Indemnizatii netaxabile',
                    money(
                      (grossComponents['allowances_non_taxable'] as num?)
                              ?.toDouble() ??
                          0,
                    ),
                  ),
                  line('Brut total', money(item.grossTotal), emphasized: true),
                ]),
                section('Contributii si taxe', [
                  line(
                    'Regula fiscala',
                    textOrDash(
                      (item.breakdown['salary_tax_rule_id'] ?? '').toString(),
                    ),
                  ),
                  line(
                    'Sursa regula',
                    textOrDash(
                      (item.breakdown['salary_tax_rule_source'] ?? '')
                          .toString(),
                    ),
                  ),
                  line(
                    'CAS${salaryTaxPercentages.isNotEmpty ? ' (${salaryTaxPercentages['employee_cas_percent'] ?? 0}%)' : ''}',
                    money(item.casAmount),
                  ),
                  line(
                    'CASS${salaryTaxPercentages.isNotEmpty ? ' (${salaryTaxPercentages['employee_cass_percent'] ?? 0}%)' : ''}',
                    money(item.cassAmount),
                  ),
                  line(
                    'Impozit${salaryTaxPercentages.isNotEmpty ? ' (${salaryTaxPercentages['income_tax_percent'] ?? 0}%)' : ''}',
                    money(item.incomeTaxAmount),
                  ),
                  line(
                    'CAM angajator${salaryTaxPercentages.isNotEmpty ? ' (${salaryTaxPercentages['employer_cam_percent'] ?? 0}%)' : ''}',
                    money(
                      (employerCosts['employer_cam_amount'] as num?)
                              ?.toDouble() ??
                          0,
                    ),
                  ),
                ]),
                section('Pontaj / concedii folosite', [
                  line(
                    'Ore lucrate',
                    '${_formatMoney(
                      attendanceInputs['worked_hours'] is num
                          ? ((attendanceInputs['worked_hours'] as num)
                              .toDouble())
                          : 0,
                    )} h',
                  ),
                  line(
                    'Zile CO',
                    '${_formatMoney(
                      attendanceInputs['vacation_working_days'] is num
                          ? ((attendanceInputs['vacation_working_days'] as num)
                              .toDouble())
                          : 0,
                    )} zile',
                  ),
                  line(
                    'Zile CM',
                    '${_formatMoney(
                      attendanceInputs['medical_leave_working_days'] is num
                          ? ((attendanceInputs['medical_leave_working_days']
                                  as num)
                              .toDouble())
                          : 0,
                    )} zile',
                  ),
                  line(
                    'Alte zile concediu',
                    '${_formatMoney(
                      attendanceInputs['other_leave_working_days'] is num
                          ? ((attendanceInputs['other_leave_working_days']
                                  as num)
                              .toDouble())
                          : 0,
                    )} zile',
                  ),
                  line(
                    'Regula medicala',
                    textOrDash(
                        (medicalLeavePolicy['rule_id'] ?? '').toString()),
                  ),
                  line(
                    'Minus o zi temporar',
                    _asDouble(medicalLeavePolicy['temporary_reduction_days']) <=
                            0
                        ? 'nu'
                        : 'da',
                  ),
                  line(
                    'Recalculare episod intre luni',
                    (medicalLeavePolicy[
                                    'episode_recalculation_cross_month_required'] ??
                                false) ==
                            true
                        ? 'da'
                        : 'nu',
                  ),
                  line(
                    'Necesita completare administrativa',
                    (medicalLeavePolicy['requires_admin_completion'] ??
                                false) ==
                            true
                        ? 'da'
                        : 'nu',
                  ),
                ]),
                section('Tichete de masa', [
                  line(
                    'Activ',
                    (mealTickets['enabled'] ?? false) == true ? 'da' : 'nu',
                  ),
                  line(
                    'Mod calcul',
                    textOrDash(
                      (mealTickets['calculation_mode'] ?? '').toString(),
                    ),
                  ),
                  line(
                    'Buget lunar',
                    money(
                      (mealTickets['monthly_budget'] as num?)?.toDouble() ?? 0,
                    ),
                  ),
                  line(
                    'Zile eligibile baza',
                    _formatMoney(
                      (mealTickets['configured_eligible_days'] as num?)
                              ?.toDouble() ??
                          0,
                    ),
                  ),
                  line(
                    'Zile eligibile angajat',
                    _formatMoney(
                      (mealTickets['eligible_days'] as num?)?.toDouble() ?? 0,
                    ),
                  ),
                  line(
                    'Valoare / zi',
                    money(
                      (mealTickets['value_per_day'] as num?)?.toDouble() ?? 0,
                    ),
                  ),
                  line(
                    'Total tichete',
                    money(
                      (mealTickets['total_value'] as num?)?.toDouble() ?? 0,
                    ),
                    emphasized: true,
                  ),
                  line(
                    'Tratament fiscal',
                    textOrDash(
                      (mealTickets['fiscal_treatment'] ?? '').toString(),
                    ),
                  ),
                  line(
                    'Regula eligibilitate',
                    textOrDash(
                      _mealTicketRulesSummary(
                        ((mealTickets['eligibility_rules'] as Map?)
                                ?.cast<String, dynamic>()
                                .map(
                                  (key, value) => MapEntry(
                                    key,
                                    value == true,
                                  ),
                                ) ??
                            const <String, bool>{}),
                      ),
                    ),
                  ),
                  line(
                    'Detaliere coduri',
                    textOrDash(
                      _mealTicketBreakdownSummary(
                        ((mealTickets['eligibility_breakdown'] as Map?)
                                ?.cast<String, dynamic>()
                                .map(
                                  (key, value) => MapEntry(
                                    key,
                                    _asDouble(value),
                                  ),
                                ) ??
                            const <String, double>{}),
                      ),
                    ),
                  ),
                ]),
                section('Retineri', [
                  line(
                    'Impozit tichete masa',
                    money(
                      _asDouble(
                        (((item.breakdown['withholdings'] as Map?)
                                    ?.cast<String, dynamic>() ??
                                const <String, dynamic>{})[
                            'meal_ticket_income_tax_amount']),
                      ),
                    ),
                  ),
                  line(
                    'CASS tichete masa',
                    money(
                      _asDouble(
                        (((item.breakdown['withholdings'] as Map?)
                                    ?.cast<String, dynamic>() ??
                                const <String, dynamic>{})[
                            'meal_ticket_cass_amount']),
                      ),
                    ),
                  ),
                  line('Retineri', money(item.deductionTotal)),
                  line(
                    'Recuperari avans',
                    money(item.advanceRecoveryTotal),
                  ),
                  line(
                    'Popriri rezervate',
                    money(item.garnishmentReservedTotal),
                  ),
                ]),
                section('Net final', [
                  line('Net final', money(item.netFinal), emphasized: true),
                ]),
                section('Breakdown / surse', [
                  SelectableText(
                    'Breakdown\n${_prettyMap(item.breakdown)}\n\nSource refs\n${_prettyMap(item.sourceRefs)}',
                    style: Theme.of(context).textTheme.bodySmall,
                  ),
                ]),
              ],
            ),
          ),
        ),
        actions: [
          TextButton.icon(
            onPressed: () {
              Navigator.of(context).pop();
              _exportPayslipPdf(item);
            },
            icon: const Icon(Icons.picture_as_pdf_outlined),
            label: const Text('Exporta PDF'),
          ),
          TextButton.icon(
            onPressed: () {
              Navigator.of(context).pop();
              _exportPayslipPdf(item, saveAs: true);
            },
            icon: const Icon(Icons.save_as_outlined),
            label: const Text('Salveaza ca...'),
          ),
          TextButton.icon(
            onPressed: () {
              Navigator.of(context).pop();
              _exportPayslipPdf(item, share: true);
            },
            icon: const Icon(Icons.share_outlined),
            label: const Text('Partajeaza'),
          ),
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('Închide'),
          ),
        ],
      ),
    );
  }

  DateTime get _selectedMonthStart =>
      DateTime(_selectedMonth.year, _selectedMonth.month, 1);

  List<HrPayrollInputSnapshot> get _timesheetImportedSnapshotsForMonth =>
      _snapshots.where((item) {
        final refs = item.sourceRefs;
        final importedId =
            (refs['monthly_timesheet_record_id'] ?? '').toString().trim();
        return importedId.isNotEmpty &&
            item.payrollMonth.year == _selectedMonthStart.year &&
            item.payrollMonth.month == _selectedMonthStart.month;
      }).toList(growable: false);

  List<HrBonus> get _monthBonuses {
    final month = _selectedMonthStart;
    final rows = _bonuses.where((item) {
      final effective = DateTime(
        item.effectiveMonth.year,
        item.effectiveMonth.month,
        1,
      );
      return effective == month;
    }).toList(growable: false);
    rows.sort((a, b) =>
        _employeeName(a.employeeId).compareTo(_employeeName(b.employeeId)));
    return rows;
  }

  List<HrDeduction> get _monthDeductions {
    final rows = _deductions
        .where((item) => item.appliesToMonth(_selectedMonthStart))
        .toList(growable: false);
    rows.sort((a, b) =>
        _employeeName(a.employeeId).compareTo(_employeeName(b.employeeId)));
    return rows;
  }

  List<HrAdvance> get _monthAdvances {
    final rows = _advances
        .where((item) => item.appliesToMonth(_selectedMonthStart))
        .toList(growable: false);
    rows.sort((a, b) =>
        _employeeName(a.employeeId).compareTo(_employeeName(b.employeeId)));
    return rows;
  }

  List<HrGarnishment> get _monthGarnishments {
    final rows = _garnishments
        .where((item) => item.appliesToMonth(_selectedMonthStart))
        .toList(growable: false);
    rows.sort((a, b) =>
        _employeeName(a.employeeId).compareTo(_employeeName(b.employeeId)));
    return rows;
  }

  String _orDash(String value) {
    final trimmed = value.trim();
    return trimmed.isEmpty ? '-' : trimmed;
  }

  Future<void> _editBonus([HrBonus? existing]) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
          'Acces restrictionat: nu poti administra bonusurile.');
      return;
    }
    if (_profiles.isEmpty) {
      setState(() => _message = 'Nu exista angajati HR disponibili.');
      return;
    }
    final now = DateTime.now();
    String employeeId = existing?.employeeId.isNotEmpty == true
        ? existing!.employeeId
        : _profiles.first.employeeId;
    String bonusType = existing?.bonusType ?? 'bonus';
    String taxableMode = existing?.taxableMode ?? 'taxable';
    String currency = existing?.currency ?? 'RON';
    String status = existing?.status ?? 'active';
    DateTime effectiveMonth = existing?.effectiveMonth ?? _selectedMonthStart;
    final amountController = TextEditingController(
      text: existing == null ? '' : existing.amount.toStringAsFixed(2),
    );
    final notesController = TextEditingController(text: existing?.notes ?? '');
    final confirmed = await showDialog<bool>(
      context: context,
      builder: (context) => StatefulBuilder(
        builder: (context, setLocalState) => AlertDialog(
          title: Text(existing == null ? 'Adauga bonus' : 'Editeaza bonus'),
          content: SizedBox(
            width: 460,
            child: SingleChildScrollView(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  DropdownButtonFormField<String>(
                    initialValue: employeeId,
                    decoration: const InputDecoration(labelText: 'Angajat'),
                    items: _profiles
                        .map((item) => DropdownMenuItem<String>(
                              value: item.employeeId,
                              child: Text(item.fullName),
                            ))
                        .toList(growable: false),
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => employeeId = value);
                      }
                    },
                  ),
                  TextFormField(
                    initialValue: bonusType,
                    decoration: const InputDecoration(labelText: 'Tip bonus'),
                    onChanged: (value) => bonusType = value,
                  ),
                  TextFormField(
                    controller: amountController,
                    decoration: const InputDecoration(labelText: 'Suma'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: taxableMode,
                    decoration: const InputDecoration(labelText: 'Taxare'),
                    items: const [
                      DropdownMenuItem(
                          value: 'taxable', child: Text('taxable')),
                      DropdownMenuItem(
                        value: 'non_taxable',
                        child: Text('non_taxable'),
                      ),
                    ],
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => taxableMode = value);
                      }
                    },
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: currency,
                    decoration: const InputDecoration(labelText: 'Moneda'),
                    items: const [
                      DropdownMenuItem(value: 'RON', child: Text('RON')),
                      DropdownMenuItem(value: 'EUR', child: Text('EUR')),
                    ],
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => currency = value);
                      }
                    },
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: status,
                    decoration: const InputDecoration(labelText: 'Status'),
                    items: const [
                      DropdownMenuItem(value: 'active', child: Text('Activ')),
                      DropdownMenuItem(value: 'draft', child: Text('Ciorna')),
                      DropdownMenuItem(
                        value: 'cancelled',
                        child: Text('Anulat'),
                      ),
                    ],
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => status = value);
                      }
                    },
                  ),
                  const SizedBox(height: 8),
                  Align(
                    alignment: Alignment.centerLeft,
                    child:
                        Text('Luna efectiva: ${_formatMonth(effectiveMonth)}'),
                  ),
                  TextButton.icon(
                    onPressed: () async {
                      final picked = await showDatePicker(
                        context: context,
                        initialDate: effectiveMonth,
                        firstDate: DateTime(2020),
                        lastDate: DateTime(2100),
                      );
                      if (picked != null) {
                        setLocalState(() {
                          effectiveMonth =
                              DateTime(picked.year, picked.month, 1);
                        });
                      }
                    },
                    icon: const Icon(Icons.calendar_month_outlined),
                    label: const Text('Alege luna'),
                  ),
                  TextFormField(
                    controller: notesController,
                    decoration: const InputDecoration(labelText: 'Note'),
                    minLines: 2,
                    maxLines: 4,
                  ),
                ],
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(false),
              child: const Text('Renunță'),
            ),
            FilledButton(
              onPressed: () => Navigator.of(context).pop(true),
              child: const Text('Salveaza'),
            ),
          ],
        ),
      ),
    );
    if (confirmed != true) return;
    final amount =
        double.tryParse(amountController.text.trim().replaceAll(',', '.')) ?? 0;
    final profile = _profileByEmployeeId[employeeId.trim()];
    final record = HrBonus(
      id: existing?.id ??
          'hr-bonus-${employeeId.trim()}-${DateTime.now().millisecondsSinceEpoch}',
      employeeId: employeeId.trim(),
      hrEmployeeProfileId: profile?.id ?? '',
      bonusType: bonusType.trim().isEmpty ? 'bonus' : bonusType.trim(),
      taxableMode: taxableMode.trim().isEmpty ? 'taxable' : taxableMode.trim(),
      amount: amount,
      currency: currency.trim().isEmpty ? 'RON' : currency.trim(),
      effectiveMonth: effectiveMonth,
      status: status.trim().isEmpty ? 'active' : status.trim(),
      notes: notesController.text.trim(),
      createdAt: existing?.createdAt ?? now,
      updatedAt: now,
    );
    try {
      await _variablePayrollService.upsertBonus(record);
      await _reload();
      if (!mounted) return;
      setState(() =>
          _message = existing == null ? 'Bonus salvat.' : 'Bonus actualizat.');
    } catch (error) {
      if (!mounted) return;
      setState(() => _message = 'Nu am putut salva bonusul: $error');
    }
  }

  Future<void> _editDeduction([HrDeduction? existing]) async {
    if (!_canManageSensitiveHr) {
      _showRestrictedMessage(
          'Acces restrictionat: nu poti administra retinerile.');
      return;
    }
    if (_profiles.isEmpty) {
      setState(() => _message = 'Nu exista angajati HR disponibili.');
      return;
    }
    final now = DateTime.now();
    String employeeId = existing?.employeeId.isNotEmpty == true
        ? existing!.employeeId
        : _profiles.first.employeeId;
    String deductionType = existing?.deductionType ?? 'retinere';
