      effectiveFrom: effectiveFrom,
      effectiveTo: effectiveTo,
      status: status.trim().isEmpty ? 'active' : status.trim(),
      notes: notesController.text.trim(),
      createdAt: existing?.createdAt ?? now,
      updatedAt: now,
    );
    try {
      await _variablePayrollService.upsertDeduction(record);
      await _reload();
      if (!mounted) return;
      setState(() => _message =
          existing == null ? 'Retinere salvata.' : 'Retinere actualizata.');
    } catch (error) {
      if (!mounted) return;
      setState(() => _message = 'Nu am putut salva retinerea: $error');
    }
  }

  Future<void> _editAdvance([HrAdvance? existing]) async {
