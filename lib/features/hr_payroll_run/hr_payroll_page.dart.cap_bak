  Future<void> _editAttendance([HrAttendanceEntry? existing]) async {
    if (!_canEditOperationalHr) {
      _showRestrictedMessage('Acces restrictionat: nu poti edita pontajul.');
      return;
    }
    if (_profiles.isEmpty) {
      setState(() {
        _message = 'Adauga mai intai un profil HR.';
      });
      return;
    }
    final now = DateTime.now();
    String profileId = existing?.hrEmployeeProfileId.isNotEmpty == true
        ? existing!.hrEmployeeProfileId
        : _profiles.first.id;
    HrEmployeeProfile selectedProfile = _profiles.firstWhere(
      (item) => item.id.trim() == profileId.trim(),
      orElse: () => _profiles.first,
    );
    DateTime selectedDate = existing?.date ?? DateTime.now();
    String sourceType = existing?.sourceType ?? 'manual';
    String teamId = existing?.teamId ?? selectedProfile.teamId;
    String status = existing?.status ?? 'draft';
    final workedController = TextEditingController(
      text: existing == null ? '0' : existing.workedHours.toStringAsFixed(2),
    );
    final overtimeController = TextEditingController(
      text: existing == null ? '0' : existing.overtimeHours.toStringAsFixed(2),
    );
    final nightController = TextEditingController(
      text: existing == null ? '0' : existing.nightHours.toStringAsFixed(2),
    );
    final leaveController = TextEditingController(
      text: existing == null ? '0' : existing.leaveHours.toStringAsFixed(2),
    );
    final approvedByController =
        TextEditingController(text: existing?.approvedByUserId ?? '');
    final reviewNotesController =
        TextEditingController(text: existing?.reviewNotes ?? '');
    final notesController = TextEditingController(text: existing?.notes ?? '');
    final confirmed = await showDialog<bool>(
      context: context,
      builder: (context) => StatefulBuilder(
        builder: (context, setLocalState) => AlertDialog(
          title: Text(existing == null ? 'Adauga pontaj' : 'Editeaza pontaj'),
          content: SizedBox(
            width: 480,
            child: SingleChildScrollView(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  DropdownButtonFormField<String>(
                    initialValue: profileId,
                    decoration:
                        const InputDecoration(labelText: 'Angajat / profil HR'),
                    items: _profiles
                        .map(
                          (item) => DropdownMenuItem<String>(
                            value: item.id,
                            child: Text(item.fullName),
                          ),
                        )
                        .toList(growable: false),
                    onChanged: (value) {
                      if (value == null) return;
                      final next = _profiles.firstWhere(
                        (item) => item.id.trim() == value.trim(),
                        orElse: () => selectedProfile,
                      );
                      setLocalState(() {
                        profileId = value;
                        selectedProfile = next;
                        if ((existing?.teamId ?? '').trim().isEmpty) {
                          teamId = next.teamId;
                        }
                      });
                    },
                  ),
                  Align(
                    alignment: Alignment.centerLeft,
                    child: Text(
                      'Data: ${selectedDate.day.toString().padLeft(2, '0')}.${selectedDate.month.toString().padLeft(2, '0')}.${selectedDate.year}',
                    ),
                  ),
                  TextButton.icon(
                    onPressed: () async {
                      final picked = await showDatePicker(
                        context: context,
                        initialDate: selectedDate,
                        firstDate: DateTime(2020),
                        lastDate: DateTime(2100),
                      );
                      if (picked != null) {
                        setLocalState(() => selectedDate = picked);
                      }
                    },
                    icon: const Icon(Icons.calendar_month_outlined),
                    label: const Text('Alege data'),
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: sourceType,
                    decoration: const InputDecoration(labelText: 'Tip sursa'),
                    items: const [
                      DropdownMenuItem(value: 'manual', child: Text('manual')),
                      DropdownMenuItem(
                        value: 'programare',
                        child: Text('programare'),
                      ),
                      DropdownMenuItem(
                          value: 'lucrare', child: Text('lucrare')),
                      DropdownMenuItem(
                          value: 'concediu', child: Text('concediu')),
                    ],
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => sourceType = value);
                      }
                    },
                  ),
                  TextFormField(
                    controller: workedController,
                    decoration: const InputDecoration(labelText: 'Ore lucrate'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  TextFormField(
                    controller: overtimeController,
                    decoration:
                        const InputDecoration(labelText: 'Ore suplimentare'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  TextFormField(
                    controller: nightController,
                    decoration:
                        const InputDecoration(labelText: 'Ore de noapte'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  TextFormField(
                    controller: leaveController,
                    decoration:
                        const InputDecoration(labelText: 'Ore concediu'),
                    keyboardType:
                        const TextInputType.numberWithOptions(decimal: true),
                  ),
                  TextFormField(
                    initialValue: teamId,
                    decoration: const InputDecoration(labelText: 'Echipa'),
                    onChanged: (value) => teamId = value,
                  ),
                  DropdownButtonFormField<String>(
                    initialValue: status,
                    decoration: const InputDecoration(labelText: 'Status'),
                    items: const [
                      DropdownMenuItem(value: 'draft', child: Text('Ciorna')),
                      DropdownMenuItem(
                        value: 'submitted',
                        child: Text('Trimis'),
                      ),
                      DropdownMenuItem(
                        value: 'approved',
                        child: Text('Aprobat'),
                      ),
                      DropdownMenuItem(
                        value: 'needs_review',
                        child: Text('Necesita revizie'),
                      ),
                      DropdownMenuItem(
                        value: 'rejected',
                        child: Text('Respins'),
                      ),
                      DropdownMenuItem(
                        value: 'cancelled',
                        child: Text('Anulat'),
                      ),
                    ],
                    onChanged: (value) {
                      if (value != null) {
                        setLocalState(() => status = value);
                      }
                    },
                  ),
                  TextFormField(
                    controller: approvedByController,
                    decoration: const InputDecoration(labelText: 'Aprobat de'),
                  ),
                  TextFormField(
                    controller: reviewNotesController,
                    decoration:
                        const InputDecoration(labelText: 'Note revizie'),
                    minLines: 2,
                    maxLines: 4,
                  ),
                  TextFormField(
                    controller: notesController,
                    decoration: const InputDecoration(labelText: 'Notite'),
                    minLines: 2,
                    maxLines: 4,
                  ),
                ],
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(false),
              child: const Text('Renunță'),
            ),
            FilledButton(
              onPressed: () => Navigator.of(context).pop(true),
              child: const Text('Salveaza'),
            ),
          ],
        ),
      ),
    );
    if (confirmed != true) return;
    if (selectedProfile.employeeId.trim().isEmpty) {
      setState(() {
        _message = 'Pontajul trebuie legat de un angajat.';
      });
      return;
    }
    double parseNonNegative(String raw) {
      final value = double.tryParse(raw.trim().replaceAll(',', '.')) ?? 0;
      return value < 0 ? 0 : value;
    }

    final record = HrAttendanceEntry(
      id: existing?.id ??
          'hr-attendance-${selectedProfile.employeeId.trim()}-${DateTime.now().millisecondsSinceEpoch}',
      employeeId: selectedProfile.employeeId,
      hrEmployeeProfileId: selectedProfile.id,
      date: selectedDate,
      sourceType: sourceType.trim().isEmpty ? 'manual' : sourceType.trim(),
      sourceRefId: existing?.sourceRefId ?? '',
      workedHours: parseNonNegative(workedController.text),
      overtimeHours: parseNonNegative(overtimeController.text),
      nightHours: parseNonNegative(nightController.text),
      leaveHours: parseNonNegative(leaveController.text),
      jobId: existing?.jobId ?? '',
      appointmentId: existing?.appointmentId ?? '',
      teamId: teamId.trim(),
      status: status.trim().isEmpty ? 'draft' : status.trim(),
      submittedAt: existing?.submittedAt,
      submittedByUserId: existing?.submittedByUserId ?? '',
      approvedAt: existing?.approvedAt,
      approvedByUserId: approvedByController.text.trim(),
      reviewedAt: existing?.reviewedAt,
      reviewedByUserId: existing?.reviewedByUserId ?? '',
      reviewNotes: reviewNotesController.text.trim(),
      notes: notesController.text.trim(),
      createdAt: existing?.createdAt ?? now,
      updatedAt: now,
    );
    try {
      await _attendanceService.upsertEntry(record);
      await _reload();
      await _refreshAttendanceSummary();
      if (!mounted) return;
      setState(() {
        _message = existing == null ? 'Pontaj salvat.' : 'Pontaj actualizat.';
      });
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _message = 'Nu am putut salva pontajul: $error';
      });
    }
  }

