                              ],
                              onChanged: canManageWide
                                  ? (value) {
                                      final certificate = value == null
                                          ? null
                                          : _warrantyCertificateById(value);
                                      setDialog(() {
                                        selectedWarrantyCertificateId.value =
                                            value ?? '';
                                        if (certificate != null) {
                                          final nextCoverage =
                                              _productCatalogService
                                                  .coverageStatusForCertificate(
                                                      certificate);
                                          if (nextCoverage ==
                                              WarrantyCoverageStatus
                                                  .inWarranty) {
                                            type.value = ComplaintType.garantie;
                                          } else if (nextCoverage ==
                                              WarrantyCoverageStatus
                                                  .postWarranty) {
                                            type.value =
                                                ComplaintType.postgarantie;
                                          }
                                        }
                                      });
                                    }
                                  : null,
                            ),
                            const SizedBox(height: 8),
                            Text(
                              selected == null
                                  ? (suggested == null
                                      ? 'Status garantie: ${WarrantyCoverageStatus.unknown.label}'
                                      : 'Sugestie automata: ${_warrantyCertificateLabel(suggested)}')
                                  : 'Status garantie: ${coverage.label}',
                            ),
                          ],
                        );
