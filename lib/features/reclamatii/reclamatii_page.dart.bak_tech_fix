  }

  Widget _clientSelector({
    required String label,
    required String currentValue,
    required ValueChanged<String?> onChanged,
    bool enabled = true,
  }) {
    return DropdownButtonFormField<String?>(
      initialValue: currentValue.trim().isEmpty ? null : currentValue,
      decoration: InputDecoration(labelText: label),
      items: [
        const DropdownMenuItem<String?>(
          value: null,
          child: Text('Neselectat'),
        ),
        ..._clients.map(
          (item) => DropdownMenuItem<String?>(
            value: item.id,
            child: Text(item.name),
          ),
        ),
      ],
      onChanged: enabled ? onChanged : null,
    );
  }

  Widget _teamSelector({
    required String currentValue,
    required ValueChanged<String?> onChanged,
    bool enabled = true,
  }) {
    final teamItems = _teams
        .where((item) => item.id.trim().isNotEmpty)
        .toList(growable: false);
    final hasTeams = teamItems.isNotEmpty;
    final selectedValue =
        hasTeams && teamItems.any((item) => item.id == currentValue.trim())
            ? currentValue.trim()
            : null;
    return DropdownButtonFormField<String?>(
      initialValue: selectedValue,
      decoration: InputDecoration(
        labelText: 'Echipa alocata',
        helperText: hasTeams
            ? 'Selecteaza o echipa existenta sau lasa nealocata.'
            : 'Nu exista echipe disponibile. Adauga echipe in modulul Echipe.',
      ),
      disabledHint: const Text('Nu exista echipe disponibile'),
      items: hasTeams
          ? [
              const DropdownMenuItem<String?>(
                value: null,
                child: Text('Nealocata'),
              ),
              ...teamItems.map(
                (item) => DropdownMenuItem<String?>(
                  value: item.id,
                  child: Text(item.name.trim().isEmpty ? item.id : item.name),
                ),
              ),
            ]
          : const <DropdownMenuItem<String?>>[
              DropdownMenuItem<String?>(
                value: null,
                child: Text('Nu exista echipe disponibile'),
              ),
            ],
      onChanged: hasTeams && enabled ? onChanged : null,
    );
  }

  Widget _employeeSelector({
    required String currentValue,
    required ValueChanged<String?> onChanged,
    bool enabled = true,
  }) {
    final employeeItems = _employees
        .where((item) => item.id.trim().isNotEmpty)
        .toList(growable: false);
    final selectedValue = employeeItems.any(
      (item) => item.id == currentValue.trim(),
    )
        ? currentValue.trim()
        : null;
    return DropdownButtonFormField<String?>(
      initialValue: selectedValue,
      decoration: const InputDecoration(labelText: 'Persoana alocata'),
      items: [
        const DropdownMenuItem<String?>(
          value: null,
          child: Text('Nealocata'),
        ),
        ...employeeItems.map(
          (item) => DropdownMenuItem<String?>(
            value: item.id,
            child: Text(item.name),
          ),
        ),
      ],
      onChanged: enabled ? onChanged : null,
    );
  }

  Widget _buildFiltersPanel(List<ComplaintRecord> filteredItems) {
    final contractorOptions = _items
        .map(_resolvedContractorName)
        .where((name) => name.trim().isNotEmpty)
        .toSet()
        .toList()
      ..sort((a, b) => a.toLowerCase().compareTo(b.toLowerCase()));
    final programmedCount = filteredItems.where(_hasAppointment).length;
    final reportedCount = filteredItems.where(_hasReport).length;
    final offeredCount = filteredItems.where(_hasOffer).length;
    final unresolvedCount = filteredItems
        .where(
          (item) =>
              item.status != ComplaintStatus.rezolvata &&
              item.status != ComplaintStatus.inchisa &&
              item.status != ComplaintStatus.anulata,
        )
        .length;
    return SingleChildScrollView(
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.stretch,
        children: [
          _sectionTitle(
            'Cautare si filtre',
            subtitle:
                'Filtreaza rapid dupa stare, tip, alocare si stadiul fluxului operational.',
          ),
          TextField(
            textCapitalization: TextCapitalization.sentences,
            controller: _searchController,
            decoration: const InputDecoration(
              labelText: 'Cauta',
              prefixIcon: Icon(Icons.search),
            ),
            onChanged: (value) => setState(() {
              _searchQuery = value;
              _updateFilteredCache();
            }),
          ),
          const SizedBox(height: 12),
          DropdownButtonFormField<ComplaintStatus?>(
            initialValue: _statusFilter,
            decoration: const InputDecoration(labelText: 'Status reclamatie'),
            items: [
              const DropdownMenuItem<ComplaintStatus?>(
                value: null,
                child: Text('Toate'),
              ),
              ...ComplaintStatus.values.map(
                (item) => DropdownMenuItem<ComplaintStatus?>(
                  value: item,
                  child: Text(item.label),
                ),
              ),
            ],
            onChanged: (value) => setState(() {
              _statusFilter = value;
              _updateFilteredCache();
            }),
          ),
          const SizedBox(height: 12),
          DropdownButtonFormField<ComplaintType?>(
            initialValue: _typeFilter,
            decoration: const InputDecoration(labelText: 'Tip'),
            items: [
              const DropdownMenuItem<ComplaintType?>(
                value: null,
                child: Text('Toate'),
              ),
              ...ComplaintType.values.map(
                (item) => DropdownMenuItem<ComplaintType?>(
                  value: item,
                  child: Text(item.label),
                ),
              ),
            ],
            onChanged: (value) => setState(() {
              _typeFilter = value;
              _updateFilteredCache();
            }),
          ),
          const SizedBox(height: 12),
          DropdownButtonFormField<String?>(
            initialValue:
                _contractorFilter.trim().isEmpty ? null : _contractorFilter,
            decoration: const InputDecoration(
              labelText: 'Colaborator / contractant',
            ),
            items: [
              const DropdownMenuItem<String?>(
                value: null,
                child: Text('Toti'),
              ),
              ...contractorOptions.map(
                (item) => DropdownMenuItem<String?>(
                  value: item,
                  child: Text(item),
                ),
              ),
            ],
            onChanged: (value) {
              setState(() {
                _contractorFilter = value ?? '';
                _updateFilteredCache();
              });
              _persistComplaintFilterPreferences();
            },
          ),
          const SizedBox(height: 12),
          _teamSelector(
            currentValue: _teamFilter,
            onChanged: (value) {
              setState(() {
                _teamFilter = value ?? '';
                _updateFilteredCache();
              });
              _persistComplaintFilterPreferences();
            },
          ),
          const SizedBox(height: 12),
          _employeeSelector(
            currentValue: _employeeFilter,
            onChanged: (value) {
              setState(() {
                _employeeFilter = value ?? '';
                _updateFilteredCache();
              });
              _persistComplaintFilterPreferences();
            },
          ),
          const SizedBox(height: 16),
          DropdownButtonFormField<bool?>(
            initialValue: _scheduledFilter,
            decoration: const InputDecoration(labelText: 'Programare'),
            items: const [
              DropdownMenuItem<bool?>(
                value: null,
                child: Text('Toate'),
              ),
              DropdownMenuItem<bool?>(
                value: true,
                child: Text('Doar programate'),
              ),
              DropdownMenuItem<bool?>(
                value: false,
                child: Text('Doar neprogramate'),
              ),
            ],
            onChanged: (value) => setState(() {
              _scheduledFilter = value;
              _updateFilteredCache();
            }),
          ),
          const SizedBox(height: 12),
          DropdownButtonFormField<bool?>(
            initialValue: _reportFilter,
            decoration: const InputDecoration(labelText: 'Proces verbal'),
            items: const [
              DropdownMenuItem<bool?>(
                value: null,
                child: Text('Toate'),
              ),
              DropdownMenuItem<bool?>(
                value: true,
                child: Text('Cu proces verbal'),
              ),
              DropdownMenuItem<bool?>(
                value: false,
                child: Text('Fara proces verbal'),
              ),
            ],
            onChanged: (value) => setState(() {
              _reportFilter = value;
              _updateFilteredCache();
            }),
          ),
          const SizedBox(height: 16),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: [
              _summaryChip(
                icon: Icons.support_agent_outlined,
                label: 'Reclamatii: ${filteredItems.length}',
              ),
              _summaryChip(
                icon: Icons.pending_actions_outlined,
                label: 'Active: $unresolvedCount',
                color: Colors.orange,
              ),
              _summaryChip(
                icon: Icons.event_available_outlined,
                label: 'Programate: $programmedCount',
                color: Colors.indigo,
              ),
              _summaryChip(
                icon: Icons.description_outlined,
                label: 'Cu PV: $reportedCount',
                color: Colors.teal,
              ),
              _summaryChip(
                icon: Icons.request_quote_outlined,
                label: 'Cu deviz: $offeredCount',
                color: Colors.deepPurple,
              ),
            ],
          ),
          const SizedBox(height: 16),
          Text(
            'Afisare lista',
            style: Theme.of(context).textTheme.titleSmall,
          ),
          const SizedBox(height: 8),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: [
              for (final option in _complaintListZoomOptions)
                ChoiceChip(
                  label: Text(option.value),
                  selected: _complaintListZoom == option.key,
                  visualDensity: VisualDensity.compact,
                  onSelected: (_) async {
                    setState(() {
                      _complaintListZoom = option.key;
                    });
                    await _persistComplaintDisplayPreferences();
                  },
                ),
              FilterChip(
                label: const Text('Compact'),
                selected: _compactComplaintCards,
                visualDensity: VisualDensity.compact,
                onSelected: (value) async {
                  setState(() {
                    _compactComplaintCards = value;
                  });
                  await _persistComplaintDisplayPreferences();
                },
              ),
            ],
          ),
          const SizedBox(height: 12),
          Wrap(
            spacing: 8,
            runSpacing: 8,
            children: [
              _summaryChip(
                icon: Icons.cloud_done_outlined,
                label: 'Sursa: $_dataSourceLabel',
              ),
              if ((_fallbackReason ?? '').trim().isNotEmpty)
                _summaryChip(
                  icon: Icons.cloud_off_outlined,
                  label: 'Fallback: ${_fallbackReason!.trim()}',
                  color: Colors.deepOrange,
                ),
            ],
          ),
          const SizedBox(height: 16),
          Align(
            alignment: Alignment.centerLeft,
            child: TextButton.icon(
              onPressed: () {
                setState(() {
                  _searchController.clear();
                  _searchQuery = '';
                  _statusFilter = null;
                  _typeFilter = null;
                  _contractorFilter = '';
                  _teamFilter = '';
                  _employeeFilter = '';
                  _scheduledFilter = null;
                  _reportFilter = null;
                });
                _persistComplaintFilterPreferences();
              },
              icon: const Icon(Icons.refresh_outlined),
              label: const Text('Reseteaza filtrele'),
            ),
          ),
          const SizedBox(height: 8),
          if (_selectedComplaint != null) ...[
            const Divider(height: 1),
            const SizedBox(height: 16),
            Text(
              'Detaliu selectat',
              style: Theme.of(context).textTheme.titleMedium,
            ),
            const SizedBox(height: 12),
            _buildComplaintDetails(_selectedComplaint!),
            const SizedBox(height: 12),
            Wrap(
              spacing: 8,
              runSpacing: 8,
              children: [
                OutlinedButton.icon(
                  onPressed: () =>
                      _openComplaintStatusPicker(_selectedComplaint!),
                  icon: const Icon(Icons.flag_outlined),
                  label: const Text('Schimba statusul'),
                ),
                FilledButton.tonalIcon(
                  onPressed: () => _scheduleComplaint(_selectedComplaint!),
                  icon: Icon(
                    _hasAppointment(_selectedComplaint!)
                        ? Icons.open_in_new_outlined
                        : Icons.event_available_outlined,
                  ),
                  label: Text(
                    _hasAppointment(_selectedComplaint!)
                        ? 'Deschide programarea'
                        : 'Programeaza',
                  ),
                ),
                if (_hasAppointment(_selectedComplaint!))
                  OutlinedButton.icon(
                    onPressed: () => _scheduleComplaint(
                      _selectedComplaint!,
                      forceNew: true,
                    ),
                    icon: const Icon(Icons.add_task_outlined),
                    label: const Text('Adauga vizita noua'),
                  ),
                OutlinedButton.icon(
                  onPressed: () => _openComplaintOffer(_selectedComplaint!),
                  icon: const Icon(Icons.request_quote_outlined),
                  label: Text(
                    _hasOffer(_selectedComplaint!)
                        ? 'Deschide deviz / oferta'
                        : 'Genereaza deviz / oferta',
                  ),
                ),
                OutlinedButton.icon(
                  onPressed: () =>
                      _openComplaintFieldPhotos(_selectedComplaint!),
                  icon: const Icon(Icons.photo_camera_outlined),
                  label: const Text('Poze teren'),
                ),
                OutlinedButton.icon(
                  onPressed: () => _openRepairReport(_selectedComplaint!),
                  icon: const Icon(Icons.description_outlined),
                  label: Text(
                    _hasReport(_selectedComplaint!)
                        ? 'Deschide proces verbal'
                        : 'Genereaza proces verbal',
                  ),
                ),
                OutlinedButton.icon(
                  onPressed: () =>
                      _openWarrantyInterventionReport(_selectedComplaint!),
                  icon: const Icon(Icons.assignment_outlined),
                  label: Text(
                    _warrantyInterventionReportForComplaint(
                                _selectedComplaint!.id) ==
                            null
                        ? 'Genereaza PV garantie'
                        : 'Deschide PV garantie',
                  ),
                ),
              ],
            ),
          ],
        ],
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    if (_loading) {
      return const Center(child: CircularProgressIndicator());
    }

    final items = _filteredItems;
    final width = MediaQuery.sizeOf(context).width;
    final showInlineSidePanel = width >= 1280;
    final sideDrawerWidth = width >= 900 ? 380.0 : width * 0.92;

    return Scaffold(
      appBar: AppBar(
        title: const Text('Reclamatii'),
        actions: [
          TextButton.icon(
            onPressed:
                _selectedComplaint == null ? null : _openComplaintAiAssistant,
            icon: const Icon(Icons.auto_awesome_outlined),
            label: const Text('Asistent AI'),
          ),
          HelpButton(content: AppHelp.reclamatii),
          if (!showInlineSidePanel)
            Builder(
              builder: (context) => IconButton(
                tooltip: 'Filtre si detaliu',
                onPressed: () => Scaffold.of(context).openEndDrawer(),
                icon: const Icon(Icons.tune_outlined),
              ),
            ),
        ],
      ),
      floatingActionButton: _canManageComplaintsWide
          ? FloatingActionButton.extended(
              onPressed: () => _openComplaintForm(),
              icon: const Icon(Icons.add),
              label: const Text('Adauga'),
            )
          : null,
      endDrawer: showInlineSidePanel
          ? null
          : Drawer(
              width: sideDrawerWidth,
              child: SafeArea(
                child: Padding(
                  padding: const EdgeInsets.all(16),
                  child: _buildFiltersPanel(items),
                ),
              ),
            ),
      body: AdaptiveSidePanelLayout(
        showSidePanel: showInlineSidePanel,
        sidePanelWidth: 380,
        mainContent: Padding(
          padding: EdgeInsets.only(
            bottom: AppViewportGuard.bottomSpacing(reserveForFab: true),
          ),
          child: Column(
            children: [
              if (!showInlineSidePanel)
                Padding(
                  padding: const EdgeInsets.fromLTRB(16, 12, 16, 0),
                  child: Align(
                    alignment: Alignment.centerLeft,
                    child: FilledButton.tonalIcon(
                      onPressed: () => Scaffold.of(context).openEndDrawer(),
                      icon: const Icon(Icons.tune_outlined),
                      label: const Text('Filtre si detaliu'),
                    ),
                  ),
                ),
              Expanded(
                child: items.isEmpty
                    ? Center(
                        child: Padding(
                          padding: const EdgeInsets.all(24),
                          child: Column(
                            mainAxisSize: MainAxisSize.min,
                            children: [
                              Icon(
                                Icons.support_agent_outlined,
                                size: 44,
                                color: Theme.of(context).colorScheme.primary,
                              ),
                              const SizedBox(height: 12),
                              Text(
                                'Nu exista reclamatii pe filtrul curent.',
                                style: Theme.of(context).textTheme.titleMedium,
                                textAlign: TextAlign.center,
                              ),
                              const SizedBox(height: 8),
                              Text(
                                _items.isEmpty
                                    ? 'Modulul este pregatit. Poti adauga prima reclamatie si apoi continua cu programare si proces verbal.'
                                    : 'Schimba filtrele sau reseteaza cautarea pentru a vedea alte reclamatii.',
                                textAlign: TextAlign.center,
                                style: Theme.of(context).textTheme.bodyMedium,
                              ),
                              const SizedBox(height: 16),
                              Wrap(
                                spacing: 8,
                                runSpacing: 8,
                                alignment: WrapAlignment.center,
                                children: [
                                  if (_items.isNotEmpty)
                                    OutlinedButton.icon(
                                      onPressed: () => setState(() {
                                        _searchController.clear();
                                        _searchQuery = '';
                                        _statusFilter = null;
                                        _typeFilter = null;
                                        _contractorFilter = '';
                                        _teamFilter = '';
                                        _employeeFilter = '';
                                        _scheduledFilter = null;
                                        _reportFilter = null;
                                      }),
                                      icon: const Icon(Icons.refresh_outlined),
                                      label: const Text('Reseteaza filtrele'),
                                    ),
                                  if (_canManageComplaintsWide)
                                    FilledButton.icon(
                                      onPressed: () => _openComplaintForm(),
                                      icon: const Icon(Icons.add),
                                      label: const Text('Adauga reclamatie'),
                                    ),
                                ],
                              ),
                            ],
                          ),
                        ),
                      )
                    : ListView.builder(
                        padding: AppViewportGuard.scrollablePadding(
                          reserveForFab: true,
                        ),
                        itemCount: items.length,
                        itemBuilder: (context, index) {
                          final item = items[index];
                          final beneficiary = _resolvedBeneficiaryName(item);
                          final contractor = _resolvedContractorName(item);
                          final selected = _selectedComplaint?.id == item.id;
                          final compact = _compactComplaintCards;
                          final zoom = _complaintListZoom;
                          final accentColor = _complaintAccentColor(item);
                          final cardPadding = (compact ? 12.0 : 14.0) * zoom;
                          final titleStyle = Theme.of(context)
                              .textTheme
                              .titleMedium
                              ?.copyWith(fontSize: 16 * zoom);
                          final subtitleStyle = Theme.of(context)
                              .textTheme
                              .bodyMedium
                              ?.copyWith(fontSize: 13 * zoom);
                          return Card(
                            color: _complaintCardSurfaceColor(
                              item,
                              selected: selected,
                            ),
                            shape: RoundedRectangleBorder(
                              borderRadius: BorderRadius.circular(16),
                              side: BorderSide(
                                color: accentColor.withValues(alpha: 0.28),
                              ),
                            ),
                            margin: EdgeInsets.only(bottom: 12 * zoom),
                            child: Row(
                              crossAxisAlignment: CrossAxisAlignment.stretch,
                              children: [
                                  Container(
                                    width: compact ? 5 : 7,
                                    decoration: BoxDecoration(
                                      color: accentColor,
                                      borderRadius:
                                          const BorderRadius.horizontal(
                                        left: Radius.circular(16),
                                      ),
                                    ),
                                  ),
                                Expanded(
                                  child: Padding(
                                    padding: EdgeInsets.all(cardPadding),
                                    child: Column(
                                      crossAxisAlignment:
                                          CrossAxisAlignment.start,
                                      children: [
                                        InkWell(
                                          borderRadius:
                                              BorderRadius.circular(12),
                                          onTap: () => _selectComplaint(
                                            item,
                                            source: 'card',
                                          ),
                                          child: Padding(
                                            padding: const EdgeInsets.all(4),
                                            child: Column(
                                              crossAxisAlignment:
                                                  CrossAxisAlignment.start,
                                              children: [
                                          Row(
                                            crossAxisAlignment:
                                                CrossAxisAlignment.start,
                                            children: [
                                              Expanded(
                                                child: Column(
                                                  crossAxisAlignment:
                                                      CrossAxisAlignment.start,
                                                  children: [
                                                    Text(
                                                      item.complaintNumber
                                                              .trim()
                                                              .isEmpty
                                                          ? 'Reclamatie'
                                                          : item
                                                              .complaintNumber,
                                                      style: titleStyle,
                                                    ),
                                                    SizedBox(height: 4 * zoom),
                                                    Text(
                                                      '${_date(item.complaintDate)} | ${item.type.label} | ${item.source.label}',
                                                      style: subtitleStyle,
                                                    ),
                                                    SizedBox(height: 6 * zoom),
                                                    Text(
                                                      beneficiary.isEmpty
                                                          ? 'Beneficiar necompletat'
                                                          : beneficiary,
                                                      style: Theme.of(context)
                                                          .textTheme
                                                          .titleSmall
                                                          ?.copyWith(
                                                            fontWeight:
                                                                FontWeight.w600,
                                                            fontSize: 14 * zoom,
                                                          ),
                                                    ),
                                                    if (!compact &&
                                                        contractor
                                                            .isNotEmpty) ...[
                                                      SizedBox(
                                                          height: 2 * zoom),
                                                      Text(
                                                        'Contractant: $contractor',
                                                        style: subtitleStyle,
                                                      ),
                                                    ],
                                                  ],
                                                ),
                                              ),
                                              _statusBadge(
                                                label:
                                                    'Status: ${item.status.label}',
                                                color:
                                                    _statusColor(item.status),
                                                icon: Icons.flag_outlined,
                                              ),
                                            ],
                                          ),
                                          SizedBox(height: 10 * zoom),
                                          Wrap(
                                            spacing: 8,
                                            runSpacing: 8,
                                            children: [
                                              _summaryChip(
                                                icon: _hasAppointment(item)
                                                    ? Icons
                                                        .event_available_outlined
                                                    : Icons.event_busy_outlined,
                                                label: _hasAppointment(item)
                                                    ? 'Programare: asociata'
                                                    : 'Fara programare',
                                                color: _hasAppointment(item)
                                                    ? Colors.indigo
                                                    : Colors.orange,
                                              ),
                                              _summaryChip(
                                                icon: Icons.schedule_outlined,
                                                label:
                                                    'Status programare: ${_appointmentStatusLabel(item)}',
                                                color: _appointmentStatusColor(
                                                    item),
                                              ),
                                              if (!compact &&
                                                  _appointmentCount(item) > 0)
                                                _summaryChip(
                                                  icon: Icons.repeat_outlined,
                                                  label: _appointmentCount(
                                                              item) ==
                                                          1
                                                      ? 'Prima vizita'
                                                      : 'Vizite: ${_appointmentCount(item)}',
                                                  color: Colors.indigo,
                                                ),
                                              if (!compact &&
                                                  _followUpCount(item) > 0)
                                                _summaryChip(
                                                  icon: Icons.redo_outlined,
                                                  label:
                                                      'Reveniri: ${_followUpCount(item)}',
                                                  color: Colors.blue,
                                                ),
                                              if (!compact &&
                                                  _hasUpcomingAppointment(item))
                                                _summaryChip(
                                                  icon: Icons.upcoming_outlined,
                                                  label: 'Programare viitoare',
                                                  color: Colors.indigo,
                                                ),
                                              if (_postponedAppointmentCount(
                                                      item) >
                                                  0)
                                                _summaryChip(
                                                  icon:
                                                      Icons.event_busy_outlined,
                                                  label:
                                                      'Amanari: ${_postponedAppointmentCount(item)}',
                                                  color: Colors.orange,
                                                ),
                                              if (!compact &&
                                                  _hasEquipmentData(item))
                                                _summaryChip(
                                                  icon: Icons
                                                      .precision_manufacturing_outlined,
                                                  label: _equipmentLabel(item),
                                                  color: Colors.cyan.shade700,
                                                ),
                                              _summaryChip(
                                                icon: _hasReport(item)
                                                    ? Icons.description_outlined
                                                    : Icons.description_rounded,
                                                label: _hasReport(item)
                                                    ? 'Proces verbal: existent'
                                                    : 'Fara proces verbal',
                                                color: _hasReport(item)
                                                    ? Colors.teal
                                                    : Colors.blueGrey,
                                              ),
                                              _summaryChip(
                                                icon: _warrantyInterventionReportForComplaint(
                                                            item.id) ==
                                                        null
                                                    ? Icons.assignment_outlined
                                                    : Icons
                                                        .assignment_turned_in_outlined,
                                                label:
                                                    _warrantyInterventionReportForComplaint(
                                                                item.id) ==
                                                            null
                                                        ? 'Fara PV garantie'
                                                        : 'PV garantie: existent',
                                                color:
                                                    _warrantyInterventionReportForComplaint(
                                                                item.id) ==
                                                            null
                                                        ? Colors.blueGrey
                                                        : Colors.green,
                                              ),
                                              _summaryChip(
                                                icon: _hasOffer(item)
                                                    ? Icons
                                                        .request_quote_outlined
                                                    : Icons
                                                        .request_quote_rounded,
                                                label: _hasOffer(item)
                                                    ? 'Deviz / oferta: existent'
                                                    : 'Fara deviz / oferta',
                                                color: _hasOffer(item)
                                                    ? Colors.deepPurple
                                                    : Colors.blueGrey,
                                              ),
                                              if (!compact &&
                                                  _hasOffer(item) &&
                                                  _offerCommercialRecipientLabel(
                                                          item) !=
                                                      '-')
                                                _summaryChip(
                                                  icon: Icons
                                                      .account_balance_wallet_outlined,
                                                  label:
                                                      'Platitor: ${_offerCommercialRecipientLabel(item)}',
                                                  color: Colors.deepPurple,
                                                ),
                                              if (!compact && _hasOffer(item))
                                                _summaryChip(
                                                  icon: _hasSignedOfferAgreement(
                                                          item)
                                                      ? Icons.verified_outlined
                                                      : Icons
                                                          .pending_actions_outlined,
                                                  label:
                                                      'Acord: ${_offerAgreementLabel(item)}',
                                                  color:
                                                      _hasSignedOfferAgreement(
                                                              item)
                                                          ? Colors.green
                                                          : Colors.orange,
                                                ),
                                              _summaryChip(
                                                icon: Icons
                                                    .assignment_ind_outlined,
                                                label: _assignmentLabel(item),
                                                color: Colors.blueGrey,
                                              ),
                                              if (!compact &&
                                                  item.phone.trim().isNotEmpty)
                                                _summaryChip(
                                                  icon: Icons.phone_outlined,
                                                  label: item.phone.trim(),
                                                  color: Colors.blueGrey,
                                                ),
                                              if (!compact &&
                                                  item.location
                                                      .trim()
                                                      .isNotEmpty)
                                                _summaryChip(
                                                  icon: Icons.place_outlined,
                                                  label: item.location.trim(),
                                                  color: Colors.blueGrey,
                                                ),
                                            ],
                                          ),
                                          SizedBox(height: 10 * zoom),
                                          Text(
                                            item.problemDescription.isEmpty
                                                ? '-'
                                                : item.problemDescription,
                                            maxLines: compact ? 2 : 3,
                                            overflow: TextOverflow.ellipsis,
                                            style: subtitleStyle,
                                          ),
                                              ],
                                            ),
                                          ),
                                        ),
                                          SizedBox(height: 10 * zoom),
                                          Wrap(
                                            spacing: 8,
                                            runSpacing: 8,
                                            children: [
                                              OutlinedButton.icon(
                                                onPressed: () {
                                                  _logComplaintUi(
                                                    'card button tapped: status id=${item.id}',
                                                  );
                                                  _openComplaintStatusPicker(
                                                    item,
                                                  );
                                                },
                                                icon: const Icon(
                                                    Icons.flag_outlined),
                                                label: const Text('Status'),
                                              ),
                                              OutlinedButton.icon(
                                                onPressed: () =>
                                                    _openComplaintDetails(item),
                                                icon: const Icon(
                                                    Icons.visibility_outlined),
                                                label: const Text('Detaliu'),
                                              ),
                                              OutlinedButton.icon(
                                                onPressed: () {
                                                  _logComplaintUi(
                                                    'card button tapped: documents id=${item.id}',
                                                  );
                                                  _openLinkedDocumentsManagerForComplaint(
                                                    item,
                                                  );
                                                },
                                                icon: Icon(
                                                  item.linkedDocuments.isEmpty
                                                      ? Icons
                                                          .attach_file_outlined
                                                      : Icons
                                                          .folder_shared_outlined,
                                                ),
                                                label: Text(
                                                  item.linkedDocuments.isEmpty
                                                      ? 'Documente'
                                                      : 'Documente ${item.linkedDocuments.length}',
                                                ),
                                              ),
                                              FilledButton.tonalIcon(
                                                onPressed: () {
                                                  _logComplaintUi(
                                                    'card button tapped: schedule id=${item.id}',
                                                  );
                                                  _scheduleComplaint(item);
                                                },
                                                icon: Icon(
                                                  _hasAppointment(item)
                                                      ? Icons
                                                          .open_in_new_outlined
                                                      : Icons
                                                          .event_available_outlined,
                                                ),
                                                label: Text(
                                                  _hasAppointment(item)
                                                      ? 'Deschide programarea'
                                                      : 'Programeaza',
                                                ),
                                              ),
                                              if (_hasAppointment(item))
                                                OutlinedButton.icon(
                                                  onPressed: () {
                                                    _logComplaintUi(
                                                      'card button tapped: new-visit id=${item.id}',
                                                    );
                                                    _scheduleComplaint(
                                                      item,
                                                      forceNew: true,
                                                    );
                                                  },
                                                  icon: const Icon(
                                                    Icons.add_task_outlined,
                                                  ),
                                                  label:
                                                      const Text('Vizita noua'),
                                                ),
                                              OutlinedButton.icon(
                                                onPressed: () {
                                                  _logComplaintUi(
                                                    'card button tapped: offer id=${item.id}',
                                                  );
                                                  _openComplaintOffer(item);
                                                },
                                                icon: const Icon(Icons
                                                    .request_quote_outlined),
                                                label: Text(
                                                  _hasOffer(item)
                                                      ? 'Deschide deviz / oferta'
                                                      : 'Genereaza deviz / oferta',
                                                ),
                                              ),
                                              OutlinedButton.icon(
                                                onPressed: () {
                                                  _logComplaintUi(
                                                    'card button tapped: report id=${item.id}',
                                                  );
                                                  _openRepairReport(item);
                                                },
                                                icon: const Icon(
                                                    Icons.description_outlined),
                                                label: Text(
                                                  _reportForComplaint(
                                                              item.id) ==
                                                          null
                                                      ? 'Genereaza proces verbal'
                                                      : 'Deschide proces verbal',
                                                ),
                                              ),
                                              OutlinedButton.icon(
                                                onPressed: () {
                                                  _logComplaintUi(
                                                    'card button tapped: warranty-report id=${item.id}',
                                                  );
                                                  _openWarrantyInterventionReport(
                                                    item,
                                                  );
                                                },
                                                icon: const Icon(
                                                  Icons.assignment_outlined,
                                                ),
                                                label: Text(
                                                  _warrantyInterventionReportForComplaint(
                                                              item.id) ==
                                                          null
                                                      ? 'PV garantie'
                                                      : 'Deschide PV garantie',
                                                ),
                                              ),
                                              OutlinedButton.icon(
                                                onPressed: () {
                                                  _logComplaintUi(
                                                    'card button tapped: edit id=${item.id}',
                                                  );
                                                  _openComplaintForm(item);
                                                },
                                                icon: const Icon(
                                                    Icons.edit_outlined),
                                                label: const Text('Editeaza'),
                                              ),
                                              if (_canManageComplaintsWide)
                                                OutlinedButton.icon(
                                                  onPressed: () {
                                                    _logComplaintUi(
                                                      'card button tapped: delete id=${item.id}',
                                                    );
                                                    _deleteComplaint(item);
                                                  },
                                                  icon: const Icon(
                                                    Icons.delete_outline,
                                                  ),
                                                  label: const Text('Șterge'),
                                                ),
                                            ],
                                          ),
                                        ],
                                      ),
                                    ),
                                  ),
                                ],
                              ),
                          );
                        },
                      ),
              ),
            ],
          ),
        ),
        sidePanel: SafeArea(
          child: SidePanelCard(
            title: 'Filtre si detaliu',
            child: _buildFiltersPanel(items),
          ),
        ),
      ),
    );
  }
}

class _CentralizerSelection {
  const _CentralizerSelection({
    required this.complaintIds,
    required this.offerIds,
  });

  final Set<String> complaintIds;
  final Set<String> offerIds;
}
