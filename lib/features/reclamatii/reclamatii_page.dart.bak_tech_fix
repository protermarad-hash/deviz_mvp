                            : _productCatalogService
                                .coverageStatusForCertificate(selected);
                        return Column(
                          crossAxisAlignment: CrossAxisAlignment.stretch,
                          children: [
                            DropdownButtonFormField<String?>(
                              initialValue: certificateId.trim().isEmpty
                                  ? null
                                  : certificateId,
