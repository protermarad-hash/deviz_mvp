class ReclamatiiPage extends StatefulWidget {
  const ReclamatiiPage({
    super.key,
    required this.repository,
    this.fieldAuthRoleKey,
    this.fieldAuthUserLabel,
    this.fieldAuthUserId,
    this.fieldAuthTeamId,
    this.initialFocusComplaintId = '',
  });

  final AppDataRepository repository;
  final String? fieldAuthRoleKey;
  final String? fieldAuthUserLabel;
  final String? fieldAuthUserId;
  final String? fieldAuthTeamId;
  final String initialFocusComplaintId;

  @override
  State<ReclamatiiPage> createState() => _ReclamatiiPageState();
}

class _ReclamatiiPageState extends State<ReclamatiiPage> {
  static const String _complaintListZoomPreferenceKey =
      'reclamatii_list_zoom_v1';
  static const String _complaintListCompactPreferenceKey =
      'reclamatii_list_compact_v1';
  // Persistența filtrelor active
  static const String _filterContractorPreferenceKey =
      'reclamatii_filter_contractor_v1';
  static const String _filterTeamPreferenceKey =
      'reclamatii_filter_team_v1';
  static const String _filterEmployeePreferenceKey =
      'reclamatii_filter_employee_v1';
  static const List<MapEntry<double, String>> _complaintListZoomOptions =
      <MapEntry<double, String>>[
    MapEntry<double, String>(0.88, 'Mic'),
    MapEntry<double, String>(1.0, 'Standard'),
    MapEntry<double, String>(1.12, 'Mare'),
  ];
  final Uuid _uuid = const Uuid();
  AiAssistantService get _aiAssistantService =>
      AiAssistantService(repository: widget.repository);
  final TextEditingController _searchController = TextEditingController();
  final LocalOferteRepository _localOferteRepository = LocalOferteRepository();
  final ProductCatalogService _productCatalogService = ProductCatalogService();
  final NotificationCenterService _notificationService =
      NotificationCenterService();
  bool _loading = true;
  Timer? _clientsReloadDebounce;
  bool _clientsReloading = false;
  AppUser? _currentUser;
  List<ComplaintRecord> _items = const <ComplaintRecord>[];
  List<ClientRecord> _clients = const <ClientRecord>[];
  List<Team> _teams = const <Team>[];
  List<EmployeeLookup> _employees = const <EmployeeLookup>[];
  List<JobRecord> _jobs = const <JobRecord>[];
  List<AgfrEquipmentRecord> _agfrEquipments = const <AgfrEquipmentRecord>[];
  List<AgfrInterventionRecord> _agfrInterventions =
      const <AgfrInterventionRecord>[];
  List<AgfrReportRecord> _agfrReports = const <AgfrReportRecord>[];
  List<Appointment> _appointments = const <Appointment>[];
  List<RepairReportRecord> _reports = const <RepairReportRecord>[];
  List<WarrantyInterventionReportRecord> _warrantyInterventionReports =
      const <WarrantyInterventionReportRecord>[];
  List<OfferRecord> _offers = const <OfferRecord>[];
  List<WarrantyCertificateRecord> _warrantyCertificates =
      const <WarrantyCertificateRecord>[];

  String _searchQuery = '';
  ComplaintStatus? _statusFilter;
  ComplaintType? _typeFilter;
  String _contractorFilter = '';
  String _teamFilter = '';
  String _employeeFilter = '';
  bool? _scheduledFilter;
  bool? _reportFilter;
  ComplaintRecord? _selectedComplaint;
  // Cache filtrare — calculat o dată la schimbarea datelor/filtrelor
  List<ComplaintRecord> _cachedFilteredItems = const <ComplaintRecord>[];
  bool _didHandleInitialFocusComplaint = false;
  double _complaintListZoom = 1.0;
  bool _compactComplaintCards = false;

  String _dataSourceLabel = 'local_cache';
  String? _fallbackReason;
  FirebaseOferteRepository? _cloudOferteRepository;
  double _defaultVatPercent = 21.0;
  double _defaultProfitPercent = 0.0;

  @override
  void initState() {
    super.initState();
    if (FirebaseBootstrap.isInitialized) {
      _cloudOferteRepository = FirebaseOferteRepository();
    }
    _loadComplaintDisplayPreferences();
    Future.microtask(_load);
    LocalAppDataRepository.clientsChangeCount.addListener(_handleClientsChanged);
  }

  @override
  void dispose() {
    LocalAppDataRepository.clientsChangeCount.removeListener(_handleClientsChanged);
    _clientsReloadDebounce?.cancel();
    _searchController.dispose();
    super.dispose();
  }

  void _handleClientsChanged() {
    if (_loading) {
      return;
    }
    _clientsReloadDebounce?.cancel();
    _clientsReloadDebounce = Timer(const Duration(milliseconds: 250), () {
      if (!mounted) return;
      _reloadClientsOnly();
    });
  }

  Future<void> _reloadClientsOnly() async {
    if (_loading || _clientsReloading) {
      return;
    }
    _clientsReloading = true;
    try {
      final clients = await widget.repository.listClients();
      if (!mounted) return;
      setState(() => _clients = clients);
    } finally {
      _clientsReloading = false;
    }
  }

  void _syncComplaintDataSourceLabel() {
    if (widget.repository is LocalAppDataRepository) {
      final repository = widget.repository as LocalAppDataRepository;
      _dataSourceLabel = repository.lastComplaintsDataSourceLabel;
      final reason = repository.lastComplaintsFallbackReason.trim();
      _fallbackReason = reason.isEmpty ? null : reason;
    } else {
      _dataSourceLabel = 'cloud';
      _fallbackReason = null;
    }
  }

  Future<void> _loadComplaintDisplayPreferences() async {
    final prefs = await SharedPreferences.getInstance();
    final zoom = prefs.getDouble(_complaintListZoomPreferenceKey) ?? 1.0;
    final compact = prefs.getBool(_complaintListCompactPreferenceKey) ?? false;
    final savedContractor =
        (prefs.getString(_filterContractorPreferenceKey) ?? '').trim();
    final savedTeam =
        (prefs.getString(_filterTeamPreferenceKey) ?? '').trim();
    final savedEmployee =
        (prefs.getString(_filterEmployeePreferenceKey) ?? '').trim();
    if (!mounted) {
      return;
    }
    setState(() {
      _complaintListZoom = zoom.clamp(0.88, 1.12);
      _compactComplaintCards = compact;
      _contractorFilter = savedContractor;
      _teamFilter = savedTeam;
      _employeeFilter = savedEmployee;
    });
  }

  Future<void> _persistComplaintDisplayPreferences() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setDouble(_complaintListZoomPreferenceKey, _complaintListZoom);
    await prefs.setBool(
      _complaintListCompactPreferenceKey,
      _compactComplaintCards,
    );
  }

  Future<void> _persistComplaintFilterPreferences() async {
    final prefs = await SharedPreferences.getInstance();
    await Future.wait([
      prefs.setString(_filterContractorPreferenceKey, _contractorFilter),
      prefs.setString(_filterTeamPreferenceKey, _teamFilter),
      prefs.setString(_filterEmployeePreferenceKey, _employeeFilter),
    ]);
  }

  Future<void> _saveComplaintResolved(ComplaintRecord complaint) async {
    await widget.repository.saveComplaint(complaint);
    _syncComplaintDataSourceLabel();
    // Queue apelat din repository (CLAUDE.md: nu din pagini)
  }

  void _logComplaintUi(String message) {
    assert(() {
      debugPrint('[Reclamatii] $message');
      return true;
    }());
  }

  void _selectComplaint(ComplaintRecord item, {required String source}) {
    _logComplaintUi('selected complaint id=${item.id} source=$source');
    setState(() {
      _selectedComplaint = item;
    });
  }

  String _fileNameFromPath(String path) {
    final normalized = path.replaceAll('\\', '/');
    final segments = normalized.split('/');
    return segments.isEmpty ? path : segments.last;
  }

  List<ComplaintLinkedDocument> _normalizeComplaintLinkedDocuments(
    Iterable<ComplaintLinkedDocument> entries,
  ) {
    final seenPaths = <String>{};
    final normalized = <ComplaintLinkedDocument>[];
    for (final entry in entries) {
      final path = entry.filePath.trim();
      if (path.isEmpty || seenPaths.contains(path)) {
        continue;
      }
      seenPaths.add(path);
      final fileName = entry.fileName.trim().isEmpty
          ? _fileNameFromPath(path)
          : entry.fileName.trim();
      normalized.add(
        entry.copyWith(
          filePath: path,
          fileName: fileName,
          label: entry.label.trim().isEmpty ? fileName : entry.label.trim(),
        ),
      );
    }
    return List<ComplaintLinkedDocument>.unmodifiable(normalized);
  }

  Future<ComplaintLinkedDocument?> _pickComplaintLinkedDocument() async {
    final result = await FilePicker.platform.pickFiles(
      type: FileType.any,
      allowMultiple: false,
      withData: false,
    );
    if (result == null || result.files.isEmpty) {
      return null;
    }
    final picked = result.files.single;
    final path = (picked.path ?? '').trim();
    if (path.isEmpty) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('Fisierul selectat nu poate fi accesat local.'),
          ),
        );
      }
      return null;
    }
    final fileName = picked.name.trim().isEmpty
        ? _fileNameFromPath(path)
        : picked.name.trim();
    return ComplaintLinkedDocument(
      label: fileName,
      filePath: path,
      fileName: fileName,
    );
  }

  Future<String?> _promptLinkedDocumentLabel({
    required String title,
    required String initialValue,
    String? helperText,
  }) async {
    final controller = TextEditingController(text: initialValue);
    return showDialog<String>(
      context: context,
      builder: (dialogContext) => AlertDialog(
        title: Text(title),
        content: TextField(
          textCapitalization: TextCapitalization.sentences,
          controller: controller,
          autofocus: true,
          decoration: InputDecoration(
            labelText: 'Eticheta document',
            helperText: helperText,
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(dialogContext).pop(),
            child: const Text('Renunta'),
          ),
          FilledButton(
            onPressed: () {
              final value = controller.text.trim();
              Navigator.of(dialogContext).pop(value);
            },
            child: const Text('Salveaza'),
          ),
        ],
      ),
    );
  }

  Future<void> _openLinkedDocumentsManagerForComplaint(
    ComplaintRecord complaint,
  ) async {
    var current = complaint;
    var documents = _normalizeComplaintLinkedDocuments(current.linkedDocuments);
    await showDialog<void>(
      context: context,
      builder: (dialogContext) {
        return StatefulBuilder(
          builder: (context, setDialogState) {
            Future<void> addDocument() async {
              final picked = await _pickComplaintLinkedDocument();
              if (picked == null) {
                return;
              }
              final updated = _normalizeComplaintLinkedDocuments(
                <ComplaintLinkedDocument>[...documents, picked],
              );
              current = current.copyWith(
                linkedDocuments: updated,
                updatedAt: DateTime.now(),
              );
              await _saveComplaintResolved(current);
              await _load();
              if (!dialogContext.mounted) {
                return;
              }
              setDialogState(() {
                documents = updated;
              });
            }

            Future<void> renameDocument(
                ComplaintLinkedDocument document) async {
              final fileName = document.fileName.trim().isEmpty
                  ? _fileNameFromPath(document.filePath)
                  : document.fileName.trim();
              final updatedLabel = await _promptLinkedDocumentLabel(
                title: 'Redenumeste documentul',
                initialValue: document.label.trim().isEmpty
                    ? fileName
                    : document.label.trim(),
                helperText:
                    'Eticheta se afiseaza in reclamatie, fara sa modifice fisierul original.',
              );
              if (updatedLabel == null || updatedLabel.trim().isEmpty) {
                return;
              }
              final updated = _normalizeComplaintLinkedDocuments(
                documents.map(
                  (entry) => entry.filePath == document.filePath
                      ? entry.copyWith(label: updatedLabel.trim())
                      : entry,
                ),
              );
              current = current.copyWith(
                linkedDocuments: updated,
                updatedAt: DateTime.now(),
              );
              await _saveComplaintResolved(current);
              await _load();
              if (!dialogContext.mounted) {
                return;
              }
              setDialogState(() {
                documents = updated;
              });
            }

            Future<void> removeDocument(
                ComplaintLinkedDocument document) async {
              final updated = _normalizeComplaintLinkedDocuments(
                documents.where((entry) => entry.filePath != document.filePath),
              );
              current = current.copyWith(
                linkedDocuments: updated,
                updatedAt: DateTime.now(),
              );
              await _saveComplaintResolved(current);
              await _load();
              if (!dialogContext.mounted) {
                return;
              }
              setDialogState(() {
                documents = updated;
              });
            }

            return AlertDialog(
              title: const Text('Documente incarcate pe reclamatie'),
              content: SizedBox(
                width: 720,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Wrap(
                      spacing: 8,
                      runSpacing: 8,
                      children: [
                        Chip(
                          avatar:
                              const Icon(Icons.attach_file_outlined, size: 16),
                          label: Text(
                            documents.isEmpty
                                ? 'Fara documente atasate'
                                : 'Documente: ${documents.length}',
                          ),
                          visualDensity: VisualDensity.compact,
                        ),
                        FilledButton.tonalIcon(
                          onPressed: addDocument,
                          icon: const Icon(Icons.upload_file_outlined),
                          label: const Text('Incarca document'),
                        ),
                      ],
                    ),
                    const SizedBox(height: 12),
                    if (documents.isEmpty)
                      const Padding(
                        padding: EdgeInsets.symmetric(vertical: 12),
                        child: Text(
                          'Incarca devize, PV-uri, poze sau alte documente relevante direct pe caz.',
                        ),
                      )
                    else
                      Flexible(
                        child: ListView.separated(
                          shrinkWrap: true,
                          itemCount: documents.length,
                          separatorBuilder: (_, __) => const Divider(height: 1),
                          itemBuilder: (context, index) {
                            final document = documents[index];
                            final fileName = document.fileName.trim().isEmpty
                                ? _fileNameFromPath(document.filePath)
                                : document.fileName.trim();
                            return ListTile(
                              contentPadding: EdgeInsets.zero,
                              leading:
                                  const Icon(Icons.insert_drive_file_outlined),
                              title: Text(
                                document.label.trim().isEmpty
                                    ? fileName
                                    : document.label.trim(),
                              ),
                              subtitle: Text(
                                fileName,
                                maxLines: 2,
                                overflow: TextOverflow.ellipsis,
                              ),
                              trailing: Wrap(
                                spacing: 4,
                                children: [
                                  IconButton(
                                    tooltip: 'Deschide',
                                    onPressed: () async {
                                      final result =
                                          await DocumentFileService.openFile(
                                        document.filePath,
                                      );
                                      if (!context.mounted) {
                                        return;
                                      }
                                      ScaffoldMessenger.of(context)
                                          .showSnackBar(
                                        SnackBar(content: Text(result.message)),
                                      );
                                    },
                                    icon:
                                        const Icon(Icons.open_in_new_outlined),
                                  ),
                                  IconButton(
                                    tooltip: 'Distribuie',
                                    onPressed: () async {
                                      await DocumentFileService.shareFile(
                                        document.filePath,
                                      );
                                    },
                                    icon: const Icon(Icons.share_outlined),
                                  ),
                                  IconButton(
                                    tooltip: 'Redenumeste eticheta',
                                    onPressed: () => renameDocument(document),
                                    icon: const Icon(
                                        Icons.drive_file_rename_outline),
                                  ),
                                  IconButton(
                                    tooltip: 'Sterge din reclamatie',
                                    onPressed: () => removeDocument(document),
                                    icon: const Icon(Icons.delete_outline),
                                  ),
                                ],
                              ),
                            );
                          },
                        ),
                      ),
                  ],
                ),
              ),
              actions: [
                TextButton(
                  onPressed: () => Navigator.of(dialogContext).pop(),
                  child: const Text('Inchide'),
                ),
              ],
            );
          },
        );
      },
    );
    if (!mounted) {
      return;
    }
    await _load();
  }

  Future<void> _deleteComplaintResolved(String complaintId) async {
    await widget.repository.deleteComplaint(complaintId);
    _syncComplaintDataSourceLabel();
    // Queue apelat din repository (CLAUDE.md: nu din pagini)
  }

  Future<void> _load() async {
    _logComplaintUi('loading state changed: start');
    try {
      await OfflineSyncRuntime.instance.syncPending();
      final results = await Future.wait<dynamic>(<Future<dynamic>>[
        widget.repository.loadCurrentUser(),
        widget.repository.listComplaints(),
        widget.repository.listClients(),
        _listTeamsResolved(),
        _listEmployeesResolved(),
        widget.repository.listJobs(),
        widget.repository.listAgfrEquipments(),
        widget.repository.listAgfrInterventions(),
        widget.repository.listAgfrReports(),
        widget.repository.listAppointments(),
        widget.repository.listRepairReports(),
        widget.repository.listWarrantyInterventionReports(),
        _listOffersResolved(),
        _productCatalogService.listWarrantyCertificates(),
        widget.repository.loadCompanyProfile(),
      ]);
      if (!mounted) {
        return;
      }
      setState(() {
        _currentUser = results[0] as AppUser?;
        _items = results[1] as List<ComplaintRecord>;
        _clients = results[2] as List<ClientRecord>;
        _teams = results[3] as List<Team>;
        _employees = results[4] as List<EmployeeLookup>;
        _jobs = results[5] as List<JobRecord>;
        _agfrEquipments = results[6] as List<AgfrEquipmentRecord>;
        _agfrInterventions = results[7] as List<AgfrInterventionRecord>;
        _agfrReports = results[8] as List<AgfrReportRecord>;
        _appointments = results[9] as List<Appointment>;
        _reports = results[10] as List<RepairReportRecord>;
        _warrantyInterventionReports =
            results[11] as List<WarrantyInterventionReportRecord>;
        _offers = results[12] as List<OfferRecord>;
        _warrantyCertificates = results[13] as List<WarrantyCertificateRecord>;
        final companyProfile = results[14] as CompanyProfile;
        _defaultVatPercent = companyProfile.defaultVatPercent;
        _defaultProfitPercent = companyProfile.defaultProfitPercent;
        final initialFocusId = widget.initialFocusComplaintId.trim();
        final initialFocusedComplaint = initialFocusId.isEmpty
            ? null
            : _items
                .where((item) => item.id == initialFocusId)
                .fold<ComplaintRecord?>(
                  null,
                  (previous, item) => previous ?? item,
                );
        _selectedComplaint = initialFocusedComplaint ??
            (_selectedComplaint == null
                ? (_items.isEmpty ? null : _items.first)
                : _items
                    .where((item) => item.id == _selectedComplaint!.id)
                    .fold<ComplaintRecord?>(
                      _items.isEmpty ? null : _items.first,
                      (previous, item) => item,
                    ));
        _syncComplaintDataSourceLabel();
        _updateFilteredCache();
      });
      await _handleInitialFocusComplaint();
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
    } finally {
      if (mounted) {
        setState(() {
          _loading = false;
        });
      }
      _logComplaintUi(
        'loading state changed: end selected=${_selectedComplaint?.id ?? '-'} items=${_items.length}',
      );
    }
  }

  Future<void> _handleInitialFocusComplaint() async {
    final initialFocusId = widget.initialFocusComplaintId.trim();
    if (_didHandleInitialFocusComplaint || initialFocusId.isEmpty || !mounted) {
      return;
    }
    final complaint = _items
        .where((item) => item.id == initialFocusId)
        .fold<ComplaintRecord?>(
          null,
          (previous, item) => previous ?? item,
        );
    if (complaint == null) {
      _didHandleInitialFocusComplaint = true;
      return;
    }
    _didHandleInitialFocusComplaint = true;
    WidgetsBinding.instance.addPostFrameCallback((_) {
      if (!mounted) {
        return;
      }
      _openComplaintDetails(complaint);
    });
  }

  Future<List<Team>> _listTeamsResolved() async {
    final localRows = await MasterLocalStore.readTeams();
    try {
      if (FirebaseBootstrap.isInitialized) {
        final cloudRows = await FirebaseEchipeRepository().listTeams();
        if (cloudRows.isNotEmpty) {
          await MasterLocalStore.writeTeams(cloudRows);
          return cloudRows
              .where((row) => row.id.trim().isNotEmpty)
              .map(_teamFromMaster)
              .toList(growable: false);
        }
      }

      final repositoryRows = await widget.repository.listTeams();
      final validRepositoryRows = repositoryRows
          .where((row) => row.id.trim().isNotEmpty)
          .toList(growable: false);
      if (validRepositoryRows.isNotEmpty) {
        return validRepositoryRows;
      }
    } catch (_) {}

    return localRows
        .where((row) => row.id.trim().isNotEmpty)
        .map(_teamFromMaster)
        .toList(growable: false);
  }

  Future<List<EmployeeLookup>> _listEmployeesResolved() async {
    try {
      final repositoryRows = await widget.repository.listEmployeesLookup();
      final validRepositoryRows = repositoryRows
          .where((row) => row.id.trim().isNotEmpty)
          .toList(growable: false);
      if (validRepositoryRows.isNotEmpty) {
        await MasterLocalStore.writeEmployees(
          validRepositoryRows.map(_masterEmployeeFromLookup).toList(),
        );
        return validRepositoryRows;
      }
    } catch (_) {}

    final localRows = await MasterLocalStore.readEmployees();
    return localRows
        .where((row) => row.id.trim().isNotEmpty)
        .map(_employeeLookupFromMaster)
        .toList(growable: false);
  }

  AiAssistantRuntimeContext? _buildSelectedComplaintAiContext() {
    final complaint = _selectedComplaint;
    if (complaint == null) return null;
    return AiAssistantRuntimeContext(
      contextType: AiAssistantContextType.complaints,
      module: 'reclamatii',
      entityId: complaint.id,
      entityLabel: complaint.complaintNumber,
      userId: widget.fieldAuthUserId?.trim() ?? '',
      contextLabel: 'Reclamatia ${complaint.complaintNumber}',
      primaryData: <String, dynamic>{
        ...complaint.toMap(),
        'type': 'complaint',
      },
      relatedData: <String, dynamic>{
        'complaint': complaint.toMap(),
        'client': <String, dynamic>{
          'beneficiary_name': complaint.beneficiaryName,
          'contractor_name': complaint.contractorName,
          'contact_person': complaint.contactPerson,
          'phone': complaint.phone,
          'email': complaint.email,
        },
        'products': <Map<String, dynamic>>[
          <String, dynamic>{
            'product_id': complaint.warrantyCertificateId,
            'brand': complaint.equipmentBrand,
            'model': complaint.equipmentModel,
            'outdoor_unit_serial': complaint.outdoorUnitSerial,
            'equipment_details': complaint.equipmentDetails,
          },
        ],
      },
      insertionTargets: const <AiAssistantInsertionTarget>[
        AiAssistantInsertionTarget(
          key: 'complaint_field_finding',
          label: 'Constatare in teren',
          description: 'Insereaza draftul in campul de constatare.',
          insertMode: AiAssistantInsertMode.replace,
        ),
        AiAssistantInsertionTarget(
          key: 'complaint_internal_notes',
          label: 'Observatii interne',
          description: 'Insereaza draftul in observatiile interne.',
          insertMode: AiAssistantInsertMode.replace,
        ),
      ],
    );
  }

  Future<void> _openComplaintAiAssistant() async {
    final runtimeContext = _buildSelectedComplaintAiContext();
    if (runtimeContext == null) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Selecteaza o reclamatie mai intai.')),
      );
      return;
    }
    await AiAssistantSheet.show(
      context: context,
      title: 'Asistent AI reclamatii',
      service: _aiAssistantService,
      runtimeContext: runtimeContext,
      actions: AiAssistantActionCatalog.actionsFor(
        AiAssistantContextType.complaints,
      ),
      onInsertDraft: _applyComplaintAiDraft,
    );
  }

  Future<bool> _applyComplaintAiDraft(String targetKey, String content) async {
    final complaint = _selectedComplaint;
    if (complaint == null) return false;
    ComplaintRecord updated;
    switch (targetKey) {
      case 'complaint_field_finding':
        updated = complaint.copyWith(
          fieldFinding: content.trim(),
          updatedAt: DateTime.now(),
        );
        break;
      case 'complaint_internal_notes':
        updated = complaint.copyWith(
          internalNotes: content.trim(),
          updatedAt: DateTime.now(),
        );
        break;
      default:
        return false;
    }
    await _saveComplaintResolved(updated);
    await _load();
    if (!mounted) return false;
    setState(() {
      _selectedComplaint = updated;
    });
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Text('Draftul AI a fost inserat in reclamatie.'),
      ),
    );
    return true;
  }

  Team _teamFromMaster(MasterTeam row) {
    return Team(
      id: row.id.trim(),
      name: row.name.trim(),
      notes: row.notes.trim(),
      memberEmployeeIds: row.memberIds
          .map((item) => item.trim())
          .where((item) => item.isNotEmpty)
          .toList(growable: false),
    );
  }

  MasterEmployee _masterEmployeeFromLookup(EmployeeLookup row) {
    return MasterEmployee(
      id: row.id.trim(),
      name: row.name.trim(),
      role: row.role.trim(),
      active: row.active,
      laborCostType: row.laborCostType,
      costLunar: row.costLunar,
      tarifOrar: row.tarifOrar,
      oreLunareStandard: row.oreLunareStandard,
      dailyAllowance: row.perDiemPerDay,
      defaultLodgingCost: row.lodgingPerDay,
      requiresLodgingByDefault: row.requiresLodgingByDefault,
    );
  }

  EmployeeLookup _employeeLookupFromMaster(MasterEmployee row) {
    return EmployeeLookup(
      id: row.id.trim(),
      name: row.name.trim(),
      role: row.role.trim(),
      active: row.active,
      laborCostType: row.laborCostType,
      costLunar: row.costLunar,
      tarifOrar: row.tarifOrar,
      oreLunareStandard: row.oreLunareStandard,
      perDiemPerDay: row.dailyAllowance,
      lodgingPerDay: row.defaultLodgingCost,
      requiresLodgingByDefault: row.requiresLodgingByDefault,
    );
  }

  Future<List<OfferRecord>> _listOffersResolved() async {
    final cloud = _cloudOferteRepository;
    if (cloud == null) {
      return _localOferteRepository.listOffers();
    }
    try {
      final cloudItems = await cloud.listOffers();
      await _localOferteRepository.replaceOffers(cloudItems);
      return cloudItems;
    } catch (_) {
      return _localOferteRepository.listOffers();
    }
  }

  UserRole? get _effectiveRole => AppRolePolicy.resolve(
        appRole: _currentUser?.role,
        roleKey: widget.fieldAuthRoleKey,
      );

  bool get _canManageComplaintsWide =>
      AppRolePolicy.canAccessTeamLead(_effectiveRole);

  bool get _canEditFieldOperations =>
      _canManageComplaintsWide || AppRolePolicy.isEmployee(_effectiveRole);

  String get _effectiveActorUserId =>
      (widget.fieldAuthUserId ?? _currentUser?.id ?? '').trim();

  String get _effectiveTeamId => (widget.fieldAuthTeamId ?? '').trim();

  bool _isComplaintVisibleToCurrentUser(ComplaintRecord item) {
    final role = _effectiveRole;
    if (role == null || role == UserRole.admin || role == UserRole.birou) {
      return true;
    }
    final userId = _effectiveActorUserId;
    final teamId = _effectiveTeamId;
    if (role == UserRole.sefEchipa) {
      if (teamId.isNotEmpty) {
        return item.assignedTeamId == teamId || item.fieldTeamId == teamId;
      }
      return true;
    }
    if (role == UserRole.tehnician) {
      if (userId.isNotEmpty &&
          (item.assignedEmployeeId == userId ||
              item.fieldTechnicianId == userId)) {
        return true;
      }
      if (teamId.isNotEmpty &&
          (item.assignedTeamId == teamId || item.fieldTeamId == teamId)) {
        return true;
      }
      return false;
    }
    return true;
  }

  List<ComplaintRecord> get _filteredItems => _cachedFilteredItems;

  void _updateFilteredCache() {
    final query = _searchQuery.trim().toLowerCase();
    _cachedFilteredItems = _items.where((item) {
      if (!_isComplaintVisibleToCurrentUser(item)) return false;
      if (_statusFilter != null && item.status != _statusFilter) return false;
      if (_typeFilter != null && item.type != _typeFilter) return false;
      if (_contractorFilter.trim().isNotEmpty &&
          _resolvedContractorName(item).trim() != _contractorFilter.trim()) {
        return false;
      }
      if (_teamFilter.trim().isNotEmpty && item.assignedTeamId != _teamFilter) {
        return false;
      }
      if (_employeeFilter.trim().isNotEmpty &&
          item.assignedEmployeeId != _employeeFilter) {
        return false;
      }
      if (_scheduledFilter != null && _hasAppointment(item) != _scheduledFilter) {
        return false;
      }
      if (_reportFilter != null && _hasReport(item) != _reportFilter) {
        return false;
      }
      if (query.isEmpty) return true;
      final haystack = <String>[
        item.complaintNumber,
        _resolvedBeneficiaryName(item),
        _resolvedContractorName(item),
        _offerLabel(item),
        _offerCommercialRecipientLabel(item),
        _reportLabel(item),
        item.contactPerson,
        item.phone,
        item.email,
        item.location,
        item.problemDescription,
      ].join(' ').toLowerCase();
      return haystack.contains(query);
    }).toList(growable: false);
  }

  String _resolvedBeneficiaryName(ComplaintRecord item) {
    if (item.beneficiaryName.trim().isNotEmpty) {
      return item.beneficiaryName.trim();
    }
    return _clients
        .where((client) => client.id == item.beneficiaryClientId)
        .map((client) => client.name)
        .fold('', (previous, name) => previous.isEmpty ? name : previous);
  }

  String _resolvedContractorName(ComplaintRecord item) {
    if (item.contractorName.trim().isNotEmpty) {
      return item.contractorName.trim();
    }
    return _clients
        .where((client) => client.id == item.contractorClientId)
        .map((client) => client.name)
        .fold('', (previous, name) => previous.isEmpty ? name : previous);
  }

  String _teamName(String teamId) {
    return _teams
        .where((team) => team.id == teamId)
        .map((team) => team.name)
        .fold('-', (previous, name) => previous == '-' ? name : previous);
  }

  String _employeeName(String employeeId) {
    return _employees
        .where((employee) => employee.id == employeeId)
        .map((employee) => employee.name)
        .fold('-', (previous, name) => previous == '-' ? name : previous);
  }

  String _jobLabel(String jobId) {
    return _jobs
        .where((job) => job.id == jobId)
        .map(
          (job) => job.jobCode.trim().isEmpty
              ? job.title
              : '${job.jobCode} - ${job.title}',
        )
        .fold('-', (previous, label) => previous == '-' ? label : previous);
  }

  String _appointmentLabel(String appointmentId) {
    return _appointments
        .where((item) => item.id == appointmentId)
        .map((item) => item.title.trim().isEmpty ? item.clientName : item.title)
        .fold('-', (previous, label) => previous == '-' ? label : previous);
  }

  List<Appointment> _appointmentsForComplaint(ComplaintRecord item) {
    final knownIds = <String>{
      if (item.appointmentId.trim().isNotEmpty) item.appointmentId.trim(),
      ...item.appointmentIds
          .map((entry) => entry.trim())
          .where((entry) => entry.isNotEmpty),
    };
    final matches = <Appointment>[
      ..._appointments.where((entry) => entry.complaintId.trim() == item.id),
      ..._appointments.where((entry) => knownIds.contains(entry.id.trim())),
    ];
    final byId = <String, Appointment>{};
    for (final entry in matches) {
      byId[entry.id.trim()] = entry;
    }
    final sorted = byId.values.toList(growable: false)
      ..sort(
        (a, b) => a.effectiveStartDateTime.compareTo(b.effectiveStartDateTime),
      );
    return sorted;
  }

  Appointment? _primaryAppointmentForComplaint(ComplaintRecord item) {
    final appointments = _appointmentsForComplaint(item);
    if (appointments.isEmpty) {
      return null;
    }
    final now = DateTime.now();
    for (final entry in appointments) {
      if (!entry.effectiveEndDateTime.isBefore(now)) {
        return entry;
      }
    }
    return appointments.last;
  }

  RepairReportRecord? _reportForComplaint(String complaintId) {
    return _reports
        .where((item) => item.complaintId == complaintId)
        .fold<RepairReportRecord?>(
          null,
          (previous, item) => previous ?? item,
        );
  }

  WarrantyInterventionReportRecord? _warrantyInterventionReportForComplaint(
    String complaintId,
  ) {
    return _warrantyInterventionReports
        .where((item) => item.complaintId == complaintId)
        .fold<WarrantyInterventionReportRecord?>(
          null,
          (previous, item) => previous ?? item,
        );
  }

  bool _hasAppointment(ComplaintRecord item) =>
      _appointmentsForComplaint(item).isNotEmpty;

  int _appointmentCount(ComplaintRecord item) =>
      _appointmentsForComplaint(item).length;

  int _followUpCount(ComplaintRecord item) {
    final count = _appointmentCount(item);
    return count <= 1 ? 0 : count - 1;
  }

  int _postponedAppointmentCount(ComplaintRecord item) {
    return _appointmentsForComplaint(item)
        .where(
            (entry) => _normalizeAppointmentStatus(entry.status) == 'amanata')
        .length;
  }

  bool _hasUpcomingAppointment(ComplaintRecord item) {
    final now = DateTime.now();
    return _appointmentsForComplaint(item)
        .any((entry) => !entry.effectiveStartDateTime.isBefore(now));
  }

  String _visitTypeLabel(Appointment appointment) {
    return appointment.complaintVisitType?.label ?? '-';
  }

  String _visitOutcomeLabel(Appointment appointment) {
    return appointment.complaintVisitOutcome?.label ?? '-';
  }

  bool _hasReport(ComplaintRecord item) => _reportForComplaint(item.id) != null;

  OfferRecord? _offerForComplaint(String complaintId) {
    return _offers
        .where((item) => item.complaintId == complaintId)
        .fold<OfferRecord?>(
          null,
          (previous, item) => previous ?? item,
        );
  }

  bool _hasOffer(ComplaintRecord item) =>
      item.offerId.trim().isNotEmpty || _offerForComplaint(item.id) != null;

  String _aggregationClientId(ComplaintRecord item) {
    final contractorId = item.contractorClientId.trim();
    if (contractorId.isNotEmpty) {
      return contractorId;
    }
    return item.beneficiaryClientId.trim();
  }

  String _aggregationClientName(ComplaintRecord item) {
    final contractor = _resolvedContractorName(item).trim();
    if (contractor.isNotEmpty) {
      return contractor;
    }
    return _resolvedBeneficiaryName(item).trim();
  }

  DateTime _operationalDateForComplaint(ComplaintRecord item) {
    final warranty = _warrantyInterventionReportForComplaint(item.id);
    if (warranty?.documentDate != null) {
      return warranty!.documentDate!;
    }
    final report = _reportForComplaint(item.id);
    if (report != null) {
      return report.interventionDate;
    }
    if (item.fieldInterventionDate != null) {
      return item.fieldInterventionDate!;
    }
    return item.complaintDate;
  }

  bool _matchesAggregationClient(
    ComplaintRecord item, {
    required String clientId,
    required String clientName,
  }) {
    final normalizedId = clientId.trim();
    final normalizedName = clientName.trim().toLowerCase();
    if (normalizedId.isNotEmpty) {
      return _aggregationClientId(item) == normalizedId;
    }
    return _aggregationClientName(item).trim().toLowerCase() == normalizedName;
  }

  List<ComplaintRecord> _complaintsForAggregation(ComplaintRecord source) {
    final clientId = _aggregationClientId(source);
    final clientName = _aggregationClientName(source);
    final sourceDate = _operationalDateForComplaint(source);
    final periodStart = DateTime(sourceDate.year, sourceDate.month, 1);
    final periodEnd =
        DateTime(sourceDate.year, sourceDate.month + 1, 0, 23, 59, 59);
    final matches = _items.where((item) {
      if (!_matchesAggregationClient(
        item,
        clientId: clientId,
        clientName: clientName,
      )) {
        return false;
      }
      final date = _operationalDateForComplaint(item);
      return !date.isBefore(periodStart) && !date.isAfter(periodEnd);
    }).toList(growable: false)
      ..sort((a, b) => _operationalDateForComplaint(a)
          .compareTo(_operationalDateForComplaint(b)));
    return matches;
  }

  bool _matchesAggregationOffer(
    OfferRecord item, {
    required String clientId,
    required String clientName,
  }) {
    final normalizedId = clientId.trim();
    final normalizedName = clientName.trim().toLowerCase();
    if (normalizedId.isNotEmpty) {
      return item.clientId.trim() == normalizedId ||
          item.beneficiaryClientId.trim() == normalizedId ||
          item.commercialRecipientClientId.trim() == normalizedId;
    }
    return item.clientName.trim().toLowerCase() == normalizedName ||
        item.beneficiaryName.trim().toLowerCase() == normalizedName ||
        item.commercialRecipientName.trim().toLowerCase() == normalizedName;
  }

  List<OfferRecord> _offersForAggregation(ComplaintRecord source) {
    final clientId = _aggregationClientId(source);
    final clientName = _aggregationClientName(source);
    final matches = _offers.where((item) {
      return _matchesAggregationOffer(
        item,
        clientId: clientId,
        clientName: clientName,
      );
    }).toList(growable: false)
      ..sort((a, b) => a.issueDate.compareTo(b.issueDate));
    return matches;
  }

  ComplaintRecord? _complaintForOffer(OfferRecord offer) {
    final complaintId = offer.complaintId.trim();
    if (complaintId.isNotEmpty) {
      return _items
          .where((item) => item.id == complaintId)
          .fold<ComplaintRecord?>(
            null,
            (previous, item) => previous ?? item,
          );
    }
    final complaintNumber = offer.complaintNumber.trim().toLowerCase();
    if (complaintNumber.isEmpty) {
      return null;
    }
    return _items
        .where(
          (item) =>
              item.complaintNumber.trim().toLowerCase() == complaintNumber,
        )
        .fold<ComplaintRecord?>(
          null,
          (previous, item) => previous ?? item,
        );
  }

  String _centralizerOfferSummary(OfferRecord offer) {
    if (offer.title.trim().isNotEmpty) {
      return offer.title.trim();
    }
    if (offer.notes.trim().isNotEmpty) {
      return offer.notes.trim();
    }
    return 'Oferta comerciala';
  }

  String _centralizerOfferBeneficiary(
      OfferRecord offer, ComplaintRecord source) {
    if (offer.beneficiaryName.trim().isNotEmpty) {
      return offer.beneficiaryName.trim();
    }
    if (offer.commercialRecipientName.trim().isNotEmpty) {
      return offer.commercialRecipientName.trim();
    }
    if (offer.clientName.trim().isNotEmpty) {
      return offer.clientName.trim();
    }
    return _aggregationClientName(source);
  }

  ComplaintClientCentralizerLine _buildCentralizerLineFromOffer(
    ComplaintRecord source,
    OfferRecord offer,
  ) {
    final complaint = _complaintForOffer(offer);
    final report = complaint == null ? null : _reportForComplaint(complaint.id);
    final warranty = complaint == null
        ? null
        : _warrantyInterventionReportForComplaint(complaint.id);
    final complaintNumber = complaint?.complaintNumber.trim().isNotEmpty == true
        ? complaint!.complaintNumber.trim()
        : offer.complaintNumber.trim().isNotEmpty
            ? offer.complaintNumber.trim()
            : offer.offerNumber.trim().isNotEmpty
                ? 'Oferta ${offer.offerNumber.trim()}'
                : 'Oferta fara numar';
    return ComplaintClientCentralizerLine(
      id: 'centralizer-offer-${offer.id}',
      complaintId: complaint?.id ?? offer.complaintId.trim(),
      complaintNumber: complaintNumber,
      interventionDate: complaint == null
          ? offer.issueDate
          : _operationalDateForComplaint(complaint),
      beneficiaryName: complaint == null
          ? _centralizerOfferBeneficiary(offer, source)
          : _resolvedBeneficiaryName(complaint),
      workSummary: complaint == null
          ? _centralizerOfferSummary(offer)
          : _buildCentralizerLine(complaint).workSummary,
      offerId: offer.id,
      offerNumber: offer.offerNumber,
      offerValue: offer.totalValue,
      repairReportId: report?.id ?? '',
      repairReportNumber: report?.reportNumber ?? '',
      warrantyReportId: warranty?.id ?? '',
      warrantyReportNumber: warranty?.documentNumber ?? '',
      includeInTotal: offer.totalValue > 0,
    );
  }

  ComplaintClientCentralizerRecord _buildSelectiveClientCentralizerDraft(
    ComplaintRecord source, {
    required Set<String> selectedComplaintIds,
    required Set<String> selectedOfferIds,
  }) {
    final lines = <ComplaintClientCentralizerLine>[];
    final complaints = _complaintsForAggregation(source);
    final offers = _offersForAggregation(source);

    for (final item in complaints) {
      if (!selectedComplaintIds.contains(item.id)) {
        continue;
      }
      lines.add(_buildCentralizerLine(item));
    }

    for (final item in offers) {
      if (!selectedOfferIds.contains(item.id)) {
        continue;
      }
      final linkedComplaint = _complaintForOffer(item);
      final linkedComplaintId = linkedComplaint?.id.trim() ?? '';
      if (linkedComplaintId.isNotEmpty &&
          selectedComplaintIds.contains(linkedComplaintId)) {
        continue;
      }
      lines.add(_buildCentralizerLineFromOffer(source, item));
    }

    lines.sort((left, right) {
      final leftDate = left.interventionDate ?? DateTime(2000);
      final rightDate = right.interventionDate ?? DateTime(2000);
      return leftDate.compareTo(rightDate);
    });

    final dates = lines
        .map((line) => line.interventionDate)
        .whereType<DateTime>()
        .toList(growable: false);
    final firstDate = dates.isEmpty
        ? DateTime.now()
        : dates.reduce(
            (previous, item) => item.isBefore(previous) ? item : previous,
          );
    final lastDate = dates.isEmpty
        ? DateTime.now()
        : dates.reduce(
            (previous, item) => item.isAfter(previous) ? item : previous,
          );

    return ComplaintClientCentralizerRecord(
      id: 'complaint-centralizer-selective-${_uuid.v4()}',
      documentNumber: '',
      clientId: _aggregationClientId(source),
      clientName: _aggregationClientName(source),
      periodStart: DateTime(firstDate.year, firstDate.month, firstDate.day),
      periodEnd: DateTime(lastDate.year, lastDate.month, lastDate.day),
      title: 'Centralizator selectiv ${_aggregationClientName(source)}',
      summaryDescription:
          'Document generat din modulul Reclamatii cu elementele selectate pentru clientul ${_aggregationClientName(source)}.',
      lines: List<ComplaintClientCentralizerLine>.unmodifiable(lines),
      createdAt: DateTime.now(),
      updatedAt: DateTime.now(),
    );
  }

  ComplaintClientCentralizerLine _buildCentralizerLine(ComplaintRecord item) {
    final offer = _offerForComplaint(item.id);
    final report = _reportForComplaint(item.id);
    final warranty = _warrantyInterventionReportForComplaint(item.id);
    final summary = item.fieldWorkPerformed.trim().isNotEmpty
        ? item.fieldWorkPerformed.trim()
        : item.fieldFinding.trim().isNotEmpty
            ? item.fieldFinding.trim()
            : item.problemDescription.trim();
    final offerValue = offer?.totalValue ?? 0;
    return ComplaintClientCentralizerLine(
      id: 'centralizer-line-${item.id}',
      complaintId: item.id,
      complaintNumber:
          item.complaintNumber.trim().isEmpty ? item.id : item.complaintNumber,
      interventionDate: _operationalDateForComplaint(item),
      beneficiaryName: _resolvedBeneficiaryName(item),
      workSummary: summary,
      offerId: offer?.id ?? '',
      offerNumber: offer?.offerNumber ?? '',
      offerValue: offerValue,
      repairReportId: report?.id ?? '',
      repairReportNumber: report?.reportNumber ?? '',
      warrantyReportId: warranty?.id ?? '',
      warrantyReportNumber: warranty?.documentNumber ?? '',
      includeInTotal: offerValue > 0,
    );
  }

  ComplaintClientCentralizerRecord _buildClientCentralizerDraft(
    ComplaintRecord item,
  ) {
    final sourceDate = _operationalDateForComplaint(item);
    final periodStart = DateTime(sourceDate.year, sourceDate.month, 1);
    final periodEnd = DateTime(sourceDate.year, sourceDate.month + 1, 0);
    final lines = _complaintsForAggregation(item)
        .map(_buildCentralizerLine)
        .toList(growable: false);
    return ComplaintClientCentralizerRecord(
      id: 'complaint-centralizer-${_uuid.v4()}',
      documentNumber: '',
      clientId: _aggregationClientId(item),
      clientName: _aggregationClientName(item),
      periodStart: periodStart,
      periodEnd: periodEnd,
      title:
          'Centralizator lunar ${_aggregationClientName(item)} ${periodStart.month.toString().padLeft(2, '0')}.${periodStart.year}',
      summaryDescription:
          'Document lunar cu interventiile si ofertele aferente perioadei selectate pentru clientul ${_aggregationClientName(item)}.',
      lines: lines,
      createdAt: DateTime.now(),
      updatedAt: DateTime.now(),
    );
  }

  ComplaintWorkOrderRecord _buildComplaintWorkOrderDraft(ComplaintRecord item) {
    final offer = _offerForComplaint(item.id);
    final summary = item.fieldWorkPerformed.trim().isNotEmpty
        ? item.fieldWorkPerformed.trim()
        : item.problemDescription.trim();
    return ComplaintWorkOrderRecord(
      id: 'complaint-work-order-${_uuid.v4()}',
      documentNumber: '',
      complaintId: item.id,
      clientId: _aggregationClientId(item),
      clientName: _aggregationClientName(item),
      beneficiaryName: _resolvedBeneficiaryName(item),
      issueDate: DateTime.now(),
      requestedBy: item.contactPerson.trim(),
      requestedPhone: item.phone.trim(),
      requestedEmail: item.email.trim(),
      location: item.location.trim(),
      subject:
          'Comanda lucrari pentru reclamatie ${item.complaintNumber.trim().isEmpty ? item.id : item.complaintNumber.trim()}',
      scopeOfWork: summary,
      executionNotes:
          'Documentul poate sta la baza facturarii dupa acceptarea clientului.',
      lines: <ComplaintWorkOrderLine>[
        ComplaintWorkOrderLine(
          id: 'work-order-line-${_uuid.v4()}',
          description: summary,
          beneficiaryName: _resolvedBeneficiaryName(item),
          quantity: 1,
          unit: 'lucrare',
          unitPrice: offer?.totalValue ?? 0,
        ),
      ],
      createdAt: DateTime.now(),
      updatedAt: DateTime.now(),
    );
  }

  String _reportLabel(ComplaintRecord item) {
    final report = _reportForComplaint(item.id);
    if (report == null) {
      return 'Fara proces verbal';
    }
    return report.reportNumber.trim().isEmpty
        ? 'Proces verbal existent'
        : report.reportNumber.trim();
  }

  String _offerLabel(ComplaintRecord item) {
    final offer = _offerForComplaint(item.id);
    if (offer == null && item.offerId.trim().isEmpty) {
      return 'Fara deviz / oferta';
    }
    final resolved = offer;
    if (resolved == null) {
      return 'Document comercial existent';
    }
    return resolved.offerNumber.trim().isEmpty
        ? 'Document comercial existent'
        : resolved.offerNumber.trim();
  }

  String _offerCommercialRecipientLabel(ComplaintRecord item) {
    final offer = _offerForComplaint(item.id);
    if (offer == null) {
      return '-';
    }
    final payer = offer.commercialRecipientName.trim().isNotEmpty
        ? offer.commercialRecipientName.trim()
        : (offer.clientName.trim().isNotEmpty ? offer.clientName.trim() : '-');
    return payer;
  }

  bool _hasSignedOfferAgreement(ComplaintRecord item) {
    final offer = _offerForComplaint(item.id);
    if (offer == null) {
      return false;
    }
    return offer.clientSignatureBase64.trim().isNotEmpty ||
        offer.issuerSignatureBase64.trim().isNotEmpty;
  }

  String _offerAgreementLabel(ComplaintRecord item) {
    final offer = _offerForComplaint(item.id);
    if (offer == null) {
      return '-';
    }
    if (offer.agreementAcceptedAt != null) {
      return 'Semnat la ${_date(offer.agreementAcceptedAt!)}';
    }
    if (_hasSignedOfferAgreement(item)) {
      return 'Semnaturi partiale salvate';
    }
    return 'In asteptare';
  }

  Appointment? _appointmentForComplaint(ComplaintRecord item) {
    return _primaryAppointmentForComplaint(item);
  }

  String _normalizeAppointmentStatus(String raw) {
    return raw.trim().toLowerCase().replaceAll(' ', '_');
  }

  String _appointmentStatusLabelFromRaw(String raw) {
    switch (_normalizeAppointmentStatus(raw)) {
      case 'planificata':
        return 'Planificata';
      case 'in_curs':
        return 'In curs';
      case 'finalizata':
        return 'Finalizata';
      case 'amanata':
        return 'Amanata';
      case 'anulata':
        return 'Anulata';
      default:
        final trimmed = raw.trim();
        return trimmed.isEmpty ? 'Programare asociata' : trimmed;
    }
  }

  Color _appointmentStatusColorFromRaw(String raw) {
    switch (_normalizeAppointmentStatus(raw)) {
      case 'planificata':
        return Colors.indigo;
      case 'in_curs':
        return Colors.blue;
      case 'finalizata':
        return Colors.green;
      case 'amanata':
        return Colors.orange;
      case 'anulata':
        return Colors.red;
      default:
        return Colors.indigo;
    }
  }

  String _appointmentStatusLabel(ComplaintRecord item) {
    if (!_hasAppointment(item)) {
      return 'Neprogramata';
    }
    final appointment = _appointmentForComplaint(item);
    if (appointment == null) {
      return 'Programare asociata';
    }
    return _appointmentStatusLabelFromRaw(appointment.status);
  }

  Color _appointmentStatusColor(ComplaintRecord item) {
    if (!_hasAppointment(item)) {
      return Colors.orange;
    }
    final appointment = _appointmentForComplaint(item);
    if (appointment == null) {
      return Colors.indigo;
    }
    return _appointmentStatusColorFromRaw(appointment.status);
  }

  Color? _colorFromCode(String raw) {
    final normalized = raw.trim().replaceFirst('#', '');
    if (normalized.isEmpty) {
      return null;
    }
    final hex = normalized.length == 6 ? 'FF$normalized' : normalized;
    final value = int.tryParse(hex, radix: 16);
    if (value == null) {
      return null;
    }
    return Color(value);
  }

  Color _complaintAccentColor(ComplaintRecord item) {
    final appointment = _appointmentForComplaint(item);
    final appointmentColor = _colorFromCode(appointment?.colorCode ?? '');
    if (appointmentColor != null) {
      return appointmentColor;
    }
    if (appointment != null) {
      return _appointmentStatusColor(item);
    }
    return _statusColor(item.status);
  }

  Color _complaintCardSurfaceColor(ComplaintRecord item,
      {bool selected = false}) {
    final accent = _complaintAccentColor(item);
    final alpha = selected ? 0.18 : 0.08;
    return Color.alphaBlend(
      accent.withValues(alpha: alpha),
      Theme.of(context).colorScheme.surface,
    );
  }

  String _assignmentLabel(ComplaintRecord item) {
    final parts = <String>[
      if (item.assignedTeamId.trim().isNotEmpty) _teamName(item.assignedTeamId),
      if (item.assignedEmployeeId.trim().isNotEmpty)
        _employeeName(item.assignedEmployeeId),
    ];
    return parts.isEmpty ? 'Nealocata' : parts.join(' | ');
  }

  bool _hasEquipmentData(ComplaintRecord item) {
    return item.equipmentType != null ||
        item.equipmentBrand.trim().isNotEmpty ||
        item.equipmentModel.trim().isNotEmpty ||
        item.outdoorUnitSerial.trim().isNotEmpty ||
        item.indoorUnitSerials.trim().isNotEmpty ||
        item.equipmentDetails.trim().isNotEmpty;
  }

  String _equipmentLabel(ComplaintRecord item) {
    final parts = <String>[
      if (item.equipmentType != null) item.equipmentType!.label,
      if (item.equipmentBrand.trim().isNotEmpty) item.equipmentBrand.trim(),
      if (item.equipmentModel.trim().isNotEmpty) item.equipmentModel.trim(),
    ];
    return parts.isEmpty ? '-' : parts.join(' | ');
  }

  WarrantyCertificateRecord? _warrantyCertificateById(String certificateId) {
    final id = certificateId.trim();
    if (id.isEmpty) return null;
    for (final item in _warrantyCertificates) {
      if (item.id == id) return item;
    }
    return null;
  }

  String _warrantyCertificateLabel(WarrantyCertificateRecord certificate) {
    final parts = <String>[
      if (certificate.fullCertificateNumber.trim().isNotEmpty)
        certificate.fullCertificateNumber.trim(),
      if (certificate.sourceEquipmentLabel.trim().isNotEmpty)
        certificate.sourceEquipmentLabel.trim(),
      if (certificate.brand.trim().isNotEmpty) certificate.brand.trim(),
      if (certificate.model.trim().isNotEmpty) certificate.model.trim(),
    ];
    return parts.isEmpty ? certificate.id : parts.join(' | ');
  }

  WarrantyCertificateRecord? _suggestWarrantyCertificate({
    required String beneficiaryClientId,
    required String jobId,
    required String outdoorSerial,
    required String brand,
    required String model,
    String currentCertificateId = '',
  }) {
    final current = _warrantyCertificateById(currentCertificateId);
    if (current != null) return current;
    WarrantyCertificateRecord? best;
    var bestScore = -1;
    for (final item in _warrantyCertificates) {
      var score = 0;
      if (beneficiaryClientId.trim().isNotEmpty &&
          item.buyerClientId.trim() == beneficiaryClientId.trim()) {
        score += 7;
      }
      if (beneficiaryClientId.trim().isNotEmpty &&
          item.buyerName.trim().isNotEmpty &&
          item.jobId.trim().isNotEmpty &&
          item.jobId.trim() == jobId.trim()) {
        score += 4;
      }
      if (jobId.trim().isNotEmpty && item.jobId.trim() == jobId.trim()) {
        score += 5;
      }
      if (outdoorSerial.trim().isNotEmpty &&
          item.serialNumberOutdoor.trim().toLowerCase() ==
              outdoorSerial.trim().toLowerCase()) {
        score += 6;
      }
      if (brand.trim().isNotEmpty &&
          item.brand.trim().toLowerCase() == brand.trim().toLowerCase()) {
        score += 1;
      }
      if (model.trim().isNotEmpty &&
          item.model.trim().toLowerCase() == model.trim().toLowerCase()) {
        score += 1;
      }
      if (beneficiaryClientId.trim().isNotEmpty &&
          _clients.any(
            (client) =>
                client.id == beneficiaryClientId.trim() &&
                client.name.trim().isNotEmpty &&
                client.name.trim().toLowerCase() ==
                    item.buyerName.trim().toLowerCase(),
          )) {
        score += 2;
      }
      if (score > bestScore) {
        best = item;
        bestScore = score;
      }
    }
    return bestScore > 0 ? best : null;
  }

  AgfrEquipmentRecord? _agfrEquipmentById(String equipmentId) {
    final id = equipmentId.trim();
    if (id.isEmpty) return null;
    for (final item in _agfrEquipments) {
      if (item.id == id) return item;
    }
    return null;
  }

  AgfrInterventionRecord? _agfrInterventionById(String interventionId) {
    final id = interventionId.trim();
    if (id.isEmpty) return null;
    for (final item in _agfrInterventions) {
      if (item.id == id) return item;
    }
    return null;
  }

  AgfrReportRecord? _agfrReportById(String reportId) {
    final id = reportId.trim();
    if (id.isEmpty) return null;
    for (final item in _agfrReports) {
      if (item.id == id) return item;
    }
    return null;
  }

  AgfrEquipmentRecord? _suggestAgfrEquipment({
    required String clientId,
    required String jobId,
    required String outdoorSerial,
    required String brand,
    required String model,
    String currentEquipmentId = '',
  }) {
    final current = _agfrEquipmentById(currentEquipmentId);
    if (current != null) return current;
    AgfrEquipmentRecord? best;
    var bestScore = -1;
    for (final item in _agfrEquipments) {
      var score = 0;
      if (clientId.trim().isNotEmpty && item.clientId == clientId.trim()) {
        score += 3;
      }
      if (jobId.trim().isNotEmpty && item.jobId == jobId.trim()) {
        score += 4;
      }
      if (outdoorSerial.trim().isNotEmpty &&
          item.serialNumber.trim().toLowerCase() ==
              outdoorSerial.trim().toLowerCase()) {
        score += 6;
      }
      if (brand.trim().isNotEmpty &&
          item.brand.trim().toLowerCase() == brand.trim().toLowerCase()) {
        score += 1;
      }
      if (model.trim().isNotEmpty &&
          item.model.trim().toLowerCase() == model.trim().toLowerCase()) {
        score += 1;
      }
      if (score > bestScore) {
        best = item;
        bestScore = score;
      }
    }
    return bestScore > 0 ? best : null;
  }

  Future<void> _syncWarrantyCertificateForComplaint(
      ComplaintRecord complaint) async {
    final certificate =
        _warrantyCertificateById(complaint.warrantyCertificateId);
    if (certificate == null) return;
    final report = _reportForComplaint(complaint.id);
    final existingTickets = [...certificate.warrantyServiceTickets];
    final ticketIndex = existingTickets.indexWhere(
      (item) => item.complaintId == complaint.id,
    );
    final now = DateTime.now();
    final nextTicket = (ticketIndex >= 0
            ? existingTickets[ticketIndex]
            : WarrantyServiceTicketRecord(
                id: 'warranty-ticket-${complaint.id}',
                complaintId: complaint.id,
                createdAt: now,
              ))
        .copyWith(
      complaintId: complaint.id,
      repairReportId: report?.id ?? '',
      receivedDate: complaint.complaintDate,
      completedDate:
          report?.interventionDate ?? complaint.fieldInterventionDate,
      defect: complaint.problemDescription.trim(),
      description: report?.workPerformed.trim().isNotEmpty == true
          ? report!.workPerformed.trim()
          : [
              complaint.fieldWorkPerformed.trim(),
              complaint.fieldMaterialsUsed.trim(),
              complaint.fieldPartsChanged.trim(),
              complaint.fieldTechnicianNotes.trim(),
              complaint.internalNotes.trim(),
            ].where((item) => item.isNotEmpty).join('\n'),
      repairReportNumber: report?.reportNumber.trim() ?? '',
      serviceSignatureLabel: report?.technicianName.trim().isNotEmpty == true
          ? report!.technicianName.trim()
          : _employeeName(complaint.fieldTechnicianId).trim().isNotEmpty
              ? _employeeName(complaint.fieldTechnicianId).trim()
              : certificate.installerName.trim(),
      updatedAt: now,
    );
    if (ticketIndex >= 0) {
      existingTickets[ticketIndex] = nextTicket;
    } else {
      existingTickets.add(nextTicket);
    }
    final complaintIds = <String>{
      ...certificate.complaintIds
          .map((item) => item.trim())
          .where((item) => item.isNotEmpty),
      complaint.id,
    }.toList(growable: false);
    final historyIds = <String>{
      ...certificate.warrantyServiceHistoryIds
          .map((item) => item.trim())
          .where((item) => item.isNotEmpty),
      nextTicket.id,
    }.toList(growable: false);
    await _productCatalogService.saveWarrantyCertificate(
      certificate.copyWith(
        complaintIds: complaintIds,
        warrantyServiceHistoryIds: historyIds,
        warrantyServiceTickets: existingTickets,
        updatedAt: now,
      ),
    );
  }

  WarrantyServiceTicketRecord? _ticketForComplaintCertificate(
    ComplaintRecord complaint,
    WarrantyCertificateRecord? certificate,
  ) {
    if (certificate == null) {
      return null;
    }
    for (final ticket in certificate.warrantyServiceTickets) {
      if (ticket.complaintId.trim() == complaint.id.trim()) {
        return ticket;
      }
    }
    return null;
  }

  Future<void> _syncWarrantyInterventionReport(
    ComplaintRecord complaint,
    WarrantyInterventionReportRecord report,
  ) async {
    final certificate = _warrantyCertificateById(report.warrantyCertificateId);
    if (certificate == null) {
      return;
    }
    final now = DateTime.now();
    final existingTickets = [...certificate.warrantyServiceTickets];
    final ticketIndex = existingTickets.indexWhere(
      (item) =>
          item.id.trim() == report.warrantyServiceTicketId.trim() ||
          item.complaintId.trim() == complaint.id.trim(),
    );
    final nextTicket = (ticketIndex >= 0
            ? existingTickets[ticketIndex]
            : WarrantyServiceTicketRecord(
                id: report.warrantyServiceTicketId.trim().isNotEmpty
                    ? report.warrantyServiceTicketId.trim()
                    : 'warranty-ticket-${complaint.id}',
                complaintId: complaint.id,
                createdAt: now,
              ))
        .copyWith(
      complaintId: complaint.id,
      repairReportId: report.id,
      receivedDate: complaint.complaintDate,
      completedDate: report.documentDate,
      defect: report.findings.trim().isNotEmpty
          ? report.findings.trim()
          : complaint.problemDescription.trim(),
      description: [
        report.workPerformed.trim(),
        report.materialsUsedText.trim(),
        report.partsReplacedText.trim(),
        report.recommendations.trim(),
      ].where((item) => item.isNotEmpty).join('\n'),
      repairReportNumber: report.documentNumber.trim(),
      serviceSignatureLabel: report.technicianName.trim(),
      updatedAt: now,
    );
    if (ticketIndex >= 0) {
      existingTickets[ticketIndex] = nextTicket;
    } else {
      existingTickets.add(nextTicket);
    }
    final complaintIds = <String>{
      ...certificate.complaintIds
          .map((item) => item.trim())
          .where((item) => item.isNotEmpty),
      complaint.id,
    }.toList(growable: false);
    final historyIds = <String>{
      ...certificate.warrantyServiceHistoryIds
          .map((item) => item.trim())
          .where((item) => item.isNotEmpty),
      nextTicket.id,
    }.toList(growable: false);
    await _productCatalogService.saveWarrantyCertificate(
      certificate.copyWith(
        complaintIds: complaintIds,
        warrantyServiceHistoryIds: historyIds,
        warrantyServiceTickets: existingTickets,
        updatedAt: now,
      ),
    );
    if (report.warrantyServiceTicketId.trim() != nextTicket.id.trim()) {
      await widget.repository.saveWarrantyInterventionReport(
        report.copyWith(
          warrantyServiceTicketId: nextTicket.id,
          updatedAt: now,
        ),
      );
    }
  }

  List<ComplaintInterventionEntry> _mergeOperationalHistory(
    ComplaintRecord? current,
    ComplaintRecord saved,
  ) {
    final finding = saved.fieldFinding.trim();
    final work = saved.fieldWorkPerformed.trim();
    final materials = saved.fieldMaterialsUsed.trim();
    final parts = saved.fieldPartsChanged.trim();
    final notes = saved.fieldTechnicianNotes.trim();
    final hasOperationalData = finding.isNotEmpty ||
        work.isNotEmpty ||
        materials.isNotEmpty ||
        parts.isNotEmpty ||
        notes.isNotEmpty ||
        saved.fieldInterventionOutcome != null ||
        saved.fieldInterventionDate != null;
    if (!hasOperationalData) {
      return current?.interventionHistory ??
          const <ComplaintInterventionEntry>[];
    }
    final now = DateTime.now();
    final rows = [
      ...(current?.interventionHistory ?? const <ComplaintInterventionEntry>[])
    ];
    final keyDate = saved.fieldInterventionDate;
    final index = rows.indexWhere((item) {
      final sameTech =
          item.technicianId.trim() == saved.fieldTechnicianId.trim();
      final sameTeam = item.teamId.trim() == saved.fieldTeamId.trim();
      final sameDate = item.interventionDate == keyDate;
      return sameTech && sameTeam && sameDate;
    });
    final next = (index >= 0
            ? rows[index]
            : ComplaintInterventionEntry(
                id: 'complaint-history-${saved.id}-${now.microsecondsSinceEpoch}',
                createdAt: now,
              ))
        .copyWith(
      interventionDate: saved.fieldInterventionDate,
      teamId: saved.fieldTeamId,
      technicianId: saved.fieldTechnicianId,
      finding: saved.fieldFinding,
      workPerformed: saved.fieldWorkPerformed,
      materialsUsed: saved.fieldMaterialsUsed,
      partsChanged: saved.fieldPartsChanged,
      technicianNotes: saved.fieldTechnicianNotes,
      outcome: saved.fieldInterventionOutcome,
      updatedAt: now,
    );
    if (index >= 0) {
      rows[index] = next;
    } else {
      rows.add(next);
    }
    return rows;
  }

  Future<void> _updateComplaintStatus(
    ComplaintRecord item,
    ComplaintStatus status,
  ) async {
    if (item.status == status) {
      return;
    }
    final updatedComplaint = item.copyWith(
      status: status,
      updatedAt: DateTime.now(),
    );
    await _saveComplaintResolved(updatedComplaint);
    await _notifyComplaintSaved(
      saved: updatedComplaint,
      previous: item,
    );
    if (!mounted) {
      return;
    }
    await _load();
    if (!mounted) {
      return;
    }
    final updated =
        _items.where((entry) => entry.id == item.id).fold<ComplaintRecord?>(
              null,
              (previous, entry) => previous ?? entry,
            );
    if (updated != null) {
      setState(() {
        _selectedComplaint = updated;
      });
    }
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text('Status reclamatie actualizat: ${status.label}'),
      ),
    );
  }

  Future<void> _notifyComplaintSaved({
    required ComplaintRecord saved,
    ComplaintRecord? previous,
  }) async {
    NotificationEventType? eventType;
    if (previous == null) {
      eventType = NotificationEventType.complaintCreated;
    } else if (previous.assignedTeamId != saved.assignedTeamId ||
        previous.assignedEmployeeId != saved.assignedEmployeeId) {
      eventType = NotificationEventType.complaintAssigned;
    } else if (previous.status != saved.status) {
      eventType = NotificationEventType.complaintStatusChanged;
    }
    if (eventType == null) {
      return;
    }
    final complaintLabel = saved.complaintNumber.trim().isEmpty
        ? 'Reclamatie'
        : saved.complaintNumber.trim();
    final statusLabel = saved.status.label;
    final title = eventType == NotificationEventType.complaintCreated
        ? 'Reclamatie noua'
        : eventType == NotificationEventType.complaintAssigned
            ? 'Reclamatie alocata'
            : 'Status reclamatie actualizat';
    final message =
        '$complaintLabel | Status: $statusLabel | Beneficiar: ${saved.beneficiaryName.trim().isEmpty ? '-' : saved.beneficiaryName.trim()} | Problema: ${saved.problemDescription.trim().isEmpty ? '-' : saved.problemDescription.trim()}';
    await _notificationService.dispatchEvent(
      NotificationDispatchRequest(
        eventType: eventType,
        title: title,
        message: message,
        sourceModule: 'reclamatii',
        sourceEntityId: saved.id,
        sourceLabel: complaintLabel,
        recipientTeamIds: saved.assignedTeamId.trim().isEmpty
            ? const <String>[]
            : <String>[saved.assignedTeamId.trim()],
        recipientEmployeeIds: saved.assignedEmployeeId.trim().isEmpty
            ? const <String>[]
            : <String>[saved.assignedEmployeeId.trim()],
        recipientRoleKeys: const <String>['admin', 'office'],
        metadata: <String, dynamic>{
          'complaint_status': saved.status.value,
          'job_id': saved.jobId,
          'appointment_id': saved.appointmentId,
        },
      ),
    );
  }

  Future<void> _openComplaintStatusPicker(ComplaintRecord item) async {
    final nextStatus = await showDialog<ComplaintStatus>(
      context: context,
      builder: (dialogContext) => SimpleDialog(
        title: const Text('Schimba statusul reclamatiei'),
        children: ComplaintStatus.values
            .map(
              (status) => SimpleDialogOption(
                onPressed: () => Navigator.of(dialogContext).pop(status),
                child: Row(
                  children: [
                    Icon(Icons.flag_outlined, color: _statusColor(status)),
                    const SizedBox(width: 10),
                    Expanded(child: Text(status.label)),
                  ],
                ),
              ),
            )
            .toList(),
      ),
    );
    if (nextStatus == null) {
      return;
    }
    await _updateComplaintStatus(item, nextStatus);
  }

  OfferRecord _buildOfferDraftFromComplaint(ComplaintRecord item) {
    final now = DateTime.now();
    final beneficiary = _resolvedBeneficiaryName(item);
    final contractor = _resolvedContractorName(item);
    final report = _reportForComplaint(item.id);
    final appointment = _primaryAppointmentForComplaint(item);
    final job = item.jobId.trim().isEmpty
        ? null
        : _jobs
            .where((entry) => entry.id == item.jobId.trim())
            .fold<JobRecord?>(null, (previous, entry) => previous ?? entry);
    final useContractorAsRecipient =
        item.type == ComplaintType.garantie && contractor.trim().isNotEmpty;
    final commercialRecipientName =
        useContractorAsRecipient ? contractor.trim() : beneficiary.trim();
    final commercialRecipientClientId = useContractorAsRecipient
        ? item.contractorClientId.trim()
        : item.beneficiaryClientId.trim();
    final noteLines = <String>[
      if (item.complaintNumber.trim().isNotEmpty)
        'Reclamatie sursa: ${item.complaintNumber.trim()}',
      if (beneficiary.trim().isNotEmpty)
        'Beneficiar real: ${beneficiary.trim()}',
      if (contractor.trim().isNotEmpty)
        'Contractant / colaborator: ${contractor.trim()}',
      if (commercialRecipientName.trim().isNotEmpty)
        'Destinatar comercial / platitor: ${commercialRecipientName.trim()}',
      if (item.contactPerson.trim().isNotEmpty)
        'Persoana contact: ${item.contactPerson.trim()}',
      if (item.phone.trim().isNotEmpty) 'Telefon: ${item.phone.trim()}',
      if (item.email.trim().isNotEmpty) 'Email: ${item.email.trim()}',
      if (item.location.trim().isNotEmpty) 'Locatie: ${item.location.trim()}',
      if (item.problemDescription.trim().isNotEmpty)
        'Problema reclamata: ${item.problemDescription.trim()}',
      if ((appointment?.title.trim() ?? '').isNotEmpty)
        'Programare: ${appointment!.title.trim()}',
      if ((report?.reportNumber.trim() ?? '').isNotEmpty)
        'Proces verbal: ${report!.reportNumber.trim()}',
      if ((report?.findings.trim() ?? '').isNotEmpty)
        'Constatare: ${report!.findings.trim()}',
      if ((report?.workPerformed.trim() ?? '').isNotEmpty)
        'Interventie efectuata: ${report!.workPerformed.trim()}',
    ];
    final titleParts = <String>[
      'Interventie',
      if (item.complaintNumber.trim().isNotEmpty) item.complaintNumber.trim(),
      if (beneficiary.trim().isNotEmpty) beneficiary.trim(),
    ];
    final laborTitle = _complaintOfferLaborTitle(item, report);
    final laborDescription = _complaintOfferLaborDescription(item, report);
    return OfferRecord(
      id: 'offer-${now.microsecondsSinceEpoch}',
      offerNumber: '',
      title: titleParts.join(' - '),
      clientId: commercialRecipientClientId,
      clientName: commercialRecipientName,
      departmentId: '',
      departmentName: '',
      contactPersonId: '',
      contactPersonName: item.contactPerson.trim(),
      contactPersonEmail: item.email.trim(),
      contactPersonPhone: item.phone.trim(),
      beneficiaryClientId: item.beneficiaryClientId.trim(),
      beneficiaryName: beneficiary,
      commercialRecipientClientId: commercialRecipientClientId,
      commercialRecipientName: commercialRecipientName,
      complaintId: item.id,
      complaintNumber: item.complaintNumber.trim(),
      appointmentId: item.appointmentId.trim(),
      equipmentType: item.equipmentType?.value ?? '',
      equipmentBrand: item.equipmentBrand.trim(),
      equipmentModel: item.equipmentModel.trim(),
      outdoorUnitSerial: item.outdoorUnitSerial.trim(),
      indoorUnitSerials: item.indoorUnitSerials.trim(),
      equipmentDetails: item.equipmentDetails.trim(),
      jobId: item.jobId.trim(),
      jobCode: job?.jobCode.trim() ?? '',
      jobTitle: job?.title.trim() ?? '',
      status: OfferStatus.draft,
      issueDate: now,
      validUntil: now.add(const Duration(days: 30)),
      currency: 'RON',
      exchangeRateSource: OfferExchangeRateSource.manual,
      bnrRate: 0,
      manualRate: 5,
      exchangeCommissionPercent: 0,
      effectiveExchangeRate: 1,
      notes: noteLines.join('\n'),
      materialSubtotal: 0,
      laborSubtotal: 0,
      subtotalDirect: 0,
      regiePercent: 0,
      regieValue: 0,
      profitPercent: _defaultProfitPercent,
      profitValue: 0,
      subtotalComercial: 0,
      subtotal: 0,
      vatPercent: _defaultVatPercent,
      vatValue: 0,
      totalValue: 0,
      lines: <OfferLineItem>[
        OfferLineItem(
          id: 'complaint-labor-${item.id}',
          name: laborTitle,
          description: laborDescription,
          unit: 'poz',
          quantity: 1,
          unitPrice: 0,
          lineTotal: 0,
          sortOrder: 1,
          lineType: OfferLineType.manopera,
        ),
      ],
      createdAt: now,
      updatedAt: now,
      createdByUserId: '',
      createdByUserEmail: '',
    );
  }

  String _complaintOfferLaborTitle(
    ComplaintRecord item,
    RepairReportRecord? report,
  ) {
    final candidates = <String>[
      item.fieldWorkPerformed.trim(),
      report?.workPerformed.trim() ?? '',
      item.fieldFinding.trim(),
      report?.findings.trim() ?? '',
      item.problemDescription.trim(),
    ];
    for (final candidate in candidates) {
      if (candidate.isNotEmpty) {
        return candidate;
      }
    }
    final complaintNumber = item.complaintNumber.trim();
    if (complaintNumber.isNotEmpty) {
      return 'Manopera interventie $complaintNumber';
    }
    return 'Manopera interventie reclamatie';
  }

  String _complaintOfferLaborDescription(
    ComplaintRecord item,
    RepairReportRecord? report,
  ) {
    final details = <String>[
      item.problemDescription.trim(),
      item.fieldFinding.trim(),
      report?.findings.trim() ?? '',
      item.fieldTechnicianNotes.trim(),
    ].where((entry) => entry.isNotEmpty).toList(growable: false);
    return details.join('\n');
  }

  Appointment _buildAppointmentDraftFromComplaint(ComplaintRecord item) {
    final now = DateTime.now();
    final start = DateTime(now.year, now.month, now.day, now.hour + 1);
    final end = start.add(const Duration(hours: 1));
    final existingVisits = _appointmentsForComplaint(item);
    final visitIndex = existingVisits.length + 1;
    final beneficiary = _resolvedBeneficiaryName(item);
    final contractor = _resolvedContractorName(item);
    final titleParts = <String>[
      if (item.complaintNumber.trim().isNotEmpty) item.complaintNumber.trim(),
      if (beneficiary.trim().isNotEmpty) beneficiary.trim(),
    ];
    final title = titleParts.isEmpty
        ? 'Interventie reclamatie'
        : 'Reclamatie ${titleParts.join(' - ')}';
    final noteLines = <String>[
      if (item.complaintNumber.trim().isNotEmpty)
        'Reclamatie: ${item.complaintNumber.trim()}',
      if (contractor.trim().isNotEmpty) 'Contractant: $contractor',
      if (item.contactPerson.trim().isNotEmpty)
        'Persoana contact: ${item.contactPerson.trim()}',
      if (item.phone.trim().isNotEmpty) 'Telefon: ${item.phone.trim()}',
      if (item.email.trim().isNotEmpty) 'Email: ${item.email.trim()}',
      if (item.problemDescription.trim().isNotEmpty)
        'Problema: ${item.problemDescription.trim()}',
      if (item.internalNotes.trim().isNotEmpty)
        'Observatii interne: ${item.internalNotes.trim()}',
      'Vizita #$visitIndex pe reclamatie',
    ];
    return Appointment(
      id: 'appt-${DateTime.now().microsecondsSinceEpoch}',
      clientId: item.beneficiaryClientId.trim(),
      clientName: beneficiary,
      contractingClientId: item.contractorClientId.trim(),
      contractingClientName: contractor,
      contactPerson: item.contactPerson.trim(),
      contactPhone: item.phone.trim(),
      contactEmail: item.email.trim(),
      title: title,
      location: item.location.trim(),
      scheduledDate: DateTime(start.year, start.month, start.day),
      startTime:
          '${start.hour.toString().padLeft(2, '0')}:${start.minute.toString().padLeft(2, '0')}',
      endTime:
          '${end.hour.toString().padLeft(2, '0')}:${end.minute.toString().padLeft(2, '0')}',
      startDateTime: start,
      endDateTime: end,
      type: 'reclamatie',
      priority: 'medie',
      status: 'planificata',
      jobId: item.jobId.trim(),
      complaintId: item.id,
      complaintNumber: item.complaintNumber.trim(),
      teamId: item.assignedTeamId.trim(),
      assignedUserId: '',
      assignedUserEmail: '',
      assignedEmployeeIds: item.assignedEmployeeId.trim().isEmpty
          ? const <String>[]
          : <String>[item.assignedEmployeeId.trim()],
      complaintVisitType: existingVisits.isEmpty
          ? ComplaintVisitType.constatare
          : ComplaintVisitType.revenire,
      complaintVisitOutcome: null,
      postponementReason: '',
      rescheduledFromStartDateTime: null,
      rescheduledFromEndDateTime: null,
      notes: noteLines.join('\n'),
    );
  }

  Future<void> _openLinkedAppointment(ComplaintRecord item) async {
    final appointment = _primaryAppointmentForComplaint(item);
    if (appointment == null) {
      return;
    }
    await _openAppointmentFromHistory(appointment);
  }

  Future<void> _openAppointmentFromHistory(Appointment appointment) async {
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (_) => ProgramariPage(
          repository: widget.repository,
          initialFocusAppointmentId: appointment.id,
        ),
      ),
    );
    if (!mounted) {
      return;
    }
    await _load();
  }

  Future<void> _scheduleComplaint(
    ComplaintRecord item, {
    bool forceNew = false,
  }) async {
    if (!forceNew && _hasAppointment(item)) {
      await _openLinkedAppointment(item);
      return;
    }
    final draft = _buildAppointmentDraftFromComplaint(item);
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (_) => ProgramariPage(
          repository: widget.repository,
          initialDraftAppointment: draft,
          autoOpenDraftOnStart: true,
          autoCloseAfterDraftSave: true,
          onAppointmentSaved: (appointment) async {
            final nextIds = <String>[
              ...item.appointmentIds
                  .map((entry) => entry.trim())
                  .where((entry) => entry.isNotEmpty),
              if (item.appointmentId.trim().isNotEmpty)
                item.appointmentId.trim(),
            ];
            if (!nextIds.contains(appointment.id)) {
              nextIds.add(appointment.id);
            }
            await _saveComplaintResolved(
              item.copyWith(
                appointmentId: appointment.id,
                appointmentIds: nextIds,
                updatedAt: DateTime.now(),
              ),
            );
          },
        ),
      ),
    );
    if (!mounted) {
      return;
    }
    await _load();
    if (!mounted) {
      return;
    }
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(
          forceNew
              ? 'Vizita noua a fost adaugata pe reclamatie.'
              : 'Programarea a fost creata din reclamatie.',
        ),
      ),
    );
  }

  Future<void> _openLinkedOffer(ComplaintRecord item) async {
    final linked = _offerForComplaint(item.id);
    final offerId = linked?.id ?? item.offerId.trim();
    if (offerId.isEmpty) {
      return;
    }
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (_) => OfertePage(
          repository: widget.repository,
          initialFocusOfferId: offerId,
        ),
      ),
    );
    if (!mounted) {
      return;
    }
    await _load();
  }

  Future<void> _openComplaintOffer(ComplaintRecord item) async {
    if (_hasOffer(item)) {
      await _openLinkedOffer(item);
      return;
    }
    final draft = _buildOfferDraftFromComplaint(item);
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (_) => OfertePage(
          repository: widget.repository,
          initialDraftOffer: draft,
          autoOpenDraftOnStart: true,
          autoCloseAfterDraftSave: false,
          onOfferSaved: (offer) async {
            await _saveComplaintResolved(
              item.copyWith(
                offerId: offer.id,
                updatedAt: DateTime.now(),
              ),
            );
          },
        ),
      ),
    );
    if (!mounted) {
      return;
    }
    await _load();
    if (!mounted) {
      return;
    }
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Text('Documentul comercial a fost generat din reclamatie.'),
      ),
    );
  }

  Future<void> _openRepairReport(ComplaintRecord item) async {
    final appointment = _primaryAppointmentForComplaint(item);
    final currentReport = _reportForComplaint(item.id);
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (_) => RepairReportEditorPage(
          repository: widget.repository,
          complaint: item,
          appointment: appointment,
          currentReport: currentReport,
        ),
      ),
    );
    if (!mounted) {
      return;
    }
    await _load();
    final refreshed = _items
        .where((entry) => entry.id == item.id)
        .fold<ComplaintRecord?>(null, (previous, entry) => previous ?? entry);
    if (refreshed != null) {
      await _syncWarrantyCertificateForComplaint(refreshed);
      if (!mounted) return;
      await _load();
    }
  }

  Future<void> _openWarrantyInterventionReport(ComplaintRecord item) async {
    final certificate = _warrantyCertificateById(item.warrantyCertificateId);
    if (certificate == null) {
      if (!mounted) {
        return;
      }
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text(
            'Asociaza mai intai un certificat de garantie pe reclamatie.',
          ),
        ),
      );
      return;
    }
    final existing = _warrantyInterventionReportForComplaint(item.id);
    final ticket = _ticketForComplaintCertificate(item, certificate);
    final appointment = _primaryAppointmentForComplaint(item);
    final saved =
        await Navigator.of(context).push<WarrantyInterventionReportRecord>(
      MaterialPageRoute<WarrantyInterventionReportRecord>(
        builder: (_) => WarrantyInterventionReportEditorPage(
          repository: widget.repository,
          complaint: item,
          jobTitle: item.jobId.trim().isEmpty ? '' : _jobLabel(item.jobId),
          certificate: certificate,
          appointment: appointment,
          existingTicket: ticket,
          currentReport: existing,
          resolvedBeneficiaryName: _resolvedBeneficiaryName(item),
          resolvedContractorName: _resolvedContractorName(item),
          resolvedTechnicianName: _employeeName(item.fieldTechnicianId),
          resolvedTeamName: _teamName(item.fieldTeamId),
          resolvedAgfrEquipmentLabel: _agfrEquipmentLabel(item.agfrEquipmentId),
          resolvedAgfrInterventionLabel:
              _agfrInterventionLabel(item.agfrInterventionId),
          resolvedAgfrReportLabel: _agfrReportLabel(item.agfrReportId),
          resolvedOfferLabel: _offerLabel(item),
        ),
      ),
    );
    if (saved == null || !mounted) {
      return;
    }
    await _syncWarrantyInterventionReport(item, saved);
    if (!mounted) {
      return;
    }
    await _load();
  }

  Future<void> _openClientCentralizer(ComplaintRecord item) async {
    final clientName = _aggregationClientName(item);
    if (clientName.trim().isEmpty) {
      if (!mounted) {
        return;
      }
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text(
              'Completeaza mai intai clientul contractant sau beneficiarul.'),
        ),
      );
      return;
    }
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (_) => ComplaintClientCentralizerEditorPage(
          repository: widget.repository,
          initialRecord: _buildClientCentralizerDraft(item),
        ),
      ),
    );
  }

  Future<void> _openSelectiveClientCentralizer(ComplaintRecord item) async {
    final clientName = _aggregationClientName(item);
    if (clientName.trim().isEmpty) {
      if (!mounted) {
        return;
      }
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text(
              'Completeaza mai intai clientul contractant sau beneficiarul.'),
        ),
      );
      return;
    }

    final complaints = _complaintsForAggregation(item);
    final offers = _offersForAggregation(item);
    if (complaints.isEmpty && offers.isEmpty) {
      if (!mounted) {
        return;
      }
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text(
              'Nu exista reclamatii sau oferte disponibile pentru selectie.'),
        ),
      );
      return;
    }

    final selectedComplaintIds = complaints
        .map((entry) => entry.id.trim())
        .where((entry) => entry.isNotEmpty)
        .toSet();
    final selectedOfferIds = offers
        .map((entry) => entry.id.trim())
        .where((entry) => entry.isNotEmpty)
        .toSet();
    String? validationMessage;

    final selection = await showDialog<_CentralizerSelection>(
      context: context,
      builder: (dialogContext) {
        return StatefulBuilder(
          builder: (context, setDialogState) {
            return AlertDialog(
              title: Text('Centralizator selectiv • $clientName'),
              content: SizedBox(
                width: 860,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const Text(
                      'Selecteaza reclamatiile si ofertele pe care vrei sa le incluzi in centralizator.',
                    ),
                    const SizedBox(height: 12),
                    Wrap(
                      spacing: 8,
                      runSpacing: 8,
                      children: [
                        Chip(
                          label: Text(
                              'Reclamatii selectate: ${selectedComplaintIds.length}'),
                        ),
                        Chip(
                          label: Text(
                              'Oferte selectate: ${selectedOfferIds.length}'),
                        ),
                      ],
                    ),
                    const SizedBox(height: 12),
                    Flexible(
                      child: ListView(
                        shrinkWrap: true,
                        children: [
                          Text(
                            'Reclamatii',
                            style: Theme.of(context).textTheme.titleSmall,
                          ),
                          const SizedBox(height: 8),
                          if (complaints.isEmpty)
                            const Padding(
                              padding: EdgeInsets.only(bottom: 12),
                              child: Text('Nu exista reclamatii disponibile.'),
                            )
                          else
                            ...complaints.map((entry) {
                              final complaintId = entry.id.trim();
                              return CheckboxListTile(
                                contentPadding: EdgeInsets.zero,
                                value:
                                    selectedComplaintIds.contains(complaintId),
                                title: Text(
                                  entry.complaintNumber.trim().isEmpty
                                      ? entry.id
                                      : entry.complaintNumber.trim(),
                                ),
                                subtitle: Text(
                                  'Data: ${_date(_operationalDateForComplaint(entry))} | Status: ${entry.status.label} | Problema: ${entry.problemDescription.trim().isEmpty ? '-' : entry.problemDescription.trim()}',
                                ),
                                onChanged: (value) {
                                  setDialogState(() {
                                    if (value == true) {
                                      selectedComplaintIds.add(complaintId);
                                    } else {
                                      selectedComplaintIds.remove(complaintId);
                                    }
                                  });
                                },
                              );
                            }),
                          const Divider(height: 24),
                          Text(
                            'Oferte',
                            style: Theme.of(context).textTheme.titleSmall,
                          ),
                          const SizedBox(height: 8),
                          if (offers.isEmpty)
                            const Padding(
                              padding: EdgeInsets.only(bottom: 12),
                              child: Text('Nu exista oferte disponibile.'),
                            )
                          else
                            ...offers.map((entry) {
                              final offerId = entry.id.trim();
                              return CheckboxListTile(
                                contentPadding: EdgeInsets.zero,
                                value: selectedOfferIds.contains(offerId),
                                title: Text(
                                  entry.offerNumber.trim().isEmpty
                                      ? entry.id
                                      : entry.offerNumber.trim(),
                                ),
                                subtitle: Text(
                                  'Data: ${_date(entry.issueDate)} | Total: ${entry.totalValue.toStringAsFixed(2)} | Reclamatie: ${entry.complaintNumber.trim().isEmpty ? '-' : entry.complaintNumber.trim()}',
                                ),
                                onChanged: (value) {
                                  setDialogState(() {
                                    if (value == true) {
                                      selectedOfferIds.add(offerId);
                                    } else {
                                      selectedOfferIds.remove(offerId);
                                    }
                                  });
                                },
                              );
                            }),
                        ],
                      ),
                    ),
                    if ((validationMessage ?? '').trim().isNotEmpty) ...[
                      const SizedBox(height: 8),
                      Text(
                        validationMessage!,
                        style: const TextStyle(color: Colors.red),
                      ),
                    ],
                  ],
                ),
              ),
              actions: [
                TextButton(
                  onPressed: () => Navigator.of(dialogContext).pop(),
                  child: const Text('Renunță'),
                ),
                FilledButton(
                  onPressed: () {
                    if (selectedComplaintIds.isEmpty &&
                        selectedOfferIds.isEmpty) {
                      setDialogState(() {
                        validationMessage =
                            'Selecteaza cel putin o reclamatie sau o oferta.';
                      });
                      return;
                    }
                    Navigator.of(dialogContext).pop(
                      _CentralizerSelection(
                        complaintIds:
                            Set<String>.unmodifiable(selectedComplaintIds),
                        offerIds: Set<String>.unmodifiable(selectedOfferIds),
                      ),
                    );
                  },
                  child: const Text('Deschide centralizatorul'),
                ),
              ],
            );
          },
        );
      },
    );

    if (!mounted || selection == null) {
      return;
    }

    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (_) => ComplaintClientCentralizerEditorPage(
          repository: widget.repository,
          initialRecord: _buildSelectiveClientCentralizerDraft(
            item,
            selectedComplaintIds: selection.complaintIds,
            selectedOfferIds: selection.offerIds,
          ),
        ),
      ),
    );
  }

  Future<void> _openComplaintWorkOrder(ComplaintRecord item) async {
    final clientName = _aggregationClientName(item);
    if (clientName.trim().isEmpty) {
      if (!mounted) {
        return;
      }
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text(
              'Completeaza mai intai clientul contractant sau beneficiarul.'),
        ),
      );
      return;
    }
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
