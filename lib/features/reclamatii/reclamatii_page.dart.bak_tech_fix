  Future<void> _openComplaintDetails(ComplaintRecord item) async {
    _logComplaintUi('card button tapped: details id=${item.id}');
    _selectComplaint(item, source: 'details');
    _logComplaintUi('open details start id=${item.id}');
    await showDialog<void>(
      context: context,
      builder: (context) => AlertDialog(
        title: Text(
          item.complaintNumber.trim().isEmpty
              ? 'Detaliu reclamatie'
              : item.complaintNumber,
        ),
        content: SizedBox(
          width: 640,
          child: SingleChildScrollView(
            child: _buildComplaintDetails(item),
          ),
        ),
        actions: [
          FilledButton.tonal(
            onPressed: _canManageComplaintsWide
                ? () {
                    Navigator.of(context).pop();
                    _openComplaintStatusPicker(item);
                  }
                : null,
            child: const Text('Schimba statusul'),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _openComplaintOffer(item);
            },
            child: Text(
              _hasOffer(item)
                  ? 'Deschide deviz / oferta'
                  : 'Genereaza deviz / oferta',
            ),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _openLinkedDocumentsManagerForComplaint(item);
            },
            child: const Text('Documente'),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _openRepairReport(item);
            },
            child: Text(
              _reportForComplaint(item.id) == null
                  ? 'Genereaza proces verbal'
                  : 'Deschide proces verbal',
            ),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _openWarrantyInterventionReport(item);
            },
            child: Text(
              _warrantyInterventionReportForComplaint(item.id) == null
                  ? 'Genereaza PV garantie'
                  : 'Deschide PV garantie',
            ),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _openClientCentralizer(item);
            },
            child: const Text('Centralizator lunar'),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _openSelectiveClientCentralizer(item);
            },
            child: const Text('Centralizator selectiv'),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _openComplaintWorkOrder(item);
            },
            child: const Text('Comanda lucrari'),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _scheduleComplaint(item);
            },
            child: Text(
              _hasAppointment(item) ? 'Deschide programarea' : 'Programeaza',
            ),
          ),
          if (_hasAppointment(item))
            FilledButton.tonal(
              onPressed: () {
                Navigator.of(context).pop();
                _scheduleComplaint(item, forceNew: true);
              },
              child: const Text('Adauga vizita noua'),
            ),
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('Închide'),
          ),
          FilledButton.tonal(
            onPressed: () {
              Navigator.of(context).pop();
              _openComplaintForm(item);
            },
            child: Text(
              _canManageComplaintsWide ? 'Editeaza' : 'Completeaza interventia',
            ),
          ),
        ],
      ),
    );
    _logComplaintUi('open details end id=${item.id}');
  }

  Future<void> _openComplaintFieldPhotos(ComplaintRecord item) async {
    await Navigator.of(context).push(
      MaterialPageRoute(
        builder: (_) => FieldPhotosPage(
          repository: widget.repository,
          sourceModule: 'reclamatii',
          sourceEntityId: item.id,
          title: 'Poze teren reclamatie',
          preferredTakenByName:
              (widget.fieldAuthUserLabel ?? _currentUser?.displayName ?? '')
                  .trim(),
          preferredTakenByUserId:
              (widget.fieldAuthUserId ?? _currentUser?.id ?? '').trim(),
        ),
      ),
    );
  }

  Future<void> _openComplaintForm([ComplaintRecord? current]) async {
    final canManageWide = _canManageComplaintsWide;
    final canEditFieldOps = _canEditFieldOperations;
    if (!canManageWide && current == null) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text(
              'Crearea reclamatiilor este disponibila pentru admin, birou si sefi de echipa.',
            ),
          ),
        );
      }
      return;
    }
    final isEdit = current != null;
    final nextNumber = isEdit
        ? current.complaintNumber
        : await widget.repository.nextComplaintNumber();
    final beneficiaryClientId = ValueNotifier<String>(
      current?.beneficiaryClientId ?? '',
    );
    final contractorClientId = ValueNotifier<String>(
      current?.contractorClientId ?? '',
    );
    final status = ValueNotifier<ComplaintStatus>(
      current?.status ?? ComplaintStatus.noua,
    );
    final type = ValueNotifier<ComplaintType>(
      current?.type ?? ComplaintType.garantie,
    );
    final source = ValueNotifier<ComplaintSource>(
      current?.source ?? ComplaintSource.directa,
    );
    final complaintDate = ValueNotifier<DateTime>(
      current?.complaintDate ?? DateTime.now(),
    );
    final assignedTeamId = ValueNotifier<String>(current?.assignedTeamId ?? '');
    final assignedEmployeeId = ValueNotifier<String>(
      current?.assignedEmployeeId ?? '',
    );
    final equipmentType = ValueNotifier<ComplaintEquipmentType?>(
      current?.equipmentType,
    );
    final selectedWarrantyCertificateId = ValueNotifier<String>(
      current?.warrantyCertificateId ?? '',
    );
    final selectedAgfrEquipmentId = ValueNotifier<String>(
      current?.agfrEquipmentId ?? '',
    );
    final selectedAgfrInterventionId = ValueNotifier<String>(
      current?.agfrInterventionId ?? '',
    );
    final selectedAgfrReportId = ValueNotifier<String>(
      current?.agfrReportId ?? '',
    );
    final fieldInterventionOutcome =
        ValueNotifier<ComplaintInterventionOutcome?>(
      current?.fieldInterventionOutcome,
    );
    final fieldInterventionDate = ValueNotifier<DateTime>(
      current?.fieldInterventionDate ?? DateTime.now(),
    );
    final fieldTeamId = ValueNotifier<String>(
      (current?.fieldTeamId ?? '').trim().isNotEmpty
          ? current?.fieldTeamId ?? ''
          : _effectiveTeamId,
    );
    final fieldTechnicianId = ValueNotifier<String>(
      (current?.fieldTechnicianId ?? '').trim().isNotEmpty
          ? current?.fieldTechnicianId ?? ''
          : _effectiveActorUserId,
    );
    final number = TextEditingController(text: nextNumber);
    final beneficiaryName =
        TextEditingController(text: current?.beneficiaryName ?? '');
    final contractorName =
        TextEditingController(text: current?.contractorName ?? '');
    final contactPerson =
        TextEditingController(text: current?.contactPerson ?? '');
    final phone = TextEditingController(text: current?.phone ?? '');
    final email = TextEditingController(text: current?.email ?? '');
    final location = TextEditingController(text: current?.location ?? '');
    final equipmentBrand =
        TextEditingController(text: current?.equipmentBrand ?? '');
    final equipmentModel =
        TextEditingController(text: current?.equipmentModel ?? '');
    final outdoorUnitSerial =
        TextEditingController(text: current?.outdoorUnitSerial ?? '');
    final indoorUnitSerials =
        TextEditingController(text: current?.indoorUnitSerials ?? '');
    final equipmentDetails =
        TextEditingController(text: current?.equipmentDetails ?? '');
    final problemDescription =
        TextEditingController(text: current?.problemDescription ?? '');
    final internalNotes =
        TextEditingController(text: current?.internalNotes ?? '');
    final fieldFinding =
        TextEditingController(text: current?.fieldFinding ?? '');
    final fieldWorkPerformed =
        TextEditingController(text: current?.fieldWorkPerformed ?? '');
    final fieldMaterialsUsed =
        TextEditingController(text: current?.fieldMaterialsUsed ?? '');
    final fieldPartsChanged =
        TextEditingController(text: current?.fieldPartsChanged ?? '');
    final fieldTechnicianNotes =
        TextEditingController(text: current?.fieldTechnicianNotes ?? '');

    void refreshWarrantySuggestion() {
      final suggested = _suggestWarrantyCertificate(
        beneficiaryClientId: beneficiaryClientId.value,
        jobId: current?.jobId ?? '',
        outdoorSerial: outdoorUnitSerial.text,
        brand: equipmentBrand.text,
        model: equipmentModel.text,
        currentCertificateId: selectedWarrantyCertificateId.value,
      );
      if (selectedWarrantyCertificateId.value.trim().isEmpty &&
          suggested != null) {
        selectedWarrantyCertificateId.value = suggested.id;
      }
    }

    void refreshAgfrSuggestion() {
      final suggested = _suggestAgfrEquipment(
        clientId: beneficiaryClientId.value,
        jobId: current?.jobId ?? '',
        outdoorSerial: outdoorUnitSerial.text,
        brand: equipmentBrand.text,
        model: equipmentModel.text,
        currentEquipmentId: selectedAgfrEquipmentId.value,
      );
      if (selectedAgfrEquipmentId.value.trim().isEmpty && suggested != null) {
        selectedAgfrEquipmentId.value = suggested.id;
      }
      final equipmentId = selectedAgfrEquipmentId.value.trim();
      if (equipmentId.isEmpty) {
        selectedAgfrInterventionId.value = '';
        selectedAgfrReportId.value = '';
        return;
      }
      final interventions = _agfrInterventions
          .where((entry) => entry.equipmentId == equipmentId)
          .toList(growable: false)
        ..sort((a, b) => b.operationDate.compareTo(a.operationDate));
      if (selectedAgfrInterventionId.value.trim().isEmpty &&
          interventions.isNotEmpty) {
        selectedAgfrInterventionId.value = interventions.first.id;
      }
      final reports = _agfrReports
          .where((entry) => entry.equipmentId == equipmentId)
          .toList(growable: false)
        ..sort((a, b) => b.operationDate.compareTo(a.operationDate));
      if (selectedAgfrReportId.value.trim().isEmpty && reports.isNotEmpty) {
        selectedAgfrReportId.value = reports.first.id;
      }
    }

    refreshWarrantySuggestion();
    refreshAgfrSuggestion();

    if (!mounted) {
      return;
    }

    Future<void> save(BuildContext dialogContext) async {
      _logComplaintUi('saving start id=${current?.id ?? 'new'}');
      final messenger = ScaffoldMessenger.of(context);
      final selectedCertificate =
          _warrantyCertificateById(selectedWarrantyCertificateId.value);
      final draft = ComplaintRecord(
        id: current?.id ?? _uuid.v4(),
        complaintNumber: number.text.trim(),
        complaintDate: complaintDate.value,
        status: status.value,
        type: type.value,
        source: source.value,
        beneficiaryClientId: beneficiaryClientId.value.trim(),
        beneficiaryName: beneficiaryName.text.trim(),
        contractorClientId: contractorClientId.value.trim(),
        contractorName: contractorName.text.trim(),
        contactPerson: contactPerson.text.trim(),
        phone: phone.text.trim(),
        email: email.text.trim(),
        location: location.text.trim(),
        assignedTeamId: assignedTeamId.value.trim(),
        assignedEmployeeId: assignedEmployeeId.value.trim(),
        problemDescription: problemDescription.text.trim(),
        internalNotes: internalNotes.text.trim(),
        jobId: current?.jobId ?? '',
        appointmentId: current?.appointmentId ?? '',
        appointmentIds: current?.appointmentIds ?? const <String>[],
        offerId: current?.offerId ?? '',
        warrantyCertificateId: selectedWarrantyCertificateId.value.trim(),
        warrantyCoverageStatus: selectedCertificate == null
            ? WarrantyCoverageStatus.unknown
            : _productCatalogService.coverageStatusForCertificate(
                selectedCertificate,
              ),
        agfrEquipmentId: selectedAgfrEquipmentId.value.trim(),
        agfrInterventionId: selectedAgfrInterventionId.value.trim(),
        agfrReportId: selectedAgfrReportId.value.trim(),
        equipmentType: equipmentType.value,
        equipmentBrand: equipmentBrand.text.trim(),
        equipmentModel: equipmentModel.text.trim(),
        outdoorUnitSerial: outdoorUnitSerial.text.trim(),
        indoorUnitSerials: indoorUnitSerials.text.trim(),
        equipmentDetails: equipmentDetails.text.trim(),
        fieldFinding: fieldFinding.text.trim(),
        fieldWorkPerformed: fieldWorkPerformed.text.trim(),
        fieldMaterialsUsed: fieldMaterialsUsed.text.trim(),
        fieldPartsChanged: fieldPartsChanged.text.trim(),
        fieldTechnicianNotes: fieldTechnicianNotes.text.trim(),
        fieldInterventionOutcome: fieldInterventionOutcome.value,
        fieldInterventionDate: fieldInterventionDate.value,
        fieldTeamId: fieldTeamId.value.trim(),
        fieldTechnicianId: fieldTechnicianId.value.trim(),
        linkedDocuments:
            current?.linkedDocuments ?? const <ComplaintLinkedDocument>[],
        createdAt: current?.createdAt ?? DateTime.now(),
        updatedAt: DateTime.now(),
      );
      final saved = draft.copyWith(
        interventionHistory: _mergeOperationalHistory(current, draft),
      );
      await _saveComplaintResolved(saved);
      await _notifyComplaintSaved(
        saved: saved,
        previous: current,
      );
      await _syncWarrantyCertificateForComplaint(saved);
      if (!mounted || !dialogContext.mounted) {
        return;
      }
      Navigator.of(dialogContext).pop();
      await _load();
      if (!mounted) {
        return;
      }
      setState(() {
        _selectedComplaint =
            _items.where((item) => item.id == saved.id).fold<ComplaintRecord?>(
                  _selectedComplaint,
                  (previous, item) => item,
                );
      });
      _logComplaintUi(
        'saving end id=${saved.id} selected=${_selectedComplaint?.id ?? '-'}',
      );
      messenger.showSnackBar(
        SnackBar(
          content: Text(
            isEdit
                ? 'Reclamatia a fost actualizata.'
                : 'Reclamatia a fost adaugata.',
          ),
        ),
      );
    }

    await showDialog<void>(
      context: context,
      builder: (dialogContext) => StatefulBuilder(
        builder: (context, setDialog) {
          return AlertDialog(
            title: Text(
              isEdit ? 'Editeaza reclamatie' : 'Adauga reclamatie',
            ),
            content: SizedBox(
              width: 760,
              child: SingleChildScrollView(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.stretch,
                  children: [
                    _sectionTitle(
                      'Identificare si stare',
                      subtitle:
                          'Statusul reclamatiei este controlat explicit si ramane separat de statusul programarii.',
                    ),
                    TextField(
                      textCapitalization: TextCapitalization.sentences,
                      controller: number,
                      enabled: canManageWide,
                      decoration: const InputDecoration(
                        labelText: 'Numar reclamatie',
                        helperText:
                            'Se poate pastra numerotarea automata REC-xxxx.',
                      ),
                    ),
                    const SizedBox(height: 12),
                    Wrap(
                      spacing: 12,
                      runSpacing: 12,
                      children: [
                        SizedBox(
                          width: 220,
                          child: _dateButton(
                            context,
                            label: 'Data reclamatie',
                            value: complaintDate.value,
                            enabled: canManageWide,
                            onChanged: (value) =>
                                setDialog(() => complaintDate.value = value),
                          ),
                        ),
                        SizedBox(
                          width: 220,
                          child: DropdownButtonFormField<ComplaintStatus>(
                            initialValue: status.value,
                            decoration: const InputDecoration(
                              labelText: 'Status reclamatie',
                            ),
                            items: ComplaintStatus.values
                                .map(
                                  (item) => DropdownMenuItem<ComplaintStatus>(
                                    value: item,
                                    child: Text(item.label),
                                  ),
                                )
                                .toList(),
                            onChanged: canManageWide
                                ? (value) {
                                    if (value != null) {
                                      setDialog(() => status.value = value);
                                    }
                                  }
                                : null,
                          ),
                        ),
                        SizedBox(
                          width: 220,
                          child: DropdownButtonFormField<ComplaintType>(
                            initialValue: type.value,
                            decoration: const InputDecoration(
                              labelText: 'Tip reclamatie',
                            ),
                            items: ComplaintType.values
                                .map(
                                  (item) => DropdownMenuItem<ComplaintType>(
