  Future<void> _deleteComplaint(ComplaintRecord item) async {
    final confirm = await showDialog<bool>(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Șterge reclamație'),
        content: Text(
          'Stergi reclamatie ${item.complaintNumber.trim().isEmpty ? item.id : item.complaintNumber}?',
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(false),
            child: const Text('Renunță'),
          ),
          FilledButton(
            onPressed: () => Navigator.of(context).pop(true),
            child: const Text('Șterge'),
          ),
        ],
      ),
    );
    if (confirm != true) {
      return;
    }
    await _deleteComplaintResolved(item.id);
    await _load();
    if (!mounted) {
      return;
    }
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(content: Text('Reclamatia a fost stearsa.')),
    );
  }

  Widget _dateButton(
    BuildContext context, {
    required String label,
    required DateTime value,
    required ValueChanged<DateTime> onChanged,
    bool enabled = true,
  }) {
    return OutlinedButton(
      onPressed: !enabled
          ? null
          : () async {
              final picked = await showDatePicker(
                context: context,
                initialDate: value,
                firstDate: DateTime(2020),
                lastDate: DateTime(2100),
              );
              if (picked != null) {
                onChanged(picked);
              }
            },
      child: Text('$label: ${_date(value)}'),
    );
  }

  String _date(DateTime value) {
    return '${value.day.toString().padLeft(2, '0')}.${value.month.toString().padLeft(2, '0')}.${value.year}';
  }

  Color _statusColor(ComplaintStatus status) {
    switch (status) {
      case ComplaintStatus.noua:
        return Colors.blueGrey;
      case ComplaintStatus.analizata:
        return Colors.orange;
      case ComplaintStatus.programata:
        return Colors.indigo;
      case ComplaintStatus.inLucru:
        return Colors.blue;
      case ComplaintStatus.inAsteptare:
        return Colors.amber.shade800;
      case ComplaintStatus.rezolvata:
        return Colors.green;
      case ComplaintStatus.inchisa:
        return Colors.teal;
      case ComplaintStatus.anulata:
        return Colors.red;
    }
  }

  Widget _detailLine(String label, String value) {
    return Padding(
      padding: const EdgeInsets.only(bottom: 6),
      child: Row(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          SizedBox(
            width: 160,
            child: Text(
              label,
              style: const TextStyle(fontWeight: FontWeight.w600),
            ),
          ),
          Expanded(child: Text(value.trim().isEmpty ? '-' : value.trim())),
        ],
      ),
    );
  }

  Widget _sectionTitle(String title, {String? subtitle}) {
    return Padding(
      padding: const EdgeInsets.only(bottom: 8),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Text(
            title,
            style: Theme.of(context).textTheme.titleSmall?.copyWith(
                  fontWeight: FontWeight.w700,
                ),
          ),
          if ((subtitle ?? '').trim().isNotEmpty) ...[
            const SizedBox(height: 2),
            Text(
              subtitle!,
              style: Theme.of(context).textTheme.bodySmall,
            ),
          ],
        ],
      ),
    );
  }

  Widget _summaryChip({
    required IconData icon,
    required String label,
    Color? color,
  }) {
    final resolvedColor = color ?? Theme.of(context).colorScheme.primary;
    final compact = _compactComplaintCards;
    final fontSize = compact ? 12.0 : 13.0 * _complaintListZoom;
    return Chip(
      avatar: Icon(icon, size: 18, color: resolvedColor),
      label: Text(label, style: TextStyle(fontSize: fontSize)),
      side: BorderSide(color: resolvedColor.withValues(alpha: 0.22)),
      backgroundColor: resolvedColor.withValues(alpha: 0.08),
      visualDensity: compact ? VisualDensity.compact : VisualDensity.standard,
    );
  }

  Widget _statusBadge({
    required String label,
    required Color color,
    IconData? icon,
  }) {
    final compact = _compactComplaintCards;
    final horizontal = (compact ? 8.0 : 10.0) * _complaintListZoom;
    final vertical = (compact ? 5.0 : 6.0) * _complaintListZoom;
    return Container(
      padding: EdgeInsets.symmetric(horizontal: horizontal, vertical: vertical),
      decoration: BoxDecoration(
        color: color.withValues(alpha: 0.12),
        borderRadius: BorderRadius.circular(999),
        border: Border.all(color: color.withValues(alpha: 0.28)),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          if (icon != null) ...[
            Icon(icon, size: 16, color: color),
            const SizedBox(width: 6),
          ],
          Text(
            label,
            style: TextStyle(
              color: color,
              fontWeight: FontWeight.w600,
              fontSize: compact ? 12 : 13 * _complaintListZoom,
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildVisitHistorySection(ComplaintRecord item) {
    final visits = _appointmentsForComplaint(item);
    if (visits.isEmpty) {
      return Text(
        'Nu exista inca vizite asociate acestei reclamatii.',
        style: Theme.of(context).textTheme.bodyMedium,
      );
    }
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: visits.map((visit) {
        final teamLabel =
            visit.teamId.trim().isEmpty ? '-' : _teamName(visit.teamId);
        final employeeLabel = visit.assignedEmployeeIds.isEmpty
            ? '-'
            : _employeeName(visit.assignedEmployeeIds.first);
        final intervalLabel =
            '${_date(visit.effectiveStartDateTime)} ${visit.startTime} - ${visit.endTime}';
        return Card(
          margin: const EdgeInsets.only(bottom: 10),
          child: Padding(
            padding: const EdgeInsets.all(12),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Wrap(
                  spacing: 8,
                  runSpacing: 8,
                  children: [
                    _statusBadge(
                      label: intervalLabel,
                      color: Colors.blueGrey,
                      icon: Icons.event_outlined,
                    ),
                    _statusBadge(
                      label: 'Tip: ${_visitTypeLabel(visit)}',
                      color: Colors.indigo,
                      icon: Icons.build_circle_outlined,
                    ),
                    _statusBadge(
                      label:
                          'Status: ${_appointmentStatusLabelFromRaw(visit.status)}',
                      color: _appointmentStatusColorFromRaw(visit.status),
                      icon: Icons.schedule_outlined,
                    ),
                    _statusBadge(
                      label: 'Rezultat: ${_visitOutcomeLabel(visit)}',
                      color: visit.complaintVisitOutcome == null
                          ? Colors.blueGrey
                          : Colors.teal,
                      icon: Icons.assignment_turned_in_outlined,
                    ),
                  ],
                ),
                const SizedBox(height: 8),
                _detailLine('Echipa', teamLabel),
                _detailLine('Tehnician', employeeLabel),
                _detailLine(
                  'Scop / nota scurta',
                  visit.notes.trim().isEmpty ? '-' : visit.notes.trim(),
                ),
                _detailLine(
                  'Amanata',
                  _normalizeAppointmentStatus(visit.status) == 'amanata'
                      ? 'Da'
                      : 'Nu',
                ),
                _detailLine(
                  'Motiv amanare / reprogramare',
                  visit.postponementReason.trim(),
                ),
                if (visit.rescheduledFromStartDateTime != null &&
                    visit.rescheduledFromEndDateTime != null)
                  _detailLine(
                    'Interval anterior',
                    '${_date(visit.rescheduledFromStartDateTime!)} ${visit.rescheduledFromStartDateTime!.hour.toString().padLeft(2, '0')}:${visit.rescheduledFromStartDateTime!.minute.toString().padLeft(2, '0')} - ${visit.rescheduledFromEndDateTime!.hour.toString().padLeft(2, '0')}:${visit.rescheduledFromEndDateTime!.minute.toString().padLeft(2, '0')}',
                  ),
                Align(
                  alignment: Alignment.centerRight,
                  child: OutlinedButton.icon(
                    onPressed: () => _openAppointmentFromHistory(visit),
                    icon: const Icon(Icons.open_in_new_outlined),
                    label: const Text('Deschide programarea'),
                  ),
                ),
              ],
            ),
          ),
        );
      }).toList(growable: false),
    );
  }

  String _agfrEquipmentLabel(String equipmentId) {
    final equipment = _agfrEquipmentById(equipmentId);
    if (equipment == null) {
      return '-';
    }
    final parts = <String>[
      equipment.clientName.trim(),
      [equipment.brand.trim(), equipment.model.trim()]
          .where((entry) => entry.isNotEmpty)
          .join(' '),
      equipment.serialNumber.trim(),
    ].where((entry) => entry.isNotEmpty).toList(growable: false);
    return parts.isEmpty ? equipment.id : parts.join(' | ');
  }

  String _agfrInterventionLabel(String interventionId) {
    final intervention = _agfrInterventionById(interventionId);
    if (intervention == null) {
      return '-';
    }
    return '${_date(intervention.operationDate)} | ${intervention.operationType.label}';
  }

  String _agfrReportLabel(String reportId) {
    final report = _agfrReportById(reportId);
    if (report == null) {
      return '-';
    }
    return report.reportNumber.trim().isEmpty ? report.id : report.reportNumber;
  }

  Widget _buildInterventionHistorySection(ComplaintRecord item) {
    if (item.interventionHistory.isEmpty) {
      return Text(
        'Nu exista inca interventii de teren salvate in reclamatie.',
        style: Theme.of(context).textTheme.bodyMedium,
      );
    }
    final rows = [...item.interventionHistory]..sort((a, b) {
        final left = a.interventionDate ?? a.updatedAt ?? a.createdAt;
        final right = b.interventionDate ?? b.updatedAt ?? b.createdAt;
        if (left == null && right == null) return 0;
        if (left == null) return 1;
        if (right == null) return -1;
        return right.compareTo(left);
      });
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: rows.map((entry) {
        return Card(
          margin: const EdgeInsets.only(bottom: 10),
          child: Padding(
            padding: const EdgeInsets.all(12),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Wrap(
                  spacing: 8,
                  runSpacing: 8,
                  children: [
                    _statusBadge(
                      label: entry.interventionDate == null
                          ? 'Data nesetata'
                          : _date(entry.interventionDate!),
                      color: Colors.blueGrey,
                      icon: Icons.event_outlined,
                    ),
                    _statusBadge(
                      label: entry.outcome?.label ?? 'Rezultat nesetat',
                      color:
                          entry.outcome == null ? Colors.blueGrey : Colors.teal,
                      icon: Icons.assignment_turned_in_outlined,
                    ),
                  ],
                ),
                const SizedBox(height: 8),
                _detailLine('Echipa', _teamName(entry.teamId)),
                _detailLine('Tehnician', _employeeName(entry.technicianId)),
                _detailLine('Constatare', entry.finding),
                _detailLine('Lucrari efectuate', entry.workPerformed),
                _detailLine('Materiale folosite', entry.materialsUsed),
                _detailLine('Piese schimbate', entry.partsChanged),
                _detailLine('Observatii tehnician', entry.technicianNotes),
              ],
            ),
          ),
        );
      }).toList(growable: false),
    );
  }

