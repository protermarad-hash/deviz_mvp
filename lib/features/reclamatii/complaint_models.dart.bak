import '../product_catalog/product_sales_models.dart';

enum ComplaintInterventionOutcome {
  rezolvata,
  necesitaRevenire,
  necesitaPiese,
  monitorizare,
  clientIndisponibil,
  faraDefectConstatat;

  String get value {
    switch (this) {
      case ComplaintInterventionOutcome.rezolvata:
        return 'rezolvata';
      case ComplaintInterventionOutcome.necesitaRevenire:
        return 'necesita_revenire';
      case ComplaintInterventionOutcome.necesitaPiese:
        return 'necesita_piese';
      case ComplaintInterventionOutcome.monitorizare:
        return 'monitorizare';
      case ComplaintInterventionOutcome.clientIndisponibil:
        return 'client_indisponibil';
      case ComplaintInterventionOutcome.faraDefectConstatat:
        return 'fara_defect_constatat';
    }
  }

  String get label {
    switch (this) {
      case ComplaintInterventionOutcome.rezolvata:
        return 'Rezolvata';
      case ComplaintInterventionOutcome.necesitaRevenire:
        return 'Necesita revenire';
      case ComplaintInterventionOutcome.necesitaPiese:
        return 'Necesita piese';
      case ComplaintInterventionOutcome.monitorizare:
        return 'Monitorizare';
      case ComplaintInterventionOutcome.clientIndisponibil:
        return 'Client indisponibil';
      case ComplaintInterventionOutcome.faraDefectConstatat:
        return 'Fara defect constatat';
    }
  }

  static ComplaintInterventionOutcome? fromValue(String? raw) {
    final value = (raw ?? '').trim().toLowerCase();
    for (final item in ComplaintInterventionOutcome.values) {
      if (item.value == value) {
        return item;
      }
    }
    return null;
  }
}

class ComplaintInterventionEntry {
  const ComplaintInterventionEntry({
    required this.id,
    this.interventionDate,
    this.teamId = '',
    this.technicianId = '',
    this.finding = '',
    this.workPerformed = '',
    this.materialsUsed = '',
    this.partsChanged = '',
    this.technicianNotes = '',
    this.outcome,
    this.createdAt,
    this.updatedAt,
  });

  final String id;
  final DateTime? interventionDate;
  final String teamId;
  final String technicianId;
  final String finding;
  final String workPerformed;
  final String materialsUsed;
  final String partsChanged;
  final String technicianNotes;
  final ComplaintInterventionOutcome? outcome;
  final DateTime? createdAt;
  final DateTime? updatedAt;

  ComplaintInterventionEntry copyWith({
    String? id,
    DateTime? interventionDate,
    String? teamId,
    String? technicianId,
    String? finding,
    String? workPerformed,
    String? materialsUsed,
    String? partsChanged,
    String? technicianNotes,
    ComplaintInterventionOutcome? outcome,
    bool clearOutcome = false,
    DateTime? createdAt,
    DateTime? updatedAt,
  }) {
    return ComplaintInterventionEntry(
      id: id ?? this.id,
      interventionDate: interventionDate ?? this.interventionDate,
      teamId: teamId ?? this.teamId,
      technicianId: technicianId ?? this.technicianId,
      finding: finding ?? this.finding,
      workPerformed: workPerformed ?? this.workPerformed,
      materialsUsed: materialsUsed ?? this.materialsUsed,
      partsChanged: partsChanged ?? this.partsChanged,
      technicianNotes: technicianNotes ?? this.technicianNotes,
      outcome: clearOutcome ? null : (outcome ?? this.outcome),
      createdAt: createdAt ?? this.createdAt,
      updatedAt: updatedAt ?? this.updatedAt,
    );
  }

  Map<String, dynamic> toMap() {
    return <String, dynamic>{
      'id': id,
      'intervention_date': interventionDate?.toIso8601String(),
      'team_id': teamId,
      'technician_id': technicianId,
      'finding': finding,
      'work_performed': workPerformed,
      'materials_used': materialsUsed,
      'parts_changed': partsChanged,
      'technician_notes': technicianNotes,
      'outcome': outcome?.value ?? '',
      'created_at': createdAt?.toIso8601String(),
      'updated_at': updatedAt?.toIso8601String(),
    };
  }

  factory ComplaintInterventionEntry.fromMap(Map<String, dynamic> map) {
    return ComplaintInterventionEntry(
      id: (map['id'] ?? '').toString().trim(),
      interventionDate: DateTime.tryParse(
        (map['intervention_date'] ?? map['interventionDate'] ?? '').toString(),
      ),
      teamId: (map['team_id'] ?? map['teamId'] ?? '').toString().trim(),
      technicianId:
          (map['technician_id'] ?? map['technicianId'] ?? '').toString().trim(),
      finding: (map['finding'] ?? '').toString().trim(),
      workPerformed: (map['work_performed'] ?? map['workPerformed'] ?? '')
          .toString()
          .trim(),
      materialsUsed: (map['materials_used'] ?? map['materialsUsed'] ?? '')
          .toString()
          .trim(),
      partsChanged:
          (map['parts_changed'] ?? map['partsChanged'] ?? '').toString().trim(),
      technicianNotes: (map['technician_notes'] ?? map['technicianNotes'] ?? '')
          .toString()
          .trim(),
      outcome: ComplaintInterventionOutcome.fromValue(
        (map['outcome'] ?? '').toString(),
      ),
      createdAt: DateTime.tryParse(
        (map['created_at'] ?? map['createdAt'] ?? '').toString(),
      ),
      updatedAt: DateTime.tryParse(
        (map['updated_at'] ?? map['updatedAt'] ?? '').toString(),
      ),
    );
  }
}

class ComplaintLinkedDocument {
  const ComplaintLinkedDocument({
    required this.label,
    required this.filePath,
    this.fileName = '',
  });

  final String label;
  final String filePath;
  final String fileName;

  ComplaintLinkedDocument copyWith({
    String? label,
    String? filePath,
    String? fileName,
  }) {
    return ComplaintLinkedDocument(
      label: label ?? this.label,
      filePath: filePath ?? this.filePath,
      fileName: fileName ?? this.fileName,
    );
  }

  Map<String, dynamic> toMap() {
    return <String, dynamic>{
      'label': label,
      'file_path': filePath,
      'file_name': fileName,
    };
  }

  factory ComplaintLinkedDocument.fromMap(Map<String, dynamic> map) {
    return ComplaintLinkedDocument(
      label: (map['label'] ?? '').toString().trim(),
      filePath: (map['file_path'] ?? map['filePath'] ?? '').toString().trim(),
      fileName: (map['file_name'] ?? map['fileName'] ?? '').toString().trim(),
    );
  }
}

enum ComplaintStatus {
  noua,
  analizata,
  programata,
  inLucru,
  inAsteptare,
  rezolvata,
  inchisa,
  anulata;

  String get value {
    switch (this) {
      case ComplaintStatus.noua:
        return 'noua';
      case ComplaintStatus.analizata:
        return 'analizata';
      case ComplaintStatus.programata:
        return 'programata';
      case ComplaintStatus.inLucru:
        return 'in_lucru';
      case ComplaintStatus.inAsteptare:
        return 'in_asteptare';
      case ComplaintStatus.rezolvata:
        return 'rezolvata';
      case ComplaintStatus.inchisa:
        return 'inchisa';
      case ComplaintStatus.anulata:
        return 'anulata';
    }
  }

  String get label {
    switch (this) {
      case ComplaintStatus.noua:
        return 'Noua';
      case ComplaintStatus.analizata:
        return 'Analizata';
      case ComplaintStatus.programata:
        return 'Programata';
      case ComplaintStatus.inLucru:
        return 'In lucru';
      case ComplaintStatus.inAsteptare:
        return 'In asteptare';
      case ComplaintStatus.rezolvata:
        return 'Rezolvata';
      case ComplaintStatus.inchisa:
        return 'Inchisa';
      case ComplaintStatus.anulata:
        return 'Anulata';
    }
  }

  static ComplaintStatus fromValue(String? raw) {
    final value = (raw ?? '').trim().toLowerCase();
    switch (value) {
      case 'in_analiza':
        return ComplaintStatus.analizata;
      case 'alocata':
        return ComplaintStatus.programata;
    }
    return ComplaintStatus.values.firstWhere(
      (item) => item.value == value,
      orElse: () => ComplaintStatus.noua,
    );
  }
}

