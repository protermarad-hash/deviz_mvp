                                    tooltip: 'Șterge departament',
                                    onPressed: () {
                                      setDialog(() {
                                        departments.removeWhere(
                                          (item) => item.id == department.id,
                                        );
                                        for (var i = 0;
                                            i < contacts.length;
                                            i++) {
                                          if (contacts[i].departmentId ==
                                              department.id) {
                                            contacts[i] = contacts[i].copyWith(
                                              departmentId: '',
                                            );
                                          }
                                        }
                                      });
                                    },
                                    icon: const Icon(Icons.delete_outline),
                                  ),
                                ],
                              ),
                            );
                          }).toList(growable: false),
                        ),
