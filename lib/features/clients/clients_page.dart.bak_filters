                        },
                      ),
                      const SizedBox(height: 8),
                      TextField(
                        textCapitalization: TextCapitalization.sentences,
                        controller: name,
                        decoration: const InputDecoration(
                          labelText: 'Nume client / Denumire firma',
                        ),
                      ),
                      const SizedBox(height: 8),
                      TextField(
                        textCapitalization: TextCapitalization.sentences,
                        controller: contact,
                        decoration: const InputDecoration(
                          labelText: 'Persoana principala de contact',
                        ),
                      ),
                      const SizedBox(height: 8),
                      Row(
                        children: [
                          Expanded(
                            child: TextField(
                              controller: phone,
                              keyboardType: TextInputType.phone,
                              decoration:
                                  const InputDecoration(labelText: 'Telefon'),
                            ),
                          ),
                          const SizedBox(width: 8),
                          Expanded(
                            child: TextField(
                              controller: email,
                              keyboardType: TextInputType.emailAddress,
                              decoration:
                                  const InputDecoration(labelText: 'Email'),
                            ),
                          ),
                        ],
                      ),
                      const SizedBox(height: 8),
                      Row(
                        children: [
                          Expanded(
                            child: TextField(
                              controller: phone2,
                              keyboardType: TextInputType.phone,
                              decoration: const InputDecoration(
                                labelText: 'Telefon 2 (opțional)',
                              ),
                            ),
                          ),
                          const SizedBox(width: 8),
                          Expanded(
                            child: TextField(
                              controller: phone3,
                              keyboardType: TextInputType.phone,
                              decoration: const InputDecoration(
                                labelText: 'Telefon 3 (opțional)',
                              ),
                            ),
                          ),
                        ],
                      ),
                      ValueListenableBuilder<ClientType>(
                        valueListenable: type,
                        builder: (_, value, __) {
                          if (value == ClientType.persoanaJuridica) {
                            return Padding(
                              padding: const EdgeInsets.only(top: 8),
                              child: AnafCompanyAutofillSection(
                                cuiController: cui,
                                nameController: name,
                                tradeRegisterController: reg,
                                phoneController: phone,
                                ibanController: iban,
                                addressController: address,
                                cityController: city,
                                countyController: county,
                              ),
                            );
                          }
                          return Padding(
                            padding: const EdgeInsets.only(top: 8),
                            child: TextField(
                              controller: cui,
                              decoration:
                                  const InputDecoration(labelText: 'CUI'),
                            ),
                          );
                        },
                      ),
                      const SizedBox(height: 8),
                      Row(
                        children: [
                          Expanded(
                            child: TextField(
                              controller: reg,
                              decoration: const InputDecoration(
                                labelText: 'Nr. Reg. Com.',
                              ),
                            ),
                          ),
                          const SizedBox(width: 8),
                          const Expanded(child: SizedBox.shrink()),
                        ],
                      ),
