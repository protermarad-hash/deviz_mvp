                              if (contactItem.role.trim().isNotEmpty)
                                contactItem.role.trim(),
                              if (departmentName.isNotEmpty)
                                'Dept: $departmentName',
                              if (contactItem.phone.trim().isNotEmpty)
                                'Tel: ${contactItem.phone.trim()}',
                              if (contactItem.email.trim().isNotEmpty)
                                'Email: ${contactItem.email.trim()}',
                            ];
                            return ListTile(
                              dense: true,
                              contentPadding: EdgeInsets.zero,
                              title: Text(contactItem.fullName),
                              subtitle: Text(
                                subtitleParts.isEmpty
                                    ? '-'
                                    : subtitleParts.join(' | '),
                              ),
                              trailing: Wrap(
                                spacing: 4,
                                children: [
                                  IconButton(
                                    tooltip: 'Editează contact',
                                    onPressed: () async {
                                      final updated = await openContactDialog(
                                        existing: contactItem,
                                      );
                                      if (updated == null) return;
                                      setDialog(() {
                                        final index = contacts.indexWhere(
                                          (item) => item.id == contactItem.id,
                                        );
                                        if (index >= 0) {
                                          contacts[index] = updated;
                                        }
                                      });
                                    },
                                    icon: const Icon(Icons.edit_outlined),
                                  ),
                                  IconButton(
                                    tooltip: 'Șterge contact',
                                    onPressed: () {
                                      setDialog(() {
                                        contacts.removeWhere(
                                          (item) => item.id == contactItem.id,
                                        );
                                      });
                                    },
                                    icon: const Icon(Icons.delete_outline),
                                  ),
                                ],
                              ),
                            );
                          }).toList(growable: false),
                        ),
                      const SizedBox(height: 8),
                      ValueListenableBuilder<bool>(
                        valueListenable: active,
                        builder: (_, value, __) {
                          return SwitchListTile(
                            contentPadding: EdgeInsets.zero,
                            value: value,
                            title: const Text('Client activ'),
                            onChanged: (newValue) {
                              active.value = newValue;
                              setDialog(() {});
                            },
                          );
                        },
                      ),
                      if (formError != null && formError!.trim().isNotEmpty)
                        Align(
                          alignment: Alignment.centerLeft,
                          child: Text(
                            formError!,
                            style: const TextStyle(color: Colors.red),
                          ),
                        ),
                    ],
                  ),
                ),
              ),
              actions: [
                TextButton(
                  onPressed: () => Navigator.of(dialogCtx).pop(false),
                  child: const Text('Renunță'),
                ),
                FilledButton(
                  onPressed: () async {
                    final hasName = name.text.trim().isNotEmpty;
                    final hasPhoneOrEmail = phone.text.trim().isNotEmpty ||
                        email.text.trim().isNotEmpty;
                    if (!hasName) {
                      setDialog(() {
                        formError = 'Completează numele clientului.';
                      });
                      return;
                    }
                    if (code.text.trim().isEmpty) {
                      setDialog(() {
                        formError = 'Completează codul clientului intern.';
                      });
                      return;
                    }
                    if (!hasPhoneOrEmail) {
                      setDialog(() {
                        formError = 'Completează cel puțin telefon sau email.';
                      });
                      return;
                    }
                    final now = DateTime.now();
                    final item = ClientRecord(
                      id: current?.id ?? now.microsecondsSinceEpoch.toString(),
                      clientCode: code.text.trim(),
                      externalClientCode: externalClientCode.text.trim(),
                      externalClientSource: externalClientSource.text.trim(),
                      type: type.value,
                      name: name.text.trim(),
                      contactPerson: contact.text.trim(),
                      phone: phone.text.trim(),
                      phone2: phone2.text.trim(),
                      phone3: phone3.text.trim(),
                      email: email.text.trim(),
                      cui: cui.text.trim(),
                      regCom: reg.text.trim(),
                      iban: iban.text.trim(),
                      bank: bank.text.trim(),
                      departments: List<ClientDepartment>.unmodifiable(
                        departments,
                      ),
                      contactPeople: List<ClientContactPerson>.unmodifiable(
                        contacts,
                      ),
                      address: address.text.trim(),
                      city: city.text.trim(),
                      county: county.text.trim(),
                      notes: notes.text.trim(),
                      isActive: active.value,
                      createdAt: current?.createdAt ?? now,
                      updatedAt: now,
                    );
                    // Duplicate CUI detection
                    final cuiValue = cui.text.trim();
                    if (cuiValue.isNotEmpty) {
                      ClientRecord? duplicate;
                      for (final c in _items) {
                        if (c.cui.trim().toLowerCase() ==
                                cuiValue.toLowerCase() &&
                            c.id != (current?.id ?? '')) {
                          duplicate = c;
                          break;
                        }
                      }
                      if (duplicate != null && dialogCtx.mounted) {
                        final proceed = await showDialog<bool>(
                          context: dialogCtx,
                          builder: (alertCtx) => AlertDialog(
                            title: const Text('CUI duplicat detectat'),
                            content: Text(
                              'Există deja un client cu CUI "$cuiValue":\n\n'
                              '• ${duplicate!.name.trim().isEmpty ? duplicate.id : duplicate.name}\n\n'
                              'Doriți să salvați oricum?',
                            ),
                            actions: [
                              TextButton(
                                onPressed: () =>
                                    Navigator.of(alertCtx).pop(false),
                                child: const Text('Anulează'),
                              ),
                              FilledButton(
                                onPressed: () =>
                                    Navigator.of(alertCtx).pop(true),
                                child: const Text('Salvează oricum'),
                              ),
                            ],
                          ),
                        );
                        if (proceed != true) return;
                      }
                    }
                    await _saveClientResolved(item);
                    if (dialogCtx.mounted) {
                      Navigator.of(dialogCtx).pop(true);
                    }
                  },
                  child: const Text('Salvează'),
                ),
              ],
            );
          },
        );
      },
    );

    dialogScrollController.dispose();
    code.dispose();
    externalClientCode.dispose();
    externalClientSource.dispose();
    name.dispose();
    contact.dispose();
    phone.dispose();
    phone2.dispose();
    phone3.dispose();
    email.dispose();
    cui.dispose();
    reg.dispose();
    bank.dispose();
    iban.dispose();
    address.dispose();
    city.dispose();
    county.dispose();
    notes.dispose();
    type.dispose();
    useAutomaticCode.dispose();
    active.dispose();
    if (!mounted) return;
    if (saved == true) {
      await _load();
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('Clientul a fost salvat cu succes.'),
        ),
      );
    }
  }

  Future<void> _delete(ClientRecord client) async {
    final confirm = await showDialog<bool>(
      context: context,
      builder: (dialogCtx) {
        return AlertDialog(
          title: const Text('Șterge client'),
          content: Text(
            'Sigur vrei să ștergi clientul ${client.name} (${client.clientCode})?',
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(dialogCtx).pop(false),
              child: const Text('Nu'),
            ),
            FilledButton(
              onPressed: () => Navigator.of(dialogCtx).pop(true),
              child: const Text('Da, șterge'),
            ),
          ],
        );
      },
    );
    if (confirm != true) return;
    await _deleteClientResolved(client.id);
    await _load();
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(content: Text('Clientul a fost sters.')),
    );
  }

  String _dateLabel(DateTime? value) {
    if (value == null) {
      return '-';
    }
    final day = value.day.toString().padLeft(2, '0');
    final month = value.month.toString().padLeft(2, '0');
    return '$day.$month.${value.year}';
  }

  String _appointmentStatusLabel(String rawStatus) {
    switch (rawStatus.trim().toLowerCase()) {
      case 'planificata':
        return 'Planificata';
      case 'in_curs':
        return 'In curs';
      case 'finalizata':
        return 'Finalizata';
      case 'amanata':
        return 'Amanata';
      case 'anulata':
        return 'Anulata';
      default:
        return rawStatus.trim().isEmpty ? '-' : rawStatus.trim();
    }
  }

  bool _matchesClientId(String sourceClientId, ClientRecord client) {
    final left = sourceClientId.trim();
    final right = client.id.trim();
    return left.isNotEmpty && right.isNotEmpty && left == right;
  }

  bool _matchesClientName(String rawName, ClientRecord client) {
    final left = rawName.trim().toLowerCase();
    final right = client.name.trim().toLowerCase();
    return left.isNotEmpty && right.isNotEmpty && left == right;
  }

  OfferRecord? _offerForCentralizerComplaint(
    ComplaintRecord complaint,
    List<OfferRecord> offers,
  ) {
    final complaintId = complaint.id.trim();
    if (complaintId.isNotEmpty) {
      for (final offer in offers) {
        if (offer.complaintId.trim() == complaintId) {
          return offer;
        }
      }
    }
    final complaintNumber = complaint.complaintNumber.trim().toLowerCase();
    if (complaintNumber.isEmpty) {
      return null;
    }
    for (final offer in offers) {
      if (offer.complaintNumber.trim().toLowerCase() == complaintNumber) {
        return offer;
      }
    }
    return null;
  }

  RepairReportRecord? _repairReportForCentralizerComplaint(
    String complaintId,
    List<RepairReportRecord> reports,
  ) {
    final normalizedId = complaintId.trim();
    if (normalizedId.isEmpty) {
      return null;
    }
    for (final report in reports) {
      if (report.complaintId.trim() == normalizedId) {
        return report;
      }
    }
    return null;
  }

  WarrantyInterventionReportRecord? _warrantyReportForCentralizerComplaint(
    String complaintId,
    List<WarrantyInterventionReportRecord> reports,
  ) {
    final normalizedId = complaintId.trim();
    if (normalizedId.isEmpty) {
      return null;
    }
    for (final report in reports) {
      if (report.complaintId.trim() == normalizedId) {
        return report;
      }
    }
    return null;
  }

  ComplaintRecord? _complaintForCentralizerOffer(
    OfferRecord offer,
    List<ComplaintRecord> complaints,
  ) {
    final complaintId = offer.complaintId.trim();
    if (complaintId.isNotEmpty) {
      for (final complaint in complaints) {
        if (complaint.id.trim() == complaintId) {
          return complaint;
        }
      }
    }
    final complaintNumber = offer.complaintNumber.trim().toLowerCase();
    if (complaintNumber.isEmpty) {
      return null;
    }
    for (final complaint in complaints) {
      if (complaint.complaintNumber.trim().toLowerCase() == complaintNumber) {
        return complaint;
      }
    }
    return null;
  }

  String _centralizerSummaryFromComplaint(ComplaintRecord complaint) {
    if (complaint.fieldWorkPerformed.trim().isNotEmpty) {
      return complaint.fieldWorkPerformed.trim();
    }
    if (complaint.fieldFinding.trim().isNotEmpty) {
      return complaint.fieldFinding.trim();
    }
    if (complaint.problemDescription.trim().isNotEmpty) {
      return complaint.problemDescription.trim();
    }
    return 'Interventie client';
  }

  String _centralizerSummaryFromOffer(OfferRecord offer) {
    if (offer.title.trim().isNotEmpty) {
      return offer.title.trim();
    }
    if (offer.notes.trim().isNotEmpty) {
      return offer.notes.trim();
    }
    return 'Oferta comerciala';
  }

  String _centralizerBeneficiaryFromComplaint(
    ComplaintRecord complaint,
    ClientRecord client,
  ) {
    if (complaint.beneficiaryName.trim().isNotEmpty) {
      return complaint.beneficiaryName.trim();
    }
    if (complaint.contractorName.trim().isNotEmpty) {
      return complaint.contractorName.trim();
    }
    return client.name.trim();
  }

  String _centralizerBeneficiaryFromOffer(
      OfferRecord offer, ClientRecord client) {
    if (offer.beneficiaryName.trim().isNotEmpty) {
      return offer.beneficiaryName.trim();
    }
    if (offer.commercialRecipientName.trim().isNotEmpty) {
      return offer.commercialRecipientName.trim();
    }
    if (offer.clientName.trim().isNotEmpty) {
      return offer.clientName.trim();
    }
    return client.name.trim();
  }

  ComplaintClientCentralizerLine _buildCentralizerLineFromComplaint(
    ClientRecord client,
    ComplaintRecord complaint,
    _ClientActivityBundle bundle,
  ) {
    final offer = _offerForCentralizerComplaint(complaint, bundle.offers);
    final repairReport = _repairReportForCentralizerComplaint(
      complaint.id,
      bundle.repairReports,
    );
    final warrantyReport = _warrantyReportForCentralizerComplaint(
      complaint.id,
      bundle.warrantyReports,
    );
    final offerValue = offer?.totalValue ?? 0;
    return ComplaintClientCentralizerLine(
      id: 'centralizer-complaint-${complaint.id}',
      complaintId: complaint.id,
      complaintNumber: complaint.complaintNumber.trim().isEmpty
          ? complaint.id
          : complaint.complaintNumber.trim(),
      interventionDate: complaint.complaintDate,
      beneficiaryName: _centralizerBeneficiaryFromComplaint(complaint, client),
      workSummary: _centralizerSummaryFromComplaint(complaint),
      offerId: offer?.id ?? '',
      offerNumber: offer?.offerNumber ?? '',
      offerValue: offerValue,
      repairReportId: repairReport?.id ?? '',
      repairReportNumber: repairReport?.reportNumber ?? '',
      warrantyReportId: warrantyReport?.id ?? '',
      warrantyReportNumber: warrantyReport?.documentNumber ?? '',
      includeInTotal: offerValue > 0,
    );
  }

  ComplaintClientCentralizerLine _buildCentralizerLineFromOffer(
    ClientRecord client,
    OfferRecord offer,
    _ClientActivityBundle bundle,
  ) {
    final complaint = _complaintForCentralizerOffer(offer, bundle.complaints);
    final repairReport = complaint == null
        ? null
        : _repairReportForCentralizerComplaint(
            complaint.id,
            bundle.repairReports,
          );
    final warrantyReport = complaint == null
        ? null
        : _warrantyReportForCentralizerComplaint(
            complaint.id,
            bundle.warrantyReports,
          );
    final complaintNumber = complaint?.complaintNumber.trim().isNotEmpty == true
        ? complaint!.complaintNumber.trim()
        : offer.complaintNumber.trim().isNotEmpty
            ? offer.complaintNumber.trim()
            : offer.offerNumber.trim().isNotEmpty
                ? 'Oferta ${offer.offerNumber.trim()}'
                : 'Oferta fara numar';
    return ComplaintClientCentralizerLine(
      id: 'centralizer-offer-${offer.id}',
      complaintId: complaint?.id ?? offer.complaintId.trim(),
      complaintNumber: complaintNumber,
      interventionDate: complaint?.complaintDate ?? offer.issueDate,
      beneficiaryName: complaint == null
          ? _centralizerBeneficiaryFromOffer(offer, client)
          : _centralizerBeneficiaryFromComplaint(complaint, client),
      workSummary: complaint == null
          ? _centralizerSummaryFromOffer(offer)
          : _centralizerSummaryFromComplaint(complaint),
      offerId: offer.id,
      offerNumber: offer.offerNumber,
      offerValue: offer.totalValue,
      repairReportId: repairReport?.id ?? '',
      repairReportNumber: repairReport?.reportNumber ?? '',
      warrantyReportId: warrantyReport?.id ?? '',
      warrantyReportNumber: warrantyReport?.documentNumber ?? '',
      includeInTotal: offer.totalValue > 0,
    );
  }

  ComplaintClientCentralizerRecord _buildClientCentralizerFromSelection(
    ClientRecord client,
    _ClientActivityBundle bundle,
    _CentralizerSourceSelection selection,
  ) {
    final lines = <ComplaintClientCentralizerLine>[];
    final selectedComplaintIds = selection.complaintIds;
    final selectedOfferIds = selection.offerIds;

    for (final complaint in bundle.complaints) {
      if (!selectedComplaintIds.contains(complaint.id)) {
        continue;
      }
      lines.add(_buildCentralizerLineFromComplaint(client, complaint, bundle));
    }

    for (final offer in bundle.offers) {
      if (!selectedOfferIds.contains(offer.id)) {
        continue;
      }
      final linkedComplaint = _complaintForCentralizerOffer(
        offer,
        bundle.complaints,
      );
      final linkedComplaintId = linkedComplaint?.id.trim() ?? '';
      if (linkedComplaintId.isNotEmpty &&
          selectedComplaintIds.contains(linkedComplaintId)) {
        continue;
      }
      lines.add(_buildCentralizerLineFromOffer(client, offer, bundle));
    }

    lines.sort((left, right) {
      final leftDate = left.interventionDate ?? DateTime(2000);
      final rightDate = right.interventionDate ?? DateTime(2000);
      return leftDate.compareTo(rightDate);
    });

    final dates = lines
        .map((line) => line.interventionDate)
        .whereType<DateTime>()
        .toList(growable: false);
    final firstDate = dates.isEmpty
        ? DateTime.now()
        : dates.reduce(
            (previous, item) => item.isBefore(previous) ? item : previous,
          );
    final lastDate = dates.isEmpty
        ? DateTime.now()
        : dates.reduce(
            (previous, item) => item.isAfter(previous) ? item : previous,
          );
    final periodStart =
        DateTime(firstDate.year, firstDate.month, firstDate.day);
    final periodEnd = DateTime(lastDate.year, lastDate.month, lastDate.day);
    final complaintsCount =
        lines.where((line) => line.complaintId.isNotEmpty).length;
    final offersCount = lines.where((line) => line.offerId.isNotEmpty).length;

    return ComplaintClientCentralizerRecord(
      id: 'client-centralizer-${DateTime.now().microsecondsSinceEpoch}',
      documentNumber: '',
      clientId: client.id,
      clientName: client.name,
      periodStart: periodStart,
      periodEnd: periodEnd,
      title: 'Centralizator ${client.name}',
      summaryDescription:
          'Centralizator generat din modulul Clienti pentru ${client.name}. Include $complaintsCount reclamatii si $offersCount oferte selectate.',
      lines: List<ComplaintClientCentralizerLine>.unmodifiable(lines),
      createdAt: DateTime.now(),
      updatedAt: DateTime.now(),
    );
  }

  Future<_CentralizerSourceSelection?> _selectCentralizerSources(
    ClientRecord client,
    _ClientActivityBundle bundle,
  ) async {
    final selectedComplaintIds = bundle.complaints
        .map((item) => item.id.trim())
        .where((item) => item.isNotEmpty)
        .toSet();
    final selectedOfferIds = bundle.offers
        .map((item) => item.id.trim())
        .where((item) => item.isNotEmpty)
        .toSet();
    String? validationMessage;

    return showDialog<_CentralizerSourceSelection>(
      context: context,
      builder: (dialogContext) {
        return StatefulBuilder(
          builder: (context, setDialogState) {
            return AlertDialog(
              title: Text('Centralizator selectiv • ${client.name}'),
              content: SizedBox(
                width: 860,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const Text(
                      'Selecteaza reclamatiile si ofertele pe care vrei sa le incluzi in centralizator.',
                    ),
                    const SizedBox(height: 12),
                    Wrap(
                      spacing: 8,
                      runSpacing: 8,
                      children: [
                        Chip(
                          label: Text(
                            'Reclamatii selectate: ${selectedComplaintIds.length}',
                          ),
                        ),
                        Chip(
                          label: Text(
                            'Oferte selectate: ${selectedOfferIds.length}',
                          ),
                        ),
                      ],
                    ),
                    const SizedBox(height: 12),
                    Flexible(
                      child: ListView(
                        shrinkWrap: true,
                        children: [
                          Text(
                            'Reclamatii',
                            style: Theme.of(context).textTheme.titleSmall,
                          ),
                          const SizedBox(height: 8),
                          if (bundle.complaints.isEmpty)
                            const Padding(
                              padding: EdgeInsets.only(bottom: 12),
                              child: Text(
                                  'Clientul nu are reclamatii disponibile.'),
                            )
                          else
                            ...bundle.complaints.map((item) {
                              final complaintId = item.id.trim();
                              return CheckboxListTile(
                                contentPadding: EdgeInsets.zero,
                                value:
                                    selectedComplaintIds.contains(complaintId),
                                title: Text(
                                  item.complaintNumber.trim().isEmpty
                                      ? item.id
                                      : item.complaintNumber.trim(),
                                ),
                                subtitle: Text(
                                  'Data: ${_dateLabel(item.complaintDate)} | Status: ${item.status.label} | Problema: ${item.problemDescription.trim().isEmpty ? '-' : item.problemDescription.trim()}',
                                ),
                                onChanged: (value) {
                                  setDialogState(() {
                                    if (value == true) {
                                      selectedComplaintIds.add(complaintId);
                                    } else {
                                      selectedComplaintIds.remove(complaintId);
                                    }
                                  });
                                },
                              );
                            }),
                          const Divider(height: 24),
                          Text(
                            'Oferte',
                            style: Theme.of(context).textTheme.titleSmall,
                          ),
                          const SizedBox(height: 8),
                          if (bundle.offers.isEmpty)
                            const Padding(
                              padding: EdgeInsets.only(bottom: 12),
                              child:
                                  Text('Clientul nu are oferte disponibile.'),
                            )
                          else
                            ...bundle.offers.map((item) {
                              final offerId = item.id.trim();
                              return CheckboxListTile(
                                contentPadding: EdgeInsets.zero,
                                value: selectedOfferIds.contains(offerId),
                                title: Text(
                                  item.offerNumber.trim().isEmpty
                                      ? item.id
                                      : item.offerNumber.trim(),
                                ),
                                subtitle: Text(
                                  'Data: ${_dateLabel(item.issueDate)} | Total: ${item.totalValue.toStringAsFixed(2)} | Reclamatie: ${item.complaintNumber.trim().isEmpty ? '-' : item.complaintNumber.trim()}',
                                ),
                                onChanged: (value) {
                                  setDialogState(() {
                                    if (value == true) {
                                      selectedOfferIds.add(offerId);
                                    } else {
                                      selectedOfferIds.remove(offerId);
                                    }
                                  });
                                },
                              );
                            }),
                        ],
                      ),
                    ),
                    if ((validationMessage ?? '').trim().isNotEmpty) ...[
                      const SizedBox(height: 8),
                      Text(
                        validationMessage!,
                        style: const TextStyle(color: Colors.red),
                      ),
                    ],
                  ],
                ),
              ),
              actions: [
                TextButton(
                  onPressed: () => Navigator.of(dialogContext).pop(),
                  child: const Text('Renunță'),
                ),
                FilledButton(
                  onPressed: () {
                    if (selectedComplaintIds.isEmpty &&
                        selectedOfferIds.isEmpty) {
                      setDialogState(() {
                        validationMessage =
                            'Selecteaza cel putin o reclamatie sau o oferta.';
                      });
                      return;
                    }
                    Navigator.of(dialogContext).pop(
                      _CentralizerSourceSelection(
                        complaintIds:
                            Set<String>.unmodifiable(selectedComplaintIds),
                        offerIds: Set<String>.unmodifiable(selectedOfferIds),
                      ),
                    );
                  },
                  child: const Text('Genereaza centralizator selectiv'),
                ),
              ],
            );
          },
        );
      },
    );
  }

  Future<void> _openCentralizerGeneratorForClient(
    ClientRecord client, {
    _ClientActivityBundle? initialBundle,
  }) async {
    final bundle = initialBundle ?? await _loadClientActivityBundle(client);
    if (!mounted) {
      return;
    }
    if (bundle.complaints.isEmpty && bundle.offers.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(
            'Clientul ${client.name} nu are reclamatii sau oferte pentru centralizator.',
          ),
        ),
      );
      return;
    }
    final selection = await _selectCentralizerSources(client, bundle);
    if (!mounted || selection == null) {
      return;
    }
    final draft = _buildClientCentralizerFromSelection(
      client,
      bundle,
      selection,
    );
    await Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (_) => ComplaintClientCentralizerEditorPage(
          repository: widget.repository,
          initialRecord: draft,
        ),
      ),
    );
  }

  Future<_ClientActivityBundle> _loadClientActivityBundle(
    ClientRecord client,
  ) async {
    final results = await Future.wait<dynamic>(<Future<dynamic>>[
      _listOffersResolved(),
      widget.repository.listAppointments(),
      widget.repository.listComplaints(),
      widget.repository.listJobs(),
      widget.repository.listRepairReports(),
      widget.repository.listWarrantyInterventionReports(),
      widget.repository.listComplaintClientCentralizers(),
      widget.repository.listComplaintWorkOrders(),
      widget.repository.listAgfrEquipments(),
    ]);

    final offers = (results[0] as List<OfferRecord>)
        .where(
          (item) =>
              _matchesClientId(item.clientId, client) ||
              _matchesClientId(item.beneficiaryClientId, client) ||
              _matchesClientId(item.commercialRecipientClientId, client) ||
              _matchesClientName(item.clientName, client) ||
              _matchesClientName(item.beneficiaryName, client) ||
              _matchesClientName(item.commercialRecipientName, client),
        )
        .toList(growable: false)
      ..sort((a, b) => b.updatedAt.compareTo(a.updatedAt));

    final appointments = (results[1] as List<Appointment>)
        .where(
          (item) =>
              _matchesClientId(item.clientId, client) ||
              _matchesClientId(item.contractingClientId, client) ||
              _matchesClientName(item.clientName, client) ||
              _matchesClientName(item.contractingClientName, client),
        )
        .toList(growable: false)
      ..sort((a, b) =>
          b.effectiveStartDateTime.compareTo(a.effectiveStartDateTime));

    final complaints = (results[2] as List<ComplaintRecord>)
        .where(
          (item) =>
              _matchesClientId(item.beneficiaryClientId, client) ||
              _matchesClientId(item.contractorClientId, client) ||
              _matchesClientName(item.beneficiaryName, client) ||
              _matchesClientName(item.contractorName, client),
        )
        .toList(growable: false)
      ..sort((a, b) => b.complaintDate.compareTo(a.complaintDate));

    final complaintIds = complaints
        .map((item) => item.id.trim())
        .where((item) => item.isNotEmpty)
        .toSet();

    final jobs = (results[3] as List<JobRecord>)
        .where((item) => _matchesClientId(item.clientId, client))
        .toList(growable: false)
      ..sort((a, b) => b.updatedAt.compareTo(a.updatedAt));

    final repairReports = (results[4] as List<RepairReportRecord>)
        .where(
          (item) =>
              complaintIds.contains(item.complaintId.trim()) ||
              _matchesClientName(item.beneficiaryName, client) ||
              _matchesClientName(item.contractorName, client),
        )
        .toList(growable: false)
      ..sort((a, b) => b.interventionDate.compareTo(a.interventionDate));

    final warrantyReports =
        (results[5] as List<WarrantyInterventionReportRecord>)
            .where(
              (item) =>
                  complaintIds.contains(item.complaintId.trim()) ||
                  _matchesClientId(item.clientId, client) ||
                  _matchesClientName(item.clientName, client),
            )
            .toList(growable: false)
          ..sort((a, b) {
            final left = a.documentDate ?? a.updatedAt;
            final right = b.documentDate ?? b.updatedAt;
            return right.compareTo(left);
          });

    final centralizers = (results[6] as List<ComplaintClientCentralizerRecord>)
        .where(
          (item) =>
              _matchesClientId(item.clientId, client) ||
              _matchesClientName(item.clientName, client),
        )
        .toList(growable: false)
      ..sort((a, b) => b.periodEnd.compareTo(a.periodEnd));

    final workOrders = (results[7] as List<ComplaintWorkOrderRecord>)
        .where(
          (item) =>
              _matchesClientId(item.clientId, client) ||
              _matchesClientName(item.clientName, client) ||
              _matchesClientName(item.beneficiaryName, client),
        )
        .toList(growable: false)
      ..sort((a, b) => b.issueDate.compareTo(a.issueDate));

    final agfrEquipments = (results[8] as List<AgfrEquipmentRecord>)
        .where((item) => _matchesClientId(item.clientId, client))
        .toList(growable: false)
      ..sort((a, b) => b.createdAt.compareTo(a.createdAt));

    return _ClientActivityBundle(
      offers: offers,
      appointments: appointments,
      complaints: complaints,
      jobs: jobs,
      repairReports: repairReports,
      warrantyReports: warrantyReports,
      centralizers: centralizers,
      workOrders: workOrders,
      agfrEquipments: agfrEquipments,
    );
  }

