                          children: contacts.map((contactItem) {
                            final departmentName = departments
                                .where(
                                  (item) => item.id == contactItem.departmentId,
                                )
                                .map((item) => item.name.trim())
                                .cast<String>()
                                .firstWhere(
                                  (item) => item.isNotEmpty,
                                  orElse: () => '',
                                );
