class ClientsPage extends StatefulWidget {
  const ClientsPage({
    super.key,
    required this.repository,
  });

  final AppDataRepository repository;

  @override
  State<ClientsPage> createState() => _ClientsPageState();
}

class _ClientsPageState extends State<ClientsPage> {
  bool _loading = true;
  final TextEditingController _search = TextEditingController();
  final LocalOferteRepository _localOffersRepository = LocalOferteRepository();
  List<ClientRecord> _items = const <ClientRecord>[];
  ClientType? _typeFilter;
  bool? _activeFilter;
  String _dataSourceLabel = 'local_cache';
  String? _cloudFallbackReason;
  bool _filtersVisible = false;

  int get _activeFilterCount {
    int count = 0;
    if (_typeFilter != null) count++;
    if (_activeFilter != null) count++;
    if (_search.text.trim().isNotEmpty) count++;
    return count;
  }

  String _shortCloudError(Object error) {
    final raw = error.toString().replaceAll('\n', ' ').trim();
    if (raw.isEmpty) return 'necunoscuta';
    return raw.length > 140 ? '${raw.substring(0, 140)}…' : raw;
  }

  void _syncClientDataSourceLabel() {
    final repository = widget.repository;
    if (repository is LocalAppDataRepository) {
      _dataSourceLabel = repository.lastClientsDataSourceLabel;
      final reason = repository.lastClientsFallbackReason.trim();
      _cloudFallbackReason = reason.isEmpty ? null : _shortCloudError(reason);
      return;
    }
    _dataSourceLabel = 'cloud';
    _cloudFallbackReason = null;
  }

  @override
  void initState() {
    super.initState();
    _load();
  }

  @override
  void dispose() {
    _search.dispose();
    super.dispose();
  }

  Future<List<ClientRecord>> _listClientsResolved() async {
    await OfflineSyncRuntime.instance.syncPending();
    final items = await widget.repository.listClients();
    _syncClientDataSourceLabel();
    return items;
  }

  Future<void> _saveClientResolved(ClientRecord item) async {
    final saved = await widget.repository.saveClient(item);
    _syncClientDataSourceLabel();
    await OfflineSyncRuntime.instance.queueClient(saved);
  }

  Future<void> _importCsv() async {
    final result = await FilePicker.platform.pickFiles(
      type: FileType.custom,
      allowedExtensions: const ['csv', 'txt'],
      withData: true,
    );
    if (result == null || result.files.isEmpty) return;
    final bytes = result.files.first.bytes;
    if (bytes == null) return;

    final content = String.fromCharCodes(bytes);
    final lines = content
        .split(RegExp(r'\r?\n'))
        .where((l) => l.trim().isNotEmpty)
        .toList(growable: false);
    if (lines.length < 2) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('CSV gol sau fără rânduri de date.')),
        );
      }
      return;
    }

    List<String> parseCsvRow(String line) {
      final fields = <String>[];
      final buf = StringBuffer();
      bool inQuotes = false;
      for (var i = 0; i < line.length; i++) {
        final ch = line[i];
        if (ch == '"') {
          if (inQuotes && i + 1 < line.length && line[i + 1] == '"') {
            buf.write('"');
            i++;
          } else {
            inQuotes = !inQuotes;
          }
        } else if (ch == ',' && !inQuotes) {
          fields.add(buf.toString().trim());
          buf.clear();
        } else {
          buf.write(ch);
        }
      }
      fields.add(buf.toString().trim());
      return fields;
    }

    // Parse header
    final header = parseCsvRow(lines[0]).map((h) => h.toLowerCase()).toList();
    int col(String name) => header.indexOf(name);

    final iName = col('name') != -1 ? col('name') : col('nume');
    final iCui = col('cui') != -1 ? col('cui') : col('cif');
    final iPhone = col('phone') != -1 ? col('phone') : col('telefon');
    final iEmail = col('email');
    final iAddress = col('address') != -1 ? col('address') : col('adresa');
    final iCity = col('city') != -1 ? col('city') : col('oras');
    final iCounty = col('county') != -1 ? col('county') : col('judet');

    if (iName == -1) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text(
              'Coloana "name" sau "nume" nu a fost găsită în header CSV.',
            ),
          ),
        );
      }
      return;
    }

    String safeField(List<String> row, int idx) =>
        idx >= 0 && idx < row.length ? row[idx] : '';

    final preview = <ClientRecord>[];
    final now = DateTime.now();
    for (var i = 1; i < lines.length; i++) {
      final row = parseCsvRow(lines[i]);
      final name = safeField(row, iName);
      if (name.isEmpty) continue;
      preview.add(
        ClientRecord(
          id: 'csv-import-${now.millisecondsSinceEpoch}-$i',
          clientCode: '',
          externalClientCode: '',
          externalClientSource: '',
          type: ClientType.persoanaJuridica,
          name: name,
          contactPerson: '',
          phone: safeField(row, iPhone),
          email: safeField(row, iEmail),
          cui: safeField(row, iCui),
          regCom: '',
          iban: '',
          bank: '',
          departments: const [],
          contactPeople: const [],
          address: safeField(row, iAddress),
          city: safeField(row, iCity),
          county: safeField(row, iCounty),
          notes: '',
          isActive: true,
          createdAt: now,
          updatedAt: now,
        ),
      );
    }

    if (!mounted) return;

    // Show preview dialog
    if (preview.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Nu s-au găsit rânduri valide în CSV.')),
      );
      return;
    }

    final confirmed = await showDialog<bool>(
      context: context,
      builder: (ctx) => AlertDialog(
        title: Text('Import ${preview.length} clienți din CSV'),
        content: SizedBox(
          width: 560,
          height: 400,
          child: ListView.builder(
            itemCount: preview.length,
            itemBuilder: (_, i) {
              final c = preview[i];
              return ListTile(
                dense: true,
                title: Text(c.name),
                subtitle: Text(
                  [
                    if (c.cui.isNotEmpty) 'CUI: ${c.cui}',
                    if (c.phone.isNotEmpty) c.phone,
                    if (c.email.isNotEmpty) c.email,
                    if (c.city.isNotEmpty) c.city,
                  ].join(' | '),
                ),
              );
            },
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(ctx).pop(false),
            child: const Text('Anulează'),
          ),
          FilledButton(
            onPressed: () => Navigator.of(ctx).pop(true),
            child: Text('Importă ${preview.length} clienți'),
          ),
        ],
      ),
    );

    if (confirmed != true || !mounted) return;

    int imported = 0;
    for (final client in preview) {
      try {
        final code = await widget.repository.nextClientCode();
        final withCode = client.copyWith(clientCode: code);
        await _saveClientResolved(withCode);
        imported++;
      } catch (_) {
        // skip failed rows
      }
    }
    await _load();
    if (mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
            content: Text('Importat $imported din ${preview.length} clienți.')),
      );
    }
  }

  Future<void> _deleteClientResolved(String id) async {
    await widget.repository.deleteClient(id);
    _syncClientDataSourceLabel();
    await OfflineSyncRuntime.instance.queueClientDelete(id);
  }

  Future<List<OfferRecord>> _listOffersResolved() async {
    if (FirebaseBootstrap.isInitialized) {
      try {
        final cloudItems = await FirebaseOferteRepository().listOffers();
        await _localOffersRepository.replaceOffers(cloudItems);
        return cloudItems;
      } catch (_) {}
    }
    return _localOffersRepository.listOffers();
  }

  Future<void> _load() async {
    try {
      final items = await _listClientsResolved();
      if (!mounted) return;
      setState(() {
        _items = items;
      });
    } catch (error) {
      FirebaseBootstrap.registerRuntimeError(error);
    } finally {
      if (mounted) {
        setState(() {
          _loading = false;
        });
      }
    }
  }

  List<ClientRecord> get _filtered {
    final query = _search.text.trim().toLowerCase();
    return _items.where((item) {
      if (_typeFilter != null && item.type != _typeFilter) return false;
      if (_activeFilter != null && item.isActive != _activeFilter) return false;
      if (query.isEmpty) return true;
      return item.name.toLowerCase().contains(query) ||
          item.phone.toLowerCase().contains(query) ||
          item.phone2.toLowerCase().contains(query) ||
          item.phone3.toLowerCase().contains(query) ||
          item.email.toLowerCase().contains(query) ||
          item.cui.toLowerCase().contains(query) ||
          item.clientCode.toLowerCase().contains(query) ||
          item.externalClientCode.toLowerCase().contains(query) ||
          item.externalClientSource.toLowerCase().contains(query);
    }).toList();
  }

  Future<void> _openForm({ClientRecord? current}) async {
    final isEdit = current != null;
    final initialCode =
        isEdit ? current.clientCode : await widget.repository.nextClientCode();
    if (!mounted) return;
    final code = TextEditingController(text: initialCode);
    final externalClientCode = TextEditingController(
      text: current?.externalClientCode ?? '',
    );
    final externalClientSource = TextEditingController(
      text: current?.externalClientSource ?? '',
    );
    final name = TextEditingController(text: current?.name ?? '');
    final contact = TextEditingController(text: current?.contactPerson ?? '');
    final phone = TextEditingController(text: current?.phone ?? '');
    final phone2 = TextEditingController(text: current?.phone2 ?? '');
    final phone3 = TextEditingController(text: current?.phone3 ?? '');
    final email = TextEditingController(text: current?.email ?? '');
    final cui = TextEditingController(text: current?.cui ?? '');
    final reg = TextEditingController(text: current?.regCom ?? '');
    final bank = TextEditingController(text: current?.bank ?? '');
    final iban = TextEditingController(text: current?.iban ?? '');
    final address = TextEditingController(text: current?.address ?? '');
    final city = TextEditingController(text: current?.city ?? '');
    final county = TextEditingController(text: current?.county ?? '');
    final notes = TextEditingController(text: current?.notes ?? '');
    final type = ValueNotifier<ClientType>(
      current?.type ?? ClientType.persoanaJuridica,
    );
    final useAutomaticCode = ValueNotifier<bool>(
      !isEdit || current.clientCode.trim().isEmpty,
    );
    final active = ValueNotifier<bool>(current?.isActive ?? true);
    final departments = <ClientDepartment>[...?current?.departments];
    final contacts = <ClientContactPerson>[...?current?.contactPeople];
    String? formError;
    final dialogScrollController = ScrollController();

    Future<ClientDepartment?> openDepartmentDialog({
      ClientDepartment? existing,
    }) async {
      final nameController = TextEditingController(text: existing?.name ?? '');
      final notesController =
          TextEditingController(text: existing?.notes ?? '');
      String? localError;
      final saved = await showDialog<ClientDepartment>(
        context: context,
        builder: (dialogContext) {
          return StatefulBuilder(
            builder: (context, setLocalState) {
              return AlertDialog(
                title: Text(
                  existing == null
                      ? 'Adaugă departament'
                      : 'Editează departament',
                ),
                content: SizedBox(
                  width: 420,
                  child: Column(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      TextField(
                        textCapitalization: TextCapitalization.sentences,
                        controller: nameController,
                        decoration: const InputDecoration(
                            labelText: 'Nume departament'),
                      ),
                      const SizedBox(height: 8),
                      TextField(
                        textCapitalization: TextCapitalization.sentences,
                        controller: notesController,
                        maxLines: 3,
                        decoration:
                            const InputDecoration(labelText: 'Observații'),
                      ),
                      if ((localError ?? '').trim().isNotEmpty) ...[
                        const SizedBox(height: 8),
                        Align(
                          alignment: Alignment.centerLeft,
                          child: Text(
                            localError!,
                            style: const TextStyle(color: Colors.red),
                          ),
                        ),
                      ],
                    ],
                  ),
                ),
                actions: [
                  TextButton(
                    onPressed: () => Navigator.of(dialogContext).pop(),
                    child: const Text('Renunță'),
                  ),
                  FilledButton(
                    onPressed: () {
                      final trimmedName = nameController.text.trim();
                      if (trimmedName.isEmpty) {
                        setLocalState(() {
                          localError = 'Completează numele departamentului.';
                        });
                        return;
                      }
                      Navigator.of(dialogContext).pop(
                        ClientDepartment(
                          id: existing?.id ??
                              'dep-${DateTime.now().microsecondsSinceEpoch}',
                          name: trimmedName,
                          notes: notesController.text.trim(),
                        ),
                      );
                    },
                    child: const Text('Salvează'),
                  ),
                ],
              );
            },
          );
        },
      );
      nameController.dispose();
      notesController.dispose();
      return saved;
    }

    Future<ClientContactPerson?> openContactDialog({
      ClientContactPerson? existing,
    }) async {
      final fullNameController =
          TextEditingController(text: existing?.fullName ?? '');
      final roleController = TextEditingController(text: existing?.role ?? '');
      final emailController =
          TextEditingController(text: existing?.email ?? '');
      final phoneController =
          TextEditingController(text: existing?.phone ?? '');
      final notesController =
          TextEditingController(text: existing?.notes ?? '');
      String? selectedDepartmentId =
          (existing?.departmentId ?? '').trim().isEmpty
              ? null
              : existing?.departmentId.trim();
      String? localError;
      final saved = await showDialog<ClientContactPerson>(
        context: context,
        builder: (dialogContext) {
          return StatefulBuilder(
            builder: (context, setLocalState) {
              return AlertDialog(
                title: Text(
                    existing == null ? 'Adaugă contact' : 'Editează contact'),
                content: SizedBox(
                  width: 520,
                  child: SingleChildScrollView(
                    child: Column(
                      mainAxisSize: MainAxisSize.min,
                      children: [
                        TextField(
                          textCapitalization: TextCapitalization.sentences,
                          controller: fullNameController,
                          decoration: const InputDecoration(
                            labelText: 'Nume complet',
                          ),
                        ),
                        const SizedBox(height: 8),
                        TextField(
                          textCapitalization: TextCapitalization.sentences,
                          controller: roleController,
                          decoration:
                              const InputDecoration(labelText: 'Funcție'),
                        ),
                        const SizedBox(height: 8),
                        Row(
                          children: [
                            Expanded(
                              child: TextField(
                                textCapitalization: TextCapitalization.sentences,
                                controller: phoneController,
                                decoration: const InputDecoration(
                                  labelText: 'Telefon',
                                ),
                              ),
                            ),
                            const SizedBox(width: 8),
                            Expanded(
                              child: TextField(
                                controller: emailController,
                                decoration: const InputDecoration(
                                  labelText: 'Email',
                                ),
                              ),
                            ),
                          ],
                        ),
                        const SizedBox(height: 8),
                        DropdownButtonFormField<String?>(
                          initialValue: selectedDepartmentId != null &&
                                  departments.any(
                                    (item) => item.id == selectedDepartmentId,
                                  )
                              ? selectedDepartmentId
                              : null,
                          decoration:
                              const InputDecoration(labelText: 'Departament'),
                          items: [
                            const DropdownMenuItem<String?>(
                              value: null,
                              child: Text('Fără departament'),
                            ),
                            ...departments.map(
                              (item) => DropdownMenuItem<String?>(
                                value: item.id,
                                child: Text(item.name),
                              ),
                            ),
                          ],
                          onChanged: (value) {
                            setLocalState(() {
                              selectedDepartmentId = value;
                            });
                          },
                        ),
                        const SizedBox(height: 8),
                        TextField(
                          textCapitalization: TextCapitalization.sentences,
                          controller: notesController,
                          maxLines: 3,
                          decoration:
                              const InputDecoration(labelText: 'Observații'),
                        ),
                        if ((localError ?? '').trim().isNotEmpty) ...[
                          const SizedBox(height: 8),
                          Align(
                            alignment: Alignment.centerLeft,
                            child: Text(
                              localError!,
                              style: const TextStyle(color: Colors.red),
                            ),
                          ),
                        ],
                      ],
                    ),
                  ),
                ),
                actions: [
                  TextButton(
                    onPressed: () => Navigator.of(dialogContext).pop(),
                    child: const Text('Renunță'),
                  ),
                  FilledButton(
                    onPressed: () {
                      final trimmedName = fullNameController.text.trim();
                      if (trimmedName.isEmpty) {
                        setLocalState(() {
                          localError =
                              'Completează numele persoanei de contact.';
                        });
                        return;
                      }
                      Navigator.of(dialogContext).pop(
                        ClientContactPerson(
                          id: existing?.id ??
                              'contact-${DateTime.now().microsecondsSinceEpoch}',
                          fullName: trimmedName,
                          role: roleController.text.trim(),
                          email: emailController.text.trim(),
                          phone: phoneController.text.trim(),
                          departmentId: selectedDepartmentId ?? '',
                          notes: notesController.text.trim(),
                        ),
                      );
                    },
                    child: const Text('Salvează'),
                  ),
                ],
              );
            },
          );
        },
      );
      fullNameController.dispose();
      roleController.dispose();
      emailController.dispose();
      phoneController.dispose();
      notesController.dispose();
      return saved;
    }

    final saved = await showDialog<bool>(
      context: context,
      builder: (dialogCtx) {
        return StatefulBuilder(
          builder: (context, setDialog) {
            return AlertDialog(
              title: Text(isEdit ? 'Editează client' : 'Adaugă client'),
              content: SizedBox(
                width: 760,
                child: SingleChildScrollView(
                  controller: dialogScrollController,
                  primary: false,
                  child: Column(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      TextField(
                        textCapitalization: TextCapitalization.sentences,
                        controller: code,
                        enabled: !useAutomaticCode.value,
                        decoration: InputDecoration(
                          labelText: 'Cod client intern',
                          helperText: useAutomaticCode.value
                              ? 'Generat automat'
                              : 'Editare manuala',
                        ),
                      ),
                      Align(
                        alignment: Alignment.centerLeft,
                        child: ValueListenableBuilder<bool>(
                          valueListenable: useAutomaticCode,
                          builder: (_, value, __) {
                            return SwitchListTile(
                              contentPadding: EdgeInsets.zero,
                              dense: true,
                              value: value,
                              title: const Text('Cod client intern automat'),
                              onChanged: (newValue) async {
                                useAutomaticCode.value = newValue;
                                if (newValue) {
                                  code.text =
                                      current?.clientCode.trim().isNotEmpty ==
                                              true
                                          ? current!.clientCode.trim()
