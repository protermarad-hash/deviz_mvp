  Widget _historyMetric(
    BuildContext context, {
    required IconData icon,
    required String label,
    required int count,
  }) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 8),
      decoration: BoxDecoration(
        border: Border.all(color: Theme.of(context).colorScheme.outlineVariant),
        borderRadius: BorderRadius.circular(12),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(icon, size: 18),
          const SizedBox(width: 8),
          Text('$label: $count'),
        ],
      ),
    );
  }

  Widget _buildActivitySection({
    required String title,
    required IconData icon,
    required int count,
    required List<Widget> children,
  }) {
    return Card(
      margin: const EdgeInsets.only(bottom: 12),
      child: ExpansionTile(
        leading: Icon(icon),
        title: Text(title),
        subtitle:
            Text(count == 0 ? 'Fara inregistrari' : '$count inregistrari'),
        initiallyExpanded: count > 0,
        childrenPadding: const EdgeInsets.fromLTRB(16, 0, 16, 16),
        children: children.isEmpty
            ? const [
                Align(
                  alignment: Alignment.centerLeft,
                  child: Padding(
                    padding: EdgeInsets.only(top: 4),
                    child: Text('Nu exista date pentru aceasta categorie.'),
                  ),
                ),
              ]
            : children,
      ),
    );
  }

  Future<void> _openClientHistory(ClientRecord client) async {
    await showDialog<void>(
      context: context,
      builder: (dialogContext) {
        return AlertDialog(
          title: Text('Istoric client • ${client.name}'),
          content: SizedBox(
            width: 980,
            child: FutureBuilder<_ClientActivityBundle>(
              future: _loadClientActivityBundle(client),
              builder: (context, snapshot) {
                if (snapshot.connectionState != ConnectionState.done) {
                  return const SizedBox(
                    height: 240,
                    child: Center(child: CircularProgressIndicator()),
                  );
                }
                if (snapshot.hasError || !snapshot.hasData) {
                  return const SizedBox(
                    height: 240,
                    child: Center(
                      child: Text(
                        'Nu am putut incarca istoricul clientului.',
                      ),
                    ),
                  );
                }
                final bundle = snapshot.data!;
                ComplaintRecord? complaintForId(String complaintId) {
                  final normalized = complaintId.trim();
                  if (normalized.isEmpty) {
                    return null;
                  }
                  return bundle.complaints
                      .where((item) => item.id == normalized)
                      .fold<ComplaintRecord?>(
                        null,
                        (previous, item) => previous ?? item,
                      );
                }

                Future<void> closeAndOpen(
                    Future<void> Function() action) async {
                  Navigator.of(dialogContext).pop();
                  await action();
                }

                return SingleChildScrollView(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Align(
                        alignment: Alignment.centerLeft,
                        child: FilledButton.icon(
                          onPressed: () => closeAndOpen(
                            () => _openCentralizerGeneratorForClient(
                              client,
                              initialBundle: bundle,
                            ),
                          ),
                          icon: const Icon(Icons.post_add_outlined),
                          label: const Text('Centralizator selectiv'),
                        ),
                      ),
                      const SizedBox(height: 12),
                      Wrap(
                        spacing: 8,
                        runSpacing: 8,
                        children: [
                          _historyMetric(
                            context,
                            icon: Icons.request_quote_outlined,
                            label: 'Oferte',
                            count: bundle.offers.length,
                          ),
                          _historyMetric(
                            context,
                            icon: Icons.event_note_outlined,
                            label: 'Programari',
                            count: bundle.appointments.length,
                          ),
                          _historyMetric(
                            context,
                            icon: Icons.support_agent_outlined,
                            label: 'Reclamatii',
                            count: bundle.complaints.length,
                          ),
                          _historyMetric(
                            context,
                            icon: Icons.work_outline,
                            label: 'Lucrari',
                            count: bundle.jobs.length,
                          ),
                          _historyMetric(
                            context,
                            icon: Icons.description_outlined,
                            label: 'PV reparatie',
                            count: bundle.repairReports.length,
                          ),
                          _historyMetric(
                            context,
                            icon: Icons.assignment_turned_in_outlined,
                            label: 'PV garantie',
                            count: bundle.warrantyReports.length,
                          ),
                          _historyMetric(
                            context,
                            icon: Icons.table_chart_outlined,
                            label: 'Centralizatoare',
                            count: bundle.centralizers.length,
                          ),
                          _historyMetric(
                            context,
                            icon: Icons.receipt_long_outlined,
                            label: 'Comenzi lucrari',
                            count: bundle.workOrders.length,
                          ),
                          _historyMetric(
                            context,
                            icon: Icons.air_outlined,
                            label: 'Echipamente HVAC',
                            count: bundle.agfrEquipments.length,
                          ),
                        ],
                      ),
                      const SizedBox(height: 16),
                      _buildActivitySection(
                        title: 'Oferte',
                        icon: Icons.request_quote_outlined,
                        count: bundle.offers.length,
                        children: bundle.offers
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                onTap: () => closeAndOpen(
                                  () => _openOfferFromHistory(item),
                                ),
                                trailing:
                                    const Icon(Icons.open_in_new_outlined),
                                title: Text(
                                  item.offerNumber.trim().isEmpty
                                      ? item.id
                                      : item.offerNumber,
                                ),
                                subtitle: Text(
                                  '${item.title.trim().isEmpty ? 'Oferta fara titlu' : item.title.trim()}\n'
                                  'Data: ${_dateLabel(item.issueDate)} | Client: ${item.clientName.trim().isEmpty ? '-' : item.clientName.trim()} | Total: ${item.totalValue.toStringAsFixed(2)}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                      _buildActivitySection(
                        title: 'Programari',
                        icon: Icons.event_note_outlined,
                        count: bundle.appointments.length,
                        children: bundle.appointments
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                onTap: () => closeAndOpen(
                                  () => _openAppointmentFromHistory(item),
                                ),
                                trailing:
                                    const Icon(Icons.open_in_new_outlined),
                                title: Text(
                                  item.title.trim().isEmpty
                                      ? 'Programare ${_dateLabel(item.effectiveStartDateTime)}'
                                      : item.title.trim(),
                                ),
                                subtitle: Text(
                                  'Data: ${_dateLabel(item.effectiveStartDateTime)} | Status: ${_appointmentStatusLabel(item.status)} | Lucrare: ${item.jobId.trim().isEmpty ? '-' : item.jobId.trim()}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                      _buildActivitySection(
                        title: 'Reclamatii',
                        icon: Icons.support_agent_outlined,
                        count: bundle.complaints.length,
                        children: bundle.complaints
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                onTap: () => closeAndOpen(
                                  () => _openComplaintFromHistory(item.id),
                                ),
                                trailing:
                                    const Icon(Icons.open_in_new_outlined),
                                title: Text(
                                  item.complaintNumber.trim().isEmpty
                                      ? item.id
                                      : item.complaintNumber,
                                ),
                                subtitle: Text(
                                  'Data: ${_dateLabel(item.complaintDate)} | Status: ${item.status.label} | Problema: ${item.problemDescription.trim().isEmpty ? '-' : item.problemDescription.trim()}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                      _buildActivitySection(
                        title: 'Lucrari',
                        icon: Icons.work_outline,
                        count: bundle.jobs.length,
                        children: bundle.jobs
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                onTap: () => closeAndOpen(
                                  () => _openJobFromHistory(item, client),
                                ),
                                trailing:
                                    const Icon(Icons.open_in_new_outlined),
                                title: Text(
                                  item.jobCode.trim().isEmpty
                                      ? item.title.trim()
                                      : '${item.jobCode} • ${item.title.trim()}',
                                ),
                                subtitle: Text(
                                  'Status: ${item.status.label} | Creat: ${_dateLabel(item.createdAt)}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                      _buildActivitySection(
                        title: 'PV reparatie',
                        icon: Icons.description_outlined,
                        count: bundle.repairReports.length,
                        children: bundle.repairReports
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                onTap: complaintForId(item.complaintId) == null
                                    ? null
                                    : () => closeAndOpen(
                                          () => _openComplaintFromHistory(
                                            item.complaintId,
                                          ),
                                        ),
                                trailing:
                                    const Icon(Icons.open_in_new_outlined),
                                title: Text(
                                  item.reportNumber.trim().isEmpty
                                      ? item.id
                                      : item.reportNumber,
                                ),
                                subtitle: Text(
                                  'Data: ${_dateLabel(item.interventionDate)} | Beneficiar: ${item.beneficiaryName.trim().isEmpty ? '-' : item.beneficiaryName.trim()}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                      _buildActivitySection(
                        title: 'PV garantie',
                        icon: Icons.assignment_turned_in_outlined,
                        count: bundle.warrantyReports.length,
                        children: bundle.warrantyReports
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                onTap: complaintForId(item.complaintId) == null
                                    ? null
                                    : () => closeAndOpen(
                                          () => _openComplaintFromHistory(
                                            item.complaintId,
                                          ),
                                        ),
                                trailing:
                                    const Icon(Icons.open_in_new_outlined),
                                title: Text(
                                  item.documentNumber.trim().isEmpty
                                      ? item.id
                                      : item.documentNumber,
                                ),
                                subtitle: Text(
                                  'Data: ${_dateLabel(item.documentDate ?? item.updatedAt)} | Client: ${item.clientName.trim().isEmpty ? '-' : item.clientName.trim()}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                      _buildActivitySection(
                        title: 'Centralizatoare client',
                        icon: Icons.table_chart_outlined,
                        count: bundle.centralizers.length,
                        children: bundle.centralizers
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                onTap: () => closeAndOpen(
                                  () => _openCentralizerFromHistory(item),
                                ),
                                trailing:
                                    const Icon(Icons.open_in_new_outlined),
                                title: Text(
                                  item.documentNumber.trim().isEmpty
                                      ? item.id
                                      : item.documentNumber,
                                ),
                                subtitle: Text(
                                  '${item.title.trim().isEmpty ? 'Centralizator client' : item.title.trim()}\n'
                                  'Perioada: ${_dateLabel(item.periodStart)} - ${_dateLabel(item.periodEnd)} | Total: ${item.totalValue.toStringAsFixed(2)}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                      _buildActivitySection(
                        title: 'Comenzi lucrari',
                        icon: Icons.receipt_long_outlined,
                        count: bundle.workOrders.length,
                        children: bundle.workOrders
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                onTap: () => closeAndOpen(
                                  () => _openWorkOrderFromHistory(item),
                                ),
                                trailing:
                                    const Icon(Icons.open_in_new_outlined),
                                title: Text(
                                  item.documentNumber.trim().isEmpty
                                      ? item.id
                                      : item.documentNumber,
                                ),
                                subtitle: Text(
                                  '${item.subject.trim().isEmpty ? 'Comanda lucrari' : item.subject.trim()}\n'
                                  'Data: ${_dateLabel(item.issueDate)} | Total: ${item.totalValue.toStringAsFixed(2)}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                      _buildActivitySection(
                        title: 'Echipamente HVAC instalate',
                        icon: Icons.air_outlined,
                        count: bundle.agfrEquipments.length,
                        children: bundle.agfrEquipments
                            .map(
                              (item) => ListTile(
                                contentPadding: EdgeInsets.zero,
                                leading: CircleAvatar(
                                  backgroundColor: Theme.of(context)
                                      .colorScheme
                                      .primaryContainer,
                                  child: Icon(
                                    Icons.hvac_outlined,
                                    color: Theme.of(context)
                                        .colorScheme
                                        .onPrimaryContainer,
                                    size: 18,
                                  ),
                                ),
                                title: Text(
                                  [item.brand.trim(), item.model.trim()]
                                          .where((s) => s.isNotEmpty)
                                          .join(' ')
                                          .trim()
                                          .isEmpty
                                      ? 'Echipament HVAC'
                                      : [item.brand.trim(), item.model.trim()]
                                          .where((s) => s.isNotEmpty)
                                          .join(' '),
                                ),
                                subtitle: Text(
                                  '${item.equipmentCategory.label} | '
                                  'Freon: ${item.refrigerantType.isEmpty ? '-' : item.refrigerantType}, '
                                  '${item.totalChargeKg.toStringAsFixed(2)} kg | '
                                  'Locație: ${item.location.isEmpty ? '-' : item.location}\n'
                                  'Nr. serie: ${item.serialNumber.isEmpty ? '-' : item.serialNumber} | '
                                  'Înregistrat: ${_dateLabel(item.createdAt)}',
                                ),
                              ),
                            )
                            .toList(growable: false),
                      ),
                    ],
                  ),
                );
              },
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(dialogContext).pop(),
              child: const Text('Închide'),
            ),
          ],
        );
      },
    );
  }

  @override
  Widget build(BuildContext context) {
    if (_loading) {
      return const Center(child: CircularProgressIndicator());
    }
    final items = _filtered;
    return Scaffold(
      appBar: AppBar(
        title: const Text('Clienți'),
        actions: [
          HelpButton(content: AppHelp.clienti),
        ],
      ),
      floatingActionButton: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          FloatingActionButton.extended(
            heroTag: 'csv_import',
            onPressed: _importCsv,
            icon: const Icon(Icons.upload_file_outlined),
            label: const Text('Import CSV'),
          ),
          const SizedBox(width: 12),
          FloatingActionButton.extended(
            heroTag: 'add_client',
            onPressed: () => _openForm(),
            icon: const Icon(Icons.add),
            label: const Text('Adaugă client'),
          ),
        ],
      ),
      floatingActionButtonLocation: FloatingActionButtonLocation.endFloat,
      body: Column(
        children: [
          LayoutBuilder(
            builder: (context, constraints) {
              // Pe ecrane largi (Windows/tablet ≥600px) filtrele sunt mereu vizibile
              final isWide = constraints.maxWidth >= 600;
              final showFilters = isWide || _filtersVisible;
              final cs = Theme.of(context).colorScheme;
              final hasFilters = _activeFilterCount > 0;

              return Card(
                margin: const EdgeInsets.fromLTRB(16, 16, 16, 8),
                child: Padding(
                  padding:
                      const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
                  child: Column(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      // Rândul 1: search + buton filtre (DOAR pe mobil)
                      Row(
                        children: [
                          Expanded(
                            child: TextField(
                              controller: _search,
                              onChanged: (_) => setState(() {}),
                              decoration: InputDecoration(
                                hintText:
                                    'Caută după nume, telefon, email, CUI...',
                                prefixIcon: const Icon(Icons.search),
                                suffixIcon: _search.text.trim().isNotEmpty
                                    ? IconButton(
                                        icon: const Icon(Icons.clear),
                                        onPressed: () {
                                          _search.clear();
                                          setState(() {});
                                        },
                                      )
                                    : null,
                                isDense: true,
                                contentPadding: const EdgeInsets.symmetric(
                                  vertical: 10,
                                  horizontal: 12,
                                ),
                                border: OutlineInputBorder(
                                  borderRadius: BorderRadius.circular(8),
                                ),
                              ),
                            ),
                          ),
                          // Buton filtre: DOAR pe mobil
                          if (!isWide) ...[
                            const SizedBox(width: 8),
                            Stack(
                              clipBehavior: Clip.none,
                              children: [
                                OutlinedButton.icon(
                                  onPressed: () => setState(() =>
                                      _filtersVisible = !_filtersVisible),
                                  icon: Icon(
                                    _filtersVisible
                                        ? Icons.filter_list_off
                                        : Icons.filter_list,
                                    size: 18,
                                  ),
                                  label: Text(
                                      _filtersVisible ? 'Ascunde' : 'Filtre'),
                                  style: OutlinedButton.styleFrom(
                                    foregroundColor:
                                        hasFilters ? cs.primary : null,
                                    side: hasFilters
                                        ? BorderSide(
                                            color: cs.primary, width: 1.5)
                                        : null,
                                    padding: const EdgeInsets.symmetric(
                                      horizontal: 12,
                                      vertical: 10,
                                    ),
                                  ),
                                ),
                                if (hasFilters)
                                  Positioned(
                                    top: -4,
                                    right: -4,
                                    child: Container(
                                      padding: const EdgeInsets.all(4),
                                      decoration: BoxDecoration(
                                        color: cs.primary,
                                        shape: BoxShape.circle,
                                      ),
                                      child: Text(
                                        '$_activeFilterCount',
                                        style: TextStyle(
                                          color: cs.onPrimary,
                                          fontSize: 10,
                                          fontWeight: FontWeight.bold,
                                        ),
                                      ),
                                    ),
                                  ),
                              ],
                            ),
                          ],
                        ],
                      ),
                      // Rândul 2: filtre (mereu pe desktop, colapsabile pe mobil)
                      if (showFilters) ...[
                        const SizedBox(height: 8),
                        Wrap(
                          spacing: 8,
                          runSpacing: 8,
                          crossAxisAlignment: WrapCrossAlignment.center,
                          children: [
                            SizedBox(
                              width: 200,
                              child: DropdownButtonFormField<ClientType>(
                                initialValue: _typeFilter,
                                items: ClientType.values
                                    .map(
                                      (item) => DropdownMenuItem<ClientType>(
                                        value: item,
                                        child: Text(item.label),
                                      ),
                                    )
                                    .toList(),
                                onChanged: (value) =>
                                    setState(() => _typeFilter = value),
                                decoration: const InputDecoration(
                                    labelText: 'Tip client'),
                              ),
                            ),
                            SizedBox(
                              width: 180,
                              child: DropdownButtonFormField<bool>(
                                initialValue: _activeFilter,
                                items: const [
                                  DropdownMenuItem<bool>(
                                    value: true,
                                    child: Text('Activ'),
                                  ),
                                  DropdownMenuItem<bool>(
                                    value: false,
                                    child: Text('Inactiv'),
                                  ),
                                ],
                                onChanged: (value) =>
                                    setState(() => _activeFilter = value),
                                decoration: const InputDecoration(
                                  labelText: 'Status',
                                ),
                              ),
                            ),
                            TextButton(
                              onPressed: () {
                                _search.clear();
                                setState(() {
                                  _typeFilter = null;
                                  _activeFilter = null;
                                  _filtersVisible = false;
                                });
                              },
                              child: const Text('Resetează'),
                            ),
                            Chip(
                              label: Text('Sursă: $_dataSourceLabel'),
                              visualDensity: VisualDensity.compact,
                            ),
                            if ((_cloudFallbackReason ?? '').trim().isNotEmpty)
                              Text(
                                'Fallback: ${_shortCloudError(_cloudFallbackReason!)}',
                                style: Theme.of(context).textTheme.bodySmall,
                              ),
                          ],
                        ),
                      ],
                    ],
                  ),
                ),
              );
            },
          ),
          Expanded(
            child: items.isEmpty
                ? const Center(child: Text('Nu există clienți salvați.'))
                : ListView.separated(
                    padding: AppViewportGuard.scrollablePadding(
                      top: 8,
                      reserveForFab: true,
                    ),
                    itemCount: items.length,
                    separatorBuilder: (_, __) => const SizedBox(height: 8),
                    itemBuilder: (_, i) {
                      final item = items[i];
                      final externalCodeLabel =
                          item.externalClientCode.trim().isEmpty
                              ? '-'
                              : item.externalClientCode.trim();
                      final externalSourceLabel =
                          item.externalClientSource.trim().isEmpty
                              ? '-'
                              : item.externalClientSource.trim();
                      return Card(
                        child: ListTile(
                          onTap: () => _openClientHistory(item),
                          title: Text('${item.clientCode} • ${item.name}'),
                          subtitle: Text(
                            'Contact: ${item.contactPerson.isEmpty ? '-' : item.contactPerson} | '
                            'Tel: ${item.phone.isEmpty ? '-' : item.phone}'
                            '${item.phone2.isEmpty ? '' : ' / ${item.phone2}'}'
                            '${item.phone3.isEmpty ? '' : ' / ${item.phone3}'} | '
                            'Email: ${item.email.isEmpty ? '-' : item.email}\n'
                            'Cod extern: $externalCodeLabel | '
                            'Partener: $externalSourceLabel\n'
                            'Oras: ${item.city.isEmpty ? '-' : item.city} | '
                            'Tip: ${item.type.label} | '
                            'Status: ${item.isActive ? 'Activ' : 'Inactiv'} | '
                            'Departamente: ${item.departments.length} | '
                            'Contacte: ${item.contactPeople.length}',
                          ),
                          trailing: PopupMenuButton<String>(
                            icon: const Icon(Icons.more_vert),
                            tooltip: 'Acțiuni',
                            itemBuilder: (_) => [
                              const PopupMenuItem(
                                value: 'history',
                                child: ListTile(
                                  leading: Icon(Icons.history_outlined),
                                  title: Text('Istoric client'),
                                  contentPadding: EdgeInsets.zero,
                                ),
                              ),
                              const PopupMenuItem(
                                value: 'centralizer',
                                child: ListTile(
                                  leading: Icon(Icons.post_add_outlined),
                                  title: Text('Centralizator selectiv'),
                                  contentPadding: EdgeInsets.zero,
                                ),
                              ),
                              const PopupMenuItem(
                                value: 'edit',
                                child: ListTile(
                                  leading: Icon(Icons.edit_outlined),
                                  title: Text('Editează'),
                                  contentPadding: EdgeInsets.zero,
                                ),
                              ),
                              const PopupMenuItem(
                                value: 'delete',
                                child: ListTile(
                                  leading: Icon(Icons.delete_outline),
                                  title: Text('Șterge'),
                                  contentPadding: EdgeInsets.zero,
                                ),
                              ),
                            ],
                            onSelected: (value) {
                              switch (value) {
                                case 'history':
                                  _openClientHistory(item);
                                case 'centralizer':
                                  _openCentralizerGeneratorForClient(item);
                                case 'edit':
                                  _openForm(current: item);
                                case 'delete':
                                  _delete(item);
                              }
                            },
                          ),
                        ),
                      );
                    },
                  ),
          ),
        ],
      ),
    );
  }
}

class _ClientActivityBundle {
  const _ClientActivityBundle({
    required this.offers,
    required this.appointments,
    required this.complaints,
    required this.jobs,
    required this.repairReports,
    required this.warrantyReports,
    required this.centralizers,
    required this.workOrders,
    required this.agfrEquipments,
  });

  final List<OfferRecord> offers;
  final List<Appointment> appointments;
  final List<ComplaintRecord> complaints;
  final List<JobRecord> jobs;
  final List<RepairReportRecord> repairReports;
  final List<WarrantyInterventionReportRecord> warrantyReports;
  final List<ComplaintClientCentralizerRecord> centralizers;
  final List<ComplaintWorkOrderRecord> workOrders;
  final List<AgfrEquipmentRecord> agfrEquipments;
}

class _CentralizerSourceSelection {
  const _CentralizerSourceSelection({
    required this.complaintIds,
    required this.offerIds,
  });

  final Set<String> complaintIds;
  final Set<String> offerIds;
}
