                                              .nextClientCode();
                                  if (!dialogCtx.mounted) return;
                                }
                                setDialog(() {});
                              },
                            );
                          },
                        ),
                      ),
                      const SizedBox(height: 8),
                      Row(
                        children: [
                          Expanded(
                            child: TextField(
                              textCapitalization: TextCapitalization.sentences,
