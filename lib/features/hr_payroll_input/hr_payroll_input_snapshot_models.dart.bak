class HrPayrollInputSnapshot {
  const HrPayrollInputSnapshot({
    required this.id,
    required this.employeeId,
    required this.hrEmployeeProfileId,
    required this.contractId,
    required this.payrollMonth,
    required this.ruleVersionIds,
    required this.workedHours,
    required this.overtimeHours,
    required this.nightHours,
    required this.leaveHoursPaid,
    required this.leaveHoursUnpaid,
    required this.vacationWorkingDays,
    required this.medicalLeaveWorkingDays,
    required this.otherLeaveWorkingDays,
    required this.baseSalaryGross,
    required this.currency,
    required this.mealTicketsEnabled,
    required this.mealTicketCalculationMode,
    required this.mealTicketsMonthlyBudget,
    required this.mealTicketConfiguredEligibleDays,
    required this.mealTicketValuePerDay,
    required this.mealTicketEligibleDays,
    required this.mealTicketsTotalValue,
    required this.mealTicketEligibilityRules,
    required this.mealTicketEligibilityBreakdown,
    required this.bonusEntries,
    required this.deductionEntries,
    required this.allowanceEntries,
    required this.sourceRefs,
    required this.status,
    required this.generatedAt,
    required this.generatedByUserId,
    required this.notes,
    required this.createdAt,
    required this.updatedAt,
  });

  final String id;
  final String employeeId;
  final String hrEmployeeProfileId;
  final String contractId;
  final DateTime payrollMonth;
  final List<String> ruleVersionIds;
  final double workedHours;
  final double overtimeHours;
  final double nightHours;
  final double leaveHoursPaid;
  final double leaveHoursUnpaid;
  final double vacationWorkingDays;
  final double medicalLeaveWorkingDays;
  final double otherLeaveWorkingDays;
  final double baseSalaryGross;
  final String currency;
  final bool mealTicketsEnabled;
  final String mealTicketCalculationMode;
  final double mealTicketsMonthlyBudget;
  final double mealTicketConfiguredEligibleDays;
  final double mealTicketValuePerDay;
  final double mealTicketEligibleDays;
  final double mealTicketsTotalValue;
  final Map<String, bool> mealTicketEligibilityRules;
  final Map<String, double> mealTicketEligibilityBreakdown;
  final List<Map<String, dynamic>> bonusEntries;
  final List<Map<String, dynamic>> deductionEntries;
  final List<Map<String, dynamic>> allowanceEntries;
  final Map<String, dynamic> sourceRefs;
  final String status;
  final DateTime generatedAt;
  final String generatedByUserId;
  final String notes;
  final DateTime createdAt;
  final DateTime updatedAt;

  HrPayrollInputSnapshot copyWith({
    String? id,
    String? employeeId,
    String? hrEmployeeProfileId,
    String? contractId,
    DateTime? payrollMonth,
    List<String>? ruleVersionIds,
    double? workedHours,
    double? overtimeHours,
    double? nightHours,
    double? leaveHoursPaid,
    double? leaveHoursUnpaid,
    double? vacationWorkingDays,
    double? medicalLeaveWorkingDays,
    double? otherLeaveWorkingDays,
    double? baseSalaryGross,
    String? currency,
    bool? mealTicketsEnabled,
    String? mealTicketCalculationMode,
    double? mealTicketsMonthlyBudget,
    double? mealTicketConfiguredEligibleDays,
    double? mealTicketValuePerDay,
    double? mealTicketEligibleDays,
    double? mealTicketsTotalValue,
    Map<String, bool>? mealTicketEligibilityRules,
    Map<String, double>? mealTicketEligibilityBreakdown,
    List<Map<String, dynamic>>? bonusEntries,
    List<Map<String, dynamic>>? deductionEntries,
    List<Map<String, dynamic>>? allowanceEntries,
    Map<String, dynamic>? sourceRefs,
    String? status,
    DateTime? generatedAt,
    String? generatedByUserId,
    String? notes,
    DateTime? createdAt,
    DateTime? updatedAt,
  }) {
    return HrPayrollInputSnapshot(
      id: id ?? this.id,
      employeeId: employeeId ?? this.employeeId,
      hrEmployeeProfileId: hrEmployeeProfileId ?? this.hrEmployeeProfileId,
      contractId: contractId ?? this.contractId,
      payrollMonth: payrollMonth ?? this.payrollMonth,
      ruleVersionIds: ruleVersionIds ?? this.ruleVersionIds,
      workedHours: workedHours ?? this.workedHours,
      overtimeHours: overtimeHours ?? this.overtimeHours,
      nightHours: nightHours ?? this.nightHours,
      leaveHoursPaid: leaveHoursPaid ?? this.leaveHoursPaid,
      leaveHoursUnpaid: leaveHoursUnpaid ?? this.leaveHoursUnpaid,
      vacationWorkingDays: vacationWorkingDays ?? this.vacationWorkingDays,
      medicalLeaveWorkingDays:
          medicalLeaveWorkingDays ?? this.medicalLeaveWorkingDays,
      otherLeaveWorkingDays:
          otherLeaveWorkingDays ?? this.otherLeaveWorkingDays,
      baseSalaryGross: baseSalaryGross ?? this.baseSalaryGross,
      currency: currency ?? this.currency,
      mealTicketsEnabled: mealTicketsEnabled ?? this.mealTicketsEnabled,
      mealTicketCalculationMode:
          mealTicketCalculationMode ?? this.mealTicketCalculationMode,
      mealTicketsMonthlyBudget:
          mealTicketsMonthlyBudget ?? this.mealTicketsMonthlyBudget,
      mealTicketConfiguredEligibleDays:
          mealTicketConfiguredEligibleDays ??
              this.mealTicketConfiguredEligibleDays,
      mealTicketValuePerDay:
          mealTicketValuePerDay ?? this.mealTicketValuePerDay,
      mealTicketEligibleDays:
          mealTicketEligibleDays ?? this.mealTicketEligibleDays,
      mealTicketsTotalValue:
          mealTicketsTotalValue ?? this.mealTicketsTotalValue,
      mealTicketEligibilityRules:
          mealTicketEligibilityRules ?? this.mealTicketEligibilityRules,
      mealTicketEligibilityBreakdown: mealTicketEligibilityBreakdown ??
          this.mealTicketEligibilityBreakdown,
      bonusEntries: bonusEntries ?? this.bonusEntries,
      deductionEntries: deductionEntries ?? this.deductionEntries,
      allowanceEntries: allowanceEntries ?? this.allowanceEntries,
      sourceRefs: sourceRefs ?? this.sourceRefs,
      status: status ?? this.status,
      generatedAt: generatedAt ?? this.generatedAt,
      generatedByUserId: generatedByUserId ?? this.generatedByUserId,
      notes: notes ?? this.notes,
      createdAt: createdAt ?? this.createdAt,
      updatedAt: updatedAt ?? this.updatedAt,
    );
  }

  Map<String, dynamic> toMap() {
    return <String, dynamic>{
      'id': id,
      'employee_id': employeeId,
      'hr_employee_profile_id': hrEmployeeProfileId,
      'contract_id': contractId,
      'payroll_month':
          DateTime(payrollMonth.year, payrollMonth.month, 1).toIso8601String(),
      'rule_version_ids': ruleVersionIds,
      'worked_hours': workedHours,
      'overtime_hours': overtimeHours,
      'night_hours': nightHours,
      'leave_hours_paid': leaveHoursPaid,
      'leave_hours_unpaid': leaveHoursUnpaid,
      'vacation_working_days': vacationWorkingDays,
      'medical_leave_working_days': medicalLeaveWorkingDays,
      'other_leave_working_days': otherLeaveWorkingDays,
      'base_salary_gross': baseSalaryGross,
      'currency': currency,
      'meal_tickets_enabled': mealTicketsEnabled,
      'meal_ticket_calculation_mode': mealTicketCalculationMode,
      'meal_tickets_monthly_budget': mealTicketsMonthlyBudget,
      'meal_ticket_configured_eligible_days': mealTicketConfiguredEligibleDays,
      'meal_ticket_value_per_day': mealTicketValuePerDay,
      'meal_ticket_eligible_days': mealTicketEligibleDays,
      'meal_tickets_total_value': mealTicketsTotalValue,
      'meal_ticket_eligibility_rules': mealTicketEligibilityRules,
      'meal_ticket_eligibility_breakdown': mealTicketEligibilityBreakdown,
      'bonus_entries': bonusEntries,
      'deduction_entries': deductionEntries,
      'allowance_entries': allowanceEntries,
      'source_refs': sourceRefs,
      'status': status,
      'generated_at': generatedAt.toIso8601String(),
      'generated_by_user_id': generatedByUserId,
      'notes': notes,
      'created_at': createdAt.toIso8601String(),
      'updated_at': updatedAt.toIso8601String(),
    };
  }

  factory HrPayrollInputSnapshot.fromMap(Map<String, dynamic> map) {
    DateTime parseDate(dynamic raw) {
      final text = (raw ?? '').toString().trim();
      return DateTime.tryParse(text) ?? DateTime.fromMillisecondsSinceEpoch(0);
    }

    double parseDouble(dynamic raw) {
      if (raw is num) return raw.toDouble();
      return double.tryParse((raw ?? '').toString().replaceAll(',', '.')) ?? 0;
    }

    bool parseBool(dynamic raw) {
      if (raw is bool) return raw;
      final text = (raw ?? '').toString().trim().toLowerCase();
      return text == 'true' || text == '1' || text == 'yes';
    }

    List<String> parseStringList(dynamic raw) {
      if (raw is! List) return const <String>[];
      return raw
          .map((item) => item.toString().trim())
          .where((item) => item.isNotEmpty)
          .toList(growable: false);
    }

    List<Map<String, dynamic>> parseMapList(dynamic raw) {
      if (raw is! List) return const <Map<String, dynamic>>[];
      return raw
          .whereType<Map>()
          .map((item) => Map<String, dynamic>.from(item))
          .toList(growable: false);
    }

    Map<String, dynamic> parseMap(dynamic raw) {
      if (raw is Map<String, dynamic>) return raw;
      if (raw is Map) return Map<String, dynamic>.from(raw);
      return const <String, dynamic>{};
    }

    Map<String, bool> parseBoolMap(dynamic raw) {
      final map = parseMap(raw);
      return <String, bool>{
        for (final entry in map.entries)
          entry.key.toString().trim(): parseBool(entry.value),
      };
    }

    Map<String, double> parseDoubleMap(dynamic raw) {
      final map = parseMap(raw);
      return <String, double>{
        for (final entry in map.entries)
          entry.key.toString().trim(): parseDouble(entry.value),
      };
    }

    return HrPayrollInputSnapshot(
      id: (map['id'] ?? '').toString(),
      employeeId: (map['employee_id'] ?? map['employeeId'] ?? '').toString(),
      hrEmployeeProfileId:
          (map['hr_employee_profile_id'] ?? map['hrEmployeeProfileId'] ?? '')
              .toString(),
      contractId: (map['contract_id'] ?? map['contractId'] ?? '').toString(),
      payrollMonth: parseDate(map['payroll_month'] ?? map['payrollMonth']),
      ruleVersionIds:
          parseStringList(map['rule_version_ids'] ?? map['ruleVersionIds']),
      workedHours: parseDouble(map['worked_hours'] ?? map['workedHours']),
      overtimeHours: parseDouble(map['overtime_hours'] ?? map['overtimeHours']),
      nightHours: parseDouble(map['night_hours'] ?? map['nightHours']),
      leaveHoursPaid:
          parseDouble(map['leave_hours_paid'] ?? map['leaveHoursPaid']),
      leaveHoursUnpaid:
          parseDouble(map['leave_hours_unpaid'] ?? map['leaveHoursUnpaid']),
      vacationWorkingDays: parseDouble(
        map['vacation_working_days'] ?? map['vacationWorkingDays'],
      ),
      medicalLeaveWorkingDays: parseDouble(
        map['medical_leave_working_days'] ?? map['medicalLeaveWorkingDays'],
      ),
      otherLeaveWorkingDays: parseDouble(
        map['other_leave_working_days'] ?? map['otherLeaveWorkingDays'],
      ),
      baseSalaryGross:
          parseDouble(map['base_salary_gross'] ?? map['baseSalaryGross']),
      currency: (map['currency'] ?? 'RON').toString(),
      mealTicketsEnabled: parseBool(
        map['meal_tickets_enabled'] ?? map['mealTicketsEnabled'],
      ),
      mealTicketCalculationMode:
          (map['meal_ticket_calculation_mode'] ??
                  map['mealTicketCalculationMode'] ??
                  'monthly_budget_divided_by_eligible_days')
              .toString(),
      mealTicketsMonthlyBudget: parseDouble(
        map['meal_tickets_monthly_budget'] ?? map['mealTicketsMonthlyBudget'],
      ),
      mealTicketConfiguredEligibleDays: parseDouble(
        map['meal_ticket_configured_eligible_days'] ??
            map['mealTicketConfiguredEligibleDays'],
      ),
      mealTicketValuePerDay: parseDouble(
        map['meal_ticket_value_per_day'] ?? map['mealTicketValuePerDay'],
      ),
      mealTicketEligibleDays: parseDouble(
        map['meal_ticket_eligible_days'] ?? map['mealTicketEligibleDays'],
      ),
      mealTicketsTotalValue: parseDouble(
        map['meal_tickets_total_value'] ?? map['mealTicketsTotalValue'],
      ),
      mealTicketEligibilityRules: parseBoolMap(
        map['meal_ticket_eligibility_rules'] ??
            map['mealTicketEligibilityRules'],
      ),
      mealTicketEligibilityBreakdown: parseDoubleMap(
        map['meal_ticket_eligibility_breakdown'] ??
            map['mealTicketEligibilityBreakdown'],
      ),
      bonusEntries: parseMapList(map['bonus_entries'] ?? map['bonusEntries']),
      deductionEntries:
          parseMapList(map['deduction_entries'] ?? map['deductionEntries']),
      allowanceEntries:
          parseMapList(map['allowance_entries'] ?? map['allowanceEntries']),
      sourceRefs: parseMap(map['source_refs'] ?? map['sourceRefs']),
      status: (map['status'] ?? 'generated').toString(),
      generatedAt: parseDate(map['generated_at'] ?? map['generatedAt']),
      generatedByUserId:
          (map['generated_by_user_id'] ?? map['generatedByUserId'] ?? '')
              .toString(),
      notes: (map['notes'] ?? '').toString(),
      createdAt: parseDate(map['created_at'] ?? map['createdAt']),
      updatedAt: parseDate(map['updated_at'] ?? map['updatedAt']),
    );
  }
}

class MealTicketEligibilityRules {
  const MealTicketEligibilityRules._();

  static const Map<String, bool> defaults = <String, bool>{
    'worked_hours': true,
    'CO': false,
    'CM': false,
    'INV': false,
    'ABS': false,
    'MAT': false,
    'ST': false,
    'ALT': false,
    'CCC': false,
  };

  static Map<String, bool> normalize(Map<String, bool> raw) {
    return <String, bool>{
      for (final entry in defaults.entries)
        entry.key: raw[entry.key] ?? entry.value,
    };
  }
}
