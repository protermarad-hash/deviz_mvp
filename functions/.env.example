# Optional local fallback for Firebase Functions email delivery.
# Preferred production setup is Firebase Secrets, documented in README_EMAIL_SETUP.md.

NOTIFICATION_SMTP_HOST=smtp.example.com
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USER=mailer@example.com
NOTIFICATION_SMTP_PASS=replace-with-real-password
NOTIFICATION_EMAIL_FROM="DevizPro Ultra <mailer@example.com>"
NOTIFICATION_SMTP_SECURE=false
